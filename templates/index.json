    "az_concern_grid_7ja4CW": {
      "type": "az-concern-grid",
      "blocks": {
        "product_iWnrcJ": {
          "type": "product",
          "settings": {
            "product": "afoulki",
            "areas": "lice",
            "types": "moisturizer,treatment",
            "concerns": "dryness,sensitivity,aging,dullness",
            "benefits": "Dugotrajna hidratacija, Gladi fine linije, Jača barijeru",
            "badge": "Protiv bora",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti AFOULKI",
            "flip_text": "<p><br/>“Afoulki” znači ljepota. Ulje sjemenki opuncije, za koje je potrebna tona plodova po litri, i autentični marokanski argan zajednički omekšavaju fine linije i vraćaju sjaj. Ružina vodica i shea maslac daju dugotrajnu hidrataciju i obnovu.</p>",
            "flip_points": "Bogata antioksidansima\nSvakodnevna obnova barijere\nLako se upija, pogodna ispod šminke\nKlinčki osmišljena emulzija, bez teškog filma"
          }
        },
        "product_Na63EJ": {
          "type": "product",
          "settings": {
            "product": "amaan",
            "areas": "lice",
            "types": "cleanser",
            "concerns": "dryness,sensitivity,dullness,pores,acne",
            "benefits": "Skida SPF i šminku, pH uravnotežen, Ne isušuje",
            "badge": "Ne isušuje",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p>“Amaan” znači voda, čisto i neophodno. Nježno čisti bez narušavanja vlažnosti. Aloe vera i surfaktanti izvedeni iz krastavca uklanjaju nečistoće, prirodni vitamin C daje jasnoću. Koža je svježa, hidrirana i uravnotežena.</p>",
            "flip_points": "Nisko pjeni, ne isušuje, pH uravnotežen\nAloe, glicerin i xylitol kompleks održavaju vlagu\nSpreman za jutro i večer, idealan prvi korak"
          }
        },
        "product_B76rJ9": {
          "type": "product",
          "settings": {
            "product": "tawenza",
            "areas": "kosa",
            "types": "mask,treatment, moisturizer",
            "concerns": "damage,dryness,dullness",
            "benefits": "Obnova oštećenja, Lakše raščešljavanje, Manje frizza",
            "badge": "Obnova kose",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>“Tawenza” simbolizira lijepu, obnovljenu kosu. Shea maslac i badem dubinski hrane, korijen sljeza prirodno omekšava i raspetljava. Marokanski argan i vitamin E jačaju vlas. Kosa izgleda zdravije, glatkije i življe.</p>",
            "flip_points": "Dubinska njega bez otežavanja\nVidljivo manje čvorova i frizza\nIdealno uz tjedni tretman od 20 minuta"
          }
        },
        "product_48FCfN": {
          "type": "product",
          "settings": {
            "product": "100-arganovo-ulje",
            "areas": "lice,tijelo,kosa",
            "types": "oil,treatment",
            "concerns": "dryness,damage,aging,dullness,sensitivity",
            "benefits": "Hranjiva njega, Sjaj bez težine, Višenamjensko",
            "badge": "100% čisto",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>Hladno prešano, čisto ulje s visokim udjelom oleinske i linolne kiseline. Za lice, bradu, nokte i vrhove kose. Vraća mekoću i sjaj bez masnog filma.</p>",
            "flip_points": "100% jedno sastojak, lagan osjećaj\nUmiruje suhu kožu, spašava vrhove\nDodaje sjaj i zaštitni sloj"
          }
        },
        "product_FyfUnW": {
          "type": "product",
          "settings": {
            "product": "tayri",
            "areas": "lice,tijelo",
            "types": "soap,cleanser",
            "concerns": "dullness,dryness,sensitivity",
            "benefits": "Kremasta pjena, Umiruje kožu, Za osjetljivu",
            "badge": "Vrlo blago",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>Tayri znači ljubav. Svježe kozje mlijeko donosi prirodne laktate koji otapaju dnevne naslage, vitamin A i selen jačaju barijeru. pH-uravnotežena mješavina maslinovog, lanenog i suncokretovog ulja daje baršunast osjećaj. Bez mirisa, izuzetno nježan, umiruje suhu i osjetljivu kožu.</p>",
            "flip_points": "Vrlo blag, pogodna svakodnevna upotreba\nHranjiva krema od prirodnih ulja\nOstavlja kožu mekom i mirnom"
          }
        },
        "product_Mh3AVU": {
          "type": "product",
          "settings": {
            "product": "sanouj",
            "areas": "lice,tijelo",
            "types": "soap,cleanser",
            "concerns": "acne,pores,dullness,sensitivity",
            "benefits": "Smanjuje prištiće, Čisti pore, Bez mirisa",
            "badge": "Protiv akni",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>Sanouj je magrebski naziv za Nigella sativa, “blagoslovljeno sjeme”. Hladno prešano ulje crnog kima donosi timokinon za smirenje vidljivog crvenila, mikro-mljevene ljuske podižu nečistoće iz pora. Baza od maslinovog ulja bez mirisa ostavlja uravnotežen, mat završetak.<br/><br/><br/></p>",
            "flip_points": "Čišćenje sklonog masnoći i T-zoni\nSmiruje izgled sitnih nepravilnosti\nNježna pjena, svakodnevna upotreba"
          }
        },
        "product_tdt9G3": {
          "type": "product",
          "settings": {
            "product": "tifawin",
            "areas": "lice,tijelo",
            "types": "soap,treatment",
            "concerns": "dullness,pores,dryness",
            "benefits": "Fino poliranje, Glatkija koža, Sjajniji ten",
            "badge": "Uklanja sivilo",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>Tifawin znači izlazak sunca, prva jasna svjetlost. Gotovo 900 kg ploda daju litar ovog vitaminom E bogatog “pustinjskog zlata”, ovdje u prahu sjemenki za fini, neabrazivni piling. Visok sadržaj linolne kiseline uz nježnu eksfolijaciju zaglađuje i njeguje, koža je satenski glatka i elastična.</p>",
            "flip_points": "Nježan piling 2–3 puta sedmično\nZategnutiji izgled i bolji sjaj\nLako klizi, brzo se ispire"
          }
        },
        "product_9aXKUg": {
          "type": "product",
          "settings": {
            "product": "tislit",
            "areas": "lice,tijelo",
            "types": "soap,cleanser",
            "concerns": "dryness,aging,damage",
            "benefits": "Ujednačeniji ten, Mekša koža, Kremasta pjena",
            "badge": "Nježno posvjetljuje",
            "back_align": "top",
            "flip_title": "Zašto će ti se svidjeti",
            "flip_text": "<p><br/>Tislit znači mlada. Nadahnuta fesanskim vjenčanim ritualom Aker Fassi, miješa fino mljeveni pigment od maka s planinskim medom u sporosušenoj bazi od maslinovog ulja. Poppy antioksidansi i minerali skidaju sivilo, enzimi meda zaglađuju teksturu. Ten izgleda svježe, ružičasto i meko hidrirano.</p>",
            "flip_points": "Blagi sjaj i ujednačen ton\nKremasta pjena, koža ostaje mekana\nDobar kao jutarnje “buđenje” tena"
          }
        }
