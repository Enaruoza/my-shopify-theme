            "video_url": ""
          }
        },
        "review_L3brNM": {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Najbolje arganovo ulje koje sam probala. Tekstura je zlatna i bogata, a miris vrlo blag, što mi je veliki plus. Lijepa prezentacija, staklena bočica s kapaljkom i jasno naznačen datum proizvodnje i isteka. Djeluje izrazito hranjivo na kožu.",
            "name": "Selma K.",
            "verified": true,
            "product": "100-arganovo-ulje",
            "image": "shopify://shop_images/61YJpSVcp6L._SL1600__1.jpg",
            "video_url": ""
          }
        },
        "review_RPhcUY": {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Tokom posjete Bosni na nekoliko sedmica, koža mi se jako isušila zbog putovanja i  zraka. Uobičajeni proizvodi nisu pomagali. Odlučila sam dati šansu AFOULKI kremi i već nakon 2 dana koža mi je bila vidno mekša i hidratiziranija. Nakon 2 sedmice ten mi je bio osjetno ujednačeniji, čišći i, iznenađujuće, blistaviji. Ostajem pri AFOULKI-ju.",
            "name": "Rania S.",
            "verified": true,
            "product": "afoulki",
            "image": "shopify://shop_images/ChatGPT_Image_Sep_23_2025_11_57_52_AM.png",
            "video_url": ""
          }
        },
        "review_YfPHmq": {
