{%- liquid
  assign id = section.id | downcase | split: '_' | join: '-'
  assign s = section.settings

  assign heading_font = s.heading_font
  assign subheading_font = s.subheading_font
  assign jumbo_font = s.jumbo_font

  echo heading_font | font_face: font_display: 'swap'
  echo subheading_font | font_face: font_display: 'swap'
  echo jumbo_font | font_face: font_display: 'swap'
-%}

{%- style -%}
  :root {
    --heading-font: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --heading-weight: {{ heading_font.weight }};
    --heading-style: {{ heading_font.style }};
    --subheading-font: {{ subheading_font.family }}, {{ subheading_font.fallback_families }};
    --subheading-weight: {{ subheading_font.weight }};
    --subheading-style: {{ subheading_font.style }};
    --jumbo-font: {{ jumbo_font.family }}, {{ jumbo_font.fallback_families }};
    --jumbo-weight: {{ jumbo_font.weight }};
    --jumbo-style: {{ jumbo_font.style }};
    --accent-1: {{ s.accent_color_1 }};
    --accent-2: {{ s.accent_color_2 }};
    --accent-3: {{ s.accent_color_3 }};
    --accent-4: {{ s.accent_color_4 }};
    --jumbo-text-color: {{ s.jumbo_text_color }};
    --jumbo-font-size: {{ s.jumbo_font_size | divided_by: 100.0 }}vw;
  }
  #azourane-shorts-{{ id }} {
    position: relative;
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
    {% if s.show_gradient_background %}
      background: linear-gradient(135deg, var(--accent-1) 0%, var(--accent-2) 25%, var(--accent-3) 75%, var(--accent-4) 100%);
    {% else %}
      background-color: {{ s.background_color }};
    {% endif %}
    overflow: hidden;
  }
  #azourane-shorts-{{ id }} .jumbo-text-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: {{ s.jumbo_horizontal_align }};
    align-items: {{ s.jumbo_vertical_align }};
    padding: 20px;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  #azourane-shorts-{{ id }} .jumbo-text {
    font-family: var(--jumbo-font);
    font-weight: var(--jumbo-weight);
    font-style: var(--jumbo-style);
    font-size: var(--jumbo-font-size);
    color: var(--jumbo-text-color);
    line-height: 0.8;
    white-space: nowrap;
    text-transform: uppercase;
    opacity: {{ s.jumbo_text_opacity | divided_by: 100.0 }};
  }
  #azourane-shorts-{{ id }} .section-header {
    position: relative;
    z-index: 1;
    text-align: {{ s.text_alignment }};
    margin-bottom: 40px;
    color: {{ s.text_color }};
    padding: 0 20px;
  }
  #azourane-shorts-{{ id }} .section-header h2 {
    font-family: var(--heading-font);
    font-weight: var(--heading-weight);
    font-style: var(--heading-style);
    font-size: 2.5rem;
    margin: 0 0 8px 0;
  }
  #azourane-shorts-{{ id }} .section-header p {
    font-family: var(--subheading-font);
    font-weight: var(--subheading-weight);
    font-style: var(--subheading-style);
    font-size: 1.1rem;
    margin: 0;
    opacity: 0.9;
  }
  #azourane-shorts-{{ id }} .carousel-wrapper {
    position: relative;
    z-index: 1;
  }
  #azourane-shorts-{{ id }} .shorts-container {
    display: flex;
    gap: {{ s.gap }}px;
    padding-bottom: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    cursor: grab;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #azourane-shorts-{{ id }} .shorts-container::-webkit-scrollbar { display: none; }
  #azourane-shorts-{{ id }} .shorts-card {
    flex: 0 0 {{ s.card_width }}px;
    position: relative;
    scroll-snap-align: center;
    border-radius: {{ s.border_radius }}px;
    background-color: #1a1a1a;
    aspect-ratio: 9 / 16;
    transform: scale(0.85);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
  }
  #azourane-shorts-{{ id }} .shorts-card.is-active {
    transform: scale(1);
  }
  #azourane-shorts-{{ id }} .shorts-card:first-child { margin-left: calc(50% - {{ s.card_width | divided_by: 2 }}px); }
  #azourane-shorts-{{ id }} .shorts-card:last-child { margin-right: calc(50% - {{ s.card_width | divided_by: 2 }}px); }
  #azourane-shorts-{{ id }} .iframe-wrapper {
    position: absolute; inset: 0; border-radius: inherit; overflow: hidden;
  }
  #azourane-shorts-{{ id }} .shorts-iframe { width: 100%; height: 100%; border: none; }
  #azourane-shorts-{{ id }} .card-controls {
    position: absolute;
    bottom: 15px;
    right: 15px;
    display: flex;
    gap: 12px;
    z-index: 10;
  }
  #azourane-shorts-{{ id }} .control-button {
    width: 42px; height: 42px; border-radius: 50%;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: white; transition: transform 0.2s;
  }
  #azourane-shorts-{{ id }} .control-button:hover { transform: scale(1.1); }
  #azourane-shorts-{{ id }} .nav-arrows {
    position: absolute; top: 50%; width: 100%;
    transform: translateY(-50%); z-index: 5;
    display: flex; justify-content: space-between;
    padding: 0 5vw; pointer-events: none;
  }
  #azourane-shorts-{{ id }} .arrow {
    width: 48px; height: 48px; border-radius: 50%;
    background: white; color: black; border: none;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    transition: transform 0.3s; pointer-events: auto;
  }
  #azourane-shorts-{{ id }} .arrow:hover { transform: scale(1.1); }
  #azourane-shorts-{{ id }} .dots-nav {
    position: relative; z-index: 1; display: flex; justify-content: center;
    gap: 12px; margin-top: 30px;
  }
  #azourane-shorts-{{ id }} .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: {{ s.dot_color | color_modify: 'alpha', 0.5 }};
    transition: all 0.4s; cursor: pointer;
  }
  #azourane-shorts-{{ id }} .dot.active {
    background: {{ s.dot_color }};
    transform: scale(1.3);
  }
  @media screen and (max-width: 767px) {
    #azourane-shorts-{{ id }} { padding-top: {{ s.padding_top | times: 0.6 }}px; padding-bottom: {{ s.padding_bottom | times: 0.6 }}px; }
    #azourane-shorts-{{ id }} .section-header h2 { font-size: 2rem; }
    #azourane-shorts-{{ id }} .section-header p { font-size: 1rem; }
    #azourane-shorts-{{ id }} .shorts-card { flex: 0 0 {{ s.card_width_mobile }}px; transform: scale(0.9); }
    #azourane-shorts-{{ id }} .shorts-card.is-active { transform: scale(1); }
    #azourane-shorts-{{ id }} .shorts-card:first-child { margin-left: calc(50% - {{ s.card_width_mobile | divided_by: 2 }}px); }
    #azourane-shorts-{{ id }} .shorts-card:last-child { margin-right: calc(50% - {{ s.card_width_mobile | divided_by: 2 }}px); }
  }
{%- endstyle -%}

<div id="azourane-shorts-{{ id }}">
  <div class="jumbo-text-wrapper">
    <div class="jumbo-text">{{ s.jumbo_text }}</div>
  </div>

  <div class="section-header">
    {%- if s.heading != blank -%}
      <h2>{{ s.heading }}</h2>
    {%- endif -%}
    {%- if s.subheading != blank -%}
      <p>{{ s.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="carousel-wrapper">
    <div class="shorts-container">
      {%- for block in section.blocks -%}
        {%- assign video_url = block.settings.video_url -%}
        {%- if video_url != blank -%}
          {%- liquid
            assign video_id = ''
            if video_url contains 'watch?v='
              assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first
            elsif video_url contains 'shorts/'
              assign video_id = video_url | split: 'shorts/' | last | split: '?' | first
            elsif video_url contains 'youtu.be/'
              assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
            endif
          -%}
          {%- if video_id != '' -%}
            <div
              class="shorts-card"
              data-video-id="{{ video_id }}"
              data-block-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <div class="iframe-wrapper">
                <div id="player-{{ block.id }}" class="shorts-iframe"></div>
              </div>
              <div class="card-controls">
                <button class="control-button mute-unmute" aria-label="Mute/Unmute">
                  <svg
                    class="volume-icon"
                    style="display:none;"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                  </svg>
                  <svg
                    class="mute-icon"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line>
                  </svg>
                </button>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if s.show_arrows -%}
      <div class="nav-arrows">
        <button class="arrow prev-arrow" aria-label="Previous">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="arrow next-arrow" aria-label="Next">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </div>

  {%- if s.show_dots and section.blocks.size > 0 -%}
    <div class="dots-nav">
      {%- for block in section.blocks -%}
        <div class="dot" data-index="{{ forloop.index0 }}"></div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  ((id) => {
    const YouTubeAPI = {
      isReady: false,
      isLoaded: false,
      queue: [],
      load() {
        if (this.isLoaded) return;
        this.isLoaded = true;
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(tag);
        window.onYouTubeIframeAPIReady = () => {
          this.isReady = true;
          this.queue.forEach(callback => callback());
        };
      },
      onReady(callback) {
        if (this.isReady) {
          callback();
        } else {
          this.queue.push(callback);
          this.load();
        }
      }
    };
    class AzouraneShortsCarousel {
      constructor(el) {
        this.el = el;
        this.container = el.querySelector('.shorts-container');
        this.cards = Array.from(el.querySelectorAll('.shorts-card'));
        this.dots = el.querySelectorAll('.dot');
        this.players = {};
        this.observer = null;
        if (!this.cards.length) return;
        this.init();
      }
      init() {
        YouTubeAPI.onReady(() => this.initPlayers());
        this.bindEvents();
        this.setupIntersectionObserver();
      }
      initPlayers() {
        this.cards.forEach(card => {
          const videoId = card.dataset.videoId;
          const blockId = card.dataset.blockId;
          const playerId = `player-${blockId}`;
          this.players[blockId] = new YT.Player(playerId, {
            videoId: videoId,
            playerVars: { 'playsinline': 1, 'controls': 0, 'rel': 0, 'modestbranding': 1, 'loop': 1, 'playlist': videoId },
            events: {
              'onReady': (e) => this.onPlayerReady(e, blockId)
            }
          });
        });
      }
      onPlayerReady(event, blockId) {
        event.target.mute();
        this.updateMuteIcon(blockId, true);
      }
      setupIntersectionObserver() {
          this.observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              const card = entry.target;
              const blockId = card.dataset.blockId;
              const player = this.players[blockId];
              card.classList.toggle('is-active', entry.isIntersecting);

              if (entry.isIntersecting) {
                player?.playVideo();
                this.updateActiveDot(card);
              } else {
                player?.pauseVideo();
              }
            });
          }, { root: this.container, threshold: 0.95 });
          this.cards.forEach(card => this.observer.observe(card));
      }
      updateActiveDot(activeCard) {
        const activeIndex = this.cards.indexOf(activeCard);
        this.dots.forEach((dot, index) => dot.classList.toggle('active', index === activeIndex));
      }
      bindEvents() {
        this.el.querySelector('.prev-arrow')?.addEventListener('click', () => this.navigate(-1));
        this.el.querySelector('.next-arrow')?.addEventListener('click', () => this.navigate(1));
        this.dots.forEach((dot, index) => dot.addEventListener('click', () => this.scrollToCard(index)));

        this.cards.forEach(card => {
          const blockId = card.dataset.blockId;
          card.querySelector('.mute-unmute')?.addEventListener('click', (e) => {
            e.stopPropagation();
            this.toggleMute(blockId);
          });
          card.addEventListener('click', (e) => {
            e.stopPropagation();
            this.togglePlayPause(blockId);
          });
        });
      }
      navigate(direction) {
        const activeCard = this.el.querySelector('.shorts-card.is-active');
        const currentIndex = activeCard ? this.cards.indexOf(activeCard) : 0;
        let targetIndex = currentIndex + direction;
        this.scrollToCard(targetIndex);
      }
      scrollToCard(index) {
        const targetIndex = Math.max(0, Math.min(this.cards.length - 1, index));
        this.cards[targetIndex]?.scrollIntoView({ behavior: 'smooth', inline: 'center' });
      }
      togglePlayPause(blockId) {
        const player = this.players[blockId];
        if (!player || typeof player.getPlayerState !== 'function') return;
        const state = player.getPlayerState();
        if (state === YT.PlayerState.PLAYING || state === YT.PlayerState.BUFFERING) {
          player.pauseVideo();
        } else {
          player.playVideo();
        }
      }
      toggleMute(blockId) {
        const player = this.players[blockId];
        if (!player || typeof player.isMuted !== 'function') return;
        if (player.isMuted()) {
          player.unMute();
          this.updateMuteIcon(blockId, false);
        } else {
          player.mute();
          this.updateMuteIcon(blockId, true);
        }
      }
      updateMuteIcon(blockId, isMuted) {
        const card = this.el.querySelector(`[data-block-id="${blockId}"]`);
        if (!card) return;
        const volumeIcon = card.querySelector('.volume-icon');
        const muteIcon = card.querySelector('.mute-icon');
        if (volumeIcon && muteIcon) {
            volumeIcon.style.display = isMuted ? 'none' : 'block';
            muteIcon.style.display = isMuted ? 'block' : 'none';
        }
      }
    }
    const carouselEl = document.getElementById(`azourane-shorts-${id}`);
    if (carouselEl) {
      new AzouraneShortsCarousel(carouselEl);
    }
  })('{{ id }}');
</script>

{% schema %}
{
  "name": "Azourane Shorts Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Jumbo Background Text"
    },
    {
      "type": "text",
      "id": "jumbo_text",
      "label": "Text",
      "default": "AZOURANE"
    },
    {
      "type": "font_picker",
      "id": "jumbo_font",
      "label": "Font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "jumbo_font_size",
      "label": "Font Size",
      "min": 5, "max": 40, "step": 1, "unit": "vw",
      "default": 25
    },
    {
      "type": "color",
      "id": "jumbo_text_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "jumbo_text_opacity",
      "label": "Opacity",
      "min": 0, "max": 20, "step": 1, "unit": "%",
      "default": 8
    },
    {
      "type": "select",
      "id": "jumbo_vertical_align",
      "label": "Vertical Position",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "jumbo_horizontal_align",
      "label": "Horizontal Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Content & Fonts"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "sans-serif"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Subheading Font",
      "default": "sans-serif"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout & Design"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 200, "step": 4, "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 200, "step": 4, "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Header Text Color",
      "default": "#1d1d1f"
    },
    {
      "type": "checkbox",
      "id": "show_gradient_background",
      "label": "Show gradient background",
      "default": false
    },
    { "type": "range", "id": "card_width", "min": 220, "max": 400, "step": 10, "unit": "px", "label": "Card width", "default": 300 },
    { "type": "range", "id": "card_width_mobile", "min": 200, "max": 320, "step": 10, "unit": "px", "label": "Mobile card width", "default": 260 },
    { "type": "range", "id": "gap", "min": 10, "max": 50, "step": 2, "unit": "px", "label": "Space between cards", "default": 30 },
    { "type": "range", "id": "border_radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Card border radius", "default": 24 },
    { "type": "checkbox", "id": "show_arrows", "label": "Show navigation arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show navigation dots", "default": true },
    {
      "type": "header",
      "content": "Gradient Colors (Optional)"
    },
    { "type": "color", "id": "accent_color_1", "label": "Gradient Color 1 (Sky Blue)", "default": "#87CEEB" },
    { "type": "color", "id": "accent_color_2", "label": "Gradient Color 2 (Apricot)", "default": "#FFDAB9" },
    { "type": "color", "id": "accent_color_3", "label": "Gradient Color 3 (Light Blue)", "default": "#ADD8E6" },
    { "type": "color", "id": "accent_color_4", "label": "Gradient Color 4 (Light Orange)", "default": "#FFA07A" },
    { "type": "color", "id": "dot_color", "label": "Navigation Dot Color", "default": "#1d1d1f" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 12,
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "YouTube Video URL",
          "info": "Paste a YouTube Shorts or standard video URL."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Azourane Shorts Carousel",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
