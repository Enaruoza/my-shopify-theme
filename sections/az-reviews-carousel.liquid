{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign reviews_product = section.settings.reviews_product
-%}

<az-reviews-carousel
  class="az-reviews color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
  role="region"
  aria-label="{{ section.settings.title | default: 'Recenzije' | escape }}"
>
  <div class="az-container page-width">
    <div class="az-reviews__header title-wrapper title-wrapper--no-top-margin">
      {%- if section.settings.title != blank -%}
        <h2 class="az-reviews__title title {{ section.settings.heading_size }}">
          {{- section.settings.title | escape -}}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <div class="az-reviews__subtitle subtitle">
          {{- section.settings.subtitle -}}
        </div>
      {%- endif -%}

      {%- if reviews_product and reviews_product.metafields.reviews.rating.value -%}
        <div class="az-reviews__stats" aria-live="polite">
          <div class="az-reviews__stat">
            <span class="az-reviews__stat-number">{{ reviews_product.metafields.reviews.rating_count }}</span>
            <span class="az-reviews__stat-label">Recenzije</span>
          </div>
          <div class="az-reviews__stat">
            <span class="az-reviews__stat-number">{{ reviews_product.metafields.reviews.rating.value.rating | round: 1 }}</span>
            <span class="az-reviews__stat-label">Prosječna ocjena</span>
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="az-reviews__carousel" data-carousel>
      <div class="az-reviews__track" data-carousel-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign has_media = false
            if block.settings.image != blank or block.settings.video_url != blank
              assign has_media = true
            endif
          -%}
          <article class="az-review{% unless has_media %} az-review--no-media{% endunless %}" {{ block.shopify_attributes }}>
            <div class="az-review__media card-wrapper" aria-hidden="true">
              {%- if block.settings.video_url != blank -%}
                {%- if block.settings.video_poster != blank -%}
                  {{ block.settings.video_url | video_tag:
                      autoplay: false,
                      loop: false,
                      controls: true,
                      muted: false,
                      class: 'az-review__video',
                      poster: block.settings.video_poster | image_url: width: 600
                  }}
                {%- else -%}
                  {{ block.settings.video_url | video_tag:
                      autoplay: false,
                      loop: false,
                      controls: true,
                      muted: false,
                      class: 'az-review__video'
                  }}
                {%- endif -%}
              {%- elsif block.settings.image != blank -%}
                {%- assign img = block.settings.image -%}
                <img
                  srcset="{{ img | image_url: width: 300 }} 300w, {{ img | image_url: width: 400 }} 400w, {{ img | image_url: width: 600 }} 600w"
                  src="{{ img | image_url: width: 400 }}"
                  sizes="(max-width: 768px) 250px, 300px"
                  width="{{ img.width }}"
                  height="{{ img.height }}"
                  class="az-review__image"
                  alt="{{ block.settings.quote | default: block.settings.name | truncate: 50 | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {%- else -%}
                <div class="az-review__media--placeholder" role="img" aria-label="Kupac">
                  <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-account" fill="none" viewBox="0 0 18 19">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9 0.5C5.41 0.5 2.5 3.41 2.5 7C2.5 10.59 5.41 13.5 9 13.5C12.59 13.5 15.5 10.59 15.5 7C15.5 3.41 12.59 0.5 9 0.5ZM0.5 7C0.5 2.313 4.313 -1.5 9 -1.5C13.687 -1.5 17.5 2.313 17.5 7C17.5 11.687 13.687 15.5 9 15.5C4.313 15.5 0.5 11.687 0.5 7Z" fill="currentColor"/>
                    <path d="M9 13.5C12.59 13.5 15.5 10.59 15.5 7H17.5C17.5 11.687 13.687 15.5 9 15.5V13.5Z" fill="currentColor"/>
                    <path d="M9 13.5C5.41 13.5 2.5 10.59 2.5 7H0.5C0.5 11.687 4.313 15.5 9 15.5V13.5Z" fill="currentColor"/>
                    <path d="M4.5 18.5C4.5 16.291 6.545 14.5 9 14.5C11.455 14.5 13.5 16.291 13.5 18.5H15.5C15.5 15.186 12.56 12.5 9 12.5C5.44 12.5 2.5 15.186 2.5 18.5H4.5Z" fill="currentColor"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            <div class="az-review__content">
              <div class="az-review__rating" role="img" aria-label="{{ block.settings.rating }} od 5 zvjezdica">
                {%- for i in (1..5) -%}
                  <svg class="az-review__star {% if block.settings.rating >= i %}az-review__star--filled{% endif %}" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M9.49 1.33l2.9 5.88 6.5 0.94-4.72 4.08 1.11 6.5-5.79-3.05-5.79 3.05 1.11-6.5L.17 8.15l6.5-.94L10.51 1.33z"/>
                  </svg>
                {%- endfor -%}
              </div>

              <blockquote class="az-review__quote">
                <p>{{ block.settings.quote | escape }}</p>
              </blockquote>

              <div class="az-review__author">
                <cite class="az-review__name">{{ block.settings.name | default: 'Verifikovani kupac' | escape }}</cite>

                {%- if block.settings.verified -%}
                  <span class="az-review__verified" aria-label="Verifikovana kupovina">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path d="M13.485 1L5.88 8.6l-3.365-3.365L1 8.8l4.88 4.88L15 4.515z"/>
                    </svg>
                    Verifikovano
                  </span>
                {%- endif -%}

                {%- if block.settings.product -%}
                  {%- assign product = block.settings.product -%}
                  <div class="az-review__product-trigger-wrapper">
                    <button
                      type="button"
                      class="az-review__product-trigger"
                      aria-expanded="false"
                      aria-controls="ProductPopup-{{ block.id }}"
                      data-product-trigger
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                      <span>{{ product.title | truncate: 15 }}</span>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="az-reviews__controls">
          <button class="az-reviews__control az-reviews__control--prev" data-carousel-prev aria-label="Prethodna recenzija">
            <svg class="icon icon-caret" viewBox="0 0 10 6"><path d="M9 5L5 1 1 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </button>
          <div class="az-reviews__progress-bar" data-carousel-progress>
            <div class="az-reviews__progress-bar-inner" data-carousel-progress-inner></div>
          </div>
          <button class="az-reviews__control az-reviews__control--next" data-carousel-next aria-label="Sljedeća recenzija">
             <svg class="icon icon-caret" viewBox="0 0 10 6"><path d="M9 5L5 1 1 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <div class="az-reviews__footer">
        <a href="{{ section.settings.cta_url }}" class="button button--primary">
          {{- section.settings.cta_text | escape -}}
        </a>
      </div>
    {%- endif -%}
  </div>

  <div class="az-reviews__popups-container" aria-hidden="true">
    {%- for block in section.blocks -%}
      {%- if block.settings.product -%}
        {%- assign product = block.settings.product -%}
        <div id="ProductPopup-{{ block.id }}" class="az-review__product-popup card card--product" tabindex="-1" hidden>
          <button type="button" class="az-review__product-popup-close" aria-label="Zatvori">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>

          {%- if product.featured_image -%}
            <img
              srcset="{{ product.featured_image | image_url: width: 160 }} 160w, {{ product.featured_image | image_url: width: 320 }} 320w"
              src="{{ product.featured_image | image_url: width: 160 }}"
              sizes="80px"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              class="az-review__product-image"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}

          <div class="az-review__product-info">
            <a href="{{ product.url }}" class="az-review__product-link full-unstyled-link">{{ product.title | escape }}</a>

            <div class="price az-review__product-price">
              {%- if product.compare_at_price > product.price -%}
                <span class="visually-hidden">Regular price</span>
                <s class="price-item price-item--regular">{{ product.compare_at_price | money }}</s>
                <span class="visually-hidden">Sale price</span>
                <span class="price-item price-item--sale">{{ product.price | money }}</span>
              {%- else -%}
                <span class="visually-hidden">Regular price</span>
                <span class="price-item">{{ product.price | money }}</span>
              {%- endif -%}
            </div>

            <form class="product-form" data-ajax-add>
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                name="add"
                class="az-review__product-add-button button button--primary"
                data-add-to-cart
                {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
              >
                <span class="label-add">
                  {%- if product.selected_or_first_available_variant.available -%}
                    Dodaj u korpu
                  {%- else -%}
                    Nema na stanju
                  {%- endif -%}
                </span>
                <span class="label-adding" hidden>Dodavanje…</span>
                <span class="label-added" hidden>Dodano</span>
              </button>
            </form>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="az-toast" data-az-toast hidden>
    Dodano u korpu. <a href="{{ routes.cart_url }}">Vidi korpu</a>
  </div>
</az-reviews-carousel>

{%- style -%}
  {{ heading_font | font_face }}
  {{ body_font | font_face }}

  .az-reviews[data-section-id="{{ section.id }}"] {
    --color-background: {{ section.settings.background_color.red }}, {{ section.settings.background_color.green }}, {{ section.settings.background_color.blue }};
    --color-background-alt: {{ section.settings.background_alt_color.red }}, {{ section.settings.background_alt_color.green }}, {{ section.settings.background_alt_color.blue }};
    --color-border: {{ section.settings.border_color.red }}, {{ section.settings.border_color.green }}, {{ section.settings.border_color.blue }};
    --color-header-title: {{ section.settings.header_title_color.red }}, {{ section.settings.header_title_color.green }}, {{ section.settings.header_title_color.blue }};
    --color-header-subtitle: {{ section.settings.header_subtitle_color.red }}, {{ section.settings.header_subtitle_color.green }}, {{ section.settings.header_subtitle_color.blue }};
    --color-stat-number: {{ section.settings.stat_number_color.red }}, {{ section.settings.stat_number_color.green }}, {{ section.settings.stat_number_color.blue }};
    --color-stat-label: {{ section.settings.stat_label_color.red }}, {{ section.settings.stat_label_color.green }}, {{ section.settings.stat_label_color.blue }};
    --color-review-quote: {{ section.settings.review_quote_color.red }}, {{ section.settings.review_quote_color.green }}, {{ section.settings.review_quote_color.blue }};
    --color-review-author: {{ section.settings.review_author_color.red }}, {{ section.settings.review_author_color.green }}, {{ section.settings.review_author_color.blue }};
    --color-star: {{ section.settings.star_color.red }}, {{ section.settings.star_color.green }}, {{ section.settings.star_color.blue }};
    --color-verified-badge-bg: {{ section.settings.verified_badge_bg.red }}, {{ section.settings.verified_badge_bg.green }}, {{ section.settings.verified_badge_bg.blue }};
    --color-verified-badge-text: {{ section.settings.verified_badge_text.red }}, {{ section.settings.verified_badge_text.green }}, {{ section.settings.verified_badge_text.blue }};
    --color-product-popup-bg: {{ section.settings.product_popup_bg.red }}, {{ section.settings.product_popup_bg.green }}, {{ section.settings.product_popup_bg.blue }};
    --color-product-popup-text: {{ section.settings.product_popup_text.red }}, {{ section.settings.product_popup_text.green }}, {{ section.settings.product_popup_text.blue }};
    --font-headings: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
    --font-weight-headings: {{ heading_font.weight }};
    --font-weight-body: {{ body_font.weight }};
    background-color: rgb(var(--color-background));
    padding-top: calc(var(--section-padding) * .75);
    padding-bottom: calc(var(--section-padding) * .75);
    font-family: var(--font-body);
    font-weight: var(--font-weight-body);
    position: relative;
  }

  .az-reviews__header { text-align: center; margin-bottom: 2rem; }
  .az-reviews__title { color: rgb(var(--color-header-title)); margin: 0 0 0.75rem; font-family: var(--font-headings); font-weight: var(--font-weight-headings); }
  .az-reviews__subtitle { color: rgb(var(--color-header-subtitle)); max-width: 50ch; margin: 0 auto 1.5rem; }
  .az-reviews__stats { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
  .az-reviews__stat-number { display: block; font-size: 1.5rem; font-weight: var(--font-weight-headings); color: rgb(var(--color-stat-number)); }
  .az-reviews__stat-label { font-size: 0.875rem; color: rgb(var(--color-stat-label)); text-transform: uppercase; letter-spacing: 0.05em; }
  .az-reviews__carousel { position: relative; overflow: hidden; }
  .az-reviews__track { display: flex; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  .az-review { flex: 0 0 100%; display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; padding: 0 2rem; align-items: center; }
  .az-review__media { aspect-ratio: 1 / 1; border-radius: var(--card-corner-radius); overflow: hidden; }
  .az-review__media--placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; background-color: rgba(var(--color-border), 0.2); border: 1px solid rgba(var(--color-border), 0.5); color: rgba(var(--color-border), 0.8); }
  .az-review__image, .az-review__video { width: 100%; height: 100%; object-fit: cover; }
  .az-review__media--placeholder .icon { width: 4rem; height: 4rem; }
  .az-review__content { padding: 0.75rem 0; }
  .az-review__rating { display: flex; gap: 4px; margin-bottom: 1rem; }
  .az-review__star { color: rgba(var(--color-border)); }
  .az-review__star--filled { color: rgb(var(--color-star)); }
  .az-review__quote { font-size: clamp(1.1rem, 2.5vw, 1.5rem); line-height: 1.5; font-style: italic; color: rgb(var(--color-review-quote)); margin: 0 0 1.25rem; quotes: "“" "”"; }
  .az-review__quote p { margin: 0; }
  .az-review__author { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .az-review__name { font-weight: var(--font-weight-headings); color: rgb(var(--color-review-author)); font-style: normal; }
  .az-review__verified { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: rgb(var(--color-verified-badge-text)); background-color: rgb(var(--color-verified-badge-bg)); padding: 4px 0.75rem; border-radius: var(--button-corner-radius); }

  .az-review__product-trigger-wrapper { position: relative; }
  .az-review__product-trigger { display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; color: rgb(var(--color-review-quote)); padding: 4px 8px; border: 1px solid rgba(var(--color-border)); border-radius: 99px; cursor: pointer; background-color: transparent; transition: background-color 0.2s ease, border-color 0.2s ease; }

  .az-review__product-popup {
    position: fixed;
    width: 300px;
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background-color: rgb(var(--color-product-popup-bg));
    border-radius: var(--card-corner-radius);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(var(--color-border));
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  }
  .az-review__product-popup[hidden] { display: flex; }
  .az-review__product-image { width: 80px; height: 80px; object-fit: cover; border-radius: calc(var(--card-corner-radius) - var(--card-border-width) - var(--card-image-padding)); flex-shrink: 0; }
  .az-review__product-info { flex: 1; text-align: left; }
  .az-review__product-link { display: block; font-size: 0.875rem; color: rgb(var(--color-product-popup-text)); text-decoration: none; font-weight: 600; line-height: 1.3; margin-bottom: 0.5rem; }
  .az-review__product-price { color: rgb(var(--color-product-popup-text)); font-size: 0.875rem; margin-bottom: 0.75rem; display: block; }
  .az-review__product-add-button { width: 100%; }

  .az-reviews__footer { text-align: center; margin-top: 2rem; }
  .az-review__product-popup-close { position: absolute; top: 6px; right: 6px; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background-color: transparent; border: none; padding: 0; cursor: pointer; color: rgba(var(--color-product-popup-text), 0.5); transition: color 0.2s ease; }
  .az-review__product-popup-close:hover { color: rgb(var(--color-product-popup-text)); }

  .az-review--no-media { grid-template-columns: 1fr; text-align: center; }
  .az-review--no-media .az-review__media { display: none; }
  .az-review--no-media .az-review__rating,
  .az-review--no-media .az-review__author { justify-content: center; }

  .az-reviews__controls { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 2.5rem; }
  .az-reviews__control { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(var(--color-border)); background-color: transparent; cursor: pointer; transition: background-color 0.2s ease; }
  .az-reviews__control:hover { background-color: rgba(var(--color-border), 0.2); }
  .az-reviews__control:disabled { opacity: 0.5; cursor: not-allowed; }
  .az-reviews__control .icon { width: 12px; height: 12px; }
  .az-reviews__control--prev .icon { transform: rotate(-90deg); }
  .az-reviews__control--next .icon { transform: rotate(90deg); }
  .az-reviews__progress-bar { width: 100%; max-width: 200px; height: 3px; background-color: rgba(var(--color-border), 0.5); border-radius: 3px; overflow: hidden; }
  .az-reviews__progress-bar-inner { height: 100%; background-color: rgb(var(--color-header-title)); width: 0%; transition: width 0.4s ease; }

  @media screen and (max-width: 768px) {
    .az-review { grid-template-columns: 1fr; padding: 0 1.5rem; }
    .az-review__media { max-width: 250px; margin: 0 auto 1.5rem; }
    .az-review__content { text-align: center; }
    .az-review__rating, .az-review__author { justify-content: center; }
    .az-review--no-media .az-review__media { display: none; }
  }

  .az-review__product-popup.is-visible { opacity: 1; visibility: visible; transform: none; }

  .az-toast {
    position: fixed;
    left: 50%;
    bottom: 18px;
    transform: translateX(-50%) translateY(8px);
    background: #111827;
    color: #fff;
    padding: 10px 14px;
    border-radius: 8px;
    box-shadow: var(--shadow-lg);
    font-size: 14px;
    z-index: 1000;
    opacity: 0;
    transition: opacity .2s ease, transform .2s ease;
  }
  .az-toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }
  .az-toast a { color: #fff; text-decoration: underline; }
{%- endstyle -%}

<script>
  class AZReviewsCarousel extends HTMLElement {
    constructor() {
      super();
      this.carousel = this;
      this.track = this.querySelector('[data-carousel-track]');
      this.reviews = this.track ? Array.from(this.track.children) : [];
      this.totalReviews = this.reviews.length;

      if (this.totalReviews <= 1) {
        const controls = this.querySelector('.az-reviews__controls');
        if (controls) controls.style.display = 'none';
      }

      this.prevBtn = this.querySelector('[data-carousel-prev]');
      this.nextBtn = this.querySelector('[data-carousel-next]');
      this.progressBarInner = this.querySelector('[data-carousel-progress-inner]');
      this.currentIndex = 0;
      this.autoplayInterval = null;
      this.isInteracting = false;
      this.isDesktop = window.innerWidth > 768;

      const autoplayAttr = this.getAttribute('data-autoplay');
      this.autoplayEnabled = autoplayAttr === 'true';
      const intervalAttr = parseInt(this.getAttribute('data-interval'), 10);
      this.autoplayMs = isNaN(intervalAttr) ? 5000 : Math.max(2000, intervalAttr);

      if (this.totalReviews > 1) {
        this.init();
      }
      this.initProductPopups();
    }

    debounce(fn, wait) {
      let t;
      return (...args) => { clearTimeout(t); t = setTimeout(() => fn.apply(this, args), wait); };
    }

    init() {
      this.attachEventListeners();
      this.updateCarousel();
      if (this.autoplayEnabled) this.startAutoplay();
      this.wireAjaxATC();
    }

    attachEventListeners() {
      this.prevBtn?.addEventListener('click', () => this.goToSlide(this.currentIndex - 1, false));
      this.nextBtn?.addEventListener('click', () => this.goToSlide(this.currentIndex + 1, false));

      const pauseEls = [this];
      pauseEls.forEach(el => {
        el.addEventListener('mouseenter', () => { this.isInteracting = true; this.stopAutoplay(); });
        el.addEventListener('mouseleave', () => { this.isInteracting = false; if (this.autoplayEnabled) this.startAutoplay(); });
        el.addEventListener('focusin', () => { this.isInteracting = true; this.stopAutoplay(); });
        el.addEventListener('focusout', () => { this.isInteracting = false; if (this.autoplayEnabled) this.startAutoplay(); });
      });

      let touchStartX = 0;
      this.track?.addEventListener('touchstart', e => touchStartX = e.changedTouches[0].screenX, { passive: true });
      this.track?.addEventListener('touchend', e => {
        const touchEndX = e.changedTouches[0].screenX;
        if (Math.abs(touchStartX - touchEndX) > 50) {
          touchStartX > touchEndX ? this.goToSlide(this.currentIndex + 1) : this.goToSlide(this.currentIndex - 1);
        }
      }, { passive: true });

      window.addEventListener('resize', this.debounce(() => {
        const wasDesktop = this.isDesktop;
        this.isDesktop = window.innerWidth > 768;
        if (wasDesktop !== this.isDesktop) {
          this.stopAutoplay();
          if (this.autoplayEnabled) this.startAutoplay();
        }
        this.updateCarousel();
      }, 200));
    }

    updateCarousel() {
      if (!this.track) return;
      this.track.style.transform = `translateX(-${this.currentIndex * 100}%)`;
      if (this.progressBarInner) {
        const pct = ((this.currentIndex + 1) / this.totalReviews) * 100;
        this.progressBarInner.style.width = `${pct}%`;
      }
      if (this.prevBtn) this.prevBtn.disabled = this.currentIndex === 0;
      if (this.nextBtn) this.nextBtn.disabled = this.currentIndex === this.totalReviews - 1;
    }

    goToSlide(index, loop = true) {
      let newIndex = index;
      if (loop) newIndex = (index + this.totalReviews) % this.totalReviews;
      else if (index < 0 || index >= this.totalReviews) return;
      this.currentIndex = newIndex;
      this.updateCarousel();
    }

    startAutoplay() {
      if (!this.isDesktop || this.isInteracting) return;
      this.stopAutoplay();
      this.autoplayInterval = setInterval(() => this.goToSlide(this.currentIndex + 1, true), this.autoplayMs);
    }

    stopAutoplay() {
      if (this.autoplayInterval) clearInterval(this.autoplayInterval);
      this.autoplayInterval = null;
    }

    initProductPopups() {
      const triggers = this.querySelectorAll('[data-product-trigger]');
      if (!triggers.length) return;

      const closeAll = () => {
        const popups = this.querySelectorAll('.az-review__product-popup');
        popups.forEach(popup => { popup.classList.remove('is-visible'); popup.removeAttribute('style'); });
        triggers.forEach(btn => { btn.setAttribute('aria-expanded', 'false'); });
      };

      triggers.forEach(btn => {
        const popupId = btn.getAttribute('aria-controls');
        const popup = this.querySelector('#' + popupId);
        if (!popup) return;

        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isExpanded = btn.getAttribute('aria-expanded') === 'true';
          closeAll();
          if (!isExpanded) {
            btn.setAttribute('aria-expanded', 'true');
            popup.classList.add('is-visible');

            requestAnimationFrame(() => {
              const r = btn.getBoundingClientRect();
              const w = popup.offsetWidth;
              const h = popup.offsetHeight;
              const vw = window.innerWidth;
              const s = 10;

              let left = r.left + (r.width / 2) - (w / 2);
              if (left < s) left = s;
              else if (left + w > vw - s) left = vw - w - s;

              let top = r.top - h - s;
              if (top < s) top = r.bottom + s;

              popup.style.top = `${top}px`;
              popup.style.left = `${left}px`;
              popup.focus();
            });
          }
        });

        const closeBtn = popup.querySelector('.az-review__product-popup-close');
        if (closeBtn) closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closeAll(); });
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('[data-product-trigger]') && !e.target.closest('.az-review__product-popup.is-visible')) closeAll();
      });

      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });
    }

    wireAjaxATC() {
      const forms = this.querySelectorAll('form[data-ajax-add]');
      forms.forEach((form) => {
        if (form._azBound) return;
        form._azBound = true;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = form.querySelector('[data-add-to-cart]');
          const idInput = form.querySelector('input[name="id"]');
          if (!idInput || !idInput.value) return;

          try {
            btn?.setAttribute('disabled', 'disabled');
            this.setButtonState(btn, 'adding');

            // Use FormData – Shopify accepts multipart and urlencoded; this avoids content-type issues.
            const fd = new FormData(form);
            if (!fd.get('quantity')) fd.set('quantity', '1');

            const res = await fetch('/cart/add.js', {
              method: 'POST',
              body: fd,
              headers: { 'Accept': 'application/json' },
              credentials: 'same-origin'
            });

            if (!res.ok) throw new Error('add_failed');

            await this.refreshCartCount();
            this.showToast();

            this.setButtonState(btn, 'added');
            setTimeout(() => this.setButtonState(btn, 'default'), 1200);

            const popup = form.closest('.az-review__product-popup');
            if (popup) {
              popup.classList.remove('is-visible');
              popup.removeAttribute('style');
              const trigger = this.querySelector(`[aria-controls="${popup.id}"]`);
              if (trigger) trigger.setAttribute('aria-expanded', 'false');
            }

            // Notify theme if it listens for cart updates.
            document.body.dispatchEvent(new CustomEvent('cart:refresh'));
            document.body.dispatchEvent(new CustomEvent('cart:updated'));
          } catch (err) {
            this.showToast('Greška pri dodavanju, pokušaj ponovo.');
            this.setButtonState(btn, 'default');
          } finally {
            btn?.removeAttribute('disabled');
          }
        });
      });
    }

    setButtonState(btn, state) {
      if (!btn) return;
      const lAdd = btn.querySelector('.label-add');
      const lAdding = btn.querySelector('.label-adding');
      const lAdded = btn.querySelector('.label-added');
      const show = (el, on) => { if (el) el.hidden = !on; };
      if (state === 'adding') { show(lAdd, false); show(lAdded, false); show(lAdding, true); }
      else if (state === 'added') { show(lAdd, false); show(lAdding, false); show(lAdded, true); }
      else { show(lAdd, true); show(lAdding, false); show(lAdded, false); }
    }

    async refreshCartCount() {
      try {
        const res = await fetch('/cart.js', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' });
        if (!res.ok) return;
        const cart = await res.json();
        const countEls = document.querySelectorAll('[data-cart-count],[data-items-in-cart]');
        countEls.forEach(el => { el.textContent = cart.item_count; });
      } catch (_) {}
    }

    showToast(message) {
      const toast = this.querySelector('[data-az-toast]');
      if (!toast) return;
      if (message) {
        if (toast.firstChild && toast.firstChild.nodeType === Node.TEXT_NODE) {
          toast.firstChild.nodeValue = message + ' ';
        }
      }
      toast.hidden = false;
      toast.classList.add('is-visible');
      clearTimeout(this._toastTimer);
      this._toastTimer = setTimeout(() => {
        toast.classList.remove('is-visible');
        toast.hidden = true;
      }, 2200);
    }
  }

  customElements.define('az-reviews-carousel', AZReviewsCarousel);
</script>

