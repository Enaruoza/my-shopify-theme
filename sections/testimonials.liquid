      "label": "Section Max Width",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Design & Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#F9FAFB"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#F59E0B"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Card Roundness",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading Size",
      "default": 48
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
