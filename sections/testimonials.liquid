{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign card_bg = section.settings.card_background_color
  assign text_color = section.settings.heading_color
-%}

<style>
  {{ heading_font | font_face }}
  {{ body_font | font_face }}

  :root {
    --ts-gap: 24px;
    --ts-card-width-desktop: 400px;
    --ts-card-width-mobile: 85vw;
    --ts-radius: {{ section.settings.card_radius }}px;
    --ts-primary: {{ section.settings.heading_color }};
    --ts-star: {{ section.settings.star_color }};
  }

  .testimonial-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
    position: relative;
  }

  .testimonial-section-{{ section.id }} .section-header {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto 40px;
    padding: 0 24px;
    text-align: center;
  }

  .testimonial-section-{{ section.id }} h2 {
    margin: 0;
    color: var(--ts-primary);
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    font-weight: {{ heading_font.weight }};
    font-size: {{ section.settings.heading_font_size }}px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  /* --- MASONRY LAYOUT (The Wall of Love) --- */
  .testimonial-section-{{ section.id }} .scroller-wrapper {
    width: 100%;
    column-count: 3;
    column-gap: 30px;
    padding: 40px 20px; /* Space for rotations */
    overflow: visible; /* Allow pins to stick out */
    display: block; /* Reset flex */
  }

  @media (max-width: 1024px) {
    .testimonial-section-{{ section.id }} .scroller-wrapper {
      column-count: 2;
    }
  }

  @media (max-width: 767px) {
    .testimonial-section-{{ section.id }} .scroller-wrapper {
      column-count: 1;
    }
  }

  /* --- CARD DESIGN ("Pinned Notes") --- */
  .testimonial-section-{{ section.id }} .t-card {
    break-inside: avoid; /* Prevent split across columns */
    margin-bottom: 40px; /* Space between vertical items */
    width: 100%;
    background-color: {{ section.settings.card_background_color }};
    border-radius: 2px; /* Paper-like corners */
    padding: 32px;
    position: relative;
    font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
    
    /* Paper Shadow */
    box-shadow: 
      0 1px 1px rgba(0,0,0,0.1), 
      0 10px 20px -5px rgba(0,0,0,0.15),
      0 0 1px rgba(0,0,0,0.1);
    
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: auto; 
    
    /* Subtle Paper Texture */
    background-image: linear-gradient(to bottom right, rgba(0,0,0,0.02) 0%, transparent 100%);
  }

  /* Random Rotations for "Pinned" feel */
  .testimonial-section-{{ section.id }} .t-card:nth-child(odd) { transform: rotate(-1.5deg); }
  .testimonial-section-{{ section.id }} .t-card:nth-child(even) { transform: rotate(1deg); }
  .testimonial-section-{{ section.id }} .t-card:nth-child(3n) { transform: rotate(2deg); }
  .testimonial-section-{{ section.id }} .t-card:nth-child(5n) { transform: rotate(-2deg); }

  /* Hover Lift & Straighten */
  .testimonial-section-{{ section.id }} .t-card:hover {
    transform: scale(1.02) rotate(0deg) !important;
    z-index: 10;
    box-shadow: 
      0 20px 40px -10px rgba(0,0,0,0.2), 
      0 0 1px rgba(0,0,0,0.1);
  }

  /* THE PIN */
  .testimonial-section-{{ section.id }} .t-card::after {
    content: '';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #ff6b6b, #c92a2a);
    box-shadow: 
      1px 2px 4px rgba(0,0,0,0.3),
      inset -1px -1px 2px rgba(0,0,0,0.2);
    z-index: 5;
  }
  
  /* Pin Shadow on paper */
  .testimonial-section-{{ section.id }} .t-card::before {
    content: '';
    position: absolute;
    top: -2px;
    left: 52%;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0,0,0,0.3);
    filter: blur(1px);
    z-index: 4;
  }

  /* RATING */
  .testimonial-section-{{ section.id }} .t-stars {
    color: var(--ts-star);
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 16px;
    display: flex;
    gap: 2px;
  }

  /* TITLE & TEXT */
  .testimonial-section-{{ section.id }} .t-title {
    color: var(--ts-primary);
    font-weight: 800;
    font-size: {{ section.settings.title_font_size }}px;
    margin: 0 0 12px 0;
    line-height: 1.3;
    /* Handwritten feel for title? Optional */
  }

  .testimonial-section-{{ section.id }} .t-text {
    color: {{ section.settings.heading_color | color_lighten: 20 }};
    font-size: {{ section.settings.body_font_size }}px;
    line-height: 1.7;
    flex-grow: 1;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  /* CUSTOMER FOOTER */
  .testimonial-section-{{ section.id }} .t-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px dashed rgba(0,0,0,0.1); /* Dashed line for notes */
  }

  .testimonial-section-{{ section.id }} .t-avatar {
    width: 40px;
    height: 40px;
    background-color: var(--ts-primary);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .testimonial-section-{{ section.id }} .t-meta {
    display: flex;
    flex-direction: column;
    font-size: 13px;
  }

  .testimonial-section-{{ section.id }} .t-name {
    font-weight: 700;
    color: var(--ts-primary);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* Verified Badge */
  .testimonial-section-{{ section.id }} .verified-badge {
    display: inline-flex;
    align-items: center;
    color: #10B981; /* Green Trust Color */
  }
  .testimonial-section-{{ section.id }} .verified-badge svg {
    width: 14px;
    height: 14px;
  }

  .testimonial-section-{{ section.id }} .t-product {
    color: var(--ts-primary);
    opacity: 0.6;
    text-decoration: none;
    margin-top: 2px;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .testimonial-section-{{ section.id }} .t-product:hover {
    opacity: 1;
    text-decoration: underline;
  }

  /* NAVIGATION HIDDEN (Masonry shows all) */
  .testimonial-section-{{ section.id }} .nav-wrapper {
    display: none;
  }
  
  /* RESPONSIVE */
  @media (max-width: 767px) {
    .testimonial-section-{{ section.id }} .t-card {
      width: 100%;
      padding: 24px;
      margin-bottom: 30px;
    }
  }
</style>

<div class="testimonial-section-{{ section.id }}">
  
  {%- if section.settings.heading != blank -%}
    <div class="section-header">
      <h2>{{ section.settings.heading | escape }}</h2>
    </div>
  {%- endif -%}

  <div class="scroller-wrapper" id="Track-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="t-card" {{ block.shopify_attributes }}>
        
        {% if block.settings.rating > 0 %}
          <div class="t-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for i in (1..block.settings.rating) %}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            {% endfor %}
          </div>
        {% endif %}

        {% if block.settings.review_title != blank and block.settings.review_title != 'AUTO' %}
          <h3 class="t-title">{{ block.settings.review_title | escape }}</h3>
        {% endif %}
        
        {% if block.settings.review_text != blank %}
          <div class="t-text">{{ block.settings.review_text }}</div>
        {% endif %}

        <div class="t-footer">
          {%- assign name = block.settings.customer_name | default: 'Customer' -%}
          {%- assign first_letter = name | slice: 0 | upcase -%}
          
          <div class="t-avatar">{{ first_letter }}</div>

          <div class="t-meta">
            <span class="t-name">
              {{ name }}
              <span class="verified-badge" title="Verified Customer">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              </span>
            </span>

            {%- if block.settings.product -%}
              <a href="{{ block.settings.product.url }}" class="t-product">Verified buyer of {{ block.settings.product.title }}</a>
            {%- elsif block.settings.product_reference != blank and block.settings.product_reference != 'AUTO' -%}
               <span class="t-product">Verified buyer of {{ block.settings.product_reference }}</span>
            {%- else -%}
               <span class="t-product" style="opacity: 0.5; font-size: 12px;">Verified Review</span>
            {%- endif -%}
          </div>
        </div>

      </div>
    {% endfor %}
  </div>

  <div class="nav-wrapper">
    <button class="nav-btn" id="Prev-{{ section.id }}" aria-label="Previous">
       <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>
    <button class="nav-btn" id="Next-{{ section.id }}" aria-label="Next">
       <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('Track-{{ section.id }}');
    const prev = document.getElementById('Prev-{{ section.id }}');
    const next = document.getElementById('Next-{{ section.id }}');
    
    if(!track || !prev || !next) return;

    // Scroll Distance = width of card + gap
    const getScrollAmount = () => {
      const card = track.querySelector('.t-card');
      return card ? card.offsetWidth + 24 : 300; 
    }

    next.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    // Optional: Drag to scroll logic
    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', () => isDown = false);
    track.addEventListener('mouseup', () => isDown = false);
    track.addEventListener('mousemove', (e) => {
      if(!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 2; 
      track.scrollLeft = scrollLeft - walk;
    });
  });
</script>

{% schema %}
{
  "name": "Award-Winning Reviews",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by thousands"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Section Max Width",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Design & Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#F9FAFB"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#F59E0B"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Card Roundness",
      "default": 16
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading Size",
      "default": 48
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Review Title Size",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Review Text Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Stars",
          "default": 5
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Headline",
          "default": "Absolutely incredible!"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Review",
          "default": "<p>The quality exceeded my expectations. Shipping was fast and the packaging was beautiful. Highly recommended.</p>"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Sarah J."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Purchased Product"
        },
        {
          "type": "text",
          "id": "product_reference",
          "label": "Product Name (Fallback)",
          "info": "Used if product picker is empty"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Award-Winning Reviews",
      "blocks": [
        {"type": "testimonial"},
        {"type": "testimonial"},
        {"type": "testimonial"},
        {"type": "testimonial"}
      ]
    }
  ]
}
{% endschema %}