```liquid
<section id="az-hero-{{ section.id }}" class="az-hero color-{{ section.settings.color_scheme }} gradient az-hero--animation-{{ section.settings.animation_style }}" data-section-id="{{ section.id }}" data-auto-rotate="{{ section.settings.auto_rotate }}" data-rotate-ms="{{ section.settings.rotate_ms | times: 1000 }}" data-animation="{{ section.settings.animation_style }}">
  <style>
    {%- liquid
      assign heading_font = settings[section.settings.heading_font] | default: settings.type_header_font
      assign body_font = settings[section.settings.body_font] | default: settings.type_body_font
      
      assign desktop_padding_top = section.settings.desktop_padding_top | append: 'px'
      assign desktop_padding_bottom = section.settings.desktop_padding_bottom | append: 'px'
      assign mobile_padding_top = section.settings.mobile_padding_top | append: 'px'
      assign mobile_padding_bottom = section.settings.mobile_padding_bottom | append: 'px'
      
      assign primary_cta_bg = section.settings.primary_cta_color | default: 'rgb(var(--color-accent))'
    -%}
    
    #az-hero-{{ section.id }} {
      --az-heading-font: {{ heading_font | font_face: font_display: 'swap' }};
      --az-body-font: {{ body_font | font_face: font_display: 'swap' }};
      --az-primary-cta-bg: {{ primary_cta_bg }};
      
      {% if section.settings.full_width_background %}
        width: 100%;
      {% else %}
        max-width: 1400px;
        margin: 0 auto;
      {% endif %}
      padding-top: {{ desktop_padding_top }};
      padding-bottom: {{ desktop_padding_bottom }};
      padding-left: 20px;
      padding-right: 20px;
      position: relative;
      overflow: hidden;
    }
    
    #az-hero-{{ section.id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: radial-gradient(ellipse at center top, rgba(var(--color-accent), 0.03) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    
    .az-hero__container {
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    
    .az-hero__slider {
      position: relative;
      width: 100%;
    }
    
    .az-hero__track {
      display: flex;
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    
    .az-hero--animation-fade .az-hero__track {
      transition: opacity 0.6s ease-in-out;
    }
    
    .az-hero--animation-scale .az-hero__track {
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease-in-out;
    }
    
    .az-hero__slide {
      flex: 0 0 100%;
      display: grid;
      grid-template-columns: 1fr minmax(360px, 420px);
      gap: 60px;
      align-items: center;
      position: relative;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease-in-out, visibility 0.4s ease-in-out;
    }
    
    .az-hero__slide.is-active {
      opacity: 1;
      visibility: visible;
    }
    
    .az-hero__media {
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      animation: az-float 6s ease-in-out infinite;
    }
    
    @keyframes az-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    
    @media (prefers-reduced-motion: reduce) {
      .az-hero__media { animation: none; }
      .az-hero__track { transition: none; }
    }
    
    .az-hero__media img {
      max-width: 100%;
      max-height: 500px;
      height: auto;
      object-fit: contain;
      filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.1));
    }
    
    .az-hero__trust-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: rgba(var(--color-background), 0.95);
      backdrop-filter: blur(10px);
      padding: 8px 16px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--az-body-font);
      font-size: 13px;
      font-weight: 500;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      opacity: 0;
      animation: az-badge-in 0.6s 0.5s forwards;
    }
    
    @keyframes az-badge-in {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .az-hero__trust-badge svg {
      width: 16px;
      height: 16px;
      color: rgb(var(--color-accent));
    }
    
    .az-hero__chips {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      max-width: 400px;
    }
    
    .az-hero__chip {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: rgba(var(--color-background), 0.95);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(var(--color-foreground), 0.08);
      border-radius: 25px;
      font-family: var(--az-body-font);
      font-size: 13px;
      font-weight: 500;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
      opacity: 0;
      transform: translateY(20px) scale(0.9);
      transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }
    
    .az-hero__slide.is-active .az-hero__chip {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    
    .az-hero__slide.is-active .az-hero__chip:nth-child(1) { transition-delay: 0.1s; }
    .az-hero__slide.is-active .az-hero__chip:nth-child(2) { transition-delay: 0.2s; }
    .az-hero__slide.is-active .az-hero__chip:nth-child(3) { transition-delay: 0.3s; }
    .az-hero__slide.is-active .az-hero__chip:nth-child(4) { transition-delay: 0.4s; }
    
    .az-hero__chip svg {
      width: 14px;
      height: 14px;
      color: rgb(var(--color-accent));
    }
    
    .az-hero__meta {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    
    .az-hero__urgency {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: rgba(var(--color-accent), 0.1);
      border-radius: 20px;
      font-family: var(--az-body-font);
      font-size: 13px;
      font-weight: 600;
      color: rgb(var(--color-accent));
      align-self: flex-start;
      animation: az-pulse 2s infinite;
    }
    
    @keyframes az-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    
    .az-hero__urgency svg {
      width: 14px;
      height: 14px;
    }
    
    .az-hero__badge {
      display: inline-block;
      padding: 6px 14px;
      background: linear-gradient(135deg, rgba(var(--color-accent), 0.1) 0%, rgba(var(--color-accent), 0.05) 100%);
      border: 1px solid rgba(var(--color-accent), 0.2);
      border-radius: 25px;
      font-family: var(--az-body-font);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
      align-self: flex-start;
      color: rgb(var(--color-accent));
    }
    
    .az-hero__heading {
      font-family: var(--az-heading-font);
      font-size: 36px;
      font-weight: 700;
      line-height: 1.1;
      margin: 0;
      letter-spacing: -0.02em;
      color: rgb(var(--color-foreground));
    }
    
    .az-hero__subheading {
      font-family: var(--az-body-font);
      font-size: 17px;
      line-height: 1.6;
      opacity: 0.8;
      margin: 0;
      color: rgba(var(--color-foreground), 0.8);
    }
    
    .az-hero__value-props {
      display: flex;
      gap: 20px;
      padding: 16px 0;
      border-top: 1px solid rgba(var(--color-foreground), 0.08);
      border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    }
    
    .az-hero__value-prop {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--az-body-font);
      font-size: 13px;
      color: rgba(var(--color-foreground), 0.7);
    }
    
    .az-hero__value-prop svg {
      width: 16px;
      height: 16px;
      color: rgb(var(--color-accent));
    }
    
    .az-hero__cta-group {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .az-hero__cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: 6px;
      text-decoration: none;
      font-family: var(--az-body-font);
      font-size: 15px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }
    
    .az-hero__cta--primary {
      background: var(--az-primary-cta-bg);
      color: rgb(var(--color-background));
      border: 2px solid var(--az-primary-cta-bg);
    }
    
    .az-hero__cta--primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    
    .az-hero__cta--secondary {
      background: transparent;
      color: rgb(var(--color-foreground));
      border: 2px solid rgba(var(--color-foreground), 0.2);
    }
    
    .az-hero__cta--secondary:hover {
      border-color: rgba(var(--color-foreground), 0.4);
      background: rgba(var(--color-foreground), 0.05);
    }
    
    .az-hero__social-proof {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 8px;
    }
    
    .az-hero__rating {
      display: flex;
      gap: 2px;
    }
    
    .az-hero__rating svg {
      width: 16px;
      height: 16px;
      fill: #ffd700;
    }
    
    .az-hero__rating svg.az-hero__star--empty {
      fill: rgba(var(--color-foreground), 0.2);
    }
    
    .az-hero__reviews {
      font-family: var(--az-body-font);
      font-size: 13px;
      color: rgba(var(--color-foreground), 0.6);
    }
    
    .az-hero__controls {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 24px;
      margin-top: 40px;
    }
    
    .az-hero__arrow {
      background: rgba(var(--color-background), 0.9);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(var(--color-foreground), 0.1);
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      color: rgb(var(--color-foreground));
    }
    
    .az-hero__arrow:hover {
      background: rgb(var(--color-accent));
      color: rgb(var(--color-background));
      border-color: rgb(var(--color-accent));
      transform: scale(1.1);
    }
    
    .az-hero__arrow:focus-visible {
      outline: 2px solid rgb(var(--color-accent));
      outline-offset: 2px;
    }
    
    .az-hero__arrow:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .az-hero__arrow svg { 
      width: 18px; 
      height: 18px; 
    }
    
    .az-hero__dots {
      display: flex;
      gap: 10px;
      padding: 10px 20px;
      background: rgba(var(--color-foreground), 0.05);
      border-radius: 30px;
      backdrop-filter: blur(10px);
    }
    
    .az-hero__dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(var(--color-foreground), 0.2);
      transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      cursor: pointer;
      border: none;
      padding: 0;
    }
    
    .az-hero__dot:hover {
      background: rgba(var(--color-foreground), 0.4);
    }
    
    .az-hero__dot--active {
      background: rgb(var(--color-accent));
      width: 28px;
      border-radius: 4px;
    }
    
    .az-hero__placeholder {
      text-align: center;
      padding: 100px 20px;
      background: rgba(var(--color-foreground), 0.03);
      border-radius: 12px;
      font-family: var(--az-body-font);
    }
    
    @media (max-width: 900px) {
      #az-hero-{{ section.id }} {
        padding-top: {{ mobile_padding_top }};
        padding-bottom: {{ mobile_padding_bottom }};
      }
      
      .az-hero__slide { 
        grid-template-columns: 1fr; 
        gap: 30px; 
        text-align: center; 
      }
      
      .az-hero__media { order: 1; }
      .az-hero__meta { order: 2; align-items: center; }
      
      .az-hero__chips {
        position: static;
        transform: none;
        margin-top: 20px;
        order: 3;
        max-width: 100%;
      }
      
      .az-hero__heading { font-size: 28px; }
      .az-hero__value-props { flex-direction: column; gap: 12px; }
      .az-hero__cta-group { flex-direction: column; width: 100%; }
      .az-hero__cta { width: 100%; justify-content: center; }
      .az-hero__trust-badge { top: 10px; right: 10px; font-size: 12px; }
    }
  </style>

  <div class="az-hero__container">
    <div class="az-hero__main">
      {% assign product_slides = section.blocks | where: "type", "product_slide" %}
      {% if product_slides.size > 0 %}
        <div class="az-hero__slider" role="region" aria-roledescription="carousel" aria-label="{{ 'accessibility.carousel' | t }}">
          <div class="az-hero__track" data-track>
            {% for slide_block in product_slides %}
              {% assign product = all_products[slide_block.settings.product] %}
              {% if product %}
                <div class="az-hero__slide{% if forloop.first %} is-active{% endif %}" 
                     role="group" 
                     aria-roledescription="slide" 
                     aria-label="{{ forloop.index }} {{ 'accessibility.of' | t | default: 'of' }} {{ product_slides.size }}" 
                     data-slide-index="{{ forloop.index0 }}" 
                     data-product-id="{{ product.id }}"
                     {{ slide_block.shopify_attributes }}>
                  
                  <div class="az-hero__media">
                    {% if slide_block.settings.image %}
                      {% assign slide_image = slide_block.settings.image %}
                    {% else %}
                      {% assign slide_image = product.featured_image %}
                    {% endif %}
                    
                    {% if slide_image %}
                      {% if forloop.first %}
                        <img src="{{ slide_image | image_url: width: 1200 }}" 
                             alt="{{ slide_image.alt | default: product.title | escape }}" 
                             width="{{ slide_image.width }}" 
                             height="{{ slide_image.height }}" 
                             loading="eager" 
                             fetchpriority="high">
                      {% else %}
                        <img src="{{ slide_image | image_url: width: 1200 }}" 
                             alt="{{ slide_image.alt | default: product.title | escape }}" 
                             width="{{ slide_image.width }}" 
                             height="{{ slide_image.height }}" 
                             loading="lazy">
                      {% endif %}
                    {% endif %}
                    
                    {% if slide_block.settings.trust_text != blank %}
                      <div class="az-hero__trust-badge">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                        </svg>
                        <span>{{ slide_block.settings.trust_text }}</span>
                      </div>
                    {% endif %}
                    
                    {% assign benefit_chips = section.blocks | where: "type", "benefit_chip" %}
                    {% assign slide_benefits = '' %}
                    {% for chip in benefit_chips %}
                      {% if chip.settings.parent_slide == slide_block.id %}
                        {% assign slide_benefits = slide_benefits | append: chip.id | append: ',' %}
                      {% endif %}
                    {% endfor %}
                    
                    {% if slide_benefits != blank %}
                      <div class="az-hero__chips">
                        {% for chip_block in benefit_chips %}
                          {% if chip_block.settings.parent_slide == slide_block.id %}
                            <div class="az-hero__chip" {{ chip_block.shopify_attributes }}>
                              {% case chip_block.settings.icon %}
                                {% when 'check' %}
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                  </svg>
                                {% when 'sparkle' %}
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 0L14.59 8.41 23 11 14.59 13.59 12 22 9.41 13.59 1 11 9.41 8.41z"/>
                                  </svg>
                                {% else %}
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                  </svg>
                              {% endcase %}
                              <span>{{ chip_block.settings.text }}</span>
                            </div>
                          {% endif %}
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                  
                  <div class="az-hero__meta">
                    {% if slide_block.settings.urgency_text != blank %}
                      <div class="az-hero__urgency">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                        </svg>
                        <span>{{ slide_block.settings.urgency_text }}</span>
                      </div>
                    {% endif %}
                    
                    {% if slide_block.settings.badge_text != blank %}
                      <span class="az-hero__badge">{{ slide_block.settings.badge_text }}</span>
                    {% endif %}
                    
                    <h2 class="az-hero__heading">
                      {{ slide_block.settings.heading | default: product.title }}
                    </h2>
                    
                    <p class="az-hero__subheading">
                      {{ slide_block.settings.subheading | default: product.description | strip_html | truncate: 150 }}
                    </p>
                    
                    {% if slide_block.settings.show_value_props %}
                      <div class="az-hero__value-props">
                        <div class="az-hero__value-prop">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12l5 5L20 7"/>
                          </svg>
                          <span>{{ slide_block.settings.value_prop_1 }}</span>
                        </div>
                        <div class="az-hero__value-prop">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12l5 5L20 7"/>
                          </svg>
                          <span>{{ slide_block.settings.value_prop_2 }}</span>
                        </div>
                      </div>
                    {% endif %}
                    
                    <div class="az-hero__cta-group">
                      {% assign cta_url = product.url %}
                      {% if slide_block.settings.primary_cta_action == 'add_to_cart' %}
                        {% assign cta_url = '/cart/add?id=' | append: product.selected_or_first_available_variant.id %}
                      {% endif %}
                      
                      <a href="{{ cta_url }}" 
                         class="az-hero__cta az-hero__cta--primary"
                         {% if slide_block.settings.primary_cta_action == 'add_to_cart' %}
                           data-add-to-cart="{{ product.selected_or_first_available_variant.id }}"
                         {% endif %}>
                        {{ slide_block.settings.cta_label }}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                      </a>
                      
                      {% if slide_block.settings.show_secondary_cta %}
                        <a href="{{ product.url }}#details" class="az-hero__cta az-hero__cta--secondary">
                          {{ slide_block.settings.secondary_cta_label }}
                        </a>
                      {% endif %}
                    </div>
                    
                    {% if slide_block.settings.show_social_proof %}
                      {% liquid
                        assign review_count = 0
                        assign average_rating = 0
                        
                        if section.settings.review_count_metafield != blank and product.metafields[section.settings.review_count_metafield] != blank
                          assign review_count = product.metafields[section.settings.review_count_metafield]
                        elsif product.metafields.reviews.rating_count
                          assign review_count = product.metafields.reviews.rating_count
                        endif
                        
                        if section.settings.average_rating_metafield != blank and product.metafields[section.settings.average_rating_metafield] != blank
                          assign average_rating = product.metafields[section.settings.average_rating_metafield] | times: 1.0
                        elsif product.metafields.reviews.rating
                          assign average_rating = product.metafields.reviews.rating.value | times: 1.0
                        endif
                        
                        if review_count == 0 and slide_block.settings.fallback_review_count != blank
                          assign review_count = slide_block.settings.fallback_review_count
                        endif
                        
                        if average_rating == 0 and slide_block.settings.fallback_rating != blank
                          assign average_rating = slide_block.settings.fallback_rating | times: 1.0
                        endif
                      %}
                      
                      {% if review_count > 0 %}
                        <div class="az-hero__social-proof">
                          <div class="az-hero__rating" role="img" aria-label="{{ average_rating }} out of 5 stars">
                            {% for i in (1..5) %}
                              {% if average_rating >= i %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                              {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="az-hero__star--empty">
                                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                              {% endif %}
                            {% endfor %}
                          </div>
                          <span class="az-hero__reviews">{{ review_count }} {{ 'general.reviews' | t | default: 'reviews' }}</span>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>

          <div class="az-hero__controls">
            <button type="button" 
                    class="az-hero__arrow az-hero__arrow--prev" 
                    aria-label="{{ 'accessibility.previous_slide' | t | default: 'Previous slide' }}" 
                    data-prev>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            
            {% if section.settings.show_dots %}
              <div class="az-hero__dots" role="tablist" aria-label="{{ 'accessibility.dots' | t | default: 'Slide dots' }}" data-dots></div>
            {% endif %}
            
            <button type="button" 
                    class="az-hero__arrow az-hero__arrow--next" 
                    aria-label="{{ 'accessibility.next_slide' | t | default: 'Next slide' }}" 
                    data-next>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        </div>
      {% else %}
        <div class="az-hero__placeholder">
          <p>{{ 'sections.hero.placeholder' | t | default: 'Add product slides to display the hero carousel' }}</p>
        </div>
      {% endif %}
    </div>
  </div>

  <script>
    (function() {
      const section = document.getElementById('az-hero-{{ section.id }}');
      const track = section.querySelector('[data-track]');
      const slides = track ? track.querySelectorAll('.az-hero__slide') : [];
      const prevBtn = section.querySelector('[data-prev]');
      const nextBtn = section.querySelector('[data-next]');
      const dotsContainer = section.querySelector('[data-dots]');
      const animationStyle = section.dataset.animation;
      
      if (slides.length === 0) return;
      
      let currentIndex = 0;
      let autoRotateInterval = null;
      let touchStartX = 0;
      let touchEndX = 0;
      let isTransitioning = false;
      
      // Create dots dynamically
      if (dotsContainer) {
        slides.forEach((_, i) => {
          const dot = document.createElement('button');
          dot.className = 'az-hero__dot' + (i === 0 ? ' az-hero__dot--active' : '');
          dot.setAttribute('role', 'tab');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
          dot.addEventListener('click', () => goToSlide(i));
          dotsContainer.appendChild(dot);
        });
      }
      
      const dots = section.querySelectorAll('.az-hero__dot');
      
      function updateSlider() {
        if (isTransitioning) return;
        isTransitioning = true;
        
        // Handle different animation styles
        if (animationStyle === 'fade') {
          slides.forEach((slide, i) => {
            if (i === currentIndex) {
              slide.style.position = 'relative';
              slide.style.opacity = '1';
              slide.style.visibility = 'visible';
            } else {
              slide.style.position = 'absolute';
              slide.style.opacity = '0';
              slide.style.visibility = 'hidden';
            }
          });
        } else if (animationStyle === 'scale') {
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
          slides.forEach((slide, i) => {
            if (i === currentIndex) {
              slide.style.transform = 'scale(1)';
              slide.style.opacity = '1';
            } else {
              slide.style.transform = 'scale(0.95)';
              slide.style.opacity = '0.5';
            }
          });
        } else {
          // Default slide animation
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
        
        // Update active states
        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === currentIndex);
        });
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('az-hero__dot--active', i === currentIndex);
          dot.setAttribute('aria-selected', i === currentIndex ? 'true' : 'false');
        });
        
        setTimeout(() => {
          isTransitioning = false;
        }, 600);
      }
      
      function goToSlide(index) {
        if (index === currentIndex || isTransitioning) return;
        currentIndex = index;
        updateSlider();
        resetAutoRotate();
      }
      
      function goToNext() {
        if (isTransitioning) return;
        currentIndex = (currentIndex + 1) % slides.length;
        updateSlider();
      }
      
      function goToPrev() {
        if (isTransitioning) return;
        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
        updateSlider();
      }
      
      function startAutoRotate() {
        const shouldRotate = section.dataset.autoRotate === 'true';
        const interval = parseInt(section.dataset.rotateMs) || 8000;
        
        if (shouldRotate && slides.length > 1) {
          autoRotateInterval = setInterval(goToNext, interval);
        }
      }
      
      function stopAutoRotate() {
        if (autoRotateInterval) {
          clearInterval(autoRotateInterval);
          autoRotateInterval = null;
        }
      }
      
      function resetAutoRotate() {
        stopAutoRotate();
        startAutoRotate();
      }
      
      // Event listeners
      prevBtn.addEventListener('click', () => {
        goToPrev();
        resetAutoRotate();
      });
      
      nextBtn.addEventListener('click', () => {
        goToNext();
        resetAutoRotate();
      });
      
      section.addEventListener('mouseenter', stopAutoRotate);
      section.addEventListener('mouseleave', startAutoRotate);
      
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopAutoRotate();
        } else {
          startAutoRotate();
        }
      });
      
      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (e.target.closest('#az-hero-{{ section.id }}')) {
          if (e.key === 'ArrowLeft') {
            goToPrev();
            resetAutoRotate();
          } else if (e.key === 'ArrowRight') {
            goToNext();
            resetAutoRotate();
          }
        }
      });
      
      // Touch/swipe support
      let touchStartY = 0;
      
      track.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
      }, { passive: true });
      
      track.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const touchEndY = e.changedTouches[0].screenY;
        const diffX = touchStartX - touchEndX;
        const diffY = Math.abs(touchStartY - touchEndY);
        
        // Only process horizontal swipes
        if (Math.abs(diffX) > 30 && diffY < Math.abs(diffX)) {
          if (diffX > 0) {
            goToNext();
          } else {
            goToPrev();
          }
          resetAutoRotate();
        }
      }, { passive: true });
      
      // Handle add to cart buttons
      section.querySelectorAll('[data-add-to-cart]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const variantId = btn.dataset.addToCart;
          if (variantId) {
            e.preventDefault();
            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                id: variantId,
                quantity: 1
              })
            })
            .then(response => response.json())
            .then(data => {
              // Trigger cart drawer or redirect
              if (window.Shopify && window.Shopify.theme && window.Shopify.theme.jsCart) {
                window.Shopify.theme.jsCart.init();
              } else {
                window.location.href = '/cart';
              }
            })
            .catch(error => console.error('Error:', error));
          }
        });
      });
      
      // Initialize
      startAutoRotate();
    })();
  </script>
</section>

