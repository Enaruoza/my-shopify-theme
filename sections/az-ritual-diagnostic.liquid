{% comment %} AZOURANE Ritual Diagnostic - Multi-step quiz modal {% endcomment %}
<section class="az-ritual">
  <div class="az-container">
    <div class="az-ritual__intro">
      <h2 class="az-h2">{{ section.settings.heading }}</h2>
      <p class="az-copy">{{ section.settings.subheading }}</p>
      <button class="az-btn az-btn--primary" data-open-diagnostic>
        {{ section.settings.button_label }}
      </button>
    </div>
  </div>
  
  <div class="az-modal" data-diagnostic-modal aria-hidden="true">
    <div class="az-modal__overlay" data-modal-close></div>
    <div class="az-modal__content">
      <button class="az-modal__close" data-modal-close aria-label="Zatvori">×</button>
      
      <div class="az-modal__body">
        <div class="az-modal__sidebar">
          <h3 class="az-modal__sidebar-title">Tvoja preporuka</h3>
          <div class="az-modal__recommendations" data-recommendations>
            <p class="az-modal__empty">Odgovori na pitanja da vidim preporuke</p>
          </div>
        </div>
        
        <div class="az-modal__main">
          <div class="az-modal__progress">
            <div class="az-modal__progress-bar" data-progress style="width: 20%"></div>
          </div>
          
          <div class="az-modal__steps" data-steps>
            <!-- Step 1: Skin/Hair Type -->
            <div class="az-modal__step active" data-step="1">
              <h3 class="az-modal__step-title">Kakav je tvoj tip kože?</h3>
              <div class="az-modal__options">
                <button class="az-modal__option" data-answer="skin-dry">Suha</button>
                <button class="az-modal__option" data-answer="skin-oily">Masna</button>
                <button class="az-modal__option" data-answer="skin-combo">Kombinovana</button>
                <button class="az-modal__option" data-answer="skin-normal">Normalna</button>
              </div>
            </div>
            
            <!-- Step 2: Concerns -->
            <div class="az-modal__step" data-step="2">
              <h3 class="az-modal__step-title">Koji su tvoji problemi? (max 3)</h3>
              <div class="az-modal__options az-modal__options--multi">
                <button class="az-modal__option" data-answer="concern-dryness">Suhoća</button>
                <button class="az-modal__option" data-answer="concern-sensitivity">Osjetljivost</button>
                <button class="az-modal__option" data-answer="concern-aging">Znakovi starenja</button>
                <button class="az-modal__option" data-answer="concern-acne">Akne</button>
                <button class="az-modal__option" data-answer="concern-pores">Proširene pore</button>
                <button class="az-modal__option" data-answer="concern-pigmentation">Pigmentacija</button>
              </div>
            </div>
            
            <!-- Step 3: Routine -->
            <div class="az-modal__step" data-step="3">
              <h3 class="az-modal__step-title">Koliko koraka želiš u rutini?</h3>
              <div class="az-modal__options">
                <button class="az-modal__option" data-answer="routine-minimal">Minimalno (2-3)</button>
                <button class="az-modal__option" data-answer="routine-moderate">Umjereno (4-5)</button>
                <button class="az-modal__option" data-answer="routine-full">Potpuno (6+)</button>
              </div>
            </div>
            
            <!-- Step 4: Sensitivity -->
            <div class="az-modal__step" data-step="4">
              <h3 class="az-modal__step-title">Imaš li osjetljivost na mirise?</h3>
              <div class="az-modal__options">
                <button class="az-modal__option" data-answer="fragrance-ok">Ne, volim prirodne mirise</button>
                <button class="az-modal__option" data-answer="fragrance-sensitive">Da, preferiram bez mirisa</button>
              </div>
            </div>
            
            <!-- Step 5: Budget -->
            <div class="az-modal__step" data-step="5">
              <h3 class="az-modal__step-title">Tvoj budžet?</h3>
              <div class="az-modal__options">
                <button class="az-modal__option" data-answer="budget-starter">Do 50 KM</button>
                <button class="az-modal__option" data-answer="budget-regular">50-100 KM</button>
                <button class="az-modal__option" data-answer="budget-premium">100+ KM</button>
              </div>
            </div>
            
            <!-- Final: Email -->
            <div class="az-modal__step" data-step="6">
              <h3 class="az-modal__step-title">Pošalji mi preporuke</h3>
              <form class="az-modal__form" data-diagnostic-form action="/contact#contact_form" method="post">
                <input type="hidden" name="form_type" value="contact">
                <input type="hidden" name="utf8" value="✓">
                <input type="hidden" name="contact[tags]" value="diagnostic,quiz">
                <input type="hidden" name="contact[answers]" data-answers-field>
                
                <input type="email" name="contact[email]" placeholder="Tvoj email" required class="az-modal__input">
                
                <label class="az-modal__checkbox">
                  <input type="checkbox" name="contact[consent]" required>
                  <span>Slažem se da primam preporuke i savjete</span>
                </label>
                
                <button type="submit" class="az-btn az-btn--primary">Završi</button>
              </form>
            </div>
            
            <!-- Success -->
            <div class="az-modal__step" data-step="success">
              <h3 class="az-modal__step-title">Hvala!</h3>
              <p>Tvoja personalizovana rutina je spremna.</p>
              <div class="az-modal__actions">
                <button class="az-btn az-btn--primary" data-add-all>Dodaj sve u korpu</button>
                <button class="az-btn az-btn--secondary" data-print-routine>Preuzmi rutinu (PDF)</button>
              </div>
            </div>
          </div>
          
          <div class="az-modal__nav">
            <button class="az-modal__nav-btn" data-prev disabled>← Nazad</button>
            <button class="az-modal__nav-btn" data-next>Dalje →</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.az-ritual__intro {
  text-align: center;
  padding: 60px 0;
}

.az-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: none;
}

.az-modal[aria-hidden="false"] {
  display: block;
}

.az-modal__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
}

.az-modal__content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-width: 900px;
  max-height: 90vh;
  background: #fff;
  border-radius: 24px;
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: translate(-50%, -45%); }
  to { opacity: 1; transform: translate(-50%, -50%); }
}

.az-modal__close {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  border: none;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 24px;
  cursor: pointer;
  z-index: 1;
}

.az-modal__body {
  display: grid;
  grid-template-columns: 280px 1fr;
  height: 600px;
}

.az-modal__sidebar {
  background: #fafafa;
  padding: 40px 24px;
  overflow-y: auto;
}

.az-modal__sidebar-title {
  font-size: 18px;
  font-weight: 600;
  margin: 0 0 20px;
}

.az-modal__main {
  padding: 40px;
  overflow-y: auto;
}

.az-modal__progress {
  height: 4px;
  background: #e5e5e5;
  border-radius: 2px;
  margin-bottom: 32px;
}

.az-modal__progress-bar {
  height: 100%;
  background: #111;
  border-radius: 2px;
  transition: width 0.3s ease-out;
}

.az-modal__step {
  display: none;
}

.az-modal__step.active {
  display: block;
}

.az-modal__step-title {
  font-size: 24px;
  font-weight: 600;
  margin: 0 0 24px;
}

.az-modal__options {
  display: grid;
  gap: 12px;
}

.az-modal__option {
  padding: 16px;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  background: #fff;
  font-size: 15px;
  cursor: pointer;
  text-align: left;
  transition: all 0.2s ease-out;
}

.az-modal__option:hover {
  border-color: #111;
}

.az-modal__option.selected {
  background: #111;
  color: #fff;
  border-color: #111;
}

.az-modal__form {
  display: grid;
  gap: 16px;
}

.az-modal__input {
  padding: 12px 16px;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  font-size: 15px;
}

.az-modal__checkbox {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
}

.az-modal__nav {
  display: flex;
  justify-content: space-between;
  margin-top: 32px;
}

.az-modal__nav-btn {
  padding: 12px 24px;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  background: #fff;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.2s ease-out;
}

.az-modal__nav-btn:hover:not(:disabled) {
  border-color: #111;
}

.az-modal__nav-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.az-modal__recommendations {
  display: grid;
  gap: 12px;
}

.az-modal__rec-product {
  padding: 12px;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  font-size: 14px;
}

@media (max-width: 768px) {
  .az-modal__body {
    grid-template-columns: 1fr;
  }
  .az-modal__sidebar {
    display: none;
  }
}
</style>

<script>
(function() {
  const modal = document.querySelector('[data-diagnostic-modal]');
  const openBtn = document.querySelector('[data-open-diagnostic]');
  const closeButtons = document.querySelectorAll('[data-modal-close]');
  const steps = document.querySelectorAll('.az-modal__step');
  const prevBtn = document.querySelector('[data-prev]');
  const nextBtn = document.querySelector('[data-next]');
  const progress = document.querySelector('[data-progress]');
  const form = document.querySelector('[data-diagnostic-form]');
  
  let currentStep = 1;
  const answers = {};
  const concernsSelected = [];
  
  // Product recommendations based on answers
  const recommendations = {
    'skin-dry': ['afoulki', 'amaan', 'argan-oil'],
    'skin-oily': ['amaan', 'sanouj'],
    'concern-dryness': ['afoulki', 'argan-oil'],
    'concern-sensitivity': ['amaan', 'tayri'],
    'concern-aging': ['argan-oil', 'afoulki'],
    'routine-minimal': 2,
    'routine-moderate': 4,
    'routine-full': 6
  };
  
  function showStep(n) {
    steps.forEach(s => s.classList.remove('active'));
    steps[n - 1].classList.add('active');
    
    prevBtn.disabled = n === 1;
    nextBtn.style.display = n === 6 ? 'none' : 'block';
    
    progress.style.width = `${(n / 6) * 100}%`;
    currentStep = n;
  }
  
  function updateRecommendations() {
    const recDiv = document.querySelector('[data-recommendations]');
    const products = new Set();
    
    Object.entries(answers).forEach(([key, value]) => {
      if (recommendations[value]) {
        if (Array.isArray(recommendations[value])) {
          recommendations[value].forEach(p => products.add(p));
        }
      }
    });
    
    if (products.size > 0) {
      recDiv.innerHTML = '<div class="az-modal__rec-list">' +
        Array.from(products).slice(0, 4).map(p => 
          `<div class="az-modal__rec-product">${p.toUpperCase()}</div>`
        ).join('') +
        '</div>';
    }
  }
  
  // Open modal
  openBtn.addEventListener('click', () => {
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  });
  
  // Close modal
  closeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
  
  // Handle options
  document.querySelectorAll('.az-modal__option').forEach(opt => {
    opt.addEventListener('click', function() {
      const step = this.closest('[data-step]');
      const stepNum = step.dataset.step;
      
      if (stepNum === '2') {
        // Multi-select for concerns
        this.classList.toggle('selected');
        const selected = step.querySelectorAll('.selected');
        if (selected.length > 3) {
          this.classList.remove('selected');
        }
      } else {
        // Single select
        step.querySelectorAll('.az-modal__option').forEach(o => o.classList.remove('selected'));
        this.classList.add('selected');
      }
      
      answers[`step${stepNum}`] = this.dataset.answer;
      updateRecommendations();
    });
  });
  
  // Navigation
  nextBtn.addEventListener('click', () => {
    if (currentStep < 6) showStep(currentStep + 1);
  });
  
  prevBtn.addEventListener('click', () => {
    if (currentStep > 1) showStep(currentStep - 1);
  });
  
  // Form submit
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const answersField = this.querySelector('[data-answers-field]');
    answersField.value = JSON.stringify(answers);
    
    // Emit event for integrations
    window.dispatchEvent(new CustomEvent('az:diagnostic:submitted', {
      detail: { email: this.elements['contact[email]'].value, answers }
    }));
    
    // Show success
    showStep(7);
    steps[6].classList.add('active');
  });
  
  // Add all to cart
  document.querySelector('[data-add-all]')?.addEventListener('click', () => {
    // Implementation for multi-add to cart
    const products = Object.values(recommendations).flat().filter(p => typeof p === 'string');
    console.log('Adding products:', products);
  });
  
  // Print routine
  document.querySelector('[data-print-routine]')?.addEventListener('click', () => {
    window.print();
  });
})();
</script>

{% schema %}
{
  "name": "AZ Ritual Diagnostic",
  "settings": [
    { "type": "text", "id": "heading", "label": "Naslov", "default": "Pronađi svoju idealnu rutinu" },
    { "type": "textarea", "id": "subheading", "label": "Podnaslov", "default": "Odgovori na nekoliko pitanja i dobi personalizovane preporuke za tvoju kožu i kosu." },
    { "type": "text", "id": "button_label", "label": "Dugme", "default": "Pokreni dijagnostiku" }
  ],
  "presets": [{ "name": "AZ Ritual Diagnostic" }]
}
{% endschema %}