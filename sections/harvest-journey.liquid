{% schema %}
{
  "name": "Harvest Journey",
  "settings": [
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "main_headline",
      "label": "Main Headline",
      "default": "The Tale of Two Harvests"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro / Subheading",
      "default": "One olive, two very different oils. Discover how harvest timing shapes the flavor profile."
    },
    {
      "type": "header",
      "content": "Left Column (Early Harvest)"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "left_headline",
      "label": "Left Headline",
      "default": "HARVESTED EARLY — VITAL & PEPPERY"
    },
    {
      "type": "textarea",
      "id": "left_body",
      "label": "Left Body",
      "default": "Early in the season, the olives are green, firm, and packed with polyphenols. This harvest yields a bold, vibrant oil with a distinct bite."
    },
    {
      "type": "text",
      "id": "left_yield",
      "label": "Left Yield Info",
      "default": "24 kg of fruit = 1 liter of oil.\nLower yield. Higher potency."
    },
    {
      "type": "text",
      "id": "left_mood",
      "label": "Left Mood Word",
      "default": "Bright. Punchy. Robust."
    },
    {
      "type": "textarea",
      "id": "left_description",
      "label": "Left Description",
      "default": "Ideal for finishing dishes, dipping bread, and waking up the palate."
    },
    {
      "type": "header",
      "content": "Right Column (Late Harvest)"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "right_headline",
      "label": "Right Headline",
      "default": "HARVESTED LATER — FULL & GENEROUS"
    },
    {
      "type": "textarea",
      "id": "right_body",
      "label": "Right Body",
      "default": "As the season matures, the fruit softens and yields more oil. This is when we gather the richer, juicier crops."
    },
    {
      "type": "text",
      "id": "right_yield",
      "label": "Right Yield Info",
      "default": "13 kg of ripe fruit = 1 liter of oil.\nHigher yield. Softer profile."
    },
    {
      "type": "text",
      "id": "right_mood",
      "label": "Right Mood Word",
      "default": "Mellow. Warm. Versatile."
    },
    {
      "type": "textarea",
      "id": "right_description",
      "label": "Right Description",
      "default": "Ideal for daily nourishment, rich textures, and formulations that need a gentler character."
    },
    {
      "type": "header",
      "content": "Center Column (Journey)"
    },
    {
      "type": "textarea",
      "id": "center_copy",
      "label": "Center Copy",
      "default": "One land. One tradition.\nBut every harvest tells a different story.\nFollow the journey."
    },
    {
      "type": "image_picker",
      "id": "center_icon",
      "label": "Center Moving Icon (PNG)"
    },
    {
      "type": "header",
      "content": "Bottom Strip (Craft & Ritual)"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_icon",
      "label": "Bottom Left Icon"
    },
    {
      "type": "text",
      "id": "bottom_left_title",
      "label": "Bottom Left Title",
      "default": "Crafted by Hand"
    },
    {
      "type": "textarea",
      "id": "bottom_left_body",
      "label": "Bottom Left Body",
      "default": "Every ingredient is gathered, cracked, sorted, and prepared by the women who inherited this craft."
    },
    {
      "type": "image_picker",
      "id": "bottom_right_icon",
      "label": "Bottom Right Icon"
    },
    {
      "type": "text",
      "id": "bottom_right_title",
      "label": "Bottom Right Title",
      "default": "Made for Ritual"
    },
    {
      "type": "textarea",
      "id": "bottom_right_body",
      "label": "Bottom Right Body",
      "default": "Each harvest produces a different kind of oil. We use each exactly where nature intended."
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F0EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#3D3D35"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Line/Mood)",
      "default": "#6B705C"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Harvest Journey Comparison"
    }
  ]
}
{% endschema %}

<div class="harvest-journey-section" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    
    <!-- Top Header -->
    <div class="harvest-header-block">
      {% if section.settings.main_headline != blank %}
        <h2 class="h1 harvest-main-title">{{ section.settings.main_headline }}</h2>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="harvest-intro-text">{{ section.settings.intro_text | newline_to_br }}</div>
      {% endif %}
    </div>

    <!-- Main Grid -->
    <div class="harvest-grid">
      
      <!-- Left Column: Early Harvest -->
      <div class="harvest-col harvest-side-col">
        <div class="harvest-card top-aligned">
          {% if section.settings.left_image != blank %}
            <div class="harvest-img-wrapper">
              {{ section.settings.left_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'harvest-img' }}
            </div>
          {% endif %}
          
          <div class="harvest-text-content">
            {% if section.settings.left_headline != blank %}
              <h3 class="harvest-col-title">{{ section.settings.left_headline }}</h3>
            {% endif %}
            
            {% if section.settings.left_body != blank %}
              <p class="harvest-body">{{ section.settings.left_body }}</p>
            {% endif %}

            {% if section.settings.left_yield != blank %}
              <div class="harvest-yield">
                <span class="yield-line"></span>
                <p>{{ section.settings.left_yield | newline_to_br }}</p>
              </div>
            {% endif %}

            {% if section.settings.left_mood != blank %}
              <div class="harvest-mood" style="color: {{ section.settings.accent_color }}">
                {{ section.settings.left_mood }}
              </div>
            {% endif %}

            {% if section.settings.left_description != blank %}
              <p class="harvest-desc">{{ section.settings.left_description }}</p>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Center Column: The Journey -->
      <div class="harvest-col harvest-center-col">
        <div class="journey-track">
          <div class="dotted-line" style="border-left-color: {{ section.settings.accent_color }}"></div>
          
          <div class="moving-icon-wrapper" id="JourneyIcon-{{ section.id }}">
             {% if section.settings.center_icon != blank %}
               {{ section.settings.center_icon | image_url: width: 150 | image_tag: loading: 'lazy', class: 'journey-icon' }}
             {% else %}
               <div class="journey-icon-placeholder" style="background: {{ section.settings.accent_color }}"></div>
             {% endif %}
          </div>

          <div class="center-copy-block">
            {% if section.settings.center_copy != blank %}
              <div class="center-copy-text">{{ section.settings.center_copy | newline_to_br }}</div>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Right Column: Late Harvest -->
      <div class="harvest-col harvest-side-col">
        <div class="harvest-card bottom-aligned">
           {% if section.settings.right_image != blank %}
            <div class="harvest-img-wrapper">
              {{ section.settings.right_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'harvest-img' }}
            </div>
          {% endif %}
          
          <div class="harvest-text-content">
            {% if section.settings.right_headline != blank %}
              <h3 class="harvest-col-title">{{ section.settings.right_headline }}</h3>
            {% endif %}
            
            {% if section.settings.right_body != blank %}
              <p class="harvest-body">{{ section.settings.right_body }}</p>
            {% endif %}

            {% if section.settings.right_yield != blank %}
              <div class="harvest-yield">
                <span class="yield-line"></span>
                <p>{{ section.settings.right_yield | newline_to_br }}</p>
              </div>
            {% endif %}

            {% if section.settings.right_mood != blank %}
              <div class="harvest-mood" style="color: {{ section.settings.accent_color }}">
                {{ section.settings.right_mood }}
              </div>
            {% endif %}

            {% if section.settings.right_description != blank %}
              <p class="harvest-desc">{{ section.settings.right_description }}</p>
            {% endif %}
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Strip -->
    <div class="harvest-footer-strip">
      <div class="footer-block">
        {% if section.settings.bottom_left_icon != blank %}
          <div class="footer-icon">
            {{ section.settings.bottom_left_icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}
        <div class="footer-text">
          <h4 class="footer-title">{{ section.settings.bottom_left_title }}</h4>
          <p class="footer-body">{{ section.settings.bottom_left_body }}</p>
        </div>
      </div>
      
      <div class="divider-vertical"></div>

      <div class="footer-block">
        {% if section.settings.bottom_right_icon != blank %}
          <div class="footer-icon">
            {{ section.settings.bottom_right_icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}
        <div class="footer-text">
          <h4 class="footer-title">{{ section.settings.bottom_right_title }}</h4>
          <p class="footer-body">{{ section.settings.bottom_right_body }}</p>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  /* Base Layout & Typography */
  .harvest-journey-section {
    position: relative;
    overflow: hidden;
    font-family: var(--font-body-family, sans-serif);
    --ease-out-expo: cubic-bezier(0.19, 1, 0.22, 1);
  }

  .harvest-journey-section .page-width {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .harvest-header-block {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .harvest-main-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
    font-family: var(--font-heading-family, serif);
    text-wrap: balance;
  }

  .harvest-intro-text {
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    line-height: 1.6;
    opacity: 0.85;
    max-width: 600px;
    margin: 0 auto;
    text-wrap: pretty;
  }

  /* Grid Layout */
  .harvest-grid {
    display: grid;
    grid-template-columns: 1fr 140px 1fr;
    gap: 2rem;
    position: relative;
    align-items: flex-start;
  }

  /* Columns */
  .harvest-col {
    position: relative;
  }

  .harvest-side-col {
    display: flex;
    flex-direction: column;
  }

  .harvest-img-wrapper {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background-color: rgba(0,0,0,0.03);
    will-change: transform;
  }

  .harvest-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-expo);
  }
  
  .harvest-card:hover .harvest-img {
    transform: scale(1.03);
  }

  .harvest-text-content {
    text-align: center;
    padding: 0 1rem;
  }

  .harvest-col-title {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    font-weight: 600;
    opacity: 0.7;
    margin-top: 1rem;
  }

  .harvest-body {
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: currentColor;
  }

  .harvest-yield {
    border-top: 1px solid rgba(0,0,0,0.08);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding: 1.2rem 0;
    margin: 1.5rem 0;
    font-size: 0.95rem;
    font-family: var(--font-heading-family, serif);
    letter-spacing: 0.01em;
  }

  .harvest-mood {
    font-size: 1.35rem;
    font-family: var(--font-heading-family, serif);
    font-weight: 500;
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  .harvest-desc {
    font-size: 0.95rem;
    opacity: 0.75;
    font-style: italic;
  }

  /* Center Column Journey */
  .harvest-center-col {
    position: relative;
    height: auto;
    display: flex;
    justify-content: center;
  }

  .journey-track {
    position: relative;
    width: 100%;
    /* We want the track to be as tall as the content roughly, but defined by grid */
    min-height: 700px; 
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dotted-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    border-left: 2px dotted; 
    border-left-color: currentColor;
    opacity: 0.25;
    z-index: 0;
  }

  .moving-icon-wrapper {
    position: absolute;
    top: 0; /* Starting position */
    left: 50%;
    width: 64px;
    height: 64px;
    margin-left: -32px;
    z-index: 2;
    will-change: transform;
    /* Initial state for JS to pick up */
    transform: translateY(0);
  }

  .journey-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
  }
  
  .journey-icon-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  .center-copy-block {
    position: absolute;
    top: 50%;
    width: 180px;
    transform: translateY(-50%);
    background: var(--bg-color, #F4F0EA);
    padding: 1.5rem 0.5rem;
    text-align: center;
    z-index: 1;
    /* Ensure text has a nice backdrop transition if needed */
  }
  
  .center-copy-text {
    font-family: var(--font-heading-family, serif);
    font-size: 1.15rem;
    line-height: 1.4;
    font-style: italic;
    color: currentColor;
  }

  /* Bottom Strip */
  .harvest-footer-strip {
    display: flex;
    justify-content: space-between;
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    align-items: flex-start;
  }
  
  .footer-block {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    flex: 1;
    max-width: 45%;
  }

  .divider-vertical {
    width: 1px;
    height: 50px;
    background: rgba(0,0,0,0.08);
    align-self: center;
  }

  .footer-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    margin-top: 4px;
  }
  
  .footer-icon img {
     width: 100%;
     height: 100%;
     object-fit: contain;
  }

  .footer-text {
    text-align: left;
  }

  .footer-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.35rem 0;
    font-family: var(--font-heading-family, serif);
  }

  .footer-body {
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.75;
    line-height: 1.5;
  }

  /* Responsive Attributes */
  @media screen and (max-width: 900px) {
    .harvest-grid {
      grid-template-columns: 1fr;
      gap: 0; /* Remove gap, handle via padding/margin */
    }

    .harvest-col {
      padding-bottom: 2rem;
    }
    
    /* Mobile Journey: A visual connector between the two blocks */
    .harvest-center-col {
      display: block;
      height: auto;
      min-height: 160px;
      margin: 0;
      order: 2; 
    }
    
    .journey-track {
      min-height: 160px;
      overflow: hidden; /* Keep the movement contained */
    }

    .center-copy-block {
        display: block;
        width: auto;
        padding: 0.5rem 1rem;
        background: rgba(var(--bg-color-rgb), 0.9); /* slight transparency if possible */
    }

    .harvest-col.harvest-side-col:first-of-type {
       order: 1;
    }
    
    .harvest-col.harvest-side-col:last-of-type {
       order: 3;
       padding-top: 1rem;
    }

    .harvest-footer-strip {
      flex-direction: column;
      gap: 2.5rem;
      text-align: left;
    }
    
    .footer-block {
        max-width: 100%;
    }
    
    .divider-vertical {
        display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#JourneyIcon-{{ section.id }}');
    if(!section) return;
    
    const container = section.closest('.harvest-journey-section');
    const track = container.querySelector('.journey-track');
    if (!container || !track) return;

    // Physics state
    let targetProgress = 0;
    let currentProgress = 0;
    const lerpFactor = 0.08; // Lower = heavier/smoother lag
    let animationFrame;
    let isIntersecting = false;

    // Observer to only animate when visible
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            isIntersecting = entry.isIntersecting;
            if (isIntersecting) {
                requestAnimationFrame(updatePhysics);
            }
        });
    }, { threshold: 0 });
    
    observer.observe(container);

    function updateTarget() {
        if (!isIntersecting) return;
        
        const rect = track.getBoundingClientRect();
        const viewHeight = window.innerHeight;
        const trackHeight = rect.height;
        const trackTop = rect.top;
        
        // Calculate raw progress based on scroll position
        // When track top is at:
        // 80% of viewport -> Start (0)
        // 20% of viewport -> End (1)
        // This keeps the action happening in the "meat" of the screen
        
        const startThreshold = viewHeight * 0.85;
        const endThreshold = viewHeight * 0.15;
        
        // Map trackTop from startThreshold to endThreshold -> 0 to 1
        // trackTop decreases as we scroll down
        
        let progress = (startThreshold - trackTop) / (startThreshold - endThreshold);
        
        // Clamp
        if (progress < 0) progress = 0;
        if (progress > 1) progress = 1;

        targetProgress = progress;
    }

    function updatePhysics() {
        if (!isIntersecting) {
            // Stop loop if off screen
            return; 
        }

        updateTarget();

        // Lerp: current = current + (target - current) * factor
        // Precision check to stop infinite micro-calc
        if (Math.abs(targetProgress - currentProgress) > 0.0001) {
             currentProgress += (targetProgress - currentProgress) * lerpFactor;
        } else {
             currentProgress = targetProgress;
        }

        const iconHeight = section.offsetHeight;
        const trackHeight = track.offsetHeight;
        const maxTranslate = trackHeight - iconHeight;
        
        const translateY = currentProgress * maxTranslate;
        
        section.style.transform = `translateY(${translateY.toFixed(2)}px)`;
        
        animationFrame = requestAnimationFrame(updatePhysics);
    }
    
    // Kickoff
    updatePhysics();
  });
</script>
