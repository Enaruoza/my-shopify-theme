{% comment %} AZOURANE Split Hero with fade-up animation {% endcomment %}
<section class="az-hero" data-section-observe>
  <div class="az-container">
    <div class="az-hero__grid">
      <div class="az-hero__content">
        {% if section.settings.kicker != blank %}
          <span class="az-eyebrow">{{ section.settings.kicker }}</span>
        {% endif %}
        <h1 class="az-hero__heading">{{ section.settings.heading }}</h1>
        {% if section.settings.subheading != blank %}
          <p class="az-copy az-hero__subheading">{{ section.settings.subheading }}</p>
        {% endif %}

        <div class="az-hero__buttons">
          {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
            <a href="{{ section.settings.primary_link }}" class="az-btn az-btn--primary">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}
          {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="az-btn az-btn--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        {% if section.settings.badge_text != blank %}
          <div class="az-hero__badge">
            {{ section.settings.badge_text }}
          </div>
        {% endif %}
      </div>

      <div class="az-hero__media">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1600 }}"
               alt="{{ section.settings.image_alt | default: section.settings.heading | escape }}"
               width="800" height="600" loading="eager"
               class="az-hero__image">
          {% if section.settings.caption != blank %}
            <div class="az-hero__caption">{{ section.settings.caption }}</div>
          {% endif %}
        {% else %}
          <div class="az-hero__placeholder">Dodaj sliku</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
:root {
  --az-r: 16px;
  --az-gap: 24px;
  --az-card: 1px solid #e5e5e5;
  --az-radius: 16px;
}

.az-hero {
  background: #fff;
  padding: 60px 0;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.24s ease-out, transform 0.24s ease-out;
}

.az-hero.is-in {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .az-hero {
    opacity: 1;
    transform: none;
  }
}

.az-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.az-hero__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}

@media (min-width: 768px) {
  .az-hero__grid {
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
}

.az-eyebrow {
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-size: 12px;
  color: #666;
  display: inline-block;
  margin-bottom: 12px;
}

.az-hero__heading {
  font-size: clamp(32px, 5vw, 48px);
  line-height: 1.1;
  font-weight: 600;
  color: #111;
  margin: 0 0 20px;
}

.az-copy {
  color: #666;
  line-height: 1.55;
}

.az-hero__subheading {
  font-size: 18px;
  margin: 0 0 32px;
  max-width: 480px;
}

.az-hero__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 20px;
}

.az-btn {
  border-radius: 24px;
  padding: 14px 28px;
  font-weight: 500;
  font-size: 15px;
  text-decoration: none;
  display: inline-block;
  transition: all 0.2s ease-out;
}

.az-btn--primary {
  background: #111;
  color: #fff;
}

.az-btn--primary:hover {
  background: #333;
  transform: translateY(-1px);
}

.az-btn--secondary {
  background: #fff;
  border: 1px solid #ddd;
  color: #111;
}

.az-btn--secondary:hover {
  border-color: #111;
}

@media (prefers-reduced-motion: reduce) {
  .az-btn:hover {
    transform: none;
  }
}

.az-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 20px;
  border: 1px solid #e5e5e5;
  font-size: 13px;
  color: #666;
}

.az-hero__media {
  position: relative;
}

.az-hero__image {
  width: 100%;
  height: auto;
  border-radius: 24px;
  object-fit: cover;
}

.az-hero__placeholder {
  aspect-ratio: 4/3;
  background: #f5f5f5;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

.az-hero__caption {
  position: absolute;
  bottom: 20px;
  left: 20px;
  background: rgba(255,255,255,0.95);
  padding: 8px 16px;
  border-radius: 12px;
  font-size: 12px;
  color: #666;
  backdrop-filter: blur(10px);
}
</style>

<script>
(function() {
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  
  document.querySelectorAll('[data-section-observe]').forEach(el => {
    observer.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "AZ Split Hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Natpis", "default": "AZOURANE MOROCCAN COSMETICS" },
    { "type": "text", "id": "heading", "label": "Naslov", "default": "Čista rutina za kožu i kosu. Vidljiv rezultat." },
    { "type": "textarea", "id": "subheading", "label": "Podnaslov", "default": "Prirodni sastojci iz Maroka. Jednostavno, jasno i učinkovito." },
    { "type": "text", "id": "primary_label", "label": "Primarno dugme", "default": "Kupi sada" },
    { "type": "url", "id": "primary_link", "label": "Primarni link" },
    { "type": "text", "id": "secondary_label", "label": "Sekundarno dugme", "default": "Istraži proizvode" },
    { "type": "url", "id": "secondary_link", "label": "Sekundarni link" },
    { "type": "text", "id": "badge_text", "label": "Značka", "default": "Besplatna dostava iznad 100 KM" },
    { "type": "image_picker", "id": "image", "label": "Slika" },
    { "type": "text", "id": "image_alt", "label": "Alt tekst", "default": "AZOURANE prirodna kozmetika" },
    { "type": "text", "id": "caption", "label": "Opis slike", "default": "Marokanska ulja. Čista formulacija." }
  ],
  "presets": [{ "name": "AZ Split Hero" }]
}
{% endschema %}