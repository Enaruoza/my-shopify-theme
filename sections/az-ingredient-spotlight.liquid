<section
  class="az-story"
  data-section-id="{{ section.id }}"
  style="
    --color-background: {{ section.settings.color_background }};
    --color-text: {{ section.settings.color_text }};
    --color-heading: {{ section.settings.color_heading }};
    --color-secondary: {{ section.settings.color_secondary }};
    --color-accent: {{ section.settings.color_accent }};
    --color-border: {{ section.settings.color_border }};
    --desktop-chapter-spacing: {{ section.settings.desktop_chapter_spacing }}rem;
  "
>
  <div class="az-story__container">
    <div class="az-story__intro">
      <h2 class="az-story__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="az-story__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    {%- assign ingredients = section.blocks | where: 'type', 'ingredient' -%}
    {%- if ingredients.size > 0 -%}
      <!-- Mobile Dropdown Navigation -->
      <div class="az-story__mobile-selector">
        <label class="az-story__mobile-label">Select Ingredient:</label>
        <div class="az-story__mobile-dropdown">
          <button class="az-story__mobile-current" aria-expanded="false">
            <span>{{ ingredients.first.settings.name }}</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="az-story__mobile-options">
            {%- for block in ingredients -%}
              <button 
                class="az-story__mobile-option" 
                data-mobile-select="{{ forloop.index }}"
                {% if forloop.first %}data-selected="true"{% endif %}
              >
                <span class="az-story__mobile-option-number">{{ forloop.index | prepend: '0' }}</span>
                <span>{{ block.settings.name }}</span>
              </button>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Mobile Content -->
      <div class="az-story__mobile-content">
        {%- for block in ingredients -%}
          <div 
            class="az-story__mobile-panel" 
            data-mobile-panel="{{ forloop.index }}"
            {% if forloop.first %}data-active="true"{% endif %}
          >
            <div class="az-story__mobile-media">
              {% if block.settings.image != blank %}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}" 
                  alt="{{ block.settings.name | escape }}" 
                  width="800" 
                  height="800" 
                  loading="lazy"
                >
              {% else %}
                <div class="az-story__placeholder"></div>
              {% endif %}
            </div>
            <div class="az-story__mobile-text">
              <span class="az-story__chapter-number">{{ forloop.index | prepend: '0' }}</span>
              <h3 class="az-story__chapter-name">{{ block.settings.name }}</h3>
              {% if block.settings.scientific_name != blank %}
                <h4 class="az-story__chapter-scientific">{{ block.settings.scientific_name }}</h4>
              {% endif %}
              <div class="az-story__chapter-description">
                {{ block.settings.description }}
              </div>
              {%- assign benefits = block.settings.benefits | split: ',' -%}
              {% if benefits.size > 0 %}
                <div class="az-story__chapter-benefits">
                  <h5 class="az-story__benefits-title">Key Benefits</h5>
                  <ul class="az-story__benefits-list">
                    {%- for benefit in benefits -%}
                      {%- assign trimmed_benefit = benefit | strip -%}
                      {%- if trimmed_benefit != blank -%}
                        <li>{{ trimmed_benefit }}</li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                </div>
              {% endif %}
            </div>
          </div>
        {%- endfor -%}
      </div>

      <!-- Desktop Layout -->
      <div class="az-story__desktop-grid">
        <div class="az-story__nav-column">
          <div class="az-story__nav-sticky">
            <span class="az-story__nav-label">Key Ingredients</span>
            <ul class="az-story__nav-list">
              {%- for block in ingredients -%}
                <li>
                  <button 
                    class="az-story__nav-link" 
                    data-nav-index="{{ forloop.index }}"
                    data-nav-target="chapter-{{ section.id }}-{{ forloop.index }}"
                  >
                    {{ block.settings.name }}
                  </button>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        </div>

        <div class="az-story__content-column">
          {%- for block in ingredients -%}
            <article 
              class="az-story__chapter" 
              id="chapter-{{ section.id }}-{{ forloop.index }}" 
              data-chapter-index="{{ forloop.index }}"
            >
              <div class="az-story__chapter-content">
                <span class="az-story__chapter-number">{{ forloop.index | prepend: '0' }}</span>
                <h3 class="az-story__chapter-name">{{ block.settings.name }}</h3>
                {% if block.settings.scientific_name != blank %}
                  <h4 class="az-story__chapter-scientific">{{ block.settings.scientific_name }}</h4>
                {% endif %}
                <div class="az-story__chapter-description">
                  {{ block.settings.description }}
                </div>
                {%- assign benefits = block.settings.benefits | split: ',' -%}
                {% if benefits.size > 0 %}
                  <div class="az-story__chapter-benefits">
                    <h5 class="az-story__benefits-title">Key Benefits</h5>
                    <ul class="az-story__benefits-list">
                      {%- for benefit in benefits -%}
                        {%- assign trimmed_benefit = benefit | strip -%}
                        {%- if trimmed_benefit != blank -%}
                          <li>{{ trimmed_benefit }}</li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </article>
          {%- endfor -%}
        </div>

        <div class="az-story__media-column">
          <div class="az-story__media-sticky">
            {%- for block in ingredients -%}
              <div 
                class="az-story__media-item" 
                data-media-index="{{ forloop.index }}"
              >
                <div class="az-story__media-main">
                  {% if block.settings.image != blank %}
                    <img 
                      src="{{ block.settings.image | image_url: width: 1200 }}" 
                      alt="{{ block.settings.name | escape }}" 
                      width="1200" 
                      height="1200" 
                      loading="lazy"
                    >
                  {% else %}
                    <div class="az-story__placeholder"></div>
                  {% endif %}
                </div>
                {% if block.settings.texture_image != blank %}
                  <div class="az-story__media-texture">
                    <img 
                      src="{{ block.settings.texture_image | image_url: width: 400 }}" 
                      alt="{{ block.settings.name }} texture" 
                      width="400" 
                      height="400" 
                      loading="lazy"
                    >
                  </div>
                {% endif %}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .az-story {
    --spacing-section: clamp(3rem, 6vw, 5rem);
    --spacing-container: clamp(1rem, 4vw, 2rem);
    padding: var(--spacing-section) 0;
    background-color: var(--color-background);
  }

  .az-story__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--spacing-container);
  }

  .az-story__intro {
    max-width: 720px;
    margin: 0 auto clamp(2.5rem, 5vw, 4rem);
    text-align: center;
  }

  .az-story__title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .az-story__subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-secondary);
    line-height: 1.6;
  }

  .az-story__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
  }

  /* Mobile Dropdown Styles */
  .az-story__mobile-selector {
    display: block;
    margin-bottom: 2rem;
  }

  .az-story__mobile-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
  }

  .az-story__mobile-dropdown {
    position: relative;
  }

  .az-story__mobile-current {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: white;
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-heading);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .az-story__mobile-current:hover {
    border-color: var(--color-accent);
  }

  .az-story__mobile-current[aria-expanded="true"] {
    border-color: var(--color-accent);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .az-story__mobile-current svg {
    transition: transform 0.2s ease;
  }

  .az-story__mobile-current[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .az-story__mobile-options {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 2px solid var(--color-accent);
    border-top: none;
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
    max-height: 300px;
    overflow-y: auto;
    z-index: 100;
    display: none;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
  }

  .az-story__mobile-current[aria-expanded="true"] + .az-story__mobile-options {
    display: block;
  }

  .az-story__mobile-option {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: transparent;
    border: none;
    font-size: 0.9375rem;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.2s ease;
    text-align: left;
  }

  .az-story__mobile-option:hover {
    background: var(--color-border);
  }

  .az-story__mobile-option[data-selected="true"] {
    background: var(--color-accent);
    color: white;
  }

  .az-story__mobile-option-number {
    font-size: 0.875rem;
    font-weight: 600;
    opacity: 0.5;
  }

  .az-story__mobile-option[data-selected="true"] .az-story__mobile-option-number {
    opacity: 0.8;
  }

  .az-story__mobile-content {
    display: block;
  }

  .az-story__mobile-panel {
    display: none;
    animation: fadeIn 0.5s ease;
  }

  .az-story__mobile-panel[data-active="true"] {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .az-story__mobile-media {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .az-story__mobile-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop Styles */
  .az-story__desktop-grid {
    display: none;
  }

  /* Shared Content Styles */
  .az-story__chapter-number {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .az-story__chapter-name {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-heading);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .az-story__chapter-scientific {
    font-size: 1.125rem;
    font-style: italic;
    color: var(--color-secondary);
    margin: 0 0 1.5rem;
  }

  .az-story__chapter-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .az-story__chapter-benefits {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .az-story__benefits-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1rem;
  }

  .az-story__benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .az-story__benefits-list li {
    font-size: 1rem;
    color: var(--color-text);
    padding-left: 1.75rem;
    position: relative;
  }

  .az-story__benefits-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  @media (min-width: 768px) {
    .az-story__mobile-media {
      aspect-ratio: 1;
    }

    .az-story__benefits-list {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2rem;
    }
  }

  @media (min-width: 992px) {
    .az-story__mobile-selector,
    .az-story__mobile-content {
      display: none;
    }

    .az-story__desktop-grid {
      display: grid;
      grid-template-columns: 260px 1fr 420px;
      gap: clamp(2rem, 4vw, 3rem);
      align-items: start;
      position: relative;
    }

    .az-story__nav-column {
      position: sticky;
      top: 20px;
      align-self: start;
      height: fit-content;
    }

    .az-story__nav-sticky {
      position: relative;
    }

    .az-story__nav-label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-secondary);
      margin-bottom: 1.25rem;
    }

    .az-story__nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .az-story__nav-list li {
      margin-bottom: 0.5rem;
    }

    .az-story__nav-link {
      display: block;
      width: 100%;
      text-align: left;
      padding: 0.75rem 1.25rem;
      background: transparent;
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--color-secondary);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .az-story__nav-link:hover {
      background: var(--color-border);
      transform: translateX(4px);
    }

    .az-story__nav-link.is-active {
      background: var(--color-accent);
      color: white;
      border-color: var(--color-accent);
    }

    .az-story__content-column {
      padding-top: 2rem;
    }

    .az-story__chapter {
      margin-bottom: var(--desktop-chapter-spacing);
      opacity: 0.5;
      transition: opacity 0.4s ease;
    }

    .az-story__chapter.is-visible {
      opacity: 1;
    }

    .az-story__media-column {
      position: sticky;
      top: 20px;
      align-self: start;
      height: calc(100vh - 40px);
      max-height: 600px;
    }

    .az-story__media-sticky {
      position: relative;
      width: 100%;
      height: 100%;
    }

    .az-story__media-item {
      position: absolute;
      inset: 0;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.6s ease, visibility 0.6s ease;
    }

    .az-story__media-item.is-active {
      opacity: 1;
      visibility: visible;
    }

    .az-story__media-main {
      width: 100%;
      height: 75%;
      border-radius: 1.5rem;
      overflow: hidden;
      box-shadow: 0 20px 40px -15px rgba(0,0,0,0.15);
    }

    .az-story__media-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .az-story__media-texture {
      position: absolute;
      bottom: 0;
      right: 1rem;
      width: 45%;
      aspect-ratio: 1;
      border-radius: 1rem;
      overflow: hidden;
      border: 3px solid var(--color-background);
      box-shadow: 0 10px 25px -10px rgba(0,0,0,0.2);
    }

    .az-story__media-texture img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  @media (min-width: 1200px) {
    .az-story__desktop-grid {
      grid-template-columns: 280px 1fr 480px;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const isMobile = window.matchMedia('(max-width: 991px)').matches;

    if (isMobile) {
      // Mobile dropdown functionality
      const dropdownButton = section.querySelector('.az-story__mobile-current');
      const options = section.querySelectorAll('[data-mobile-select]');
      const panels = section.querySelectorAll('[data-mobile-panel]');

      // Toggle dropdown
      dropdownButton?.addEventListener('click', () => {
        const isOpen = dropdownButton.getAttribute('aria-expanded') === 'true';
        dropdownButton.setAttribute('aria-expanded', !isOpen);
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!section.contains(e.target)) {
          dropdownButton?.setAttribute('aria-expanded', 'false');
        }
      });

      // Handle option selection
      options.forEach(option => {
        option.addEventListener('click', () => {
          const targetIndex = option.dataset.mobileSelect;
          const selectedName = option.querySelector('span:not(.az-story__mobile-option-number)').textContent;
          
          // Update dropdown button text
          dropdownButton.querySelector('span').textContent = selectedName;
          dropdownButton.setAttribute('aria-expanded', 'false');
          
          // Update selected state
          options.forEach(o => o.removeAttribute('data-selected'));
          option.setAttribute('data-selected', 'true');
          
          // Update panels
          panels.forEach(p => p.removeAttribute('data-active'));
          const targetPanel = section.querySelector(`[data-mobile-panel="${targetIndex}"]`);
          if (targetPanel) {
            targetPanel.setAttribute('data-active', 'true');
          }
        });
      });
    } else {
      // Desktop functionality
      const navLinks = section.querySelectorAll('[data-nav-index]');
      const chapters = section.querySelectorAll('[data-chapter-index]');
      const mediaItems = section.querySelectorAll('[data-media-index]');
      let currentActive = null;
      let isScrolling = false;
      let scrollTimeout;

      // Navigation click handler
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          const targetId = link.dataset.navTarget;
          const targetElement = document.getElementById(targetId);
          
          if (targetElement) {
            isScrolling = true;
            const offset = window.innerHeight * 0.25;
            const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - offset;
            
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });

            // Clear scrolling flag after animation
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
              isScrolling = false;
            }, 1000);
          }
        });
      });

      // Scroll detection
      function updateActiveSection() {
        if (isScrolling) return;

        const viewportCenter = window.innerHeight / 2;
        let closestChapter = null;
        let closestDistance = Infinity;

        chapters.forEach(chapter => {
          const rect = chapter.getBoundingClientRect();
          const chapterCenter = rect.top + (rect.height / 2);
          const distance = Math.abs(viewportCenter - chapterCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestChapter = chapter;
          }
        });

        if (closestChapter) {
          const newActive = closestChapter.dataset.chapterIndex;
          
          if (newActive !== currentActive) {
            currentActive = newActive;

            // Update navigation
            navLinks.forEach(link => {
              link.classList.toggle('is-active', link.dataset.navIndex === newActive);
            });

            // Update chapters
            chapters.forEach(chapter => {
              chapter.classList.toggle('is-visible', chapter.dataset.chapterIndex === newActive);
            });

            // Update media
            mediaItems.forEach(media => {
              media.classList.toggle('is-active', media.dataset.mediaIndex === newActive);
            });
          }
        }
      }

      // Initialize first item as active
      if (chapters.length > 0) {
        currentActive = '1';
        navLinks[0]?.classList.add('is-active');
        chapters[0]?.classList.add('is-visible');
        mediaItems[0]?.classList.add('is-active');
      }

      // Debounced scroll handler
      let scrollDebounce;
      window.addEventListener('scroll', () => {
        clearTimeout(scrollDebounce);
        scrollDebounce = setTimeout(updateActiveSection, 10);
      }, { passive: true });

      // Initial check
      updateActiveSection();
    }
  })();
</script>

{% schema %}
{
  "name": "AZ Ingredient Story",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Source of Our Rituals"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We believe in the power of pure, potent ingredients. Discover the key elements that define our formulations."
    },
    {
      "type": "range",
      "id": "desktop_chapter_spacing",
      "label": "Desktop Chapter Spacing",
      "info": "Vertical space between ingredients on desktop",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "rem",
      "default": 20
    },
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Headings",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Body Text",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Secondary Text",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Accent Color",
      "default": "#BF9B7A"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Border Color",
      "default": "#F3F4F6"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name",
          "default": "Argan Oil"
        },
        {
          "type": "text",
          "id": "scientific_name",
          "label": "Scientific Name",
          "default": "Argania Spinosa"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Known as 'liquid gold,' our pure Argan oil is cold-pressed from kernels harvested by women's cooperatives in the Moroccan countryside.</p>"
        },
        {
          "type": "text",
          "id": "benefits",
          "label": "Benefits (comma-separated)",
          "default": "Deep hydration, Improves elasticity, Hair strengthening, Skin barrier protection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Main Image"
        },
        {
          "type": "image_picker",
          "id": "texture_image",
          "label": "Texture Image (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AZ Ingredient Story",
      "blocks": [
