{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
-%}

<style>
  {{ heading_font | font_face }}
  {{ body_font | font_face }}
  
  /* Swiper.js Base CSS - Scoped */
  .swiper-container-{{ section.id }} { position: relative; overflow: hidden; list-style: none; padding: 0; z-index: 1; }
  .swiper-container-{{ section.id }} .swiper-wrapper { position: relative; width: 100%; height: 100%; z-index: 1; display: flex; transition-property: transform; box-sizing: content-box; }
  .swiper-container-{{ section.id }} .swiper-slide { flex-shrink: 0; width: 100%; height: 100%; position: relative; transition-property: transform; }
  .swiper-container-{{ section.id }} .swiper-pagination { position: absolute; text-align: center; transition: .3s opacity; transform: translate3d(0,0,0); z-index: 10; }
  .swiper-container-{{ section.id }} .swiper-pagination.swiper-pagination-bullets { bottom: 10px; left: 0; width: 100%; }
  
  /* NEW: Apple-style Pagination Indicator */
  .swiper-container-{{ section.id }} .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    display: inline-block;
    border-radius: 50%;
    background-color: #cccccc;
    opacity: 1;
    margin: 0 5px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .swiper-container-{{ section.id }} .swiper-pagination-bullet-active {
    background-color: #333333;
    width: 30px;
    border-radius: 8px;
  }

  :root {
    --heading-font-{{ section.id }}: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --body-font-{{ section.id }}: {{ body_font.family }}, {{ body_font.fallback_families }};
    --accent-color-{{ section.id }}: {{ section.settings.accent_color }};
  }

  .showcase-masterpiece-{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: 50px;
    overflow-x: clip;
  }
  .showcase-masterpiece-{{ section.id }} .section-header { text-align: center; max-width: 650px; margin: 0 auto {{ section.settings.mobile_header_margin_bottom }}px; padding: 0 20px; }
  .showcase-masterpiece-{{ section.id }} .main-heading { font-family: var(--heading-font-{{ section.id }}); line-height: 1.3; margin: 0; font-size: {{ section.settings.main_heading_size_mobile }}rem; }
  .showcase-masterpiece-{{ section.id }} .urgency-subheading { opacity: 0.8; margin: 10px 0 0; font-size: 1rem; }
  
  .showcase-masterpiece-{{ section.id }} .benefit-heading {
    font-family: var(--heading-font-{{ section.id }}); font-weight: {{ heading_font.weight }};
    font-style: {{ heading_font.style }}; margin: 0 0 12px 0; color: var(--accent-color-{{ section.id }});
    font-size: {{ section.settings.benefit_heading_size_mobile }}rem;
  }
  .showcase-masterpiece-{{ section.id }} .benefit-text,
  .showcase-masterpiece-{{ section.id }} .testimonial-quote {
    font-family: var(--body-font-{{ section.id }}); font-weight: {{ body_font.weight }};
    font-style: {{ body_font.style }}; line-height: 1.6; margin: 0;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.75 }};
    font-size: {{ section.settings.benefit_text_size_mobile }}rem;
  }
  .showcase-masterpiece-{{ section.id }} .testimonial-author { font-family: var(--heading-font-{{ section.id }}); font-weight: bold; margin-top: 15px; display: block; opacity: 0.8; }
  
  .showcase-masterpiece-{{ section.id }} .cta-button {
    display: inline-block; background-color: var(--accent-color-{{ section.id }}); color: #fff;
    padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: bold;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 15px {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
  }
  .showcase-masterpiece-{{ section.id }} .cta-button:hover { transform: translateY(-2px); box-shadow: 0 7px 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.4 }}; }
  .showcase-masterpiece-{{ section.id }} .guarantee-text {
    display: flex; align-items: center; justify-content: center; gap: 8px; 
    margin-top: 15px; opacity: 0.7; font-size: {{ section.settings.guarantee_text_size }}rem;
  }
  .showcase-masterpiece-{{ section.id }} .guarantee-text svg { width: 1em; height: 1em; flex-shrink: 0; }
  .showcase-masterpiece-{{ section.id }} .certifications-row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 15px;
  }
  .showcase-masterpiece-{{ section.id }} .certification-item img {
    height: {{ section.settings.certification_icon_size }}px; 
    width: auto; object-fit: contain;
  }

  /* --- Mobile Layout --- */
  .mobile-swiper-wrapper {
    display: flex; flex-direction: column; min-height: {{ section.settings.mobile_section_height }}px; padding: 20px 0; box-sizing: border-box;
  }
  .mobile-swiper-wrapper .image-container {
    flex-grow: 1; position: relative; display: flex; flex-direction: column; 
    align-items: center; justify-content: flex-start;
    padding: {{ section.settings.mobile_image_padding }}px;
  }
  .mobile-swiper-wrapper .main-image-wrapper {
    width: 100%;
    height: {{ section.settings.mobile_image_height }}vh;
    position: relative;
    flex-shrink: 0;
  }
  .mobile-swiper-wrapper .main-image {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));
    transition: opacity 0.4s ease-in-out;
  }
  .mobile-swiper-wrapper .certifications-row { flex-shrink: 0; padding-top: 15px; }
  .mobile-swiper-wrapper .swiper-container-{{ section.id }} {
    flex-shrink: 0; width: 100%; height: auto;
    padding: 20px 10px calc(20px + 20px);
    box-sizing: border-box;
  }
  .mobile-swiper-wrapper .swiper-slide { text-align: center; }
  .mobile-swiper-wrapper .benefit-item, .mobile-swiper-wrapper .testimonial-item {
    background-color: {{ section.settings.mobile_card_bg }};
    border-radius: {{ section.settings.mobile_card_radius }}px;
    padding: {{ section.settings.mobile_text_padding_y }}px {{ section.settings.mobile_text_padding_x }}px;
  }
  .mobile-swiper-wrapper .cta-button-wrapper { text-align: center; padding: 20px 0 30px; }

  /* --- Desktop Layout --- */
  .desktop-scrolly-wrapper { display: none; }
  @media (min-width: 992px) {
    .mobile-swiper-wrapper { display: none; }
    .desktop-scrolly-wrapper { display: block; }
    
    .showcase-masterpiece-{{ section.id }} .section-header { margin-bottom: 50px; }
    .showcase-masterpiece-{{ section.id }} .main-heading { font-size: {{ section.settings.main_heading_size_desktop }}rem; }
    .showcase-masterpiece-{{ section.id }} .benefit-heading { font-size: {{ section.settings.benefit_heading_size_desktop }}rem; }
    .showcase-masterpiece-{{ section.id }} .benefit-text, .showcase-masterpiece-{{ section.id }} .testimonial-quote { font-size: {{ section.settings.benefit_text_size_desktop }}rem; }

    .showcase-masterpiece-{{ section.id }} .benefit-group {
      display: grid; 
      grid-template-columns: {{ section.settings.desktop_image_column_width }}% 1fr;
      gap: 5%; max-width: {{ section.settings.max_width }}px; margin: 0 auto;
      align-items: flex-start;
    }
    .showcase-masterpiece-{{ section.id }} .benefit-group[data-desktop-pos="right"] { 
      grid-template-columns: 1fr {{ section.settings.desktop_image_column_width }}%;
    }
     .showcase-masterpiece-{{ section.id }} .benefit-group[data-desktop-pos="left"] .group-image-column { grid-column: 1; }
    .showcase-masterpiece-{{ section.id }} .benefit-group[data-desktop-pos="left"] .benefits-list-placeholder { grid-column: 2; }
     .showcase-masterpiece-{{ section.id }} .benefit-group[data-desktop-pos="right"] .group-image-column { grid-column: 2; }
    .showcase-masterpiece-{{ section.id }} .benefit-group[data-desktop-pos="right"] .benefits-list-placeholder { grid-column: 1; }
    
    .showcase-masterpiece-{{ section.id }} .group-image-column {
      position: sticky; top: 15vh; height: 70vh; display: flex; flex-direction: column;
    }
    .showcase-masterpiece-{{ section.id }} .group-image-wrapper {
      flex-grow: 1; display: flex; align-items: center; justify-content: center;
    }
    .showcase-masterpiece-{{ section.id }} .cta-button-wrapper {
      flex-shrink: 0; text-align: center; padding-top: 20px;
    }
    .showcase-masterpiece-{{ section.id }} .group-image-wrapper img {
      width: auto; max-height: 100%; filter: drop-shadow(0 10px 25px rgba(0,0,0,0.1));
    }
    .showcase-masterpiece-{{ section.id }} .benefits-list-placeholder { padding-bottom: 30vh; }
    .showcase-masterpiece-{{ section.id }} .benefit-item { min-height: var(--benefit-spacing, 30vh); }
    .showcase-masterpiece-{{ section.id }} .testimonial-item { min-height: var(--breather-spacing, 16vh); }

    .showcase-masterpiece-{{ section.id }} .benefit-item,
    .showcase-masterpiece-{{ section.id }} .testimonial-item {
      display: flex; flex-direction: column; justify-content: center;
      transition: opacity 0.5s ease, transform 0.5s ease; text-align: left;
      opacity: 0; transform: translateY(20px);
    }
    .showcase-masterpiece-{{ section.id }} .testimonial-item { 
      border-left: 3px solid var(--accent-color-{{ section.id }}); padding-left: 25px; 
      text-align: center;
    }
    .showcase-masterpiece-{{ section.id }} .testimonial-item .testimonial-quote { font-style: italic; font-size: 1.2em; }
  }
</style>

<div class="showcase-masterpiece-{{ section.id }}">
  <div class="section-header">
    {%- if section.settings.main_heading != blank -%}
      <h2 class="main-heading">{{ section.settings.main_heading }}</h2>
    {%- endif -%}
    {%- if section.settings.urgency_subheading != blank -%}
      <p class="urgency-subheading">{{ section.settings.urgency_subheading }}</p>
    {%- endif -%}
  </div>

  <div class="mobile-swiper-wrapper">
    <div class="image-container" id="swiper-image-container-{{ section.id }}">
      <div class="main-image-wrapper"></div>
    </div>
    <div class="swiper-container-{{ section.id }}">
      <div class="swiper-wrapper"></div>
      <div class="swiper-pagination"></div>
    </div>
    {%- if section.settings.show_cta and section.settings.cta_text != blank -%}
      <div class="cta-button-wrapper">
        <a href="{{ section.settings.cta_link }}" class="cta-button">{{ section.settings.cta_text }}</a>
        {%- if section.settings.show_guarantee and section.settings.guarantee_text != blank -%}
          <div class="guarantee-text">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"></path></svg>
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="desktop-scrolly-wrapper">
    {%- for block in section.blocks -%}
      {%- if block.type == 'group_start' -%}
        <div class="benefit-group" 
             id="benefit-group-{{ block.id }}" 
             data-desktop-pos="{{ block.settings.image_position_desktop }}" 
             style="margin-top: {{ block.settings.space_before_group_desktop }}vh;">
          <div class="group-image-column">
            <div class="group-image-wrapper" data-parallax="{{ block.settings.enable_parallax }}">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" 
                     alt="{{ block.settings.image.alt | escape }}" 
                     loading="lazy"
                     style="max-width: {{ block.settings.image_max_width_desktop }}px;">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="cta-button-wrapper">
              {%- if section.settings.show_cta and section.settings.cta_text != blank -%}
                <a href="{{ section.settings.cta_link }}" class="cta-button">{{ section.settings.cta_text }}</a>
                 {%- if section.settings.show_guarantee and section.settings.guarantee_text != blank -%}
                  <div class="guarantee-text">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"></path></svg>
                    <span>{{ section.settings.guarantee_text }}</span>
                  </div>
                {%- endif -%}
              {%- endif -%}
            </div>
            <div class="certifications-row"></div>
          </div>
          <div class="benefits-list-placeholder"></div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="content-storage" style="display: none;" aria-hidden="true">
    {%- liquid 
      assign current_group_id_for_content = ''
      assign current_benefit_spacing = ''
    -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'group_start' -%}
        {%- assign current_group_id_for_content = block.id -%}
        {%- assign current_image_url_for_content = block.settings.image | image_url: width: 500 -%}
        {%- assign current_benefit_spacing = block.settings.desktop_benefit_spacing -%}
      {%- elsif block.type == 'benefit_item' -%}
        <div class="benefit-item" 
             style="--benefit-spacing: {{ current_benefit_spacing }}vh;"
             data-content-type="benefit" data-group-id="{{ current_group_id_for_content }}" data-group-image="{{ current_image_url_for_content }}">
          <h3 class="benefit-heading">{{ block.settings.heading }}</h3>
          <p class="benefit-text">{{ block.settings.text }}</p>
        </div>
      {%- elsif block.type == 'testimonial' -%}
        <div class="testimonial-item" 
             style="--breather-spacing: {{ block.settings.breather_space_desktop }}vh;"
             data-content-type="benefit" data-group-id="{{ current_group_id_for_content }}" data-group-image="{{ current_image_url_for_content }}">
          <p class="testimonial-quote">"{{ block.settings.quote_text }}"</p>
          <span class="testimonial-author">- {{ block.settings.author_name }}</span>
        </div>
      {%- elsif block.type == 'certification_icon' -%}
        <div class="certification-item" data-content-type="certification" data-group-id="{{ current_group_id_for_content }}">
          {%- if block.settings.icon != blank -%}
            <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="{{ block.settings.icon.alt | default: 'Certification icon' | escape }}">
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script src="https://unpkg.com/swiper@6.8.4/swiper-bundle.min.js"></script>
<script>
  (() => {
    const sectionId = '{{ section.id }}';
    const sectionEl = document.querySelector(`.showcase-masterpiece-${sectionId}`);
    if (!sectionEl) return;
    
    let swiperInstance = null;
    let desktopScrollHandler = null;
    let resizeTimeout;

    const initContent = () => {
      const contentItems = sectionEl.querySelectorAll('.content-storage > div');
      contentItems.forEach(item => {
        const groupId = item.dataset.groupId;
        const contentType = item.dataset.contentType;
        if (!groupId) return;

        const groupEl = document.getElementById(`benefit-group-${groupId}`);
        if (!groupEl) return;
        
        let placeholder;
        if (contentType === 'benefit') {
          placeholder = groupEl.querySelector('.benefits-list-placeholder');
        } else if (contentType === 'certification') {
          placeholder = groupEl.querySelector('.certifications-row');
        }
        
        if (placeholder) {
          placeholder.appendChild(item.cloneNode(true));
        }
      });

      const mobileSwiperWrapper = sectionEl.querySelector('.mobile-swiper-wrapper .swiper-wrapper');
      const benefitSlides = sectionEl.querySelectorAll('.content-storage > [data-content-type="benefit"]');
      if (mobileSwiperWrapper) {
        mobileSwiperWrapper.innerHTML = '';
        benefitSlides.forEach(slide => {
          const slideWrapper = document.createElement('div');
          slideWrapper.className = 'swiper-slide';
          slideWrapper.dataset.groupId = slide.dataset.groupId;
          slideWrapper.dataset.groupImage = slide.dataset.groupImage;
          slideWrapper.appendChild(slide.cloneNode(true));
          mobileSwiperWrapper.appendChild(slideWrapper);
        });
      }
    };

    const cleanup = () => {
      if (swiperInstance) { swiperInstance.destroy(true, true); swiperInstance = null; }
      if (desktopScrollHandler) window.removeEventListener('scroll', desktopScrollHandler);
    };

    const initMobile = () => {
      if (typeof Swiper === 'undefined') return;
      const imageContainer = document.getElementById(`swiper-image-container-${sectionId}`);
      if (!imageContainer) return;
      
      const mainImageWrapper = imageContainer.querySelector('.main-image-wrapper');
      let currentImageGroupId = null;
      const firstSlide = sectionEl.querySelector('.swiper-slide');
      
      const updateMobileImage = (slide) => {
        if (!slide) return;
        const newGroupId = slide.dataset.groupId;
        if (newGroupId === currentImageGroupId) return;
        
        currentImageGroupId = newGroupId;
        const newImageUrl = slide.dataset.groupImage;
        const currentImage = mainImageWrapper.querySelector('.main-image');
        
        const newImage = document.createElement('img');
        newImage.src = newImageUrl;
        newImage.className = 'main-image';
        newImage.style.opacity = '0';
        mainImageWrapper.appendChild(newImage);

        let certRow = imageContainer.querySelector('.certifications-row');
        if (certRow) certRow.remove();
        
        const storedIcons = sectionEl.querySelectorAll(`.content-storage .certification-item[data-group-id="${newGroupId}"]`);
        if (storedIcons.length > 0) {
           const newCertRow = document.createElement('div');
           newCertRow.className = 'certifications-row';
           storedIcons.forEach(icon => {
             newCertRow.appendChild(icon.cloneNode(true));
           });
           imageContainer.appendChild(newCertRow);
        }

        setTimeout(() => {
          newImage.style.opacity = '1';
          if(currentImage) currentImage.style.opacity = '0';
          setTimeout(() => { if(currentImage) currentImage.remove() }, 400);
        }, 50);
      };
      
      if (firstSlide) {
        updateMobileImage(firstSlide);
      }
      
      swiperInstance = new Swiper(`.swiper-container-${sectionId}`, {
        loop: false,
        pagination: { el: `.swiper-container-${sectionId} .swiper-pagination`, clickable: true },
        on: {
          slideChange: function () {
            const activeSlide = this.slides[this.activeIndex];
            if (activeSlide) updateMobileImage(activeSlide);
          }
        }
      });
    };

    const initDesktop = () => {
      const groups = sectionEl.querySelectorAll('.benefit-group');
      desktopScrollHandler = () => {
        const viewportCenter = window.innerHeight / 2;
        groups.forEach(group => {
          const items = group.querySelectorAll('.benefit-item, .testimonial-item');
          const imageColumn = group.querySelector('.group-image-column');
          items.forEach(item => {
            const rect = item.getBoundingClientRect();
            const itemCenter = rect.top + rect.height / 2;
            const distance = Math.abs(viewportCenter - itemCenter);
            
            if (distance < (window.innerHeight / 2.5)) {
              item.style.opacity = '1';
              item.style.transform = 'translateY(0)';
            } else {
              item.style.opacity = '0';
              item.style.transform = 'translateY(20px)';
            }
          });
          if (imageColumn && imageColumn.querySelector('.group-image-wrapper[data-parallax="true"]')) {
            const groupRect = group.getBoundingClientRect();
            if (groupRect.top < window.innerHeight && groupRect.bottom > 0) {
              const scrollProgress = (window.innerHeight - groupRect.top) / (window.innerHeight + groupRect.height);
              const parallaxOffset = (scrollProgress - 0.5) * 60;
              imageColumn.style.transform = `translateY(${parallaxOffset}px)`;
            }
          }
        });
      };
      window.addEventListener('scroll', desktopScrollHandler, { passive: true });
      desktopScrollHandler();
    };

    const onResize = () => {
      cleanup();
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const newClassName = `showcase-masterpiece-${sectionId}`;
        if(sectionEl.className !== newClassName) sectionEl.className = newClassName;

        if (window.matchMedia('(min-width: 992px)').matches) {
          initDesktop();
        } else {
          initMobile();
        }
      }, 150);
    };
    
    initContent();
    onResize();
    window.addEventListener('resize', onResize);
    document.addEventListener('shopify:section:load', onResize);
    document.addEventListener('shopify:section:unload', cleanup);
  })();
</script>

{% schema %}
{
  "name": "Benefit Showcase",
  "tag": "section",
  "class": "showcase-masterpiece-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Content & CTA"
    },
    { "type": "text", "id": "main_heading", "label": "Main Heading", "default": "6 KLJUČNIH BENEFITA ARGANSKOG ULJA" },
    { "type": "text", "id": "urgency_subheading", "label": "Optional Subheading", "info": "Use for promotions or key callouts." },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA Button", "default": true },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Naruči Odmah" },
    { "type": "url", "id": "cta_link", "label": "Button Link" },
    { "type": "checkbox", "id": "show_guarantee", "label": "Show Trust Badge / Guarantee", "default": true },
    { "type": "text", "id": "guarantee_text", "label": "Trust Badge Text", "default": "100% zadovoljstvo ili povrat novca" },
    {
      "type": "header",
      "content": "Global Styling"
    },
    { "type": "color", "id": "background_color", "label": "Section Background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#D48A5D" },
    { "type": "range", "id": "certification_icon_size", "min": 20, "max": 60, "step": 2, "unit": "px", "label": "Certification Icon Size", "default": 40 },
    {
      "type": "header",
      "content": "Typography"
    },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "helvetica_n4" },
    { "type": "font_picker", "id": "body_font", "label": "Body Font", "default": "helvetica_n4" },
    { "type": "range", "id": "main_heading_size_desktop", "min": 1.5, "max": 4, "step": 0.1, "unit": "rem", "label": "Main Heading Size (Desktop)", "default": 2.5 },
    { "type": "range", "id": "main_heading_size_mobile", "min": 1.2, "max": 3, "step": 0.1, "unit": "rem", "label": "Main Heading Size (Mobile)", "default": 1.8 },
    { "type": "range", "id": "benefit_heading_size_desktop", "min": 1, "max": 3, "step": 0.1, "unit": "rem", "label": "Benefit Heading Size (Desktop)", "default": 1.5 },
    { "type": "range", "id": "benefit_text_size_desktop", "min": 0.8, "max": 2, "step": 0.1, "unit": "rem", "label": "Benefit Body Size (Desktop)", "default": 1.0 },
    { "type": "range", "id": "benefit_heading_size_mobile", "min": 1, "max": 2.5, "step": 0.1, "unit": "rem", "label": "Benefit Heading Size (Mobile)", "default": 1.2 },
