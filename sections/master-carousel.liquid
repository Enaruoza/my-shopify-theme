{% liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign gap = section.settings.gap
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
%}

<div class="master-carousel section color-{{ section.settings.color_scheme }}" style="--padding-top: {{ padding_top }}px; --padding-bottom: {{ padding_bottom }}px;">
  <div class="master-carousel__container">
    {%- if section.settings.heading != blank -%}
      <div class="master-carousel__header {{ section.settings.heading_alignment }}">
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <div class="rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="master-carousel__wrapper" id="Carousel-{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}" data-speed="{{ section.settings.speed }}">
      
      {%- if section.settings.show_arrows -%}
        <button class="master-carousel__arrow master-carousel__arrow--prev" aria-label="Previous">
          {% render 'icon', icon: 'arrow-left' %}
        </button>
        <button class="master-carousel__arrow master-carousel__arrow--next" aria-label="Next">
          {% render 'icon', icon: 'arrow-right' %}
        </button>
      {%- endif -%}

      <div class="master-carousel__track" style="--columns-desktop: {{ columns_desktop }}; --columns-mobile: {{ columns_mobile }}; --gap: {{ gap }}px;">
        {%- for block in section.blocks -%}
          <div class="master-carousel__item master-carousel__item--{{ block.type }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'review' -%}
                <div class="carousel-review">
                  <div class="carousel-review__stars">
                    {%- for i in (1..block.settings.stars) -%}
                      {% render 'icon', icon: 'star' %}
                    {%- endfor -%}
                  </div>
                  <div class="carousel-review__text rte">{{ block.settings.text }}</div>
                  <div class="carousel-review__author">{{ block.settings.author }}</div>
                </div>

              {%- when 'logo' -%}
                <div class="carousel-logo">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 400 | image_tag: class: 'carousel-logo__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'carousel-logo__img opacity-50' }}
                  {%- endif -%}
                </div>

              {%- when 'product_card' -%}
                {%- if block.settings.product != blank -%}
                  {% render 'card-product', card_product: block.settings.product %}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="master-carousel__dots">
          {%- for block in section.blocks -%}
            <button class="master-carousel__dot {% if forloop.first %}active{% endif %}" aria-label="Go to slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .master-carousel {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    overflow: hidden;
  }

  .master-carousel__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .master-carousel__header {
    margin-bottom: 2rem;
  }
  .master-carousel__header.text-center { text-align: center; }
  .master-carousel__header.text-right { text-align: right; }

  .master-carousel__wrapper {
    position: relative;
  }

  .master-carousel__track {
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 20px;
  }
  
  .master-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .master-carousel__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: calc((100% - ((var(--columns-mobile) - 1) * var(--gap))) / var(--columns-mobile));
  }

  @media (min-width: 768px) {
    .master-carousel__item {
      width: calc((100% - ((var(--columns-desktop) - 1) * var(--gap))) / var(--columns-desktop));
    }
  }

  /* Arrows */
  .master-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.2s;
  }
  .master-carousel__arrow:hover { transform: translateY(-50%) scale(1.1); }
  .master-carousel__arrow--prev { left: 0; }
  .master-carousel__arrow--next { right: 0; }
  
  .master-carousel__arrow svg { width: 20px; height: 20px; }

  /* Dots */
  .master-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 1rem;
  }
  .master-carousel__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #e5e7eb;
    border: none;
    cursor: pointer;
    transition: background 0.3s;
  }
  .master-carousel__dot.active { background: #000; }

  /* Review Block */
  .carousel-review {
    background: #f9fafb;
    padding: 2rem;
    border-radius: 12px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }
  .carousel-review__stars {
    color: #fbbf24;
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    gap: 4px;
  }
  .carousel-review__stars svg { width: 16px; height: 16px; }
  .carousel-review__text {
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    font-style: italic;
  }
  .carousel-review__author {
    font-weight: bold;
    font-size: 0.875rem;
  }

  /* Logo Block */
  .carousel-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  .carousel-logo:hover { opacity: 1; }
  .carousel-logo__img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = {{ section.id | json }};
    const wrapper = document.getElementById('Carousel-' + sectionId);
    if (!wrapper) return;

    const track = wrapper.querySelector('.master-carousel__track');
    const prevBtn = wrapper.querySelector('.master-carousel__arrow--prev');
    const nextBtn = wrapper.querySelector('.master-carousel__arrow--next');
    const autoplay = wrapper.dataset.autoplay === 'true';
    const speed = parseFloat(wrapper.dataset.speed) * 1000;
    
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -track.clientWidth / 2, behavior: 'smooth' });
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: track.clientWidth / 2, behavior: 'smooth' });
      });
    }

    if (autoplay) {
      let interval;
      const startAutoplay = () => {
        interval = setInterval(() => {
          if (track.scrollLeft + track.clientWidth >= track.scrollWidth - 10) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: 300, behavior: 'smooth' });
          }
        }, speed);
      };
      
      startAutoplay();
      
      wrapper.addEventListener('mouseenter', () => clearInterval(interval));
      wrapper.addEventListener('mouseleave', startAutoplay);
      wrapper.addEventListener('touchstart', () => clearInterval(interval));
      wrapper.addEventListener('touchend', startAutoplay);
    }
  });
</script>

{% schema %}
{
  "name": "Master Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Desktop Columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1",
      "label": "Mobile Columns"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24,
      "label": "Gap (px)"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "speed",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "default": 3,
      "label": "Autoplay Speed (s)"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "min": 1, "max": 5, "step": 1, "default": 5, "label": "Stars" },
        { "type": "richtext", "id": "text", "label": "Review Text", "default": "<p>Amazing product!</p>" },
        { "type": "text", "id": "author", "label": "Author", "default": "Customer Name" }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo Image" }
      ]
    },
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Master Carousel",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
