  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Odaberi po problemu" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Filtriraj po dijelu tijela, tipu proizvoda i problemu koji želiš riješiti." },
    { "type": "header", "content": "Shipping" },
    { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping threshold (KM)", "default": 100 },
    { "type": "header", "content": "Layout & Colors" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#111111" },
    { "type": "color", "id": "petals_color", "label": "Flower petals color", "default": "#e86b91" },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 5, "step": 1, "label": "Products per row (Desktop)", "default": 4 },
    { "type": "radio", "id": "columns_mobile", "label": "Products per row (Mobile)", "options": [ { "value": "1", "label": "1" }, { "value": "2", "label": "2" } ], "default": "2" },
    { "type": "header", "content": "Filter Button (Mobile)" },
    { "type": "text", "id": "filter_button_label", "label": "Filter button label", "default": "Filter" },
    { "type": "color", "id": "filter_button_bg", "label": "Filter button background", "default": "#f5f5f7" },
    { "type": "color", "id": "filter_button_fg", "label": "Filter button text color", "default": "#111111" },
    { "type": "header", "content": "Sticky Footer" },
    { "type": "text", "id": "sticky_button_label", "label": "Checkout button label", "default": "Završi kupovinu" },
    { "type": "text", "id": "sticky_toggle_label", "label": "Progress toggle aria label", "default": "Prikaži ili sakrij traku za dostavu" },
    { "type": "header", "content": "Accessibility" },
    { "type": "text", "id": "flip_icon_aria", "label": "Flip icon aria-label", "default": "Okreni karticu" },
    { "type": "header", "content": "Functionality" },
    { "type": "checkbox", "id": "enable_multiselect", "label": "Enable multi-select filtering", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "areas", "label": "Areas (comma separated)", "default": "lice,tijelo" },
        { "type": "text", "id": "types", "label": "Types (comma separated)", "default": "oil,treatment" },
        { "type": "text", "id": "concerns", "label": "Concerns (comma separated)", "default": "dryness,aging,damage" },
        { "type": "text", "id": "benefits", "label": "Front chips (comma separated)", "default": "Hidratacija, Anti-age, Sjaj" },
        { "type": "text", "id": "badge", "label": "Badge (leave blank to hide)" },
        { "type": "select", "id": "back_align", "label": "Back content alignment", "options": [ { "value": "top", "label": "Top" }, { "value": "center", "label": "Center" }, { "value": "bottom", "label": "Bottom" } ], "default": "top" },
        { "type": "text", "id": "flip_title", "label": "Back title", "default": "Zašto će ti se svidjeti" },
        { "type": "richtext", "id": "flip_text", "label": "Back description", "default": "<p>Kratak opis ključnih sastojaka i efekata.</p>" },
        { "type": "textarea", "id": "flip_points", "label": "Back bullet points (one per line)", "default": "Ključna tvrdnja 1\nKljučna tvrdnja 2\nKljučna tvrdnja 3" }
      ]
    }
  ],
  "presets": [
    { "name": "AZ Concern Selector", "blocks": [ { "type": "product" } ] }
  ]
}
{% endschema %}
