{% comment %} AZOURANE Diagnostic CTA Strip {% endcomment %}
<section class="az-diagnostic-cta">
  <div class="az-container">
    <div class="az-diagnostic-cta__inner">
      <div class="az-diagnostic-cta__content">
        <h2 class="az-h2">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="az-copy">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      <div class="az-diagnostic-cta__actions">
        <a href="{{ section.settings.primary_link | default: '#' }}" class="az-btn az-btn--primary">
          {{ section.settings.primary_label }}
        </a>
        {% if section.settings.secondary_link != blank and section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_link }}" class="az-btn az-btn--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
.az-diagnostic-cta {
  background: #fafafa;
  padding: 40px 0;
}

.az-diagnostic-cta__inner {
  display: flex;
  flex-direction: column;
  gap: 24px;
  align-items: flex-start;
}

@media (min-width: 768px) {
  .az-diagnostic-cta__inner {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
}

.az-h2 {
  font-size: clamp(24px, 3.2vw, 32px);
  line-height: 1.2;
  font-weight: 600;
  color: #111;
  margin: 0 0 8px;
}

.az-diagnostic-cta__actions {
  display: flex;
  gap: 12px;
  flex-shrink: 0;
}
</style>

{% schema %}
{
  "name": "AZ Diagnostic CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Naslov", "default": "Pronađi rutinu koja ti odgovara" },
    { "type": "textarea", "id": "subheading", "label": "Podnaslov", "default": "Brzi upitnik ispod 4 minute. Preporuka proizvoda po tvojoj koži." },
    { "type": "text", "id": "primary_label", "label": "Primarno dugme", "default": "Pokreni dijagnostiku" },
    { "type": "url", "id": "primary_link", "label": "Primarni link" },
    { "type": "text", "id": "secondary_label", "label": "Sekundarno dugme", "default": "Saznaj više" },
    { "type": "url", "id": "secondary_link", "label": "Sekundarni link" }
  ],
  "presets": [{ "name": "AZ Diagnostic CTA" }]
}
{% endschema %}