{% comment %}
 =====================================================================================
 SECTION SETTINGS & VARIABLES
 =====================================================================================
{% endcomment %}
{% assign section_id = section.id %}
{% assign initial_stock = section.settings.initial_stock | default: 100 %}
{% assign current_stock = section.settings.current_stock | default: 100 %}

{% comment %} FIX: Logic is now based on percentage of stock REMAINING, not sold. {% endcomment %}
{% if initial_stock > 0 %}
  {% assign stock_percentage_remaining = current_stock | times: 100.0 | divided_by: initial_stock %}
{% else %}
  {% assign stock_percentage_remaining = 0 %}
{% endif %}

{% comment %}
 =====================================================================================
 CSS STYLES
 =====================================================================================
{% endcomment %}
{% style %}
  .preorder-hero-{{ section_id }} {
    --bg-start: {{ section.settings.bg_gradient_start }};
    --bg-end: {{ section.settings.bg_gradient_end }};
    --text-color: {{ section.settings.text_color }};
    --btn-primary: {{ section.settings.button_gradient_start }};
    --btn-secondary: {{ section.settings.button_gradient_end }};
    --accent: var(--btn-primary);
    width: 100%; padding: 60px 20px; background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
    position: relative; overflow-x: hidden;
  }
  .container-{{ section_id }} { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; position: relative; z-index: 1; }
  .gallery-wrapper-{{ section_id }} { position: sticky; top: 100px; width: 100%; aspect-ratio: 4 / 5; }
  .product-showcase-{{ section_id }} { position: relative; width: 100%; height: 100%; }
  .showcase-card { position: absolute; width: 100%; height: 100%; border-radius: 24px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out; opacity: 0; transform: scale(0.95); }
  .showcase-card.active { opacity: 1; transform: scale(1); z-index: 2; }
  .showcase-card img { width: 100%; height: 100%; object-fit: cover; }
  .gallery-dots-{{ section_id }} { position: absolute; bottom: -40px; left: 50%; transform: translateX(-50%); display: flex; gap: 12px; z-index: 3; }
  .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--text-color); opacity: 0.3; cursor: pointer; transition: all 0.3s ease; }
  .dot.active { width: 30px; border-radius: 5px; opacity: 1; background: var(--btn-primary); }
  .content-wrapper-{{ section_id }} { padding: 40px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 32px; box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15); height: fit-content; }
  .hero-heading { font-family: {{ section.settings.font_heading.family }}, sans-serif; font-weight: {{ section.settings.font_heading.weight }}; font-size: clamp(40px, 5vw, 64px); line-height: 1.1; text-transform: uppercase; letter-spacing: -2px; margin: 0 0 16px 0; background: linear-gradient(45deg, var(--btn-primary), var(--btn-secondary), var(--btn-primary)); background-size: 200% 200%; -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; animation: gradientShift 3s ease infinite; }
  @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  .hero-subheading { font-size: clamp(18px, 2vw, 22px); color: var(--text-color); margin: 0 0 24px 0; opacity: 0.9; }
  .testimonial-block { background: rgba(255,255,255,0.1); border-left: 3px solid var(--accent); padding: 16px 20px; border-radius: 8px; margin: 24px 0; color: var(--text-color); }
  .countdown-wrapper { display: flex; gap: 16px; justify-content: center; margin: 24px 0; padding: 16px; background: rgba(0,0,0,0.05); border-radius: 12px; }
  .countdown-item { text-align: center; }
  .countdown-number { font-size: clamp(24px, 4vw, 40px); font-weight: bold; line-height: 1; color: var(--text-color); }
  .countdown-label { font-size: 12px; text-transform: uppercase; opacity: 0.7; color: var(--text-color); }
  .stock-counter-wrapper { margin: 24px 0; position: relative; }
  .stock-progress-bar { background: rgba(0,0,0,0.1); border-radius: 100px; padding: 4px; overflow: hidden; }
  .stock-progress-bar-inner { height: 12px; border-radius: 100px; background: linear-gradient(45deg, var(--btn-primary), var(--btn-secondary)); transition: width 0.5s ease-out; }
  .stock-text { text-align: center; font-size: 14px; font-weight: bold; color: var(--text-color); margin-top: 8px; }

  .packages-container-{{ section_id }} { margin-top: 40px; padding: 32px; background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 24px; position: relative; display: flex; flex-direction: column; gap: 12px; }
  .packages-label { font-weight: bold; text-align: center; margin-bottom: 4px; color: var(--text-color); font-size: 18px; }
  .package-option { border: 2px solid rgba(0,0,0,0.1); border-radius: 12px; padding: 16px; cursor: pointer; transition: all 0.3s ease; text-align: center; background: rgba(255,255,255,0.1); }
  .package-option.active { border-color: var(--accent); background: rgba(255,255,255,0.25); transform: scale(1.02); box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
  .package-option .price-title { font-weight: bold; font-size: 18px; color: var(--text-color); }
  .package-option .price { font-size: 16px; color: var(--text-color); opacity: 0.9; }
  .package-option .savings { color: #22c55e; font-weight: bold; font-size: 14px; margin-top: 4px; }
  
  .price-reveal { margin-bottom: 24px; padding: 20px; background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 12px; text-align: center; display: none; color: var(--text-color); animation: fadeIn 0.5s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .price-reveal .total-price-heading, .price-reveal .savings-emphasis { font-weight: bold; }
  
  .form-fields-container {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition: max-height 0.8s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.5s ease, visibility 0.5s;
  }
  .form-fields-container.visible {
    max-height: 600px;
    opacity: 1;
    visibility: visible;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .form-field { position: relative; }
  
  .form-field.full-width {
    grid-column: 1 / -1;
  }

  .form-input { width: 100%; padding: 16px 20px; background-color: rgba(255, 255, 255, 0.8); border: 1px solid rgba(0,0,0,0.1); border-radius: 12px; font-size: 16px; transition: all 0.3s ease; color: #333; }
  .form-input:focus { outline: none; border-color: var(--accent); background-color: #FFFFFF; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
  .form-label { position: absolute; top: 50%; left: 20px; transform: translateY(-50%); font-size: 16px; color: #666; pointer-events: none; transition: all 0.3s ease; }
  .form-input:focus + .form-label, .form-input:not(:placeholder-shown) + .form-label { top: -8px; left: 16px; font-size: 12px; background: white; padding: 0 8px; color: var(--accent); }
  
  .submit-button-wrapper { max-height: 0; overflow: hidden; transition: max-height 0.8s cubic-bezier(0.23, 1, 0.32, 1); }
  .submit-button-wrapper.visible { max-height: 100px; }
  .submit-button { width: 100%; padding: 18px; background: linear-gradient(45deg, var(--btn-primary), var(--btn-secondary)); border: none; border-radius: 12px; color: white; font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; position: relative; overflow: hidden; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
  .submit-button:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
  
  .accordion-item { margin-top: 10px; background: rgba(255, 255, 255, 0.05); border-radius: 16px; overflow: hidden; }
  .accordion-trigger { width: 100%; padding: 20px; background: none; border: none; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-size: 16px; font-weight: 600; color: var(--text-color); text-align: left; }
  .accordion-icon { border: solid var(--text-color); border-width: 0 2px 2px 0; display: inline-block; padding: 3px; opacity: 0.7; transform: rotate(45deg); transition: transform 0.3s ease; }
  .accordion-item.active .accordion-icon { transform: rotate(-135deg); }
  .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.23, 1, 0.32, 1); }
  .accordion-inner { padding: 0 20px 20px; color: var(--text-color); opacity: 0.8; line-height: 1.6; }

  @media (max-width: 990px) {
    .container-{{ section_id }} { grid-template-columns: 1fr; gap: 40px; }
    .gallery-wrapper-{{ section_id }} { position: relative; top: 0; aspect-ratio: 1/1; margin-bottom: 40px; }
    .content-wrapper-{{ section_id }} { padding: 24px; }
    .form-row { grid-template-columns: 1fr; }
  }
{% endstyle %}

<section class="preorder-hero-{{ section_id }}" id="preorder-{{ section_id }}">
  <div class="container-{{ section_id }}">
    <div class="gallery-wrapper-{{ section_id }}">
      <div class="product-showcase-{{ section_id }}">
        {%- assign image_blocks = section.blocks | where: 'type', 'image_card' -%}
        {%- for block in image_blocks limit: 3 -%}
          <div class="showcase-card card-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | default: block.settings.alt_text | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
            {% else %}
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'showcase-card' }}
            {% endif %}
          </div>
        {%- endfor -%}
      </div>
      {% if image_blocks.size > 1 %}
        <div class="gallery-dots-{{ section_id }}">
          {% for block in image_blocks limit: 3 %}
            <div class="dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="content-wrapper-{{ section_id }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'image_card' -%}{%- comment -%} Handled in gallery {%- endcomment -%}
          {%- when 'heading' -%}<h1 class="hero-heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h1>
          {%- when 'subheading' -%}<p class="hero-subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
          {%- when 'testimonial' -%}<blockquote class="testimonial-block" {{ block.shopify_attributes }}><p>"{{ block.settings.quote | escape }}"</p><cite>- {{ block.settings.author | escape }}</cite></blockquote>
          {%- when 'countdown' -%}
            {% if section.settings.launch_date != blank %}
              <div class="countdown-wrapper" {{ block.shopify_attributes }} data-launch-date="{{ section.settings.launch_date | escape }}">
                <div class="countdown-item"><div class="countdown-number days">00</div><div class="countdown-label">Dana</div></div>
                <div class="countdown-item"><div class="countdown-number hours">00</div><div class="countdown-label">Sati</div></div>
                <div class="countdown-item"><div class="countdown-number minutes">00</div><div class="countdown-label">Minuta</div></div>
                <div class="countdown-item"><div class="countdown-number seconds">00</div><div class="countdown-label">Sekundi</div></div>
              </div>
            {% endif %}
          {%- when 'stock_counter' -%}
            <div class="stock-counter-wrapper" {{ block.shopify_attributes }}>
              <div class="stock-progress-bar">
                <div class="stock-progress-bar-inner" style="width: {{ stock_percentage_remaining }}%;"></div>
              </div>
              <p class="stock-text">{{ block.settings.text_before }} <strong>{{ current_stock }}</strong> {{ block.settings.text_middle }} {{ initial_stock }} {{ block.settings.text_after }}</p>
            </div>
          {%- when 'package_option_container' -%}
            <div class="packages-container-{{ section_id }}" {{ block.shopify_attributes }}>
              <h3 class="packages-label">{{ block.settings.title }}</h3>
              {%- assign package_blocks = section.blocks | where: 'type', 'package_option' -%}
              {%- for sub_block in package_blocks -%}
                {% assign savings = 0 %}
                {% if sub_block.settings.regular_price > 0 and sub_block.settings.price > 0 %}
                  {% assign savings = sub_block.settings.regular_price | minus: sub_block.settings.price %}
                {% endif %}
                <div class="package-option" data-quantity="{{ forloop.index }}" data-price="{{ sub_block.settings.price }}" data-text="{{ sub_block.settings.title }} - {{ sub_block.settings.price }} {{ section.settings.currency_symbol }}" data-savings-text="Čestitamo na uštedi od {{ savings }} {{ section.settings.currency_symbol }}!" {{ sub_block.shopify_attributes }}>
                  <div class="price-title">{{ sub_block.settings.title }}</div>
                  <div class="price">{{ sub_block.settings.price }} {{ section.settings.currency_symbol }}</div>
                  {% if savings > 0 %}<div class="savings">Uštedite {{ savings }} {{ section.settings.currency_symbol }}!</div>{% endif %}
                </div>
              {%- endfor -%}
            </div>
          {%- when 'form_fields' -%}
            <form id="preorder-form-{{ section_id }}" action="{{ section.settings.formspree_url }}" method="POST">
              <input type="hidden" name="Proizvod" value="{{ section.settings.product_name | escape }}">
              <input type="hidden" name="Odabrani Paket" id="selected-package-{{ section_id }}">
              <div class="price-reveal" id="price-reveal-{{ section_id }}"></div>
              <div class="form-fields-container" id="form-fields-container-{{ section_id }}">
                <div class="form-row" style="margin-top: 24px;">
                    <div class="form-field full-width">
                        <input type="text" name="Ime i prezime" class="form-input" placeholder=" " required>
                        <label class="form-label">Ime i prezime</label>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-field">
                        <input type="tel" name="Broj telefona" class="form-input" placeholder=" " required>
                        <label class="form-label">Broj telefona</label>
                    </div>
                    <div class="form-field">
                        <input type="email" name="Email" class="form-input" placeholder=" ">
                        <label class="form-label">Email (Opcionalno)</label>
                    </div>
                </div>
              </div>
              <div class="submit-button-wrapper" id="submit-wrapper-{{ section_id }}">
                  <button type="submit" class="submit-button" style="margin-top: 16px;">
                      <span class="button-text">{{ block.settings.button_label }}</span>
                  </button>
              </div>
              <div class="form-message" style="display: none; padding: 16px; margin-top: 16px; border-radius: 8px; text-align: center;"></div>
            </form>
          {%- when 'accordion_item' -%}
            <div class="accordion-item" {{ block.shopify_attributes }}><button type="button" class="accordion-trigger"><span>{{ block.settings.title }}</span><span class="accordion-icon"></span></button><div class="accordion-content"><div class="accordion-inner">{{ block.settings.content }}</div></div></div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
 document.addEventListener('DOMContentLoaded', function() {
   const section = document.getElementById('preorder-{{ section_id }}');
   if (!section) return;

   // --- Accordion Logic ---
   section.querySelectorAll('.accordion-item').forEach(item => {
     const trigger = item.querySelector('.accordion-trigger');
     if (trigger) {
       trigger.addEventListener('click', () => {
         const content = item.querySelector('.accordion-content');
         const isOpen = item.classList.toggle('active');
         content.style.maxHeight = isOpen ? content.scrollHeight + 'px' : null;
       });
     }
   });

   // --- Image Gallery Logic ---
    const showcase = section.querySelector('.product-showcase-{{ section_id }}');
    const dotsContainer = section.querySelector('.gallery-dots-{{ section_id }}');
    if (showcase && dotsContainer) {
        const cards = showcase.querySelectorAll('.showcase-card');
        const dots = dotsContainer.querySelectorAll('.dot');

        const showCard = (index) => {
            cards.forEach((card, i) => {
                card.classList.toggle('active', i === index);
            });
            dots.forEach((dot, i) => {
                dot.classList.toggle('active', i === index);
            });
        };

        dots.forEach(dot => {
            dot.addEventListener('click', () => {
                showCard(parseInt(dot.dataset.index));
            });
        });
    }


   // --- Countdown Timer Logic ---
   const countdownEl = section.querySelector('.countdown-wrapper');
   if (countdownEl && countdownEl.dataset.launchDate) {
     const launchDate = new Date(countdownEl.dataset.launchDate.replace(" ", "T")).getTime();
     if (!isNaN(launchDate)) {
       const interval = setInterval(() => {
         const now = new Date().getTime();
         const distance = launchDate - now;
         if (distance < 0) {
           clearInterval(interval);
           countdownEl.style.display = 'none';
           return;
         }
         const format = num => String(num).padStart(2, '0');
         countdownEl.querySelector('.days').innerText = format(Math.floor(distance / 86400000));
         countdownEl.querySelector('.hours').innerText = format(Math.floor((distance % 86400000) / 3600000));
         countdownEl.querySelector('.minutes').innerText = format(Math.floor((distance % 3600000) / 60000));
         countdownEl.querySelector('.seconds').innerText = format(Math.floor((distance % 60000) / 1000));
       }, 1000);
     }
   }

   // --- Form & Package Selection Logic ---
   const form = section.querySelector('#preorder-form-{{ section_id }}');
   const packageOptions = section.querySelectorAll('.package-option');
   if (form && packageOptions.length > 0) {
     const fieldsContainer = section.querySelector('#form-fields-container-{{ section_id }}');
     const priceReveal = section.querySelector('#price-reveal-{{ section_id }}');
     const selectedPackageInput = section.querySelector('#selected-package-{{ section_id }}');
     const submitWrapper = section.querySelector('#submit-wrapper-{{ section_id }}');

     packageOptions.forEach(option => {
       option.addEventListener('click', function() {
         packageOptions.forEach(opt => opt.classList.remove('active'));
         this.classList.add('active');
         selectedPackageInput.value = this.dataset.text;
         const price = this.dataset.price;
         const savingsText = this.dataset.savingsText;
         const quantity = this.dataset.quantity;

         let headingText = `Vaš paket za ${price} {{ section.settings.currency_symbol }} je odabran!`;
         if (quantity == '1') {
           headingText = `Odabrali ste 1 komad. Odaberite veći paket da uštedite!`;
         }
         priceReveal.innerHTML = `<div class="total-price-heading">${headingText}</div>`;
         if (savingsText && quantity > '1') {
           priceReveal.innerHTML += `<div class="savings-emphasis">${savingsText}</div>`;
         }

         priceReveal.style.display = 'block';
         fieldsContainer.classList.add('visible');
         if (submitWrapper) submitWrapper.classList.add('visible');
       });
     });

     form.addEventListener('submit', function(e) {
       e.preventDefault();
       const button = form.querySelector('.submit-button');
       const buttonText = button.querySelector('.button-text');
       const originalButtonText = buttonText.textContent.trim();
       const messageDiv = form.querySelector('.form-message');
       button.disabled = true;
       buttonText.textContent = 'Slanje...';

       fetch(form.action, {
         method: 'POST',
         body: new FormData(form),
         headers: { 'Accept': 'application/json' }
       })
       .then(response => {
         if (response.ok) {
           messageDiv.style.display = 'block';
           messageDiv.style.background = 'rgba(34, 197, 94, 0.1)';
           messageDiv.style.color = '#22c55e';
           messageDiv.textContent = '✅ Hvala! Vaša prednarudžba je primljena.';
           form.reset();
           priceReveal.style.display = 'none';
           fieldsContainer.classList.remove('visible');
           if (submitWrapper) submitWrapper.classList.remove('visible');
           packageOptions.forEach(opt => opt.classList.remove('active'));
         } else {
           throw new Error('Network response was not ok.');
         }
       })
       .catch(error => {
         messageDiv.style.display = 'block';
         messageDiv.style.background = 'rgba(239, 68, 68, 0.1)';
         messageDiv.style.color = '#ef4444';
         messageDiv.textContent = '❌ Greška. Molimo pokušajte ponovo.';
       })
       .finally(() => {
         button.disabled = false;
         buttonText.textContent = originalButtonText;
         setTimeout(() => {
            if (messageDiv) messageDiv.style.display = 'none';
         }, 5000);
       });
     });
   }
 });
</script>

{% schema %}
{
  "name": "Ultimate Pre-order Hero",
  "tag": "section",
  "class": "preorder-hero-section",
  "settings": [
    { "type": "header", "content": "📝 Form & Product Info" },
    { "type": "text", "id": "product_name", "label": "Product Name", "default": "Amaan Hair Mask" },
    {
      "type": "url",
      "id": "formspree_url",
      "label": "Formspree URL",
      "info": "Paste your Formspree URL here. E.g., https://formspree.io/f/mldlloqz"
    },
    { "type": "header", "content": "⏳ Urgency Settings" },
    { "type": "text", "id": "launch_date", "label": "Countdown End Date", "info": "Format: YYYY-MM-DD HH:MM:SS" },
    { "type": "number", "id": "initial_stock", "label": "Initial Stock Level", "default": 100 },
    { "type": "number", "id": "current_stock", "label": "Current Stock Level", "default": 87 },
    { "type": "header", "content": "🎨 Design Settings" },
    { "type": "color", "id": "bg_gradient_start", "label": "Background gradient start", "default": "#FFFFFF" },
    { "type": "color", "id": "bg_gradient_end", "label": "Background gradient end", "default": "#F0F4F8" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2f4f4f" },
    { "type": "color", "id": "button_gradient_start", "label": "Accent / Button gradient start", "default": "#4f7942" },
    { "type": "color", "id": "button_gradient_end", "label": "Button gradient end", "default": "#8fbc8f" },
    { "type": "font_picker", "id": "font_heading", "label": "Heading font", "default": "playfair_display_n7" },
    { "type": "text", "id": "currency_symbol", "label": "Currency Symbol", "default": "BAM" }
  ],
  "blocks": [
    { "type": "heading", "name": "📝 Heading", "limit": 1, "settings": [{ "type": "text", "id": "text", "label": "Heading", "default": "AMAAN STIŽE" }] },
    { "type": "subheading", "name": "📄 Subheading", "limit": 1, "settings": [{ "type": "text", "id": "text", "label": "Subheading", "default": "Nježno čišćenje uz aloe veru i ekstrakt krastavca." }] },
    { "type": "testimonial", "name": "💬 Testimonial", "limit": 1, "settings": [ { "type": "textarea", "id": "quote", "label": "Quote", "default": "Kosa mi je nevjerovatno lepršava i meka..." }, { "type": "text", "id": "author", "label": "Author", "default": "Nadia" } ] },
    { "type": "countdown", "name": "⏳ Countdown", "limit": 1 },
    {
      "type": "stock_counter",
      "name": "📊 Stock Counter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text_before", "label": "Text before number", "default": "Ostalo još samo"},
        { "type": "text", "id": "text_middle", "label": "Text between numbers", "default": "od"},
        { "type": "text", "id": "text_after", "label": "Text after number", "default": "– ograničena količina!" }
      ]
    },
