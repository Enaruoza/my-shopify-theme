    .asf-timeline-track { gap: 20px; }
    .asf-timeline-milestone { margin-left: 18px; padding-left: 28px; padding-top: 2px; padding-bottom: 12px;}
    .asf-timeline-marker { left: 0px; transform: translateX(-50%); top: -2px; padding: 2px 8px; line-height: 1.3;}
    .asf-timeline-content { font-size: {{ section.settings.font_body_text_size_mobile }}px; padding-top: 3px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('.argan-solution-finder[data-section-id="{{ section.id }}"]');
  if (!section) return;
  const views = Array.from(section.querySelectorAll('.asf-view'));
  const teaserView = section.querySelector('.asf-teaser-view');
  const mainHeaderDiv = section.querySelector('.asf-main-header');
  const mainContentDiv = section.querySelector('.asf-main-content');
  const startButton = section.querySelector('.asf-start-button');
  const animatedProblemTextEl = section.querySelector('.asf-animated-problem-text');
  const typewriterCursor = section.querySelector('.asf-typewriter-cursor');
  const progressBar = section.querySelector('.asf-progress-bar');
  const bodyPartItems = section.querySelectorAll('.asf-body-part-item');
  const problemItems = section.querySelectorAll('.asf-problem-item');
  const solutionCards = section.querySelectorAll('.asf-solution-card');
  const backButtons = section.querySelectorAll('.asf-back-button');
  const restartButton = section.querySelector('.asf-restart-button');
  const progressSteps = section.querySelectorAll('.asf-progress-step[data-step]');
  const contentWrapper = section.querySelector('.asf-content-wrapper');
  const step2TitleElement = section.querySelector('[data-js-step2-title]');
  const breadcrumbBodyPartEl = section.querySelector('.asf-breadcrumb-body-part');
  const breadcrumbProblemEl = section.querySelector('.asf-breadcrumb-problem');
  let currentInternalStep = 0;
  let selectedBodyPartId = null;
  let selectedBodyPartName = '';
  let selectedProblemId = null;
  let selectedProblemName = '';
  let resizeTimeout;
  let typewriterInterval;
  let currentProblemTextIndex = 0;
  const typingSpeed = 80;
  const eraseSpeed = 40;
  const pauseBetweenAnimations = 1800;
  let animatedProblemPhrases = getAnimatedProblems();
  const isMobile = () => window.innerWidth < 768;
  const viewHeights = {
    teaser: {
      mobile: parseFloat(section.style.getPropertyValue('--asf-teaser-min-height-mobile')) || 280,
      desktop: parseFloat(section.style.getPropertyValue('--asf-teaser-min-height-desktop')) || 320
    },
    step1: {
      mobile: parseFloat("{{ section.settings.step1_view_height_mobile | default: 0 }}") || 0,
      desktop: parseFloat("{{ section.settings.step1_view_height_desktop | default: 0 }}") || 0
    },
    step2: {
      mobile: parseFloat("{{ section.settings.step2_view_height_mobile | default: 0 }}") || 0,
      desktop: parseFloat("{{ section.settings.step2_view_height_desktop | default: 0 }}") || 0
    },
    step3: {
      mobile: parseFloat("{{ section.settings.step3_view_height_mobile | default: 0 }}") || 0,
      desktop: parseFloat("{{ section.settings.step3_view_height_desktop | default: 0 }}") || 0
    }
  };
  function applyTeaserHeight() {
    if (teaserView) {
      const height = isMobile() ? viewHeights.teaser.mobile : viewHeights.teaser.desktop;
      teaserView.style.minHeight = height + 'px';
    }
  }
  function getAnimatedProblems() {
    const locale = document.documentElement.lang || 'en';
    const problemsStringEn = {{ section.settings.teaser_animated_problems_en | escape | json }};
    const problemsStringBs = {{ section.settings.teaser_animated_problems_bs | escape | json }};
    const problemsString = locale.startsWith('bs') && problemsStringBs && problemsStringBs.length > 0 ? problemsStringBs : problemsStringEn;
    if (typeof problemsString === 'string') {
      return problemsString.split(',').map(s => s.trim()).filter(s => s.length > 0);
    }
    return [];
  }
  function typeWriter(text, el, charIndex, callback) {
    if (!el) return;
    if (charIndex < text.length) {
      el.textContent += text.charAt(charIndex);
      if(typewriterCursor) typewriterCursor.style.display = 'inline-block';
      typewriterInterval = setTimeout(() => typeWriter(text, el, charIndex + 1, callback), typingSpeed);
    } else {
      if(typewriterCursor) typewriterCursor.style.display = 'inline-block';
      typewriterInterval = setTimeout(callback, pauseBetweenAnimations);
    }
  }
  function eraseText(el, callback) {
    if (!el || !el.textContent) {
      if (callback) callback();
      return;
    }
    let text = el.textContent;
    if (text.length > 0) {
      if(typewriterCursor) typewriterCursor.style.display = 'inline-block';
      el.textContent = text.substring(0, text.length - 1);
      typewriterInterval = setTimeout(() => eraseText(el, callback), eraseSpeed);
    } else {
      if(typewriterCursor) typewriterCursor.style.display = 'inline-block';
      if (callback) callback();
    }
  }
  function cycleProblemText() {
    clearTimeout(typewriterInterval);
    if (!animatedProblemPhrases || animatedProblemPhrases.length === 0 || !animatedProblemTextEl) {
        if(animatedProblemTextEl) animatedProblemTextEl.textContent = '...';
        if(typewriterCursor) typewriterCursor.style.display = 'none';
        return;
    }
    eraseText(animatedProblemTextEl, () => {
      currentProblemTextIndex = (currentProblemTextIndex + 1) % animatedProblemPhrases.length;
      animatedProblemTextEl.textContent = '';
      typeWriter(animatedProblemPhrases[currentProblemTextIndex], animatedProblemTextEl, 0, cycleProblemText);
    });
  }
  function startTeaserAnimation() {
    if (!animatedProblemTextEl) return;
    animatedProblemPhrases = getAnimatedProblems();
    stopTeaserAnimation();
    currentProblemTextIndex = 0;
    if (animatedProblemPhrases && animatedProblemPhrases.length > 0) {
      animatedProblemTextEl.textContent = '';
      typeWriter(animatedProblemPhrases[currentProblemTextIndex], animatedProblemTextEl, 0, cycleProblemText);
    } else {
        const fallbackText = (document.documentElement.lang || 'en').startsWith('bs') ? 'vaše brige' : 'your concerns';
        animatedProblemTextEl.textContent = fallbackText;
        if(typewriterCursor) typewriterCursor.style.display = 'none';
    }
  }
  function stopTeaserAnimation() {
    clearTimeout(typewriterInterval);
  }
  function getViewHeightSetting(step) {
    const mode = isMobile() ? 'mobile' : 'desktop';
    switch(step) {
      case 0: return viewHeights.teaser[mode];
      case 1: return viewHeights.step1[mode];
      case 2: return viewHeights.step2[mode];
      case 3: return viewHeights.step3[mode];
      default: return 0;
    }
  }
  function updateView(targetDisplayStep) {
    let targetView = views.find(v => parseInt(v.dataset.viewStep) === targetDisplayStep);
    views.forEach(view => {
        if (view.classList.contains('active') && view !== targetView) {
            view.classList.add('leaving');
            view.classList.remove('active');
        }
    });
    setTimeout(() => {
      let newHeight = 0;
      const customHeightSetting = getViewHeightSetting(targetDisplayStep);
      if (mainHeaderDiv) {
          mainHeaderDiv.style.display = (targetDisplayStep > 0) ? 'block' : 'none';
      }
      if (progressBar) {
          progressBar.classList.toggle('hidden', targetDisplayStep === 0);
      }
      if (targetDisplayStep === 0) {
          startTeaserAnimation();
      } else {
          stopTeaserAnimation();
      }
      if (targetView && contentWrapper) {
          targetView.classList.add('asf-measure-me');
          let tempVisibleItemsToRevertStyle = [];
          if (customHeightSetting === 0) {
              if (targetDisplayStep === 2 && selectedBodyPartId) {
                  problemItems.forEach(probItem => {
                      if (probItem.dataset.parentBodyPartId === selectedBodyPartId) {
                          probItem.style.display = 'block';
                          tempVisibleItemsToRevertStyle.push(probItem);
                      }
                  });
              } else if (targetDisplayStep === 3 && selectedProblemId && selectedBodyPartId) {
                  const card = Array.from(solutionCards).find(c => c.dataset.solutionForProblemId === selectedProblemId && c.dataset.solutionForBodyPartId === selectedBodyPartId);
                  if (card) {
                      card.style.display = 'block';
                      tempVisibleItemsToRevertStyle.push(card);
                  }
              }
              void targetView.offsetHeight;
              newHeight = targetView.scrollHeight;
              tempVisibleItemsToRevertStyle.forEach(item => item.style.display = '');
          } else {
              newHeight = customHeightSetting;
          }
          targetView.classList.remove('asf-measure-me');
          if (newHeight < 50 && !(customHeightSetting > 0 && customHeightSetting < 50)) {
              newHeight = 200;
          }
          contentWrapper.style.height = `${newHeight}px`;
      }
      setTimeout(() => {
          views.forEach(view => {
              if (view === targetView) {
                  view.classList.remove('leaving');
                  view.classList.add('active');
              } else if (!view.classList.contains('leaving')) {
                  view.classList.remove('active');
              }
          });
          const transitionDuration = parseFloat(getComputedStyle(section).getPropertyValue('--asf-transition-speed').replace('s', '')) * 1000;
          setTimeout(() => {
              views.forEach(v => v.classList.remove('leaving'));
          }, transitionDuration + 50);
      }, 50);
      currentInternalStep = targetDisplayStep;
      if (targetDisplayStep > 0) {
          updateProgress(targetDisplayStep);
      }
      const headerElement = document.querySelector('.shopify-section-header') || document.querySelector('header.site-header');
      const headerOffset = headerElement ? headerElement.offsetHeight : 60;
      let targetScrollPos = section.offsetTop - headerOffset - 20;
      const sectionRect = section.getBoundingClientRect();
      if (targetDisplayStep > 0 && (sectionRect.top < headerOffset || sectionRect.bottom > window.innerHeight * 0.9)) {
          window.scrollTo({ top: targetScrollPos, behavior: 'smooth' });
      }
    }, 20);
  }
  function updateProgress(displayStep) {
    progressSteps.forEach(stepEl => {
      const stepNum = parseInt(stepEl.dataset.step);
      stepEl.classList.remove('active', 'completed');
      if (stepNum < displayStep) {
        stepEl.classList.add('completed');
      } else if (stepNum === displayStep) {
        stepEl.classList.add('active');
      }
    });
    const progressConnectors = section.querySelectorAll('.asf-progress-connector');
    progressConnectors.forEach((connector, index) => {
      connector.classList.toggle('active', index < displayStep - 1);
    });
  }
  function updateStep2Title(bodyPartName) {
    if (!step2TitleElement) return;
    const locale = document.documentElement.lang || 'en';
    const templateEn = {{ section.settings.step2_title_template_en | json }};
    const templateBs = {{ section.settings.step2_title_template_bs | json }};
    let template = locale.startsWith('bs') && templateBs ? templateBs : templateEn;
    template = template.replace('__BODY_PART_NAME_PLACEHOLDER__', `<span class="asf-selected-body-part-placeholder">${bodyPartName}</span>`);
    step2TitleElement.innerHTML = template;
  }
  if(startButton) {
    startButton.addEventListener('click', () => {
      updateView(1);
    });
  }
  bodyPartItems.forEach(item => {
    const clickOrEnterHandler = () => {
      selectedBodyPartId = item.dataset.bodyPartId;
      selectedBodyPartName = item.querySelector('.asf-body-part-name').textContent.trim();
      updateStep2Title(selectedBodyPartName);
      if (breadcrumbBodyPartEl) breadcrumbBodyPartEl.textContent = selectedBodyPartName;
      problemItems.forEach(probItem => probItem.classList.remove('visible'));
      updateView(2);
      setTimeout(() => {
        let visibleItemCount = 0;
        problemItems.forEach(probItem => {
            if (probItem.dataset.parentBodyPartId === selectedBodyPartId) {
                setTimeout(() => probItem.classList.add('visible'), visibleItemCount * 50);
                visibleItemCount++;
            }
        });
      }, parseFloat(getComputedStyle(section).getPropertyValue('--asf-transition-speed').replace('s',''))*1000 * 0.2 + 100);
    };
    item.addEventListener('click', clickOrEnterHandler);
    item.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); clickOrEnterHandler(); }});
  });
  problemItems.forEach(item => {
    const clickOrEnterHandler = () => {
      selectedProblemId = item.dataset.problemId;
      selectedProblemName = item.querySelector('.asf-problem-name').textContent.trim();
      if (breadcrumbProblemEl) breadcrumbProblemEl.textContent = selectedProblemName;
      solutionCards.forEach(card => card.classList.remove('active'));
      updateView(3);
      setTimeout(() => {
        const cardToActivate = Array.from(solutionCards).find(card =>
            card.dataset.solutionForProblemId === selectedProblemId &&
            card.dataset.solutionForBodyPartId === selectedBodyPartId
        );
        if (cardToActivate) {
            cardToActivate.classList.add('active');
            const droplets = cardToActivate.querySelectorAll('.asf-droplet');
            droplets.forEach(d => {
                d.style.animation = 'none';
                d.offsetHeight;
                d.style.animation = '';
            });
        }
      }, parseFloat(getComputedStyle(section).getPropertyValue('--asf-transition-speed').replace('s',''))*1000 * 0.2 + 100);
    };
    item.addEventListener('click', clickOrEnterHandler);
    item.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); clickOrEnterHandler(); }});
  });
  backButtons.forEach(button => {
    button.addEventListener('click', () => {
      const targetViewStep = parseInt(button.dataset.targetStep);
      updateView(targetViewStep);
    });
  });
  if (restartButton) {
    restartButton.addEventListener('click', () => {
      updateView(0);
    });
  }
  function initialize() {
    applyTeaserHeight();
    updateView(0);
  }
  initialize();
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      applyTeaserHeight();
      const activeViewInstance = views.find(v => v.classList.contains('active') && !v.classList.contains('leaving'));
      const currentStep = activeViewInstance ? parseInt(activeViewInstance.dataset.viewStep) : 0;
      if (currentStep === 0 && contentWrapper && teaserView) {
          const teaserMinHeight = parseFloat(getComputedStyle(teaserView).minHeight);
          contentWrapper.style.height = `${teaserMinHeight}px`;
      } else if (currentStep !== 0 && contentWrapper && activeViewInstance) {
          const customHeight = getViewHeightSetting(currentStep);
          let newHeight = 0;
          const originalTransition = contentWrapper.style.transition;
          contentWrapper.style.transition = 'none';
          activeViewInstance.classList.add('asf-measure-me');
          let tempVisibleItems = [];
          if (customHeight === 0) {
              if (currentStep === 2 && selectedBodyPartId) {
                  problemItems.forEach(probItem => {
                      if (probItem.dataset.parentBodyPartId === selectedBodyPartId) {
                          probItem.style.display = 'block';
                          tempVisibleItems.push(probItem);
                      }
                  });
              } else if (currentStep === 3 && selectedProblemId && selectedBodyPartId) {
                  const card = Array.from(solutionCards).find(c => c.dataset.solutionForProblemId === selectedProblemId && c.dataset.solutionForBodyPartId === selectedBodyPartId);
                  if (card) {
                      card.style.display = 'block';
                      tempVisibleItems.push(card);
                  }
              }
              void activeViewInstance.offsetHeight;
              newHeight = activeViewInstance.scrollHeight;
              tempVisibleItems.forEach(item => item.style.display = '');
              if (newHeight < 50 && !(customHeight > 0 && customHeight < 50)) newHeight = 200;
          } else {
              newHeight = customHeight;
          }
          activeViewInstance.classList.remove('asf-measure-me');
          contentWrapper.style.height = `${newHeight}px`;
          requestAnimationFrame(() => {
              contentWrapper.style.transition = originalTransition || `height ${getComputedStyle(section).getPropertyValue('--asf-transition-speed')} cubic-bezier(0.645, 0.045, 0.355, 1)`;
          });
      }
    }, 150);
  });
  document.addEventListener('shopify:section:load', function(event) {
    if (event.target.matches('.argan-solution-finder[data-section-id="{{ section.id }}"]')) {
      animatedProblemPhrases = getAnimatedProblems();
      applyTeaserHeight();
      const activeViewInstance = views.find(v => v.classList.contains('active'));
      if (activeViewInstance) {
        const currentStep = parseInt(activeViewInstance.dataset.viewStep);
        const customHeight = getViewHeightSetting(currentStep);
        let newHeight = 0;
        if (customHeight > 0) {
            newHeight = customHeight;
        } else {
            activeViewInstance.classList.add('asf-measure-me');
            let tempVisibleItems = [];
            if (currentStep === 2 && selectedBodyPartId) {
                 problemItems.forEach(probItem => { if (probItem.dataset.parentBodyPartId === selectedBodyPartId) { probItem.style.display = 'block'; tempVisibleItems.push(probItem); }});
            } else if (currentStep === 3 && selectedProblemId && selectedBodyPartId) {
                 const card = Array.from(solutionCards).find(c => c.dataset.solutionForProblemId === selectedProblemId && c.dataset.solutionForBodyPartId === selectedBodyPartId);
                 if (card) { card.style.display = 'block'; tempVisibleItems.push(card); }
            }
            newHeight = activeViewInstance.scrollHeight;
            tempVisibleItems.forEach(item => item.style.display = '');
            activeViewInstance.classList.remove('asf-measure-me');
            if (newHeight < 50 && currentStep !==0 && !(customHeight > 0 && customHeight < 50)) newHeight = 200;
        }
        if (currentStep === 0 && teaserView) {
            contentWrapper.style.height = getComputedStyle(teaserView).minHeight;
              if (!teaserView.classList.contains('active')) {
                initialize();
              } else {
                startTeaserAnimation();
              }
        } else if (newHeight > 0) {
            contentWrapper.style.height = `${newHeight}px`;
        } else if (!activeViewInstance.classList.contains('active')) {
            initialize();
        }
      } else {
        initialize();
      }
    }
  });
  document.addEventListener('shopify:section:unload', function(event) {
    if (event.target.matches('.argan-solution-finder[data-section-id="{{ section.id }}"]')) {
      stopTeaserAnimation();
      clearTimeout(resizeTimeout);
    }
  });
});
</script>
