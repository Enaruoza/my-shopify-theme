{% schema %}
{
  "name": "Argan Benefit Explorer",
  "class": "argan-solution-finder-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width_background",
      "label": "Use Full Width Background",
      "default": true,
      "info": "If checked, the section background spans the entire width. Content inside will still be limited by 'Content Max Width'."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content Max Width (px)",
      "min": 600,
      "max": 1600,
      "step": 50,
      "default": 1200,
      "unit": "px",
      "info": "Maximum width for the content area within the section."
    },
    {
      "type": "header",
      "content": "Teaser Step (Step 0)"
    },
    {
      "type": "text",
      "id": "teaser_line1_en",
      "label": "Teaser Line 1 (English)",
      "default": "Find a solution to your"
    },
    {
      "type": "text",
      "id": "teaser_line1_bs",
      "label": "Teaser Line 1 (Bosnian)",
      "default": "Pronađi rješenje za svoje"
    },
    {
      "type": "textarea",
      "id": "teaser_animated_problems_en",
      "label": "Animated Problems (English, comma-separated)",
      "default": "dry skin, frizzy hair, brittle nails, signs of aging, dull complexion"
    },
    {
      "type": "textarea",
      "id": "teaser_animated_problems_bs",
      "label": "Animated Problems (Bosnian, comma-separated)",
      "default": "suhu kožu, neposlušnu kosu, lomljive nokte, znakove starenja, beživotan ten"
    },
    {
      "type": "font_picker",
      "id": "font_teaser_animated",
      "label": "Teaser Animated Text Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "font_teaser_animated_size_desktop",
      "label": "Teaser Animated Text Size (Desktop)",
      "min": 16, "max": 60, "step": 1, "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "font_teaser_animated_size_mobile",
      "label": "Teaser Animated Text Size (Mobile)",
      "min": 14, "max": 40, "step": 1, "unit": "px",
      "default": 22
    },
    {
      "type": "text",
      "id": "teaser_button_en",
      "label": "Teaser Start Button (English)",
      "default": "Discover Your Solution"
    },
    {
      "type": "text",
      "id": "teaser_button_bs",
      "label": "Teaser Start Button (Bosnian)",
      "default": "Otkrij Svoje Rješenje"
    },
    {
      "type": "header",
      "content": "Main Section Titles & Subtitles"
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Main Title (English)",
      "default": "Find Your Argan Oil Solution"
    },
    {
      "type": "text",
      "id": "title_bs",
      "label": "Main Title (Bosnian)",
      "default": "Pronađi Svoje Arganovo Rješenje"
    },
    {
      "type": "font_picker",
      "id": "font_title",
      "label": "Main Title Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "font_title_size_desktop",
      "label": "Main Title Size (Desktop)",
      "min": 20, "max": 72, "step": 1, "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "font_title_size_mobile",
      "label": "Main Title Size (Mobile)",
      "min": 18, "max": 48, "step": 1, "unit": "px",
      "default": 28
    },
    {
      "type": "text",
      "id": "subtitle_en",
      "label": "Main Subtitle (English)",
      "default": "Select a concern, identify your specific issue, and discover how our pure argan oil can help."
    },
    {
      "type": "text",
      "id": "subtitle_bs",
      "label": "Main Subtitle (Bosnian)",
      "default": "Odaberite područje, identificirajte svoj specifični problem i otkrijte kako naše čisto arganovo ulje može pomoći."
    },
    {
      "type": "font_picker",
      "id": "font_subtitle",
      "label": "Main Subtitle Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "font_subtitle_size_desktop",
      "label": "Main Subtitle Size (Desktop)",
      "min": 12, "max": 32, "step": 1, "unit": "px",
      "default": 19
    },
    {
      "type": "range",
      "id": "font_subtitle_size_mobile",
      "label": "Main Subtitle Size (Mobile)",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Step Specific Text Customization"
    },
    {
      "type": "text",
      "id": "step2_title_template_en",
      "label": "Step 2 Title Template (EN)",
      "default": "__BODY_PART_NAME_PLACEHOLDER__: What's Your Concern?",
      "info": "Use __BODY_PART_NAME_PLACEHOLDER__ as a placeholder for the selected body part."
    },
    {
      "type": "text",
      "id": "step2_title_template_bs",
      "label": "Step 2 Title Template (BS)",
      "default": "__BODY_PART_NAME_PLACEHOLDER__: Koji je Vaš problem?",
      "info": "Use __BODY_PART_NAME_PLACEHOLDER__ as a placeholder for the selected body part."
    },
    {
      "type": "text",
      "id": "solution_card_title_prefix_en",
      "label": "Solution Card Title Prefix (EN)",
      "default": "Solution for: "
    },
    {
      "type": "text",
      "id": "solution_card_title_prefix_bs",
      "label": "Solution Card Title Prefix (BS)",
      "default": "Rješenje za: "
    },
    {
      "type": "text",
      "id": "breadcrumb_separator",
      "label": "Breadcrumb Separator",
      "default": " &rsaquo; "
    },
    {
      "type": "header",
      "content": "View Height Customization"
    },
    {
      "type": "number",
      "id": "teaser_view_min_height_mobile",
      "label": "Teaser View Min Height (Mobile)",
      "default": 280,
      "info": "Set in pixels. 0 for auto default (280px)."
    },
    {
      "type": "number",
      "id": "teaser_view_min_height_desktop",
      "label": "Teaser View Min Height (Desktop)",
      "default": 320,
      "info": "Set in pixels. 0 for auto default (320px)."
    },
    {
      "type": "number",
      "id": "step1_view_height_mobile",
      "label": "Body Parts View Height (Mobile)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "number",
      "id": "step1_view_height_desktop",
      "label": "Body Parts View Height (Desktop)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "number",
      "id": "step2_view_height_mobile",
      "label": "Problems View Height (Mobile)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "number",
      "id": "step2_view_height_desktop",
      "label": "Problems View Height (Desktop)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "number",
      "id": "step3_view_height_mobile",
      "label": "Solution View Height (Mobile)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "number",
      "id": "step3_view_height_desktop",
      "label": "Solution View Height (Desktop)",
      "default": 0,
      "info": "Set fixed height in pixels. 0 for auto (content height)."
    },
    {
      "type": "header",
      "content": "Item & Content Typography"
    },
    {
      "type": "font_picker",
      "id": "font_item_names",
      "label": "Body Part/Problem Name Font",
      "default": "helvetica_n7"
    },
    {
      "type": "range",
      "id": "font_item_name_size_desktop",
      "label": "Item Name Size (Desktop)",
      "min": 12, "max": 32, "step": 1, "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "font_item_name_size_mobile",
      "label": "Item Name Size (Mobile)",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "default": 15
    },
    {
      "type": "font_picker",
      "id": "font_body_text",
      "label": "General Content Text Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "font_body_text_size_desktop",
      "label": "Content Text Size (Desktop)",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "font_body_text_size_mobile",
      "label": "Content Text Size (Mobile)",
      "min": 9, "max": 20, "step": 1, "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Progress Bar Typography"
    },
    {
      "type": "range",
      "id": "progress_marker_size",
      "label": "Progress Marker (Number Circle) Size",
      "min": 20, "max": 50, "step": 1, "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "progress_marker_font_size",
      "label": "Progress Marker Number Font Size",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "default": 16
    },
    {
      "type": "font_picker",
      "id": "font_progress_label",
      "label": "Progress Label Font",
      "default": "helvetica_n4"
    },
    {
      "type": "range",
      "id": "progress_label_font_size",
      "label": "Progress Label Font Size",
      "min": 8, "max": 16, "step": 1, "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout, Colors & Links"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Body Part Layout Style (Desktop)",
      "options": [
        { "value": "horizontal", "label": "Horizontal Scroll" },
        { "value": "grid", "label": "Grid View" }
      ],
      "default": "grid"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#E9B44C"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary Color",
      "default": "#726E60"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#9CB380"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFBF2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product Handle for CTA",
      "default": "argan-oil",
      "info": "Fallback if the URL link below is empty. Enter the handle of your product (e.g., 'pure-argan-oil')."
    },
    {
      "type": "url",
      "id": "final_cta_url",
      "label": "Final CTA Button Link",
      "info": "Links the final 'Shop Solution' button. Overrides the Product Handle setting if filled."
    }
  ],
  "blocks": [
    {
      "type": "body_part",
      "name": "Body Part",
      "settings": [
        {
          "type": "text",
          "id": "name_en",
          "label": "Name (English)",
          "default": "Face"
        },
        {
          "type": "text",
          "id": "name_bs",
          "label": "Name (Bosnian)",
          "default": "Lice"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image (50x50px recommended)"
        },
        {
          "type": "select",
          "id": "default_icon_svg",
          "label": "Default Icon (if no image)",
          "options": [
            { "value": "face", "label": "Face Icon" },
            { "value": "hair", "label": "Hair Icon" },
            { "value": "body", "label": "Body Icon" },
            { "value": "nails", "label": "Nails Icon" },
            { "value": "beard", "label": "Beard Icon" },
            { "value": "scalp", "label": "Scalp Icon" },
            { "value": "mothers_kids", "label": "Mothers & Kids Icon (Heart)" },
            { "value": "generic", "label": "Generic Icon (Circle)" }
          ],
          "default": "face"
        }
      ]
    },
    {
      "type": "problem",
      "name": "Problem",
      "settings": [
        {
          "type": "text",
          "id": "name_en",
          "label": "Problem Name (English)"
        },
        {
          "type": "text",
          "id": "name_bs",
          "label": "Problem Name (Bosnian)"
        },
        {
          "type": "textarea",
          "id": "description_en",
          "label": "Problem Description (English)"
        },
        {
          "type": "textarea",
          "id": "description_bs",
          "label": "Problem Description (Bosnian)"
        },
        {
          "type": "richtext",
          "id": "solution_en",
          "label": "Solution (English)"
        },
        {
          "type": "richtext",
          "id": "solution_bs",
          "label": "Solution (Bosnian)"
        },
        {
          "type": "richtext",
          "id": "usage_en",
          "label": "How to Use (English)"
        },
        {
          "type": "richtext",
          "id": "usage_bs",
          "label": "How to Use (Bosnian)"
        },
        {
          "type": "header",
          "content": "Benefit Timeline Estimates"
        },
        {
          "type": "richtext",
          "id": "timeline_7_day_en",
          "label": "7-Day Benefit (English)",
          "default": "<p>Initial improvements in hydration or comfort.</p>"
        },
        {
          "type": "richtext",
          "id": "timeline_7_day_bs",
          "label": "7-Day Benefit (Bosnian)",
          "default": "<p>Početna poboljšanja u hidrataciji ili udobnosti.</p>"
        },
        {
          "type": "richtext",
          "id": "timeline_14_day_en",
          "label": "14-Day Benefit (English)",
          "default": "<p>More noticeable changes in texture or appearance.</p>"
        },
        {
          "type": "richtext",
          "id": "timeline_14_day_bs",
          "label": "14-Day Benefit (Bosnian)",
          "default": "<p>Primjetnije promjene u teksturi ili izgledu.</p>"
        },
        {
          "type": "richtext",
          "id": "timeline_30_day_en",
          "label": "30-Day Benefit (English)",
          "default": "<p>Significant, sustained improvements with consistent use.</p>"
        },
        {
          "type": "richtext",
          "id": "timeline_30_day_bs",
          "label": "30-Day Benefit (Bosnian)",
          "default": "<p>Značajna, održiva poboljšanja uz dosljednu upotrebu.</p>"
        },
        {
          "type": "textarea",
          "id": "testimonial_en",
          "label": "Testimonial (English)"
        },
        {
          "type": "textarea",
          "id": "testimonial_bs",
          "label": "Testimonial (Bosnian)"
        },
        {
          "type": "text",
          "id": "testimonial_author",
          "label": "Testimonial Author"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Argan Benefit Explorer",
      "category": "Custom Content",
      "blocks": [
        { "type": "body_part", "settings": { "name_en": "FACE", "name_bs": "Lice", "default_icon_svg": "face" }},
        {
          "type": "problem",
          "settings": {
            "name_en": "Dry, Dehydrated Skin",
            "name_bs": "Suha, Dehidrirana Koža"
          }
        },
        {
          "type": "problem",
          "settings": {
            "name_en": "Oily & Acne-Prone Skin",
            "name_bs": "Masna Koža Sklona Aknama"
          }
        },
        { "type": "body_part", "settings": { "name_en": "BODY", "name_bs": "Tijelo", "default_icon_svg": "body" }},
        {
          "type": "problem",
          "settings": {
            "name_en": "Overall Body Dryness",
            "name_bs": "Opšta Suhoća Kože Tijela"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div
  class="argan-solution-finder"
  data-section-id="{{ section.id }}"
  data-layout="{{ section.settings.layout_style }}"
  style="
    --asf-primary-color: {{ section.settings.primary_color }};
    --asf-secondary-color: {{ section.settings.secondary_color }};
    --asf-accent-color: {{ section.settings.accent_color }};
    --asf-bg-color: {{ section.settings.bg_color }};
    --asf-text-color: {{ section.settings.text_color }};
    --asf-light-color: #FFFFFF;
    --asf-shadow-color: rgba(0, 0, 0, 0.1);
    --asf-transition-speed: 0.45s;
    --asf-border-radius: 12px;
    --asf-font-title-family: {{ section.settings.font_title.family }}{% if section.settings.font_title.fallback_families != blank %}, {{ section.settings.font_title.fallback_families }}{% endif %};
    --asf-font-title-weight: {{ section.settings.font_title.weight }};
    --asf-font-title-style: {{ section.settings.font_title.style }};
    --asf-font-teaser-animated-family: {{ section.settings.font_teaser_animated.family }}{% if section.settings.font_teaser_animated.fallback_families != blank %}, {{ section.settings.font_teaser_animated.fallback_families }}{% endif %};
    --asf-font-teaser-animated-weight: {{ section.settings.font_teaser_animated.weight }};
    --asf-font-teaser-animated-style: {{ section.settings.font_teaser_animated.style }};
    --asf-font-subtitle-family: {{ section.settings.font_subtitle.family }}{% if section.settings.font_subtitle.fallback_families != blank %}, {{ section.settings.font_subtitle.fallback_families }}{% endif %};
    --asf-font-subtitle-weight: {{ section.settings.font_subtitle.weight }};
    --asf-font-subtitle-style: {{ section.settings.font_subtitle.style }};
    --asf-font-item-names-family: {{ section.settings.font_item_names.family }}{% if section.settings.font_item_names.fallback_families != blank %}, {{ section.settings.font_item_names.fallback_families }}{% endif %};
    --asf-font-item-names-weight: {{ section.settings.font_item_names.weight }};
    --asf-font-item-names-style: {{ section.settings.font_item_names.style }};
    --asf-font-body-text-family: {{ section.settings.font_body_text.family }}{% if section.settings.font_body_text.fallback_families != blank %}, {{ section.settings.font_body_text.fallback_families }}{% endif %};
    --asf-font-body-text-weight: {{ section.settings.font_body_text.weight }};
    --asf-font-body-text-style: {{ section.settings.font_body_text.style }};
    --asf-font-progress-label-family: {{ section.settings.font_progress_label.family }}{% if section.settings.font_progress_label.fallback_families != blank %}, {{ section.settings.font_progress_label.fallback_families }}{% endif %};
    --asf-font-progress-label-weight: {{ section.settings.font_progress_label.weight }};
    --asf-font-progress-label-style: {{ section.settings.font_progress_label.style }};
    --asf-teaser-min-height-mobile: {{ section.settings.teaser_view_min_height_mobile | default: 280 }}px;
    --asf-teaser-min-height-desktop: {{ section.settings.teaser_view_min_height_desktop | default: 320 }}px;
    --asf-content-max-width: {{ section.settings.content_max_width | default: 1200 }}px;
  "
>
  <div class="asf-inner-content-limiter">
    <div class="asf-main-header" style="display: none;">
      <div class="asf-header">
        <h2 class="asf-title">
          {%- if request.locale.iso_code == 'bs' -%}
            {{- section.settings.title_bs -}}
          {%- else -%}
            {{- section.settings.title_en -}}
          {%- endif -%}
        </h2>
        <p class="asf-subtitle">
          {%- if request.locale.iso_code == 'bs' -%}
            {{- section.settings.subtitle_bs -}}
          {%- else -%}
            {{- section.settings.subtitle_en -}}
          {%- endif -%}
        </p>
      </div>
      <div class="asf-progress-bar hidden">
        <div class="asf-progress-step" data-step="1">
          <div class="asf-progress-marker">1</div>
          <div class="asf-progress-label">
            {%- if request.locale.iso_code == 'bs' -%}Područje{%- else -%}Body Part{%- endif -%}
          </div>
        </div>
        <div class="asf-progress-connector"></div>
        <div class="asf-progress-step" data-step="2">
          <div class="asf-progress-marker">2</div>
          <div class="asf-progress-label">
            {%- if request.locale.iso_code == 'bs' -%}Problem{%- else -%}Issue{%- endif -%}
          </div>
        </div>
        <div class="asf-progress-connector"></div>
        <div class="asf-progress-step" data-step="3">
          <div class="asf-progress-marker">3</div>
          <div class="asf-progress-label">
            {%- if request.locale.iso_code == 'bs' -%}Rješenje{%- else -%}Solution{%- endif -%}
          </div>
        </div>
      </div>
    </div>

    <div class="asf-content-wrapper">
      <div class="asf-view asf-teaser-view" data-view-step="0">
        <div class="asf-teaser-content">
          <h2 class="asf-teaser-title">
            <span class="asf-teaser-line-1">
              {%- if request.locale.iso_code == 'bs' -%}
                {{- section.settings.teaser_line1_bs -}}
              {%- else -%}
                {{- section.settings.teaser_line1_en -}}
              {%- endif -%}
            </span>
            <span class="asf-animated-problem-text-container">
              <span class="asf-animated-problem-text"></span><span class="asf-typewriter-cursor"></span>
            </span>
          </h2>
          <button type="button" class="asf-button asf-start-button">
            {%- if request.locale.iso_code == 'bs' -%}
              {{- section.settings.teaser_button_bs -}}
            {%- else -%}
              {{- section.settings.teaser_button_en -}}
            {%- endif -%}
          </button>
        </div>
      </div>

      <div class="asf-main-content">
        <div class="asf-view asf-body-parts-view" data-view-step="1">
          <div class="asf-body-parts-container asf-layout-{{ section.settings.layout_style }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'body_part' -%}
                <div class="asf-body-part-item" data-body-part-id="{{ block.id }}" tabindex="0">
                  <div class="asf-body-part-icon">
                    {%- if block.settings.icon != blank -%}
                      <img
                        src="{{ block.settings.icon | image_url: width: 100, height: 100 }}"
                        alt="{%- if request.locale.iso_code == 'bs' and block.settings.name_bs != blank -%}{{- block.settings.name_bs | escape -}}{%- else -%}{{- block.settings.name_en | escape -}}{%- endif -%}"
                        loading="lazy"
                        width="50"
                        height="50"
                      >
                    {%- else -%}
                      {%- assign icon_svg = block.settings.default_icon_svg -%}
                      {%- case icon_svg -%}
                        {%- when 'face' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line>
                          </svg>
                        {%- when 'hair' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <path d="M18 11C18 7 15.5 4 12 4C8.5 4 6 7 6 11C6 14.5 7.5 17 10 18.5V20H14V18.5C16.5 17 18 14.5 18 11Z" /><line x1="12" y1="18.5" x2="12" y2="7"/><line x1="9.5" y1="17" x2="9.5" y2="9"/><line x1="14.5" y1="17" x2="14.5" y2="9"/>
                          </svg>
                        {%- when 'body' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="6.5" r="2.5" /><path d="M17 10H7C5.895 10 5 10.895 5 12.25V17C5 19.209 6.791 21 9 21H15C17.209 21 19 19.209 19 17V12.25C19 10.895 18.105 10 17 10Z" />
                          </svg>
                        {%- when 'nails' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <path d="M6 14.5c0 2 2 3.5 4 3.5s4-1.5 4-3.5V5.5C14 3.5 12 2 10 2S6 3.5 6 5.5v9z"></path><path d="M18 14.5c0 2-2 3.5-4 3.5s-4-1.5-4-3.5V10"></path>
                          </svg>
                        {%- when 'beard' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <path d="M8 5h8"></path><path d="M8 10h8"></path><path d="M12 2v3"></path><path d="M8 14c0 4 3.5 6 4 6 .5 0 4-2 4-6v-4H8v4z"></path>
                          </svg>
                        {%- when 'scalp' -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="8.5" /><circle cx="13.2" cy="13.2" r="2.8" />
                          </svg>
                        {%- when 'mothers_kids' -%}
                          <svg
                            viewBox="0 0 24 24"
                            width="100%"
                            height="100%"
                            aria-hidden="true"
                            focusable="false"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1.5"
                            fill="none"
                            stroke="currentColor"
                          >
                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                          </svg>
                        {%- else -%}
                          <svg viewBox="0 0 24 24" width="100%" height="100%" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="10"></circle>
                          </svg>
                      {%- endcase -%}
                    {%- endif -%}
                  </div>
                  <div class="asf-body-part-name">
                    {%- if request.locale.iso_code == 'bs' and block.settings.name_bs != blank -%}
                      {{- block.settings.name_bs -}}
                    {%- else -%}
                      {{- block.settings.name_en -}}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="asf-view asf-problems-view" data-view-step="2">
          <button
            type="button"
            class="asf-back-button"
            data-target-step="1"
            aria-label="{%- if request.locale.iso_code == 'bs' -%}Nazad na odabir područja{%- else -%}Back to body part selection{%- endif -%}"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>
              {%- if request.locale.iso_code == 'bs' -%}Nazad na područja{%- else -%}Back to Body Parts{%- endif -%}
            </span>
          </button>
          <h3 class="asf-current-selection-title" data-js-step2-title></h3>
          <div class="asf-problems-grid">
            {%- liquid
              assign current_body_part_id_for_problems = ''
              for block_item in section.blocks
                if block_item.type == 'body_part'
                  assign current_body_part_id_for_problems = block_item.id
                elsif block_item.type == 'problem' and current_body_part_id_for_problems != ''
                  assign problem_html = '<div class="asf-problem-item" role="button" data-problem-id="' | append: block_item.id | append: '" data-parent-body-part-id="' | append: current_body_part_id_for_problems | append: '" tabindex="0">'
                  assign problem_html = problem_html | append: '<h4 class="asf-problem-name">'
                  if request.locale.iso_code == 'bs' and block_item.settings.name_bs != blank
                    assign problem_html = problem_html | append: block_item.settings.name_bs
                  else
                    assign problem_html = problem_html | append: block_item.settings.name_en
                  endif
                  assign problem_html = problem_html | append: '</h4>'
                  assign problem_html = problem_html | append: '<p class="asf-problem-description">'
                  if request.locale.iso_code == 'bs' and block_item.settings.description_bs != blank
                    assign problem_html = problem_html | append: block_item.settings.description_bs
                  else
                    assign problem_html = problem_html | append: block_item.settings.description_en
                  endif
                  assign problem_html = problem_html | append: '</p>'
                  assign problem_html = problem_html | append: '<span class="asf-problem-arrow" aria-hidden="true">&rarr;</span>'
                  assign problem_html = problem_html | append: '</div>'
                  echo problem_html
                endif
              endfor
            -%}
          </div>
        </div>

        <div class="asf-view asf-solution-view" data-view-step="3">
          <button
            type="button"
            class="asf-back-button"
            data-target-step="2"
            aria-label="{%- if request.locale.iso_code == 'bs' -%}Nazad na odabir problema{%- else -%}Back to issue selection{%- endif -%}"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>
              {%- if request.locale.iso_code == 'bs' -%}Nazad na probleme{%- else -%}Back to Issues{%- endif -%}
            </span>
          </button>
          <div class="asf-solution-breadcrumb">
            <span class="asf-breadcrumb-body-part"></span>
            {{- section.settings.breadcrumb_separator -}}
            <span class="asf-breadcrumb-problem"></span>
          </div>
          {%- liquid
            assign current_body_part_id_for_solutions = ''
            assign solution_card_prefix_bs = section.settings.solution_card_title_prefix_bs
            assign solution_card_prefix_en = section.settings.solution_card_title_prefix_en
            for block_item in section.blocks
              if block_item.type == 'body_part'
                assign current_body_part_id_for_solutions = block_item.id
              elsif block_item.type == 'problem' and current_body_part_id_for_solutions != ''
                assign solution_html = '<div class="asf-solution-card" data-solution-for-problem-id="' | append: block_item.id | append: '" data-solution-for-body-part-id="' | append: current_body_part_id_for_solutions | append: '">'
                assign solution_html = solution_html | append: '<div class="asf-solution-header">'
                assign solution_html = solution_html | append: '<div class="asf-droplet-animation" aria-hidden="true"><div class="asf-droplet"></div><div class="asf-droplet"></div><div class="asf-droplet"></div></div>'
                assign solution_html = solution_html | append: '<h3 class="asf-solution-card-title">'
                if request.locale.iso_code == 'bs' and block_item.settings.name_bs != blank
                  assign solution_html = solution_html | append: solution_card_prefix_bs | append: block_item.settings.name_bs
                else
                  assign solution_html = solution_html | append: solution_card_prefix_en | append: block_item.settings.name_en
                endif
                assign solution_html = solution_html | append: '</h3></div>'
                assign solution_html = solution_html | append: '<div class="asf-solution-content">'
                assign solution_html = solution_html | append: '<div class="asf-solution-text"><h4>'
                if request.locale.iso_code == 'bs'
                  assign solution_html = solution_html | append: 'Naše rješenje'
                else
                  assign solution_html = solution_html | append: 'Our Solution'
                endif
                assign solution_html = solution_html | append: '</h4>'
                if request.locale.iso_code == 'bs' and block_item.settings.solution_bs != empty
                  assign solution_html = solution_html | append: block_item.settings.solution_bs
                else
                  assign solution_html = solution_html | append: block_item.settings.solution_en
                endif
                assign solution_html = solution_html | append: '</div>'
                if block_item.settings.usage_en != empty or block_item.settings.usage_bs != empty
                  assign solution_html = solution_html | append: '<div class="asf-solution-usage"><h4>'
                  if request.locale.iso_code == 'bs'
                    assign solution_html = solution_html | append: 'Kako koristiti'
                  else
                    assign solution_html = solution_html | append: 'How to Use'
                  endif
                  assign solution_html = solution_html | append: '</h4>'
                  if request.locale.iso_code == 'bs' and block_item.settings.usage_bs != empty
                    assign solution_html = solution_html | append: block_item.settings.usage_bs
                  else
                    assign solution_html = solution_html | append: block_item.settings.usage_en
                  endif
                  assign solution_html = solution_html | append: '</div>'
                endif
                assign timeline_7_day_text = ''
                if request.locale.iso_code == 'bs' and block_item.settings.timeline_7_day_bs != blank and block_item.settings.timeline_7_day_bs != '<p></p>'
                  assign timeline_7_day_text = block_item.settings.timeline_7_day_bs
                elsif block_item.settings.timeline_7_day_en != blank and block_item.settings.timeline_7_day_en != '<p></p>'
                  assign timeline_7_day_text = block_item.settings.timeline_7_day_en
                endif
                assign timeline_14_day_text = ''
                if request.locale.iso_code == 'bs' and block_item.settings.timeline_14_day_bs != blank and block_item.settings.timeline_14_day_bs != '<p></p>'
                  assign timeline_14_day_text = block_item.settings.timeline_14_day_bs
                elsif block_item.settings.timeline_14_day_en != blank and block_item.settings.timeline_14_day_en != '<p></p>'
                  assign timeline_14_day_text = block_item.settings.timeline_14_day_en
                endif
                assign timeline_30_day_text = ''
                if request.locale.iso_code == 'bs' and block_item.settings.timeline_30_day_bs != blank and block_item.settings.timeline_30_day_bs != '<p></p>'
                  assign timeline_30_day_text = block_item.settings.timeline_30_day_bs
                elsif block_item.settings.timeline_30_day_en != blank and block_item.settings.timeline_30_day_en != '<p></p>'
                  assign timeline_30_day_text = block_item.settings.timeline_30_day_en
                endif
                if timeline_7_day_text != blank or timeline_14_day_text != blank or timeline_30_day_text != blank
                  assign solution_html = solution_html | append: '<div class="asf-solution-timeline"><h4>'
                  if request.locale.iso_code == 'bs'
                    assign solution_html = solution_html | append: 'Očekivani Rezultati'
                  else
                    assign solution_html = solution_html | append: 'Expected Results Timeline'
                  endif
                  assign solution_html = solution_html | append: '</h4><div class="asf-timeline-track">'
                  if timeline_7_day_text != blank
                    assign solution_html = solution_html | append: '<div class="asf-timeline-milestone"><div class="asf-timeline-marker">7 '
                    if request.locale.iso_code == 'bs'
                      assign solution_html = solution_html | append: 'Dana'
                    else
                      assign solution_html = solution_html | append: 'Days'
                    endif
                    assign solution_html = solution_html | append: '</div><div class="asf-timeline-content">' | append: timeline_7_day_text | append: '</div></div>'
                  endif
                  if timeline_14_day_text != blank
                    assign solution_html = solution_html | append: '<div class="asf-timeline-milestone"><div class="asf-timeline-marker">14 '
                    if request.locale.iso_code == 'bs'
                      assign solution_html = solution_html | append: 'Dana'
                    else
                      assign solution_html = solution_html | append: 'Days'
                    endif
                    assign solution_html = solution_html | append: '</div><div class="asf-timeline-content">' | append: timeline_14_day_text | append: '</div></div>'
                  endif
                  if timeline_30_day_text != blank
                    assign solution_html = solution_html | append: '<div class="asf-timeline-milestone"><div class="asf-timeline-marker">30 '
                    if request.locale.iso_code == 'bs'
                      assign solution_html = solution_html | append: 'Dana'
                    else
                      assign solution_html = solution_html | append: 'Days'
                    endif
                    assign solution_html = solution_html | append: '</div><div class="asf-timeline-content">' | append: timeline_30_day_text | append: '</div></div>'
                  endif
                  assign solution_html = solution_html | append: '</div></div>'
                endif
                assign current_testimonial_en = block_item.settings.testimonial_en
                assign current_testimonial_bs = block_item.settings.testimonial_bs
                assign current_testimonial_author = block_item.settings.testimonial_author
                assign display_testimonial = ''
                if request.locale.iso_code == 'bs' and current_testimonial_bs != blank
                  assign display_testimonial = current_testimonial_bs
                elsif current_testimonial_en != blank
                  assign display_testimonial = current_testimonial_en
                endif
                if display_testimonial != blank and current_testimonial_author != blank
                  assign solution_html = solution_html | append: '<div class="asf-solution-testimonial"><div class="asf-testimonial-quote">'
                  assign solution_html = solution_html | append: '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"></path></svg>'
                  assign solution_html = solution_html | append: display_testimonial
                  assign solution_html = solution_html | append: '</div><div class="asf-testimonial-author">— ' | append: current_testimonial_author | append: '</div></div>'
                endif
                assign solution_html = solution_html | append: '</div>'
                assign cta_text_bs = 'NAŠE RJEŠENJE'
                assign cta_text_en = 'Shop Argan Oil'
                assign cta_text = cta_text_en
                if request.locale.iso_code == 'bs'
                  assign cta_text = cta_text_bs
                endif
                if section.settings.final_cta_url != blank
                  assign product_page_url = section.settings.final_cta_url
                elsif section.settings.product_handle != blank and all_products[section.settings.product_handle] != blank
                  assign product_page_url = all_products[section.settings.product_handle].url
                else
                  assign product_page_url = '#'
                endif
                assign solution_html = solution_html | append: '<div class="asf-solution-cta"><a href="' | append: product_page_url | append: '" class="asf-button asf-cta-button">'
                assign solution_html = solution_html | append: cta_text
                assign solution_html = solution_html | append: '</a></div></div>'
                echo solution_html
              endif
            endfor
          -%}
          <button
            type="button"
            class="asf-button asf-restart-button"
            aria-label="{%- if request.locale.iso_code == 'bs' -%}Počni od početka{%- else -%}Start over from the beginning{%- endif -%}"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M3 2v6h6"></path><path d="M3 8C5.33 5.46 8.11 4 12 4c6.67 0 12 5.33 12 12s-5.33 12-12 12c-6.67 0-12-5.33-12-12"></path>
            </svg>
            <span>
              {%- if request.locale.iso_code == 'bs' -%}Počni ispočetka{%- else -%}Start Over{%- endif -%}
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .argan-solution-finder {
    font-family: var(--asf-font-body-text-family);
    color: var(--asf-text-color);
    position: relative;
    box-sizing: border-box;
    background-color: var(--asf-bg-color);
  }
  {%- if section.settings.full_width_background -%}
  .argan-solution-finder {
    padding-top: 40px;
    padding-bottom: 40px;
    width: 100%;
  }
  .asf-inner-content-limiter {
    max-width: var(--asf-content-max-width);
    margin-left: auto;
    margin-right: auto;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
  }
  {%- else -%}
  .argan-solution-finder {
    border-radius: var(--asf-border-radius);
    box-shadow: 0 15px 40px var(--asf-shadow-color);
    padding: 40px 20px;
    margin-top: 30px;
    margin-bottom: 30px;
    max-width: var(--asf-content-max-width);
    margin-left: auto;
    margin-right: auto;
  }
  .asf-inner-content-limiter {
    box-sizing: border-box;
  }
  {%- endif -%}
  .asf-teaser-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: var(--asf-teaser-min-height-mobile);
    padding: 20px 0;
    box-sizing: border-box;
  }
  .asf-teaser-title {
    font-family: var(--asf-font-title-family);
    font-weight: var(--asf-font-title-weight);
    font-style: var(--asf-font-title-style);
    font-size: {{ section.settings.font_teaser_animated_size_mobile }}px;
    color: var(--asf-text-color);
    margin-bottom: 20px;
    line-height: 1.4;
  }
  span.asf-teaser-line-1 {
    display: block;
    margin-bottom: 8px;
  }
  .asf-animated-problem-text-container {
    display: flex;
    align-items: baseline;
    justify-content: center;
    position: relative;
    min-width: 220px;
    white-space: nowrap;
    overflow: visible;
    border-bottom: 2px solid var(--asf-primary-color);
    padding-bottom: 2px;
    height: 1.5em;
  }
  .asf-animated-problem-text {
    font-family: var(--asf-font-teaser-animated-family);
    font-weight: var(--asf-font-teaser-animated-weight);
    font-style: var(--asf-font-teaser_animated-style);
    color: var(--asf-primary-color);
    display: inline;
    vertical-align: baseline;
    white-space: nowrap;
  }
  .asf-typewriter-cursor {
    display: inline-block;
    background-color: var(--asf-primary-color);
    width: 2px;
    height: 1em;
    animation: asfBlinkCursor 0.7s steps(1) infinite;
    margin-left: 1px;
    vertical-align: baseline;
    position: relative;
    bottom: -0.15em;
  }
  @keyframes asfBlinkCursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .asf-start-button {
    margin-top: 25px;
    padding: 14px 30px;
    font-size: {{ section.settings.font_item_name_size_mobile | times: 0.95 }}px;
    background-color: var(--asf-primary-color);
    color: var(--asf-light-color);
  }
    .asf-start-button:hover, .asf-start-button:focus-visible {
    background-color: var(--asf-secondary-color);
    transform: translateY(-2px);
  }
  .asf-main-header {
    padding: 0;
  }
  .asf-header { text-align: center; margin-bottom: 40px; }
  .asf-title {
    font-family: var(--asf-font-title-family);
    font-weight: var(--asf-font-title-weight);
    font-style: var(--asf-font-title-style);
    font-size: {{ section.settings.font_title_size_mobile }}px;
    color: var(--asf-primary-color);
    margin-bottom: 10px;
    position: relative;
    display: inline-block;
  }
  .asf-title::after {
    content: ""; position: absolute; bottom: -10px; left: 50%;
    transform: translateX(-50%); width: 80px; height: 3px;
    background-color: var(--asf-primary-color); border-radius: 3px;
  }
  .asf-subtitle {
    font-family: var(--asf-font-subtitle-family);
    font-weight: var(--asf-font-subtitle-weight);
    font-style: var(--asf-font-subtitle-style);
    font-size: {{ section.settings.font_subtitle_size_mobile }}px;
    max-width: 700px; margin: 25px auto 0;
    color: var(--asf-secondary-color); line-height: 1.6;
  }
  .asf-progress-bar {
    display: flex; justify-content: center; align-items: flex-start;
    margin-bottom: 30px; position: relative; padding: 0 10px;
    transition: opacity 0.3s ease-in-out, visibility 0s 0.3s, height 0.3s ease-in-out, margin-bottom 0.3s ease-in-out;
  }
  .asf-progress-bar.hidden {
    opacity: 0;
    visibility: hidden;
    height: 0 !important;
    margin-bottom: 0 !important;
    overflow: hidden;
    transition-delay: 0s, 0.3s, 0s, 0s;
  }
  .asf-progress-step { display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1; flex-shrink: 0; }
  .asf-progress-marker {
    width: {{ section.settings.progress_marker_size }}px;
    height: {{ section.settings.progress_marker_size }}px;
    font-size: {{ section.settings.progress_marker_font_size }}px;
    border-radius: 50%; background-color: var(--asf-light-color);
    border: 2px solid var(--asf-secondary-color); color: var(--asf-secondary-color);
    display: flex; justify-content: center; align-items: center; font-weight: bold;
    margin-bottom: 6px; transition: all var(--asf-transition-speed) ease;
  }
  .asf-progress-step[data-step].active .asf-progress-marker {
    background-color: var(--asf-primary-color); border-color: var(--asf-primary-color);
    color: var(--asf-light-color); transform: scale(1.1);
    box-shadow: 0 3px 10px color-mix(in srgb, var(--asf-primary-color) 30%, transparent);
  }
  .asf-progress-step[data-step].completed .asf-progress-marker {
    background-color: var(--asf-accent-color); border-color: var(--asf-accent-color);
    color: var(--asf-light-color);
  }
  .asf-progress-label {
    font-family: var(--asf-font-progress-label-family);
    font-weight: var(--asf-font-progress-label-weight);
    font-style: var(--asf-font-progress-label-style);
    font-size: {{ section.settings.progress_label_font_size }}px;
    color: var(--asf-secondary-color); text-align: center;
  }
  .asf-progress-step[data-step].active .asf-progress-label { color: var(--asf-primary-color); }
  .asf-progress-connector {
    flex-grow: 1; height: 2px; background-color: var(--asf-secondary-color);
    max-width: 80px; margin: 0 5px; position: relative;
    transition: background-color var(--asf-transition-speed) ease;
