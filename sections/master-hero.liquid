{% liquid
  assign media_type = section.settings.media_type
  assign height_class = 'master-hero--large'
  if section.settings.height == 'full'
    assign height_class = 'master-hero--full'
  elsif section.settings.height == 'medium'
    assign height_class = 'master-hero--medium'
  elsif section.settings.height == 'small'
    assign height_class = 'master-hero--small'
  elsif section.settings.height == 'auto'
    assign height_class = 'master-hero--auto'
  endif

  if section.settings.enable_curtain
    assign height_class = height_class | append: ' curtain-mode'
  endif
%}

<div class="master-hero {{ height_class }} color-{{ section.settings.color_scheme }}">
  
  {%- comment -%} Background Media {%- endcomment -%}
  <div class="master-hero__media">
    {%- if media_type == 'video' and section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'master-hero__media-item' }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3840 | image_tag: class: 'master-hero__media-item', widths: '400, 600, 800, 1200, 1600, 2000, 2400, 3000, 3800', sizes: '100vw' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'master-hero__media-item master-hero__placeholder' }}
    {%- endif -%}
    
    {%- comment -%} Overlay {%- endcomment -%}
    <div class="master-hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="master-hero__content-wrapper {{ section.settings.text_alignment }}">
    <div class="master-hero__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2 class="master-hero__heading {{ block.settings.heading_size }} reveal-text" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h2>
          {%- when 'text' -%}
            <div class="master-hero__text rte reveal-text delay-100" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'buttons' -%}
            <div class="master-hero__buttons reveal-text delay-200" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a href="{{ block.settings.button_link_1 }}" class="button button--primary">
                  {{ block.settings.button_label_1 }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 }}" class="button button--secondary">
                  {{ block.settings.button_label_2 }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .master-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  /* Curtain Mode: Sticky at top, lower z-index */
  .master-hero.curtain-mode {
    position: sticky;
    top: 0;
    z-index: 0;
  }

  .master-hero--full { min-height: 100vh; }
  .master-hero--large { min-height: 80vh; }
  .master-hero--medium { min-height: 60vh; }
  .master-hero--small { min-height: 40vh; }
  .master-hero--auto { min-height: 500px; }

  .master-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .master-hero__media-item {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .master-hero__placeholder {
    opacity: 0.5;
  }

  .master-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    pointer-events: none;
  }

  .master-hero__content-wrapper {
    position: relative;
    z-index: 10;
    width: 100%;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
  }

  .master-hero__content-wrapper.text-center { align-items: center; text-align: center; }
  .master-hero__content-wrapper.text-left { align-items: flex-start; text-align: left; }
  .master-hero__content-wrapper.text-right { align-items: flex-end; text-align: right; }

  .master-hero__content {
    max-width: 800px;
    width: 100%;
  }
  
  /* Mega Heading Layout Adjustments */
  .master-hero__heading.hmega {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    text-align: center;
    font-size: 12vw; /* Responsive Mega Size */
    line-height: 0.8;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    pointer-events: none; /* Let clicks pass through if needed */
    z-index: 5;
  }
  
  /* Ensure content wrapper doesn't trap the absolute mega heading */
  .master-hero__content:has(.hmega) {
    position: static;
    max-width: none;
  }
  .master-hero__content-wrapper:has(.hmega) {
    position: static;
  }

  .master-hero__heading {
    margin-bottom: 1rem;
    line-height: 1.2;
    font-weight: bold;
  }
  
  .master-hero__heading.hxl { font-size: 4rem; }
  .master-hero__heading.h1 { font-size: 3rem; }
  .master-hero__heading.h2 { font-size: 2.5rem; }
  .master-hero__heading.h3 { font-size: 2rem; }

  .master-hero__text {
    margin-bottom: 1.5rem;
    font-size: 1.125rem;
  }

  .master-hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .text-center .master-hero__buttons { justify-content: center; }
  .text-right .master-hero__buttons { justify-content: flex-end; }

  /* Animations */
  .reveal-text {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-text.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .delay-100 { transition-delay: 0.1s; }
  .delay-200 { transition-delay: 0.2s; }
  
  @media (max-width: 768px) {
    .master-hero__heading.hxl { font-size: 2.5rem; }
    .master-hero__heading.h1 { font-size: 2rem; }
    .master-hero__heading.hmega { font-size: 15vw; bottom: 80px; } /* Adjust for mobile */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Master Hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "full", "label": "Full Screen" },
        { "value": "large", "label": "Large (80vh)" },
        { "value": "medium", "label": "Medium (60vh)" },
        { "value": "small", "label": "Small (40vh)" },
        { "value": "auto", "label": "Auto" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Curtain Effect"
    },
    {
      "type": "checkbox",
      "id": "enable_curtain",
      "label": "Enable Curtain Effect",
      "default": false,
      "info": "Fixes the hero in place so the next section slides over it. Works best when the next section has a solid background."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Master Hero Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading Size",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "hxl", "label": "Extra Large" },
            { "value": "hmega", "label": "Mega (Bottom Aligned)" }
          ],
          "default": "h1"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers.</p>"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Button 1 Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 Link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button 2 Label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Master Hero",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
