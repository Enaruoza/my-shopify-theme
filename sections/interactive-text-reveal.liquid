{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .interactive-text-section {
    position: relative;
    z-index: 10; /* Ensure it sits above the curtain hero */
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .interactive-text-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center; /* Center vertically to align buttons with text */
    justify-content: center;
    text-align: center;
    gap: 0.2em 0.3em; /* Gap between words */
  }

  .it-text-segment {
    font-family: var(--font-heading-family);
    font-weight: 800;
    font-size: {{ section.settings.font_size_mobile }}px;
    line-height: 1.1;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: -0.02em;
    transition: color 0.3s ease;
  }

  .it-reveal-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    transform: scale(0.9);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    vertical-align: middle;
    margin: 0;
  }

  .it-reveal-button.is-visible {
    max-width: 300px; /* Arbitrary large limit */
    opacity: 1;
    transform: scale(1);
    margin: 0 0.2em; /* Add spacing when visible */
  }

  .it-btn-inner {
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, background-color 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .it-btn-inner:hover {
    transform: translateY(-2px);
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  /* Arrow Icon */
  .it-btn-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* Subtext */
  .it-subtext {
    max-width: 600px;
    margin: 40px auto 0;
    text-align: center;
    font-size: 1.1rem;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    line-height: 1.6;
  }

  .it-read-more {
    display: inline-block;
    margin-top: 24px;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
    color: {{ section.settings.text_color }};
  }

  @media screen and (min-width: 750px) {
    .it-text-segment {
      font-size: {{ section.settings.font_size_desktop }}px;
    }
  }
{%- endstyle -%}

<div class="interactive-text-section section-{{ section.id }}-padding">
  <div class="interactive-text-wrapper" id="InteractiveText-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'text_segment' -%}
          <span class="it-text-segment" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
        
        {%- when 'reveal_button' -%}
          <div class="it-reveal-button" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="it-btn-inner">
              {{ block.settings.label }}
              <svg class="it-btn-icon" viewBox="0 0 14 14"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.subtext != blank -%}
    <div class="it-subtext reveal-on-scroll">
      {{ section.settings.subtext }}
      {%- if section.settings.read_more_link != blank -%}
        <br>
        <a href="{{ section.settings.read_more_link }}" class="it-read-more">
          {{ section.settings.read_more_label | default: 'Read More' }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.getElementById('InteractiveText-{{ section.id }}');
    const buttons = wrapper.querySelectorAll('.it-reveal-button');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Staggered reveal
          buttons.forEach((btn, index) => {
            setTimeout(() => {
              btn.classList.add('is-visible');
            }, index * 200 + 300); // Base delay + stagger
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    observer.observe(wrapper);
  });
</script>

{% schema %}
{
  "name": "Interactive Text Reveal",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
