      "label": "Mobile Font Size",
      "default": 36
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Footer Text"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Lunaria is a premium beauty studio for women, offering expert care for skin, body, and hair.</p>"
    },
    {
      "type": "url",
      "id": "read_more_link",
      "label": "Read More Link"
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Read More Label",
      "default": "Read More"
    }
  ],
  "blocks": [
    {
      "type": "text_segment",
      "name": "Text Segment",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "WE HELP CREATE"
        }
      ]
    },
    {
      "type": "reveal_button",
      "name": "Reveal Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "ABOUT US"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Interactive Text Reveal",
      "blocks": [
        { "type": "text_segment", "settings": { "text": "WE" } },
        { "type": "reveal_button", "settings": { "label": "ABOUT US" } },
        { "type": "text_segment", "settings": { "text": "HELP CREATE" } },
        { "type": "text_segment", "settings": { "text": "MOMENTS OF BEAUTY" } }
      ]
    }
  ]
}
{% endschema %}
