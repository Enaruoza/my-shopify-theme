{%- style -%}
  .nature-scene-{{ section.id }} {
    position: relative;
    height: {{ section.settings.height }}vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.bg_color }};
  }

  .nature-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%; /* Taller for parallax movement */
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  .nature-content {
    position: relative;
    z-index: 10;
    text-align: center;
    color: {{ section.settings.text_color }};
    max-width: 800px;
    padding: 20px;
  }

  .nature-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(40px, 8vw, 120px);
    line-height: 1;
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s ease;
  }

  .nature-text {
    font-size: clamp(16px, 2vw, 24px);
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s ease 0.2s;
  }

  .nature-scene-{{ section.id }}.in-view .nature-heading,
  .nature-scene-{{ section.id }}.in-view .nature-text {
    opacity: 1;
    transform: translateY(0);
  }
{%- endstyle -%}

<div class="nature-scene-{{ section.id }}" id="NatureScene-{{ section.id }}">
  {%- if section.settings.bg_image != blank -%}
    <div class="nature-layer layer-bg" style="background-image: url({{ section.settings.bg_image | image_url: width: 2000 }}); transform: translateY(0px);"></div>
  {%- endif -%}

  {%- if section.settings.mid_image != blank -%}
    <div class="nature-layer layer-mid" style="background-image: url({{ section.settings.mid_image | image_url: width: 2000 }}); transform: translateY(0px);"></div>
  {%- endif -%}

  {%- if section.settings.fg_image != blank -%}
    <div class="nature-layer layer-fg" style="background-image: url({{ section.settings.fg_image | image_url: width: 2000 }}); transform: translateY(0px);"></div>
  {%- endif -%}

  <div class="nature-content">
    {%- if section.settings.heading != blank -%}
      <h2 class="nature-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="nature-text">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('NatureScene-{{ section.id }}');
    const layers = {
      bg: section.querySelector('.layer-bg'),
      mid: section.querySelector('.layer-mid'),
      fg: section.querySelector('.layer-fg')
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('in-view');
        }
      });
    }, { threshold: 0.3 });

    observer.observe(section);

    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      const scrolled = window.pageYOffset;
      const speed = 0.5;
      
      // Only animate if in view
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        const offset = (window.innerHeight - rect.top) * speed;
        
        if (layers.bg) layers.bg.style.transform = `translateY(${offset * 0.1}px)`;
        if (layers.mid) layers.mid.style.transform = `translateY(${offset * 0.3}px)`;
        if (layers.fg) layers.fg.style.transform = `translateY(${offset * 0.6}px)`;
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Nature Scene (Parallax)",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Section Height",
      "default": 100
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layers"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Layer (Sky/Distant)"
    },
    {
      "type": "image_picker",
      "id": "mid_image",
      "label": "Midground Layer (Trees/Hills)"
    },
    {
      "type": "image_picker",
      "id": "fg_image",
      "label": "Foreground Layer (Plants/Rocks)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Living Canvas"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Experience the beauty of nature in motion.</p>"
    }
  ],
  "presets": [
    {
      "name": "Nature Scene (Parallax)"
    }
  ]
}
{% endschema %}
