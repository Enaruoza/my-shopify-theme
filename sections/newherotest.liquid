{%- liquid
  assign left_heading_font = section.settings.left_heading_font
  assign left_body_font = section.settings.left_body_font
  assign right_heading_font = section.settings.right_heading_font
  assign right_body_font = section.settings.right_body_font
-%}

<style>
  {{ left_heading_font | font_face }}
  {{ left_body_font | font_face }}
  {{ right_heading_font | font_face }}
  {{ right_body_font | font_face }}

  .hero-sr-{{ section.id }} {
    --section-height: {{ section.settings.section_height_desktop }}vh;
    --divider-width: {{ section.settings.divider_width }}px;
    --divider-color: {{ section.settings.divider_color }};
    --handle-color: {{ section.settings.divider_handle_color }};
    --initial-position: {{ section.settings.initial_position }}%;
    position: relative;
    width: 100%;
    height: var(--section-height);
    overflow: hidden;
    background: #f0f0f0;
  }
  @media (max-width: 768px) {
    .hero-sr-{{ section.id }} {
      --section-height: {{ section.settings.section_height_mobile }}vh;
    }
  }

  .hero-sr-{{ section.id }} .hero-panel {
    position: absolute;
    top: 0;
    height: 100%;
    overflow: hidden;
  }

  .hero-sr-{{ section.id }} .hero-panel.left {
    left: 0;
    width: var(--initial-position);
    background-color: {{ section.settings.left_panel_bg }};
  }

  .hero-sr-{{ section.id }} .hero-panel.right {
    right: 0;
    width: calc(100% - var(--initial-position));
    background-color: {{ section.settings.right_panel_bg }};
  }

  .hero-sr-{{ section.id }} .panel-background {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .hero-sr-{{ section.id }} .hero-panel:hover .panel-background {
    transform: scale(1.05);
  }

  .hero-sr-{{ section.id }} .panel-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .hero-sr-{{ section.id }} .panel-content {
    position: relative;
    z-index: 5;
    height: 100%;
    padding: clamp(20px, 5vw, 60px);
    display: flex;
    flex-direction: column;
    color: {{ section.settings.left_text_color }};
  }
  .hero-sr-{{ section.id }} .hero-panel.right .panel-content {
    color: {{ section.settings.right_text_color }};
  }

  .hero-sr-{{ section.id }} .panel-content.align-left { text-align: left; align-items: flex-start; }
  .hero-sr-{{ section.id }} .panel-content.align-center { text-align: center; align-items: center; }
  .hero-sr-{{ section.id }} .panel-content.align-right { text-align: right; align-items: flex-end; }
  .hero-sr-{{ section.id }} .panel-content.justify-top { justify-content: flex-start; }
  .hero-sr-{{ section.id }} .panel-content.justify-center { justify-content: center; }
  .hero-sr-{{ section.id }} .panel-content.justify-bottom { justify-content: flex-end; }

  .hero-sr-{{ section.id }} .content-heading {
    font-size: clamp(2rem, 6vw, 4.5rem);
    margin: 0;
    line-height: 1.1;
  }
  .hero-sr-{{ section.id }} .hero-panel.left .content-heading {
    font-family: {{ left_heading_font.family }}, {{ left_heading_font.fallback_families }};
    font-weight: {{ left_heading_font.weight }};
  }
  .hero-sr-{{ section.id }} .hero-panel.right .content-heading {
    font-family: {{ right_heading_font.family }}, {{ right_heading_font.fallback_families }};
    font-weight: {{ right_heading_font.weight }};
  }

  .hero-sr-{{ section.id }} .content-subheading {
    font-size: clamp(1rem, 2vw, 1.2rem);
    max-width: 45ch;
    margin: 20px 0;
  }
  .hero-sr-{{ section.id }} .hero-panel.left .content-subheading {
    font-family: {{ left_body_font.family }}, {{ left_body_font.fallback_families }};
    font-weight: {{ left_body_font.weight }};
  }
  .hero-sr-{{ section.id }} .hero-panel.right .content-subheading {
    font-family: {{ right_body_font.family }}, {{ right_body_font.fallback_families }};
    font-weight: {{ right_body_font.weight }};
  }

  .hero-sr-{{ section.id }} .content-button {
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 50px;
    font-weight: bold;
    margin-top: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: inline-block;
  }
  .hero-sr-{{ section.id }} .content-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  .hero-sr-{{ section.id }} .hero-divider {
    position: absolute;
    top: 0;
    left: var(--initial-position);
    width: var(--divider-width);
    height: 100%;
    background-color: var(--divider-color);
    transform: translateX(-50%);
    cursor: ew-resize;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Larger invisible touch area for mobile */
  .hero-sr-{{ section.id }} .hero-divider::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 44px;
    height: 100%;
  }
  .hero-sr-{{ section.id }} .divider-handle {
    width: 40px;
    height: 40px;
    background-color: var(--handle-color);
    border: 2px solid var(--divider-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: space-evenly;
    color: var(--divider-color);
    font-size: 20px;
    box-shadow: 0 0 15px rgba(0,0,0,0.2);
    pointer-events: none; /* Make sure handle doesn't block dragging */
  }
  .hero-sr-{{ section.id }} .divider-handle svg {
    width: 10px;
    height: 10px;
    fill: var(--divider-color);
  }
</style>

<div class="hero-sr-{{ section.id }}" id="hero-sr-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="hero-panel left">
    <div class="panel-background" style="background-image: url('{{ section.settings.left_image | image_url: width: 1920 }}');"></div>
    <div class="panel-overlay" style="background: {{ section.settings.left_overlay_color }};"></div>
    <div class="panel-content align-{{ section.settings.left_align }} justify-{{ section.settings.left_justify }}">
      <div>
        {% if section.settings.left_heading != blank %}
          <h2 class="content-heading">{{ section.settings.left_heading }}</h2>
        {% endif %}
        {% if section.settings.left_subheading != blank %}
          <p class="content-subheading">{{ section.settings.left_subheading }}</p>
        {% endif %}
        {% if section.settings.left_button_text != blank and section.settings.left_button_link != blank %}
          <a href="{{ section.settings.left_button_link }}" class="content-button" style="background-color: {{ section.settings.left_button_bg }}; color: {{ section.settings.left_button_text_color }};">
            {{ section.settings.left_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="hero-panel right">
    <div class="panel-background" style="background-image: url('{{ section.settings.right_image | image_url: width: 1920 }}');"></div>
    <div class="panel-overlay" style="background: {{ section.settings.right_overlay_color }};"></div>
    <div class="panel-content align-{{ section.settings.right_align }} justify-{{ section.settings.right_justify }}">
      <div>
        {% if section.settings.right_heading != blank %}
          <h2 class="content-heading">{{ section.settings.right_heading }}</h2>
        {% endif %}
        {% if section.settings.right_subheading != blank %}
          <p class="content-subheading">{{ section.settings.right_subheading }}</p>
        {% endif %}
        {% if section.settings.right_button_text != blank and section.settings.right_button_link != blank %}
          <a href="{{ section.settings.right_button_link }}" class="content-button" style="background-color: {{ section.settings.right_button_bg }}; color: {{ section.settings.right_button_text_color }};">
            {{ section.settings.right_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="hero-divider">
    <div class="divider-handle">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/></svg>
    </div>
  </div>
</div>

<script>
  // Self-executing function to avoid polluting global scope
  (() => {
    // A registry to keep track of initialized sections, critical for editor performance
    window.registeredSections = window.registeredSections || {};
    
    class SplitRevealHero {
      constructor(container) {
        this.container = container;
        this.leftPanel = container.querySelector('.hero-panel.left');
        this.rightPanel = container.querySelector('.hero-panel.right');
        this.divider = container.querySelector('.hero-divider');
        this.isDragging = false;
        
        // Bind 'this' context for event handlers
        this.onDragStart = this.onDragStart.bind(this);
        this.onDragMove = this.onDragMove.bind(this);
        this.onDragEnd = this.onDragEnd.bind(this);

        this.addEventListeners();
      }

      onDragStart(e) {
        e.preventDefault();
        this.isDragging = true;
        this.container.style.cursor = 'ew-resize';
      }

      onDragEnd() {
        this.isDragging = false;
        this.container.style.cursor = 'default';
      }

      onDragMove(e) {
        if (!this.isDragging) return;
        
        const clientX = e.clientX || e.touches[0].clientX;
        const heroRect = this.container.getBoundingClientRect();
        let newX = clientX - heroRect.left;
        
        // Clamp the position to prevent it from going too far to the edges
        if (newX < 50) newX = 50;
        if (newX > heroRect.width - 50) newX = heroRect.width - 50;
        
        const percentage = (newX / heroRect.width) * 100;
        
        // Use requestAnimationFrame for smoother rendering
        requestAnimationFrame(() => {
          this.divider.style.left = `${percentage}%`;
          this.leftPanel.style.width = `${percentage}%`;
          this.rightPanel.style.width = `${100 - percentage}%`;
        });
      }

      addEventListeners() {
        this.divider.addEventListener('mousedown', this.onDragStart);
        this.divider.addEventListener('touchstart', this.onDragStart, { passive: false });

        window.addEventListener('mousemove', this.onDragMove);
        window.addEventListener('touchmove', this.onDragMove, { passive: false });

        window.addEventListener('mouseup', this.onDragEnd);
        window.addEventListener('touchend', this.onDragEnd);
      }

      // Cleanup function to remove global listeners, essential for Shopify editor stability
      destroy() {
        window.removeEventListener('mousemove', this.onDragMove);
        window.removeEventListener('touchmove', this.onDragMove);
        window.removeEventListener('mouseup', this.onDragEnd);
        window.removeEventListener('touchend', this.onDragEnd);
      }
    }

    const initSection = (sectionId) => {
      const heroContainer = document.getElementById(`hero-sr-${sectionId}`);
      if (heroContainer) {
        // If an instance for this section already exists, clean it up before re-initializing
        if (window.registeredSections[sectionId]) {
          window.registeredSections[sectionId].destroy();
        }
        // Create and register the new instance
        window.registeredSections[sectionId] = new SplitRevealHero(heroContainer);
      }
    };

    const cleanupSection = (sectionId) => {
      if (window.registeredSections[sectionId]) {
        window.registeredSections[sectionId].destroy();
        delete window.registeredSections[sectionId];
      }
    };
    
    // This is the Shopify Native way to handle section loading and unloading in the editor
    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        initSection(event.detail.sectionId);
      }
    });

    document.addEventListener('shopify:section:unload', (event) => {
      if (event.detail.sectionId === '{{ section.id }}') {
        cleanupSection(event.detail.sectionId);
      }
    });

    // Initial load for the page
    initSection('{{ section.id }}');

  })();
</script>

{% schema %}
{
  "name": "Split Reveal Hero",
  "tag": "section",
  "class": "shopify-section--hero-sr-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "General Layout"
    },
    { "type": "range", "id": "section_height_desktop", "min": 50, "max": 100, "step": 5, "unit": "vh", "label": "Section Height (Desktop)", "default": 85 },
    { "type": "range", "id": "section_height_mobile", "min": 50, "max": 100, "step": 5, "unit": "vh", "label": "Section Height (Mobile)", "default": 65, "info": "Controls the vertical height of the section on mobile devices." },
    { "type": "range", "id": "initial_position", "min": 25, "max": 75, "step": 1, "unit": "%", "label": "Initial Divider Position", "default": 50, "info": "Set the default split for when the page loads." },
    {
      "type": "header",
      "content": "Left Panel"
    },
    { "type": "image_picker", "id": "left_image", "label": "Background Image" },
    { "type": "color", "id": "left_panel_bg", "label": "Fallback Background Color", "default": "#e0e0e0" },
    { "type": "color", "id": "left_overlay_color", "label": "Image Overlay Color", "default": "rgba(0,0,0,0.2)" },
    { "type": "text", "id": "left_heading", "label": "Heading", "default": "Our Heritage" },
    { "type": "textarea", "id": "left_subheading", "label": "Subheading", "default": "Discover the tradition and care that goes into every bottle." },
    { "type": "text", "id": "left_button_text", "label": "Button Text", "default": "Explore Story" },
    { "type": "url", "id": "left_button_link", "label": "Button Link" },
    { "type": "color", "id": "left_text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "color", "id": "left_button_bg", "label": "Button Background", "default": "#ffffff" },
    { "type": "color", "id": "left_button_text_color", "label": "Button Text Color", "default": "#000000" },
    { "type": "font_picker", "id": "left_heading_font", "label": "Heading Font", "default": "helvetica_n7" },
    { "type": "font_picker", "id": "left_body_font", "label": "Body Font", "default": "helvetica_n4" },
    { "type": "select", "id": "left_align", "label": "Horizontal Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "select", "id": "left_justify", "label": "Vertical Alignment", "options": [{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"}], "default": "bottom" },
    {
      "type": "header",
      "content": "Right Panel"
    },
    { "type": "image_picker", "id": "right_image", "label": "Background Image" },
    { "type": "color", "id": "right_panel_bg", "label": "Fallback Background Color", "default": "#f5f5f5" },
    { "type": "color", "id": "right_overlay_color", "label": "Image Overlay Color", "default": "rgba(0,0,0,0.1)" },
    { "type": "text", "id": "right_heading", "label": "Heading", "default": "Modern Purity" },
    { "type": "textarea", "id": "right_subheading", "label": "Subheading", "default": "Experience the clean, potent results of our innovative formula." },
    { "type": "text", "id": "right_button_text", "label": "Button Text", "default": "Shop Now" },
    { "type": "url", "id": "right_button_link", "label": "Button Link" },
    { "type": "color", "id": "right_text_color", "label": "Text Color", "default": "#000000" },
    { "type": "color", "id": "right_button_bg", "label": "Button Background", "default": "#000000" },
    { "type": "color", "id": "right_button_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "font_picker", "id": "right_heading_font", "label": "Heading Font", "default": "helvetica_n7" },
    { "type": "font_picker", "id": "right_body_font", "label": "Body Font", "default": "helvetica_n4" },
    { "type": "select", "id": "right_align", "label": "Horizontal Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "right" },
    { "type": "select", "id": "right_justify", "label": "Vertical Alignment", "options": [{"value":"top","label":"Top"},{"value":"center","label":"Center"},{"value":"bottom","label":"Bottom"}], "default": "bottom" },
    {
      "type": "header",
      "content": "Divider Styling"
    },
    { "type": "range", "id": "divider_width", "min": 1, "max": 10, "step": 1, "unit": "px", "label": "Divider Width", "default": 3 },
    { "type": "color", "id": "divider_color", "label": "Divider Line Color", "default": "#ffffff" },
    { "type": "color", "id": "divider_handle_color", "label": "Divider Handle Color", "default": "#ffffff" }
  ],
  "presets": [
    {
      "name": "Split Reveal Hero"
    }
  ]
}
{% endschema %}