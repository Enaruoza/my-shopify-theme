{% liquid
  assign sid = section.id | replace: '_', '-' | downcase
%}

<section
  id="az-hero-{{ sid }}"
  class="az-hero az-hero-{{ sid }} color-{{ section.settings.color_scheme }}"
>
  <style>
    .az-hero-{{ sid }} {
      padding-top: {{ section.settings.section_padding_top }}px;
      padding-bottom: {{ section.settings.section_padding_bottom }}px;
    }

    .az-hero-{{ sid }} .az-hero__inner {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 2rem;
    }

    .az-hero-{{ sid }} .az-hero__logo-row {
      display: flex;
      width: 100%;
      padding-inline: max(1.5rem, env(safe-area-inset-left));
    }

    .az-hero-{{ sid }} .az-hero__logo-row--left {
      justify-content: flex-start;
    }

    .az-hero-{{ sid }} .az-hero__logo-row--center {
      justify-content: center;
    }

    .az-hero-{{ sid }} .az-hero__logo-row--right {
      justify-content: flex-end;
    }

    .az-hero-{{ sid }} .az-hero__logo {
      max-width: {{ section.settings.logo_max_width }}%;
    }

    .az-hero-{{ sid }} .az-hero__logo img {
      display: block;
      width: 100%;
      height: auto;
    }

    .az-hero-{{ sid }} .az-hero__logo-text {
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 0.9;
    }

    .az-hero-{{ sid }} .az-hero__frame-wrapper {
      position: relative;
      width: 100%;
    }

    .az-hero-{{ sid }} .az-hero__frame {
      position: relative;
      margin: 0 auto;
      border-radius: {{ section.settings.panel_radius }}px;
      overflow: hidden;
      padding: 2.5rem 1.5rem;
      background-color: rgba(255, 255, 255, 0.1);
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.12);
    }

    .az-hero-{{ sid }} .az-hero__media-shell {
      position: relative;
      margin: 0 auto;
      width: min(100%, 1100px);
    }

    .az-hero-{{ sid }} .az-hero__media {
      width: var(--az-hero-media-width-desktop);
      margin-left: auto;
      margin-right: auto;
      transform: translateY(var(--az-hero-media-offset-desktop));
      border-radius: {{ section.settings.media_radius }}px;
      overflow: hidden;
    }

    .az-hero-{{ sid }} .az-hero__media img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
    }

    .az-hero-{{ sid }} .az-hero__media--shape-rounded {
      border-radius: {{ section.settings.media_radius }}px;
    }

    .az-hero-{{ sid }} .az-hero__media--shape-blob {
      border-radius: 40% 60% 42% 58% / 55% 38% 62% 45%;
    }

    .az-hero-{{ sid }} .az-hero__media--shape-pill {
      border-radius: 999px;
    }

    .az-hero-{{ sid }} .az-hero__placeholder {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: inherit;
      border: 2px dashed rgba(0, 0, 0, 0.18);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
    }

    .az-hero-{{ sid }} .az-hero__cta-row {
      display: flex;
      justify-content: center;
      margin-top: 1.25rem;
    }

    .az-hero-{{ sid }} .az-hero__cta-row .button {
      min-width: 10rem;
    }

    .az-hero-{{ sid }} .az-hero__sticker {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      text-align: center;
      padding: 0.5rem;
      border-radius: 999px;
      box-shadow: 0 0.2rem 0.6rem rgba(0, 0, 0, 0.25);
      z-index: 2;
      --az-hero-translate-x: 0;
      --az-hero-translate-y: 0;
      --az-hero-rotation: 0deg;
      transform: translate(var(--az-hero-translate-x), var(--az-hero-translate-y)) rotate(var(--az-hero-rotation));
      will-change: transform;
    }

    .az-hero-{{ sid }} .az-hero__sticker--shape-burst {
      clip-path: polygon(50% 0%, 61% 13%, 78% 6%, 79% 24%, 94% 19%, 88% 35%, 100% 43%, 88% 52%, 96% 68%, 79% 67%, 80% 84%, 64% 76%, 50% 100%, 36% 76%, 20% 84%, 21% 67%, 4% 68%, 12% 52%, 0% 43%, 12% 35%, 6% 19%, 21% 24%, 22% 6%, 39% 13%);
    }

    .az-hero-{{ sid }} .az-hero__sticker--shape-circle {
      border-radius: 999px;
    }

    .az-hero-{{ sid }} .az-hero__sticker--shape-pill {
      border-radius: 999px;
      padding-inline: 1.25rem;
    }

    .az-hero-{{ sid }} .az-hero__sticker span {
      display: block;
      font-size: 0.75rem;
      line-height: 1.1;
    }

    .az-hero-{{ sid }} .az-hero__sticker--top-left {
      top: 0;
      left: 0;
      transform-origin: 30% 30%;
    }

    .az-hero-{{ sid }} .az-hero__sticker--top-right {
      top: 0;
      right: 0;
      transform-origin: 70% 30%;
    }

    .az-hero-{{ sid }} .az-hero__sticker--bottom-left {
      bottom: 0;
      left: 0;
      transform-origin: 30% 70%;
    }

    .az-hero-{{ sid }} .az-hero__sticker--bottom-right {
      bottom: 0;
      right: 0;
      transform-origin: 70% 70%;
    }

    .az-hero-{{ sid }} .az-hero__sticker--offset-inset {
      --az-hero-translate-x: 10%;
      --az-hero-translate-y: -10%;
    }

    .az-hero-{{ sid }} .az-hero__sticker--offset-outset {
      --az-hero-translate-x: -10%;
      --az-hero-translate-y: 10%;
    }

    @media screen and (max-width: 749px) {
      .az-hero-{{ sid }} .az-hero__frame {
        padding: 1.75rem 1rem 2.25rem;
      }

      .az-hero-{{ sid }} .az-hero__media {
        width: var(--az-hero-media-width-mobile);
        transform: translateY(var(--az-hero-media-offset-mobile));
      }

      .az-hero-{{ sid }} .az-hero__sticker span {
        font-size: 0.65rem;
      }
    }
  </style>

  <div class="az-hero__inner">
    <div class="az-hero__logo-row az-hero__logo-row--{{ section.settings.logo_alignment }}">
      <div class="az-hero__logo">
        {% liquid
          assign logo_image = section.settings.logo_image
        %}
        {% if logo_image != blank %}
          <img
            src="{{ logo_image | image_url: width: 1600 }}"
            width="{{ logo_image.width }}"
            height="{{ logo_image.height }}"
            alt="{{ section.settings.logo_alt }}"
            loading="lazy"
          >
        {% else %}
          {% liquid
            assign logo_text = section.settings.logo_text
          %}
          {% if logo_text == blank %}
            {% assign logo_text = shop.name %}
          {% endif %}
          <div class="az-hero__logo-text">
            {{ logo_text }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="az-hero__frame-wrapper">
      <div
        class="az-hero__frame"
        style="
          --az-hero-media-width-mobile: {{ section.settings.image_width_mobile }}%;
          --az-hero-media-offset-mobile: {{ section.settings.image_offset_mobile }}rem;
          --az-hero-media-width-desktop: {{ section.settings.image_width_desktop }}%;
          --az-hero-media-offset-desktop: {{ section.settings.image_offset_desktop }}rem;
        "
      >
        <div class="az-hero__media-shell">
          {% liquid
            assign hero_image = section.settings.hero_image
          %}
          {% if hero_image != blank %}
            <div class="az-hero__media az-hero__media--shape-{{ section.settings.image_shape }}">
              <img
                src="{{ hero_image | image_url: width: 2000 }}"
                width="{{ hero_image.width }}"
                height="{{ hero_image.height }}"
                alt="{{ section.settings.hero_alt }}"
                loading="lazy"
              >
            </div>
          {% else %}
            <div class="az-hero__media az-hero__media--shape-{{ section.settings.image_shape }}">
              <div class="az-hero__placeholder">
                {{ section.settings.placeholder_label }}
              </div>
            </div>
          {% endif %}
        </div>

        {% for block in section.blocks %}
          {% if block.type == 'sticker' %}
            {% liquid
              assign sticker_text = block.settings.text
              assign sticker_size = block.settings.size
              assign sticker_bg = block.settings.bg_color
              assign sticker_text_color = block.settings.text_color
              assign sticker_strength = block.settings.spin_speed
            %}
            {% if sticker_text == blank %}
              {% assign sticker_text = 'Sticker' %}
            {% endif %}
            <div
              class="az-hero__sticker az-hero__sticker--{{ block.settings.position }} az-hero__sticker--shape-{{ block.settings.shape }}"
              style="
                width: {{ sticker_size }}px;
                height: {{ sticker_size }}px;
                background-color: {{ sticker_bg }};
                color: {{ sticker_text_color }};
              "
              data-spin-strength="{{ sticker_strength }}"
              data-spin-direction="{{ block.settings.spin_direction }}"
              {{ block.shopify_attributes }}
            >
              <span>{{ sticker_text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% liquid
      assign button_label = section.settings.button_label
    %}
    {% if button_label != blank %}
      {% if section.settings.button_link != blank %}
        <div class="az-hero__cta-row">
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ button_label }}
          </a>
        </div>
      {% endif %}
    {% endif %}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var section = document.getElementById('az-hero-{{ sid }}');
      if (!section) return;
      var stickers = section.querySelectorAll('.az-hero__sticker');
      if (!stickers.length) return;

      function updateStickerRotation() {
        var rect = section.getBoundingClientRect();
        var viewportHeight = window.innerHeight || document.documentElement.clientHeight;
        var start = viewportHeight;
        var end = -rect.height;
        var rawProgress = (rect.top - start) / (end - start);
        var progress = Math.min(1, Math.max(0, rawProgress));

        stickers.forEach(function(el) {
          var strength = parseFloat(el.getAttribute('data-spin-strength')) || 18;
          var direction = el.getAttribute('data-spin-direction') === 'reverse' ? -1 : 1;
          var angle = direction * strength * 10 * progress;
          el.style.setProperty('--az-hero-rotation', angle + 'deg');
        });
      }

      updateStickerRotation();
      window.addEventListener('scroll', updateStickerRotation, { passive: true });
      window.addEventListener('resize', updateStickerRotation);
    });
  </script>
</section>

{% schema %}
{
  "name": "AZ hero with rotating",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo image alt text",
      "default": "Azourane logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text fallback",
      "default": "AZOURANE"
    },
    {
      "type": "select",
      "id": "logo_alignment",
      "label": "Logo alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Logo max width",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 75
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Hero image alt text",
      "default": "Azourane hero image"
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "Placeholder label",
      "default": "Add your hero image"
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "Image shape",
      "default": "rounded",
      "options": [
        {
          "value": "rounded",
          "label": "Rounded rectangle"
        },
        {
          "value": "blob",
          "label": "Organic blob"
        },
        {
          "value": "pill",
          "label": "Pill"
        }
      ]
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Media corner radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Image width on mobile",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_offset_mobile",
      "label": "Image vertical offset on mobile",
      "min": -4,
      "max": 4,
      "step": 0.5,
      "unit": "rem",
      "default": 2.5
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Image width on desktop",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "range",
      "id": "image_offset_desktop",
      "label": "Image vertical offset on desktop",
      "min": -6,
      "max": 6,
      "step": 0.5,
      "unit": "rem",
      "default": 0
    },
    {
      "type": "range",
      "id": "panel_radius",
      "label": "Panel corner radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "sticker",
      "name": "Sticker",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Sticker text",
          "default": "Sticker"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Sticker position",
          "default": "top-left",
          "options": [
            {
              "value": "top-left",
              "label": "Top left"
            },
            {
              "value": "top-right",
              "label": "Top right"
            },
            {
              "value": "bottom-left",
              "label": "Bottom left"
            },
            {
              "value": "bottom-right",
              "label": "Bottom right"
            }
          ]
        },
        {
          "type": "select",
          "id": "shape",
          "label": "Sticker shape",
          "default": "burst",
          "options": [
            {
              "value": "burst",
              "label": "Burst"
            },
            {
              "value": "circle",
              "label": "Circle"
            },
            {
              "value": "pill",
              "label": "Pill"
            }
          ]
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "default": "#9BFF3B"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "size",
          "label": "Sticker size",
          "min": 80,
          "max": 220,
          "step": 4,
          "unit": "px",
          "default": 140
        },
        {
          "type": "select",
          "id": "spin_direction",
          "label": "Spin direction",
          "default": "forward",
          "options": [
            {
              "value": "forward",
              "label": "Clockwise"
            },
            {
              "value": "reverse",
              "label": "Counter-clockwise"
            }
          ]
        },
        {
          "type": "range",
          "id": "spin_speed",
          "label": "Scroll spin strength",
          "min": 6,
          "max": 30,
          "step": 1,
          "unit": "x",
          "default": 18
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "AZ hero with rotating stickers",
      "blocks": [
        {
          "type": "sticker",
          "settings": {
            "text": "New",
            "position": "top-left",
            "shape": "burst",
            "bg_color": "#9BFF3B",
            "text_color": "#000000",
            "size": 140,
            "spin_direction": "forward",
            "spin_speed": 18
          }
        },
        {
          "type": "sticker",
          "settings": {
            "text": "Hydrated skin",
            "position": "top-right",
            "shape": "burst",
            "bg_color": "#FFEB3B",
            "text_color": "#000000",
            "size": 140,
            "spin_direction": "reverse",
            "spin_speed": 20
          }
        },
        {
          "type": "sticker",
          "settings": {
            "text": "From Morocco",
            "position": "bottom-left",
            "shape": "pill",
            "bg_color": "#FFFFFF",
            "text_color": "#000000",
            "size": 160,
            "spin_direction": "forward",
            "spin_speed": 22
          }
        },
        {
          "type": "sticker",
          "settings": {
            "text": "Limited",
            "position": "bottom-right",
            "shape": "circle",
            "bg_color": "#FF4081",
            "text_color": "#FFFFFF",
            "size": 140,
            "spin_direction": "reverse",
            "spin_speed": 16
          }
        }
      ]
    }
  ]
}
{% endschema %}
