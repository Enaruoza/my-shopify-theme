{% comment %} AZOURANE Category Tiles with hover lift {% endcomment %}
<section class="az-category-tiles">
  <div class="az-container">
    <h2 class="az-h2">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="az-copy az-category-tiles__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="az-category-tiles__grid" data-tiles-observe>
      {% for block in section.blocks %}
        {% if block.type == 'tile' %}
          <a href="{{ block.settings.link | default: '#' }}" class="az-category-tiles__tile">
            <div class="az-category-tiles__image-wrap">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 800 }}" 
                     alt="{{ block.settings.title | escape }}"
                     width="400" height="400" loading="lazy"
                     class="az-category-tiles__image">
              {% else %}
                <div class="az-category-tiles__placeholder">Bez slike</div>
              {% endif %}
            </div>
            <div class="az-category-tiles__info">
              <h3 class="az-category-tiles__title">{{ block.settings.title }}</h3>
              {% if block.settings.caption != blank %}
                <p class="az-category-tiles__caption">{{ block.settings.caption }}</p>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
.az-category-tiles {
  background: #fff;
  padding: 60px 0;
}

.az-category-tiles__sub {
  margin: 0 0 40px;
  max-width: 700px;
}

.az-category-tiles__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.3s ease-out, transform 0.3s ease-out;
}

.az-category-tiles__grid.is-in {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .az-category-tiles__grid {
    opacity: 1;
    transform: none;
  }
}

.az-category-tiles__tile {
  display: block;
  text-decoration: none;
  border: 1px solid #e5e5e5;
  border-radius: 16px;
  overflow: hidden;
  background: #fff;
  transition: transform 0.24s ease-out, box-shadow 0.24s ease-out;
}

.az-category-tiles__tile:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.08);
}

@media (prefers-reduced-motion: reduce) {
  .az-category-tiles__tile:hover {
    transform: none;
  }
}

.az-category-tiles__image-wrap {
  aspect-ratio: 1;
  overflow: hidden;
  background: #f8f8f8;
}

.az-category-tiles__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease-out;
}

.az-category-tiles__tile:hover .az-category-tiles__image {
  transform: scale(1.05);
}

@media (prefers-reduced-motion: reduce) {
  .az-category-tiles__tile:hover .az-category-tiles__image {
    transform: none;
  }
}

.az-category-tiles__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 14px;
}

.az-category-tiles__info {
  padding: 20px;
}

.az-category-tiles__title {
  font-size: 18px;
  font-weight: 500;
  color: #111;
  margin: 0 0 6px;
}

.az-category-tiles__caption {
  font-size: 14px;
  color: #666;
  margin: 0;
  line-height: 1.4;
}
</style>

<script>
(function() {
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in');
        }
      });
    },
    { threshold: 0.1 }
  );
  
  document.querySelectorAll('[data-tiles-observe]').forEach(el => {
    observer.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "AZ Category Tiles",
  "settings": [
    { "type": "text", "id": "heading", "label": "Naslov", "default": "Odaberi po potrebi" },
    { "type": "text", "id": "subheading", "label": "Podnaslov", "default": "Suhoća, osjetljivost, oštećena kosa, svakodnevno čišćenje" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Pločica",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slika" },
        { "type": "text", "id": "title", "label": "Naslov", "default": "Čišćenje lica" },
        { "type": "text", "id": "caption", "label": "Opis", "default": "Nježna formula koja ne isušuje" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { 
      "name": "AZ Category Tiles",
      "blocks": [
        { "type": "tile", "settings": { "title": "Čišćenje lica", "caption": "AMAAN nježno pjeni" } },
        { "type": "tile", "settings": { "title": "Hidratacija lica", "caption": "AFOULKI opuncija i argan" } },
        { "type": "tile", "settings": { "title": "Maska za kosu", "caption": "TAWENZA mekoća i sjaj" } },
        { "type": "tile", "settings": { "title": "Prirodni sapuni", "caption": "Ručna izrada, biljni ekstrakti" } }
      ]
    }
  ]
}
{% endschema %}