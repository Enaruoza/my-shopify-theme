{% comment %}
  AZOURANE Hero Video - Immersive storytelling
  Mobile: Vertical video + swipe up
  Desktop: Full-width cinematic
{% endcomment %}

<section class="az-hero-video" data-section-id="{{ section.id }}">
  <div class="az-hero-video__container">
    <div class="az-hero-video__media">
      {% if section.settings.video_url != blank %}
        <video class="az-hero-video__video" 
               autoplay muted loop playsinline
               poster="{{ section.settings.poster | image_url: width: 2000 }}">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.image != blank %}
        <picture>
          <source media="(max-width: 768px)" 
                  srcset="{{ section.settings.mobile_image | default: section.settings.image | image_url: width: 800 }}">
          <img src="{{ section.settings.image | image_url: width: 2000 }}"
               alt="{{ section.settings.image_alt | escape }}"
               width="2000" height="1000" loading="eager"
               class="az-hero-video__image">
        </picture>
      {% endif %}
      
      <div class="az-hero-video__overlay"></div>
    </div>
    
    <div class="az-hero-video__content">
      <div class="az-hero-video__inner">
        {% if section.settings.subtitle %}
          <p class="az-hero-video__subtitle" data-aos="fade-up">
            {{ section.settings.subtitle }}
          </p>
        {% endif %}
        
        <h1 class="az-hero-video__title" data-aos="fade-up" data-aos-delay="100">
          {{ section.settings.title | default: 'Pure Beauty, Naturally' }}
        </h1>
        
        {% if section.settings.description %}
          <p class="az-hero-video__description" data-aos="fade-up" data-aos-delay="200">
            {{ section.settings.description }}
          </p>
        {% endif %}
        
        <div class="az-hero-video__cta" data-aos="fade-up" data-aos-delay="300">
          {% if section.settings.cta_primary_text %}
            <a href="{{ section.settings.cta_primary_url }}" 
               class="az-button az-button--primary az-button--large">
              {{ section.settings.cta_primary_text }}
            </a>
          {% endif %}
          
          {% if section.settings.cta_secondary_text %}
            <a href="{{ section.settings.cta_secondary_url }}" 
               class="az-button az-button--ghost az-button--large">
              {{ section.settings.cta_secondary_text }}
            </a>
          {% endif %}
        </div>
      </div>
      
      <div class="az-hero-video__scroll" aria-hidden="true">
        <span>Scroll</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14m0 0l7-7m-7 7l-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
.az-hero-video {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
  background: var(--color-background, #000);
}

.az-hero-video__container {
  position: relative;
  width: 100%;
  height: 100%;
}

.az-hero-video__media {
  position: absolute;
  inset: 0;
}

.az-hero-video__video,
.az-hero-video__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.az-hero-video__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, 
    rgba(0,0,0,0.2) 0%, 
    rgba(0,0,0,0.4) 100%);
}

.az-hero-video__content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: var(--spacing-xl);
  color: var(--color-text-inverse, #fff);
}

.az-hero-video__inner {
  max-width: 800px;
  width: 100%;
}

.az-hero-video__subtitle {
  font-size: var(--font-size-sm);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  opacity: 0.9;
  margin-bottom: var(--spacing-md);
}

.az-hero-video__title {
  font-size: clamp(2.5rem, 8vw, 5rem);
  font-weight: var(--font-weight-bold);
  line-height: 1.1;
  margin-bottom: var(--spacing-lg);
}

.az-hero-video__description {
  font-size: var(--font-size-lg);
  opacity: 0.9;
  max-width: 600px;
  margin: 0 auto var(--spacing-xl);
  line-height: 1.6;
}

.az-hero-video__cta {
  display: flex;
  gap: var(--spacing-md);
  justify-content: center;
  flex-wrap: wrap;
}

.az-hero-video__scroll {
  position: absolute;
  bottom: var(--spacing-xl);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  opacity: 0.7;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(10px); }
}

/* Mobile Specific */
@media (max-width: 768px) {
  .az-hero-video {
    height: 100vh;
    min-height: -webkit-fill-available;
  }
  
  .az-hero-video__content {
    padding: var(--spacing-lg) var(--spacing-md);
  }
  
  .az-hero-video__title {
    font-size: clamp(2rem, 10vw, 3rem);
  }
  
  .az-hero-video__description {
    font-size: var(--font-size-base);
  }
  
  .az-hero-video__cta {
    flex-direction: column;
    width: 100%;
  }
  
  .az-hero-video__cta .az-button {
    width: 100%;
  }
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  .az-hero-video__video {
    display: none;
  }
  
  .az-hero-video__scroll {
    animation: none;
  }
}
</style>

<script>
// Intersection Observer for fade-in animations
(function() {
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -10% 0px'
  };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('aos-animate');
      }
    });
  }, observerOptions);
  
  document.querySelectorAll('[data-aos]').forEach(el => {
    observer.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "AZ Hero Video",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "MP4 format recommended. Falls back to image if not provided."
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Video Poster/Fallback Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (Optional)",
      "info": "Vertical image for mobile devices"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Hero image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "AZOURANE MOROCCAN COSMETICS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pure Beauty,<br>Naturally"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover the ancient secrets of Moroccan beauty with our pure, natural formulations."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Text Size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "xlarge", "label": "Extra Large" }
      ],
      "default": "large"
    }
  ],
  "presets": [
    {
      "name": "AZ Hero Video"
    }
  ]
}
{% endschema %}