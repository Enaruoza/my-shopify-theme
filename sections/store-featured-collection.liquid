<section class="section-spacing page-width">
  
  <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 60px;">
    {%- if section.settings.heading != 'AUTO' and section.settings.heading != blank -%}
      <h2 class="h2" style="margin: 0;">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection != blank -%}
      <a href="{{ collection.url }}" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; border-bottom: 1px solid currentColor; padding-bottom: 4px;">View All &rarr;</a>
    {%- endif -%}
  </div>
  
  <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <div class="product-card">
          <a href="{{ product.url }}" style="display: block;">
            <div class="product-card__image-wrapper">
              {%- if product.featured_media -%}
                {{ product.featured_media | image_url: width: 800 | image_tag: alt: product.title }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </a>
          
          <h3 class="product-card__title">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h3>
          <div class="product-card__price">{{ product.price | money }}</div>
          
          <form method="post" action="{{ routes.cart_add_url }}" class="form" style="width: 100%;">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" class="button" style="width: 100%; border-radius: var(--radius-button);" {% if product.available == false %}disabled{% endif %}>
              {%- if product.available -%}
                Add to cart
              {%- else -%}
                Sold out
              {%- endif -%}
            </button>
          </form>
          
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="product-card">
           <div class="product-card__image-wrapper">
             {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
           </div>
           <h3 class="product-card__title">Example Product</h3>
           <div class="product-card__price">$85.00</div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Essentials"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
