<section class="page-width" style="padding: 80px 0;">
  {%- if section.settings.heading != 'AUTO' and section.settings.heading != blank -%}
    <h2 class="h2" style="text-align: center; margin-bottom: 50px;">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- assign collection = collections[section.settings.collection] -%}
  
  {%- if collection != blank and collection.products_count > 0 -%}
    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px;">
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <div class="product-card" style="text-align: center;">
          <a href="{{ product.url }}" style="display: block; position: relative; margin-bottom: 20px;">
            <div class="product-card__image-wrapper" style="aspect-ratio: 1; background: #eee;">
              {%- if product.featured_media -%}
                {{ product.featured_media | image_url: width: 600 | image_tag: width: product.featured_media.width, height: product.featured_media.height, alt: product.title, style: 'object-fit: cover; width: 100%; height: 100%;' }}
              {%- endif -%}
            </div>
          </a>
          
          <h3 class="h5" style="margin-bottom: 8px;"><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <div class="product-card__price" style="margin-bottom: 15px;">{{ product.price | money }}</div>
          
          <form method="post" action="{{ routes.cart_add_url }}" id="product-form-{{ product.id }}" accept-charset="UTF-8" class="form" enctype="multipart/form-data">
            <input type="hidden" name="form_type" value="product">
            <input type="hidden" name="utf8" value="✓">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit" name="add" class="button" style="width: 100%;" {% if product.available == false %}disabled{% endif %}>
              {%- if product.available -%}
                Add to cart
              {%- else -%}
                Sold out
              {%- endif -%}
            </button>
          </form>
          
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div style="text-align: center; padding: 40px; background: #f9f9f9;">
      <p>Select a collection to view products.</p>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
