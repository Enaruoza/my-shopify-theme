{% assign sid = section.id | replace:'_','' | downcase %}
{% assign layout_mode = section.settings.layout_mode %}
{% assign total_bundles = 0 %}
{% for b in section.blocks %}{% if b.type == 'bundle' %}{% assign total_bundles = total_bundles | plus: 1 %}{% endif %}{% endfor %}
<style>
.azr-bundles-{{ sid }}{--wrap:{{ section.settings.container_width }}px;--gap:{{ section.settings.card_gap }}px;--pad:{{ section.settings.section_padding }}px;--r:{{ section.settings.card_radius }}px;--btnr:{{ section.settings.btn_radius }}px;--accent:{{ section.settings.accent_color }};background:{{ section.settings.background }};font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;padding:var(--pad) 0}
.azr-bundles-{{ sid }} .wrap{max-width:var(--wrap);margin:0 auto;padding:0 20px}
.azr-bundles-{{ sid }} .hd{display:grid;row-gap:8px;margin-bottom:18px;text-align:center}
.azr-bundles-{{ sid }} .title{margin:0;font-weight:800;color:#111;font-size:{{ section.settings.title_size }}px}
.azr-bundles-{{ sid }} .sub{margin:0;color:#555;font-size:{{ section.settings.subtitle_size }}px}
.azr-bundles-{{ sid }} .card{background:#fff;border-radius:var(--r);box-shadow:0 10px 24px rgba(0,0,0,.08);overflow:hidden;display:flex;flex-direction:column;opacity:0;transform:translateY(14px)}
.azr-bundles-{{ sid }} .card.is-in{opacity:1;transform:none;transition:opacity .45s ease,transform .45s ease}
.azr-bundles-{{ sid }} .img{position:relative;overflow:hidden;aspect-ratio:16/9}
.azr-bundles-{{ sid }} .img>img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s}
.azr-bundles-{{ sid }} .card:hover .img>img{transform:scale(1.04)}
.azr-bundles-{{ sid }} .badge{position:absolute;top:12px;left:12px;background:var(--accent);color:#fff;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:800}
.azr-bundles-{{ sid }} .cnt{padding:18px;display:flex;gap:12px;flex-direction:column}
.azr-bundles-{{ sid }} .ctitle{margin:0;font-weight:800;color:#111;font-size:20px}
.azr-bundles-{{ sid }} .price-row{display:flex;gap:12px;align-items:baseline;flex-wrap:wrap}
.azr-bundles-{{ sid }} .bundle{font-weight:800;color:#111}
.azr-bundles-{{ sid }} .full s{opacity:.6}
.azr-bundles-{{ sid }} .save{color:#185f3a;font-weight:800;background:#eef6f0;border:1px solid #cfe7d9;border-radius:8px;padding:2px 6px;font-size:12px}
.azr-bundles-{{ sid }} .items-label{margin:6px 0 4px;font-size:12px;color:#6b7280;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
.azr-bundles-{{ sid }} .pucks{display:flex;align-items:center}
.azr-bundles-{{ sid }} .puck{width:44px;height:44px;border-radius:50%;overflow:hidden;background:#f5f5f5;border:2px solid #fff;box-shadow:0 0 0 1px #e5e7eb}
.azr-bundles-{{ sid }} .puck:not(:first-child){margin-left:-12px}
.azr-bundles-{{ sid }} .puck img{width:100%;height:100%;object-fit:cover}
.azr-bundles-{{ sid }} .more{margin-left:8px;font-size:13px;font-weight:700;color:#6b7280}
.azr-bundles-{{ sid }} .cta{margin-top:8px;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.azr-bundles-{{ sid }} .btn{appearance:none;border:0;background:var(--accent);color:#fff;border-radius:var(--btnr);padding:14px 16px;font-weight:800;cursor:pointer;display:inline-flex;gap:8px;align-items:center;justify-content:center;width:100%;transition:filter .15s}
.azr-bundles-{{ sid }} .btn:hover{filter:brightness(.95)}
.azr-bundles-{{ sid }} .btn[disabled]{opacity:.6;cursor:not-allowed}
.azr-bundles-{{ sid }} .btn .ic{width:18px;height:18px;display:inline-block}
.azr-bundles-{{ sid }} .btn .spin{width:16px;height:16px;border:2px solid rgba(255,255,255,.5);border-top-color:#fff;border-radius:50%;display:none;animation:azrspin 1s linear infinite}
.azr-bundles-{{ sid }} .btn[aria-busy="true"] .spin{display:inline-block}
@keyframes azrspin{to{transform:rotate(360deg)}}
.azr-bundles-{{ sid }} .grid-desktop{display:flex;flex-wrap:wrap;gap:var(--gap);justify-content:center}
.azr-bundles-{{ sid }} .grid-desktop.grid--standard .card{flex:1 1 360px;max-width:360px}
.azr-bundles-{{ sid }} .grid-desktop.grid--highlight .card{flex:1 1 360px;max-width:360px}
.azr-bundles-{{ sid }} .grid-desktop.grid--highlight .card--featured{flex:1 1 720px;max-width:720px}
.azr-bundles-{{ sid }} .carousel{display:none}
@media (max-width:767px){
.azr-bundles-{{ sid }} .wrap{padding:0}
.azr-bundles-{{ sid }} .hd{padding:0 20px}
.azr-bundles-{{ sid }} .grid-desktop{display:none}
.azr-bundles-{{ sid }} .carousel{display:block}
.azr-bundles-{{ sid }} .track{display:flex!important;overflow-x:auto!important;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;gap:16px;padding:0 16px 6px;scrollbar-width:none;-ms-overflow-style:none}
.azr-bundles-{{ sid }} .track::-webkit-scrollbar{display:none}
.azr-bundles-{{ sid }} .slide{flex:0 0 86%;scroll-snap-align:center}
.azr-bundles-{{ sid }} .nav{display:flex;justify-content:center;align-items:center;gap:10px;padding:4px 16px 0}
.azr-bundles-{{ sid }} .dots{display:flex;gap:8px}
.azr-bundles-{{ sid }} .dot{width:8px;height:8px;border-radius:999px;background:#d1d5db;border:0}
.azr-bundles-{{ sid }} .dot.is-on{background:var(--accent)}
}
</style>

<div class="azr-bundles-{{ sid }}" data-section-id="{{ sid }}">
  <div class="wrap">
    <div class="hd">
      <h2 class="title">{{ section.settings.title }}</h2>
      <p class="sub">{% if section.settings.subtitle != blank %}{{ section.settings.subtitle }}{% else %}Najtraženije kombinacije za veću vrijednost.{% endif %}</p>
    </div>

    <div class="grid-desktop {% if layout_mode == 'highlight_first' and total_bundles > 2 %}grid--highlight{% else %}grid--standard{% endif %}">
      {% for block in section.blocks %}
        {% if block.type == 'bundle' %}
          {% liquid
            assign full = 0
            assign product_count = 0
            assign p1 = block.settings.product_1
            if p1 != blank
              assign v1 = p1.selected_or_first_available_variant
              assign q1 = block.settings.qty_1 | default: 1
              assign full = full | plus: v1.price | times: q1
              assign product_count = product_count | plus: 1
            endif
            assign p2 = block.settings.product_2
            if p2 != blank
              assign v2 = p2.selected_or_first_available_variant
              assign q2 = block.settings.qty_2 | default: 1
              assign full = full | plus: v2.price | times: q2
              assign product_count = product_count | plus: 1
            endif
            assign p3 = block.settings.product_3
            if p3 != blank
              assign v3 = p3.selected_or_first_available_variant
              assign q3 = block.settings.qty_3 | default: 1
              assign full = full | plus: v3.price | times: q3
              assign product_count = product_count | plus: 1
            endif
            assign p4 = block.settings.product_4
            if p4 != blank
              assign v4 = p4.selected_or_first_available_variant
              assign q4 = block.settings.qty_4 | default: 1
              assign full = full | plus: v4.price | times: q4
              assign product_count = product_count | plus: 1
            endif
            assign p5 = block.settings.product_5
            if p5 != blank
              assign v5 = p5.selected_or_first_available_variant
              assign q5 = block.settings.qty_5 | default: 1
              assign full = full | plus: v5.price | times: q5
              assign product_count = product_count | plus: 1
            endif
            assign p6 = block.settings.product_6
            if p6 != blank
              assign v6 = p6.selected_or_first_available_variant
              assign q6 = block.settings.qty_6 | default: 1
              assign full = full | plus: v6.price | times: q6
              assign product_count = product_count | plus: 1
            endif
            if product_count == 0
              continue
            endif
            assign disc_major = block.settings.discount_amount | default: 0
            assign disc_cents = disc_major | times: 100
            assign bundle_price_cents = full | minus: disc_cents
            if bundle_price_cents < 0
              assign bundle_price_cents = 0
            endif
            assign save_cents = full | minus: bundle_price_cents
            assign payload = ''
            if v1
              assign payload = payload | append: v1.id | append: ':' | append: q1 | append: ';'
            endif
            if v2
              assign payload = payload | append: v2.id | append: ':' | append: q2 | append: ';'
            endif
            if v3
              assign payload = payload | append: v3.id | append: ':' | append: q3 | append: ';'
            endif
            if v4
              assign payload = payload | append: v4.id | append: ':' | append: q4 | append: ';'
            endif
            if v5
              assign payload = payload | append: v5.id | append: ':' | append: q5 | append: ';'
            endif
            if v6
              assign payload = payload | append: v6.id | append: ':' | append: q6 | append: ';'
            endif
            assign available = 1
            if v1 and v1.available == false
              assign available = 0
            endif
            if v2 and v2.available == false
              assign available = 0
            endif
            if v3 and v3.available == false
              assign available = 0
            endif
            if v4 and v4.available == false
              assign available = 0
            endif
            if v5 and v5.available == false
              assign available = 0
            endif
            if v6 and v6.available == false
              assign available = 0
            endif
          %}
          <article class="card{% if forloop.first and layout_mode == 'highlight_first' and total_bundles > 2 %} card--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="img">
              {% assign iw = 1200 %}
              {% if block.settings.card_image %}<img src="{{ block.settings.card_image | image_url: width: iw }}" width="{{ iw }}" height="{{ iw | divided_by: block.settings.card_image.aspect_ratio | round }}" alt="{{ block.settings.title | escape }}" loading="lazy" decoding="async">
              {% elsif p1 and p1.featured_media %}<img src="{{ p1.featured_media | image_url: width: iw }}" width="{{ iw }}" height="{{ iw | divided_by: p1.featured_media.aspect_ratio | round }}" alt="{{ block.settings.title | escape }}" loading="lazy" decoding="async">
              {% else %}{{ 'image' | placeholder_svg_tag }}{% endif %}
              {% assign badge_txt = block.settings.badge_text | default: 'Ušteda' %}
              {% if badge_txt == 'AUTO' %}{% assign badge_txt = 'Ušteda ' | append: save_cents | money %}{% endif %}
              <span class="badge">{{ badge_txt }}</span>
            </div>
            <div class="cnt">
              <h3 class="ctitle">{% if block.settings.title != blank %}{{ block.settings.title }}{% else %}Set{% endif %}</h3>
              <div class="price-row">
                <div class="bundle">{{ bundle_price_cents | money }}</div>
                <div class="full"><s>{{ full | money }}</s></div>
                {% if save_cents > 0 %}<div class="save">Ušteda {{ save_cents | money }}</div>{% endif %}
              </div>
              <div class="items-label">Sadržaj seta</div>
              <div class="pucks">
                {% assign shown = 0 %}
                {% if p1 != blank and shown < 4 %}<span class="puck">{% if p1.featured_media %}<img src="{{ p1.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if p2 != blank and shown < 4 %}<span class="puck">{% if p2.featured_media %}<img src="{{ p2.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if p3 != blank and shown < 4 %}<span class="puck">{% if p3.featured_media %}<img src="{{ p3.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if p4 != blank and shown < 4 %}<span class="puck">{% if p4.featured_media %}<img src="{{ p4.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if p5 != blank and shown < 4 %}<span class="puck">{% if p5.featured_media %}<img src="{{ p5.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if p6 != blank and shown < 4 %}<span class="puck">{% if p6.featured_media %}<img src="{{ p6.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                {% if product_count > 4 %}<span class="more">+{{ product_count | minus: 4 }}</span>{% endif %}
              </div>
              {% assign dc = block.settings.discount_code | default: 'AUTO' %}
              <div class="cta">
                <button class="btn js-bundle-add" {% if available == 0 %}disabled{% endif %} data-items="{{ payload | strip }}" {% if dc != 'AUTO' %}data-discount="{{ dc | strip }}"{% endif %}>
                  <span class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7 4h-2l-1 2v2h2l3.6 7.59-1.35 2.44a1 1 0 0 0 .9 1.47h10.2v-2h-8.88l.9-1.63h6.58a1 1 0 0 0 .92-.62l3-7A1 1 0 0 0 21 6h-12l-1.2-2zM7 20a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm10 0a2 2 0 1 0 .001 4A2 2 0 0 0 17 20z"/></svg></span>
                  <span>Dodaj set u korpu</span>
                  <span class="spin" aria-hidden="true"></span>
                </button>
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="carousel">
      <div class="track" data-track>
        {% for block in section.blocks %}
          {% if block.type == 'bundle' %}
            {% liquid
              assign full = 0
              assign product_count = 0
              assign p1 = block.settings.product_1
              if p1 != blank
                assign v1 = p1.selected_or_first_available_variant
                assign q1 = block.settings.qty_1 | default: 1
                assign full = full | plus: v1.price | times: q1
                assign product_count = product_count | plus: 1
              endif
              assign p2 = block.settings.product_2
              if p2 != blank
                assign v2 = p2.selected_or_first_available_variant
                assign q2 = block.settings.qty_2 | default: 1
                assign full = full | plus: v2.price | times: q2
                assign product_count = product_count | plus: 1
              endif
              assign p3 = block.settings.product_3
              if p3 != blank
                assign v3 = p3.selected_or_first_available_variant
                assign q3 = block.settings.qty_3 | default: 1
                assign full = full | plus: v3.price | times: q3
                assign product_count = product_count | plus: 1
              endif
              assign p4 = block.settings.product_4
              if p4 != blank
                assign v4 = p4.selected_or_first_available_variant
                assign q4 = block.settings.qty_4 | default: 1
                assign full = full | plus: v4.price | times: q4
                assign product_count = product_count | plus: 1
              endif
              assign p5 = block.settings.product_5
              if p5 != blank
                assign v5 = p5.selected_or_first_available_variant
                assign q5 = block.settings.qty_5 | default: 1
                assign full = full | plus: v5.price | times: q5
                assign product_count = product_count | plus: 1
              endif
              assign p6 = block.settings.product_6
              if p6 != blank
                assign v6 = p6.selected_or_first_available_variant
                assign q6 = block.settings.qty_6 | default: 1
                assign full = full | plus: v6.price | times: q6
                assign product_count = product_count | plus: 1
              endif
              if product_count == 0
                continue
              endif
              assign disc_major = block.settings.discount_amount | default: 0
              assign disc_cents = disc_major | times: 100
              assign bundle_price_cents = full | minus: disc_cents
              if bundle_price_cents < 0
                assign bundle_price_cents = 0
              endif
              assign save_cents = full | minus: bundle_price_cents
              assign payload = ''
              if v1
                assign payload = payload | append: v1.id | append: ':' | append: q1 | append: ';'
              endif
              if v2
                assign payload = payload | append: v2.id | append: ':' | append: q2 | append: ';'
              endif
              if v3
                assign payload = payload | append: v3.id | append: ':' | append: q3 | append: ';'
              endif
              if v4
                assign payload = payload | append: v4.id | append: ':' | append: q4 | append: ';'
              endif
              if v5
                assign payload = payload | append: v5.id | append: ':' | append: q5 | append: ';'
              endif
              if v6
                assign payload = payload | append: v6.id | append: ':' | append: q6 | append: ';'
              endif
              assign available = 1
              if v1 and v1.available == false
                assign available = 0
              endif
              if v2 and v2.available == false
                assign available = 0
              endif
              if v3 and v3.available == false
                assign available = 0
              endif
              if v4 and v4.available == false
                assign available = 0
              endif
              if v5 and v5.available == false
                assign available = 0
              endif
              if v6 and v6.available == false
                assign available = 0
              endif
            %}
            <div class="slide">
              <article class="card">
                <div class="img">
                  {% assign iw = 1200 %}
                  {% if block.settings.card_image %}<img src="{{ block.settings.card_image | image_url: width: iw }}" width="{{ iw }}" height="{{ iw | divided_by: block.settings.card_image.aspect_ratio | round }}" alt="{{ block.settings.title | escape }}" loading="lazy" decoding="async">
                  {% elsif p1 and p1.featured_media %}<img src="{{ p1.featured_media | image_url: width: iw }}" width="{{ iw }}" height="{{ iw | divided_by: p1.featured_media.aspect_ratio | round }}" alt="{{ block.settings.title | escape }}" loading="lazy" decoding="async">
                  {% else %}{{ 'image' | placeholder_svg_tag }}{% endif %}
                  {% assign badge_txt = block.settings.badge_text | default: 'Ušteda' %}
                  {% if badge_txt == 'AUTO' %}{% assign badge_txt = 'Ušteda ' | append: save_cents | money %}{% endif %}
                  <span class="badge">{{ badge_txt }}</span>
                </div>
                <div class="cnt">
                  <h3 class="ctitle">{% if block.settings.title != blank %}{{ block.settings.title }}{% else %}Set{% endif %}</h3>
                  <div class="price-row">
                    <div class="bundle">{{ bundle_price_cents | money }}</div>
                    <div class="full"><s>{{ full | money }}</s></div>
                    {% if save_cents > 0 %}<div class="save">Ušteda {{ save_cents | money }}</div>{% endif %}
                  </div>
                  <div class="items-label">Sadržaj seta</div>
                  <div class="pucks">
                    {% assign shown = 0 %}
                    {% if p1 != blank and shown < 4 %}<span class="puck">{% if p1.featured_media %}<img src="{{ p1.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if p2 != blank and shown < 4 %}<span class="puck">{% if p2.featured_media %}<img src="{{ p2.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if p3 != blank and shown < 4 %}<span class="puck">{% if p3.featured_media %}<img src="{{ p3.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if p4 != blank and shown < 4 %}<span class="puck">{% if p4.featured_media %}<img src="{{ p4.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if p5 != blank and shown < 4 %}<span class="puck">{% if p5.featured_media %}<img src="{{ p5.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if p6 != blank and shown < 4 %}<span class="puck">{% if p6.featured_media %}<img src="{{ p6.featured_media | image_url: width: 88, height: 88, crop: 'center' }}" width="44" height="44" loading="lazy" decoding="async">{% endif %}</span>{% assign shown = shown | plus: 1 %}{% endif %}
                    {% if product_count > 4 %}<span class="more">+{{ product_count | minus: 4 }}</span>{% endif %}
                  </div>
                  {% assign dc = block.settings.discount_code | default: 'AUTO' %}
                  <div class="cta">
                    <button class="btn js-bundle-add" {% if available == 0 %}disabled{% endif %} data-items="{{ payload | strip }}" {% if dc != 'AUTO' %}data-discount="{{ dc | strip }}"{% endif %}>
                      <span class="ic" aria-hidden="true"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7 4h-2l-1 2v2h2l3.6 7.59-1.35 2.44a1 1 0 0 0 .9 1.47h10.2v-2h-8.88l.9-1.63h6.58a1 1 0 0 0 .92-.62l3-7A1 1 0 0 0 21 6h-12l-1.2-2zM7 20a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm10 0a2 2 0 1 0 .001 4A2 2 0 0 0 17 20z"/></svg></span>
                      <span>Dodaj set u korpu</span>
                      <span class="spin" aria-hidden="true"></span>
                    </button>
                  </div>
                </div>
              </article>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if total_bundles > 1 %}
      <div class="nav">
        <div class="dots" data-dots></div>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function(){
  const root=document.querySelector('.azr-bundles-{{ sid }}');if(!root)return;
  function addItems(pairs){const items=pairs.map(p=>({id:Number(p.id),quantity:Number(p.q)}));return fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items})}).then(r=>r.json());}
  function parsePayload(s){const out=[];if(!s)return out;s.split(';').forEach(pair=>{const parts=pair.split(':');if(parts.length===2){const id=parts[0].trim(),q=parts[1].trim();if(id&&q){out.push({id,q});}}});return out;}
  const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('is-in');io.unobserve(e.target);}})},{threshold:.12});
  root.querySelectorAll('.card').forEach(c=>io.observe(c));
  root.addEventListener('click',function(e){
    const btn=e.target.closest('.js-bundle-add');if(btn){e.preventDefault();if(btn.hasAttribute('disabled'))return;const items=parsePayload(btn.getAttribute('data-items'));if(items.length===0)return;btn.setAttribute('disabled','');btn.setAttribute('aria-busy','true');addItems(items).then(()=>{
      
      // FIX: Check for bundle-specific code, then fall back to localStorage code from popup
      let code = btn.getAttribute('data-discount') || '';
      if (!code) {
        try { code = localStorage.getItem('azr_discount_code') || ''; } catch(e){}
      }
      
      {% if section.settings.discount_apply_mode == 'redirect_cart' %}if(code){window.location.href='/discount/'+encodeURIComponent(code)+'?redirect=/cart';return;}{% endif %}document.dispatchEvent(new CustomEvent('azr:bundle-added',{detail:{items,code}}));}).catch(()=>{}).finally(()=>{btn.removeAttribute('aria-busy');btn.removeAttribute('disabled');});}
  });
  const track=root.querySelector('[data-track]');if(!track)return;
  const dotsHolder=root.querySelector('[data-dots]');const slides=Array.from(track.querySelectorAll('.slide'));
  function cardW(){const s=slides[0];if(!s)return 0;const gap=parseFloat(getComputedStyle(track).gap||'16');return s.clientWidth+gap;}
  function updateDots(){if(!dotsHolder)return;const w=cardW();let idx=0;if(w>0)idx=Math.round(track.scrollLeft/w);Array.from(dotsHolder.children).forEach((d,i)=>{if(i===idx)d.classList.add('is-on');else d.classList.remove('is-on');});}
  if(dotsHolder){dotsHolder.innerHTML='';slides.forEach((_,i)=>{const b=document.createElement('button');b.className='dot'+(i===0?' is-on':'');b.addEventListener('click',()=>track.scrollTo({left:i*cardW(),behavior:'smooth'}));dotsHolder.appendChild(b);});}
  track.addEventListener('scroll',()=>{window.requestAnimationFrame(updateDots);},{passive:true});
  window.addEventListener('resize',updateDots);
  updateDots();
})();
</script>

