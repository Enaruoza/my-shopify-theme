{% comment %} AZOURANE Education slices from blog {% endcomment %}
<section class="az-education">
  <div class="az-container">
    <h2 class="az-h2">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="az-copy az-education__sub">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="az-education__grid">
      {% if section.settings.blog != blank %}
        {% for article in blogs[section.settings.blog].articles limit: 3 %}
          <a href="{{ article.url }}" class="az-education__card">
            <div class="az-education__image-wrap">
              {% if article.image %}
                <img src="{{ article.image | image_url: width: 800 }}" 
                     alt="{{ article.image.alt | default: article.title | escape }}"
                     width="400" height="250" loading="lazy"
                     class="az-education__image">
              {% else %}
                <div class="az-education__placeholder">Bez slike</div>
              {% endif %}
            </div>
            <div class="az-education__content">
              <h3 class="az-education__title">{{ article.title }}</h3>
              {% if article.excerpt != blank %}
                <p class="az-education__excerpt">
                  {{ article.excerpt | strip_html | truncate: 120 }}
                </p>
              {% endif %}
              <span class="az-education__link">Pročitaj više →</span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <div class="az-education__empty">
          Izaberi blog u podešavanjima sekcije
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
.az-education {
  background: #fafafa;
  padding: 60px 0;
}

.az-education__sub {
  margin: 0 0 40px;
}

.az-education__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
}

.az-education__card {
  display: block;
  text-decoration: none;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 16px;
  overflow: hidden;
  transition: transform 0.24s ease-out, box-shadow 0.24s ease-out;
}

.az-education__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.08);
}

@media (prefers-reduced-motion: reduce) {
  .az-education__card:hover {
    transform: none;
  }
}

.az-education__image-wrap {
  aspect-ratio: 16/10;
  overflow: hidden;
  background: #f8f8f8;
}

.az-education__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.az-education__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 14px;
}

.az-education__content {
  padding: 20px;
}

.az-education__title {
  font-size: 18px;
  font-weight: 500;
  color: #111;
  margin: 0 0 8px;
  line-height: 1.3;
}

.az-education__excerpt {
  font-size: 14px;
  color: #666;
  margin: 0 0 12px;
  line-height: 1.5;
}

.az-education__link {
  font-size: 14px;
  font-weight: 500;
  color: #111;
  transition: transform 0.2s ease-out;
  display: inline-block;
}

.az-education__card:hover .az-education__link {
  transform: translateX(4px);
}

@media (prefers-reduced-motion: reduce) {
  .az-education__card:hover .az-education__link {
    transform: none;
  }
}

.az-education__empty {
  grid-column: 1 / -1;
  padding: 60px;
  text-align: center;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 16px;
  color: #666;
}
</style>

{% schema %}
{
  "name": "AZ Education Slices",
  "settings": [
    { "type": "text", "id": "heading", "label": "Naslov", "default": "Znanje i rutina" },
    { "type": "text", "id": "subheading", "label": "Podnaslov", "default": "Kratki vodiči i savjeti za kožu i kosu." },
    { "type": "blog", "id": "blog", "label": "Blog" }
  ],
  "presets": [{ "name": "AZ Education Slices" }]
}
{% endschema %}