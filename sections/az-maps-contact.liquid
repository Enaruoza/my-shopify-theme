{%- style -%}
.section-{{ section.id }}{padding-top:{{ section.settings.padding_top | times: 0.75 | round: 0 }}px;padding-bottom:{{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px}
.mapc-grid-{{ section.id }}{display:grid;grid-template-columns:1fr;background-color:rgb(var(--color-background));color:rgb(var(--color-foreground))}
.mapc-content-{{ section.id }}{display:flex;flex-direction:column;justify-content:center;padding:3rem 2rem}
.mapc-content-{{ section.id }}>*+*{margin-top:1.5rem}
.mapc-mapwrap-{{ section.id }}{position:relative;width:100%;height:{{ section.settings.map_height_mobile }}px;overflow:hidden;border-radius:{{ section.settings.border_radius }}px}
.mapc-mapwrap-{{ section.id }} iframe,.mapc-mapwrap-{{ section.id }} .placeholder-svg{display:block;width:100%;height:100%;border:0}
{%- if section.settings.enable_filter -%}
.mapc-mapwrap-{{ section.id }} iframe{filter:grayscale({{ section.settings.grayscale }}%) hue-rotate({{ section.settings.hue_rotate }}deg) saturate({{ section.settings.saturate }}%) brightness({{ section.settings.brightness }}%) contrast({{ section.settings.contrast }}%)}
{%- endif -%}
{%- if section.settings.enable_overlay -%}
.mapc-overlay-{{ section.id }}{position:absolute;inset:0;background:{{ section.settings.overlay_color }};pointer-events:none}
{%- endif -%}
@media(min-width:750px){
.section-{{ section.id }}{padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}
.mapc-grid-{{ section.id }}{grid-template-columns:1fr 1fr}
.mapc-mapwrap-{{ section.id }}{height:{{ section.settings.map_height_desktop }}px}
.mapc-content-{{ section.id }}{padding:4rem 5rem}
{%- if section.settings.layout == 'map_right' -%}
.mapc-col-map-{{ section.id }}{order:2}
.mapc-content-{{ section.id }}{order:1}
{%- endif -%}
}
{%- endstyle -%}

<section class="section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.width == 'page' -%}<div class="page-width">{%- endif -%}

  <div class="mapc-grid-{{ section.id }}">
    <div class="mapc-col-map-{{ section.id }}">
      <div class="mapc-mapwrap-{{ section.id }}">
        {%- if section.settings.map_embed -%}
          {%- if section.settings.map_embed != 'AUTO' -%}
            {{ section.settings.map_embed }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if section.settings.enable_overlay -%}<div class="mapc-overlay-{{ section.id }}"></div>{%- endif -%}
      </div>
    </div>

    <div class="mapc-content-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            {%- if block.settings.heading -%}
              {%- if block.settings.heading != 'AUTO' -%}
                <h2 class="h2">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}
            {%- endif -%}
          {%- when 'text' -%}
            {%- assign txt_clean = block.settings.text | strip_html | strip -%}
            {%- if txt_clean -%}
              {%- if txt_clean != 'AUTO' -%}
                <div class="rte">{{ block.settings.text }}</div>
              {%- endif -%}
            {%- endif -%}
          {%- when 'button' -%}
            {%- if block.settings.button_label -%}
              {%- if block.settings.button_label != 'AUTO' -%}
                {%- if block.settings.button_link != blank -%}
                  <a href="{{ block.settings.button_link }}" class="button">{{ block.settings.button_label | escape }}</a>
                {%- endif -%}
              {%- endif -%}
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.width == 'page' -%}</div>{%- endif -%}
</section>

{% schema %}
{
  "name": "AZ Maps & Contact",
  "class": "az-section-map-contact",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "textarea", "id": "map_embed", "label": "Map embed (iframe)", "default": "<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2877.0204581281077!2d18.405541276825456!3d43.8554046393283!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4758c9255b78cb63%3A0x9057ef1fc203a5c0!2sAzourane%20Moroccan%20Cosmetics%20d.o.o!5e0!3m2!1sen!2sba!4v1762043990340!5m2!1sen!2sba\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "width", "label": "Section width", "options": [ { "value": "page", "label": "Page width" }, { "value": "full", "label": "Full width" } ], "default": "full" },
    { "type": "select", "id": "layout", "label": "Desktop layout", "options": [ { "value": "map_left", "label": "Map left, text right" }, { "value": "map_right", "label": "Map right, text left" } ], "default": "map_left" },
    { "type": "range", "id": "map_height_desktop", "label": "Map height (desktop)", "min": 400, "max": 800, "step": 20, "unit": "px", "default": 520 },
    { "type": "range", "id": "map_height_mobile", "label": "Map height (mobile)", "min": 280, "max": 520, "step": 10, "unit": "px", "default": 360 },
    { "type": "range", "id": "border_radius", "label": "Map corner radius", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 12 },
    { "type": "header", "content": "Theming: overlay" },
    { "type": "checkbox", "id": "enable_overlay", "label": "Enable color overlay", "default": false },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#00000022" },
    { "type": "header", "content": "Theming: CSS filter" },
    { "type": "checkbox", "id": "enable_filter", "label": "Enable CSS filter", "default": false },
    { "type": "range", "id": "grayscale", "label": "Grayscale", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 0 },
    { "type": "range", "id": "hue_rotate", "label": "Hue rotate", "min": 0, "max": 360, "step": 5, "unit": "deg", "default": 0 },
    { "type": "range", "id": "saturate", "label": "Saturate", "min": 0, "max": 200, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "brightness", "label": "Brightness", "min": 50, "max": 150, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "contrast", "label": "Contrast", "min": 50, "max": 150, "step": 5, "unit": "%", "default": 100 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    { "type": "heading", "name": "Heading", "limit": 1, "settings": [ { "type": "text", "id": "heading", "label": "Heading", "default": "AUTO" } ] },
    { "type": "text", "name": "Text", "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p>AUTO</p>" } ] },
    { "type": "button", "name": "Button", "limit": 1, "settings": [ { "type": "text", "id": "button_label", "label": "Button label", "default": "AUTO" }, { "type": "url", "id": "button_link", "label": "Button link" } ] }
  ],
  "presets": [ { "name": "AZ Maps & Contact", "blocks": [ { "type": "heading" }, { "type": "text" }, { "type": "button" } ] } ]
}
{% endschema %}
