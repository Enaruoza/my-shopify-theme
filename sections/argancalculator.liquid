{% comment %}
  ** Argan Routine Calculator - v23 (Definitive Experience) **
  - LANGUAGE: All Bosnian copy updated with more elegant and persuasive phrasing.
  - VISUAL DEPTH: Results panel re-architected into a layered card design.
  - SMART UPSELL: Automatically recommends a 2-bottle bundle with a discount for intensive routines.
  - ENHANCED UX: Seamless, live-updating experience optimized for both desktop and mobile.
  - REFINED ICONS: Visual drop icons are now emojis for universal compatibility.
{% endcomment %}

{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font = section.settings.body_font
  assign product = section.settings.product
-%}

<style>
  {{ heading_font | font_face }}
  {{ body_font | font_face }}

  .argo-calc-v23-{{ section.id }} {
    --bg-color: {{ section.settings.background_color }};
    --card-bg-color: {{ section.settings.card_background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --accent-main: {{ section.settings.accent_color_main }};
    --accent-light: {{ section.settings.accent_color_light }};
    --border-color: {{ section.settings.border_color }};
    --button-bg: {{ section.settings.atc_button_bg }};
    --button-text: {{ section.settings.atc_button_text_color }};
    
    background-color: var(--bg-color);
    font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
    color: var(--text-color);
    padding: clamp(3rem, 8vw, 8rem) clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
  }
  .argo-calc-v23-{{ section.id }} .argo-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: flex-start;
  }
  @media (min-width: 992px) {
    .argo-calc-v23-{{ section.id }} .argo-container {
      grid-template-columns: minmax(0, 1fr) minmax(0, 450px);
      gap: 5rem;
    }
  }

  .argo-calc-v23-{{ section.id }} .argo-calc-heading {
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 1.2;
    color: var(--heading-color);
  }
  .argo-calc-v23-{{ section.id }} .argo-subheading {
    max-width: 55ch;
    font-size: clamp(1rem, 2vw, 1.1rem);
    line-height: 1.6;
    margin: 1rem 0 2.5rem 0;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
  }
  
  .argo-calc-v23-{{ section.id }} .argo-routine-builder h3 {
    font-size: 1.1rem;
    font-weight: 600;
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    margin-bottom: 1.5rem;
    color: {{ section.settings.heading_color | color_modify: 'alpha', 0.9 }};
  }

  .argo-calc-v23-{{ section.id }} .argo-routine-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .argo-calc-v23-{{ section.id }} .argo-routine-block {
    display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1.25rem;
    border: 1px solid var(--border-color); border-radius: {{ section.settings.border_radius }}px; cursor: pointer;
    transition: all 0.2s ease-in-out; background-color: var(--card-bg-color);
    user-select: none; font-size: 0.95rem;
  }
  .argo-calc-v23-{{ section.id }} .argo-routine-block:hover {
    transform: translateY(-2px); box-shadow: 0 4px 15px -5px rgba(0,0,0,0.08); border-color: var(--accent-main);
  }
  .argo-calc-v23-{{ section.id }} .argo-routine-block.selected {
    background-color: var(--accent-main); color: #fff; border-color: var(--accent-main);
    box-shadow: 0 4px 20px -5px {{ section.settings.accent_color_main | color_modify: 'alpha', 0.5 }};
  }
  
  .argo-calc-v23-{{ section.id }} .output-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .argo-calc-v23-{{ section.id }} .output-wrapper.visible {
    grid-template-rows: 1fr;
  }
  .argo-calc-v23-{{ section.id }} .output-panel {
    overflow: hidden;
  }

  .argo-calc-v23-{{ section.id }} .output-content {
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .argo-calc-v23-{{ section.id }} .argo-results-card,
  .argo-calc-v23-{{ section.id }} .argo-routine-card,
  .argo-calc-v23-{{ section.id }} .argo-upsell-card {
    background-color: {{ section.settings.card_background_color }};
    border-radius: {{ section.settings.border_radius }}px;
    border: 1px solid {{ section.settings.border_color }};
    padding: 2rem;
    box-shadow: 0 10px 25px -10px {{ section.settings.background_color | color_darken: 15 | color_modify: 'alpha', 0.08 }};
  }
  
  .argo-calc-v23-{{ section.id }} .argo-upsell-card {
    background-color: {{ section.settings.accent_color_main | color_modify: 'alpha', 0.1 }};
    border-color: {{ section.settings.accent_color_main | color_modify: 'alpha', 0.2 }};
    display: none; /* Hidden by default */
  }

  .argo-calc-v23-{{ section.id }} .argo-results-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: center; text-align: center;
  }
  .argo-calc-v23-{{ section.id }} .argo-results-title {
    font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.07em;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.7 }}; margin-bottom: 0.5rem;
  }
  .argo-calc-v23-{{ section.id }} .argo-results-value {
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    font-weight: {{ heading_font.weight }}; font-size: clamp(2rem, 5vw, 2.75rem);
    color: {{ section.settings.heading_color }}; line-height: 1;
  }
  .argo-calc-v23-{{ section.id }} .argo-results-suffix {
    font-size: 0.9rem; font-weight: 500; margin-left: 0.25rem;
    color: {{ section.settings.heading_color | color_modify: 'alpha', 0.7 }};
  }

  .argo-calc-v23-{{ section.id }} .argo-routine-display h4 {
    font-weight: 600; font-size: 1.25rem; color: {{ section.settings.heading_color }}; margin-bottom: 1.5rem; text-align: center;
  }
  .argo-calc-v23-{{ section.id }} .argo-routine-list {
    list-style: none; padding: 0; margin: 0; text-align: left; font-size: 0.95rem;
  }
  .argo-calc-v23-{{ section.id }} .argo-routine-list li {
    display: grid; grid-template-columns: auto 1fr; gap: 1rem; margin-bottom: 1.25rem; align-items: flex-start;
  }
  .argo-calc-v23-{{ section.id }} .routine-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    color: var(--accent-main);
    background-color: {{ section.settings.accent_color_main | color_modify: 'alpha', 0.1 }};
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .argo-calc-v23-{{ section.id }} .routine-icon:empty { display: none; }
  .argo-calc-v23-{{ section.id }} .routine-icon svg { width: 20px; height: 20px; }
  .argo-calc-v23-{{ section.id }} .routine-details .time { font-weight: 700; font-size: 1rem; color: var(--heading-color); }
  .argo-calc-v23-{{ section.id }} .routine-details .desc { color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }}; }
  .routine-card-drops { display: flex; align-items: center; gap: 0.25rem; margin-top: 0.5rem; color: {{ section.settings.accent_color_light }}; }
  
  .argo-calc-v23-{{ section.id }} .routine-actions {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .argo-calc-v23-{{ section.id }} .action-button {
    display: inline-block; width: 100%; padding: 1rem 1.5rem;
    border: none; border-radius: {{ section.settings.border_radius | minus: 4 }}px;
    font-size: 1rem; font-weight: 600; cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .argo-calc-v23-{{ section.id }} .action-button.primary {
    background-color: var(--button-bg);
    color: var(--button-text);
  }
  .argo-calc-v23-{{ section.id }} .action-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(0,0,0,0.1);
  }
  .argo-calc-v23-{{ section.id }} .screenshot-tip {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-top: 1rem; font-style: italic; font-size: 0.9rem;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
  }
  .argo-calc-v23-{{ section.id }} .screenshot-tip svg { width: 16px; height: 16px; flex-shrink: 0; }
</style>

<div class="argo-calc-v23-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="argo-container">
    <div class="argo-input-panel">
      <h2 class="argo-calc-heading">{{ section.settings.main_heading_bs }}</h2>
      <p class="argo-subheading">{{ section.settings.subheading_bs }}</p>
      
      <div class="argo-routine-builder">
        <h3>{{ section.settings.routine_builder_title_bs }}</h3>
        <div class="argo-routine-options">
          {% for i in (1..5) %}
            {%- assign option_label_setting = 'option_' | append: i | append: '_label_bs' -%}
            {%- assign option_label = section.settings[option_label_setting] -%}
            {% if option_label != blank %}
              <div class="argo-routine-block" data-option="option_{{ i }}" role="checkbox" aria-checked="false" tabindex="0">
                <span>{{ option_label }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div id="output-wrapper-{{ section.id }}" class="output-wrapper">
      <div class="output-panel">
        <div class="output-content">
          <div class="argo-results-card">
            <div class="argo-results-grid">
              <div>
                <h4 class="argo-results-title">{{ section.settings.usage_title_bs }}</h4>
                <span id="total-drops-{{ section.id }}" class="argo-results-value">0</span>
                <span class="argo-results-suffix">{{ section.settings.usage_suffix_bs }}</span>
              </div>
              <div>
                <h4 class="argo-results-title">{{ section.settings.longevity_title_bs }}</h4>
                <span id="total-days-{{ section.id }}" class="argo-results-value">...</span>
                <span class="argo-results-suffix">{{ section.settings.result_text_suffix_bs }}</span>
              </div>
            </div>
          </div>

          <div class="argo-upsell-card" id="upsell-card-{{ section.id }}">
            <h4>{{ section.settings.upsell_title_bs }}</h4>
            <p>{{ section.settings.upsell_desc_bs }}</p>
            {%- if product != blank -%}
                <form method="post" action="/cart/add">
                  <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="2">
                  <button type="submit" class="action-button primary">{{ section.settings.upsell_button_text_bs }}</button>
                </form>
            {%- endif -%}
          </div>

          <div id="routine-card-{{ section.id }}" class="argo-routine-card">
            <div class="argo-routine-display">
              <h4>{{ section.settings.routine_title_bs }}</h4>
              <ul id="routine-list-{{ section.id }}" class="argo-routine-list"></ul>
            </div>
            <div class="routine-actions">
              {%- if product != blank -%}
                <form method="post" action="/cart/add">
                  <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="action-button primary">{{ section.settings.atc_button_text_bs }}</button>
                </form>
              {%- endif -%}
              
              {%- if section.settings.screenshot_tip_bs != blank -%}
                <p class="screenshot-tip">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 0v9.5c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-9.5a.75.75 0 00-.75-.75H3.25a.75.75 0 00-.75.75z" clip-rule="evenodd" /><path d="M6.25 6.5a.75.75 0 00-1.5 0v3a.75.75 0 001.5 0v-3z" /><path d="M9 7.25a.75.75 0 01.75-.75h4a.75.75 0 010 1.5h-4A.75.75 0 019 7.25z" /></svg>
                  <span>{{ section.settings.screenshot_tip_bs }}</span>
                </p>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script id="argo-calc-settings-{{ section.id }}" type="application/json">{{ section.settings | json }}</script>

<script>
  (() => {
    const instances = window.argoCalcInstances || {};

    const ArganCalculator = class {
      constructor(container) {
        this.container = container;
        this.sectionId = container.dataset.sectionId;
        const settingsEl = document.getElementById(`argo-calc-settings-${this.sectionId}`);
        if (!settingsEl) { return; }
        this.settings = JSON.parse(settingsEl.textContent);
        
        this.routineBlocks = this.container.querySelectorAll('.argo-routine-block');
        this.totalDaysEl = this.container.querySelector(`#total-days-${this.sectionId}`);
        this.totalDropsEl = this.container.querySelector(`#total-drops-${this.sectionId}`);
        this.outputWrapperEl = this.container.querySelector(`#output-wrapper-${this.sectionId}`);
        this.routineListEl = this.container.querySelector(`#routine-list-${this.sectionId}`);
        this.upsellCardEl = this.container.querySelector(`#upsell-card-${this.sectionId}`);
        
        this.selectedRoutines = new Set();
        this.usageData = {
          'option_1': { drops: this.settings.option_1_drops, usesPerWeek: this.settings.option_1_uses_per_week, time: this.settings.option_1_time_bs, desc: this.settings.option_1_desc_bs, icon: this.settings.option_1_icon },
          'option_2': { drops: this.settings.option_2_drops, usesPerWeek: this.settings.option_2_uses_per_week, time: this.settings.option_2_time_bs, desc: this.settings.option_2_desc_bs, icon: this.settings.option_2_icon },
          'option_3': { drops: this.settings.option_3_drops, usesPerWeek: this.settings.option_3_uses_per_week, time: this.settings.option_3_time_bs, desc: this.settings.option_3_desc_bs, icon: this.settings.option_3_icon },
          'option_4': { drops: this.settings.option_4_drops, usesPerWeek: this.settings.option_4_uses_per_week, time: this.settings.option_4_time_bs, desc: this.settings.option_4_desc_bs, icon: this.settings.option_4_icon },
          'option_5': { drops: this.settings.option_5_drops, usesPerWeek: this.settings.option_5_uses_per_week, time: this.settings.option_5_time_bs, desc: this.settings.option_5_desc_bs, icon: this.settings.option_5_icon }
        };
        
        this.handleBlockClick = this.handleBlockClick.bind(this);
        this.addEventListeners();
      }

      addEventListeners() {
        this.routineBlocks.forEach(block => block.addEventListener('click', () => this.handleBlockClick(block)));
      }

      handleBlockClick(block) {
        const option = block.dataset.option;
        if (this.selectedRoutines.has(option)) {
          this.selectedRoutines.delete(option);
          block.classList.remove('selected');
        } else {
          this.selectedRoutines.add(option);
          block.classList.add('selected');
        }
        this.updateExperience();
      }

      updateExperience() {
        let totalDropsPerDay = 0;
        const routineByTime = {};

        this.selectedRoutines.forEach(option => {
          const data = this.usageData[option];
          if (data) {
            totalDropsPerDay += (data.drops * data.usesPerWeek) / 7;
            if (!routineByTime[data.time]) routineByTime[data.time] = [];
            routineByTime[data.time].push({ ...data });
          }
        });
        
        this.routineListEl.innerHTML = '';
        if (Object.keys(routineByTime).length > 0) {
          this.outputWrapperEl.classList.add('visible');
          for (const time in routineByTime) {
            const descriptions = routineByTime[time].map(item => {
              const dropIcons = '💧'.repeat(item.drops);
              return `<div class="routine-step">
                        <span class="routine-icon">${item.icon || ''}</span>
                        <div class="routine-details">
                          <div class="time">${item.time}</div>
                          <div class="desc">${item.desc}</div>
                          <div class="routine-card-drops">${dropIcons}</div>
                        </div>
                      </div>`;
            }).join('');
            const li = document.createElement('li');
            li.innerHTML = descriptions;
            this.routineListEl.appendChild(li);
          }
        } else {
          this.outputWrapperEl.classList.remove('visible');
        }

        const daysLasting = (totalDropsPerDay <= 0) ? 0 : Math.round(30 * 20 / totalDropsPerDay);
        
        this.animateValue(this.totalDaysEl, daysLasting);
        this.updateDropsDisplay(totalDropsPerDay);
        
        if (daysLasting > 0 && daysLasting < 45) {
            this.upsellCardEl.style.display = 'block';
        } else {
            this.upsellCardEl.style.display = 'none';
        }
      }
      
      updateDropsDisplay(totalDropsPerDay) {
        if (totalDropsPerDay === 0) {
          this.animateValue(this.totalDropsEl, 0);
        } else if (totalDropsPerDay > 0 && totalDropsPerDay < 1) {
          this.totalDropsEl.textContent = '< 1';
        } else if (totalDropsPerDay === Math.floor(totalDropsPerDay)) {
          this.animateValue(this.totalDropsEl, totalDropsPerDay);
        } else {
          const min = Math.floor(totalDropsPerDay);
          const max = Math.ceil(totalDropsPerDay);
          this.totalDropsEl.textContent = `${min}-${max}`;
        }
      }

      animateValue(element, endValue) {
        if (!element) return;
        let startValue = parseInt(element.textContent) || 0;
        if (startValue === endValue && element.textContent.indexOf('-') === -1) return;
        
        const animationDuration = 600;
        const frameDuration = 1000 / 60;
        const totalFrames = Math.round(animationDuration / frameDuration);
        let frame = 0;

        if (element.animation) clearInterval(element.animation);

        element.animation = setInterval(() => {
          frame++;
          const progress = frame / totalFrames;
          const easedProgress = 1 - Math.pow(1 - progress, 4);
          let currentValue = Math.round(startValue + (endValue - startValue) * easedProgress);
          element.textContent = currentValue;

          if (frame === totalFrames) {
            clearInterval(element.animation);
            element.textContent = endValue;
          }
        }, frameDuration);
      }
      
      destroy() {}
    };

    const initSection = (container) => {
      const sectionId = container.dataset.sectionId;
      if (!sectionId) return;
      if (instances[sectionId]) instances[sectionId].destroy();
      instances[sectionId] = new ArganCalculator(container);
    };

    const cleanupSection = (sectionId) => {
      if (instances[sectionId]) {
        instances[sectionId].destroy();
        delete instances[sectionId];
      }
    };
    
    document.querySelectorAll('.argo-calc-v23-{{ section.id }}').forEach(initSection);
    document.addEventListener('shopify:section:load', (e) => {
      const container = e.target.querySelector('.argo-calc-v23-{{ section.id }}');
      if (container) initSection(container);
    });
    document.addEventListener('shopify:section:unload', (e) => cleanupSection(e.detail.sectionId));
    window.argoCalcInstances = instances;
  })();
</script>

{% schema %}
{
  "name": "Argan Routine Calculator",
  "settings": [
    { "type": "header", "content": "Product & ATC Button" },
    { "type": "product", "id": "product", "label": "Product to Add" },
    { "type": "text", "id": "atc_button_text_bs", "label": "ATC Button Text (BS)", "default": "DODAJ U KORPU" },
    { "type": "color", "id": "atc_button_bg", "label": "Button Background", "default": "#00529B" },
    { "type": "color", "id": "atc_button_text_color", "label": "Button Text Color", "default": "#FFFFFF" },
    
    { "type": "header", "content": "Smart Upsell" },
    { "type": "text", "id": "upsell_title_bs", "label": "Upsell Title (BS)", "default": "Intenzivna Rutina? Udvostručite i Uštedite!" },
    { "type": "textarea", "id": "upsell_desc_bs", "label": "Upsell Description (BS)", "default": "Vaš plan njege je moćan! Osigurajte kontinuirane rezultate i uštedite 15% kupovinom dvije bočice." },
    { "type": "text", "id": "upsell_button_text_bs", "label": "Upsell Button Text (BS)", "default": "Dodaj 2 Bočice i Uštedi 15%" },

    { "type": "header", "content": "Style & Layout" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "helvetica_n7" },
    { "type": "font_picker", "id": "body_font", "label": "Body Font", "default": "helvetica_n4" },
    { "type": "range", "id": "max_width", "min": 600, "max": 1200, "step": 10, "unit": "px", "label": "Max Container Width", "default": 1100 },
    { "type": "range", "id": "border_radius", "min": 0, "max": 50, "step": 1, "unit": "px", "label": "Border Radius", "default": 24 },
    
    { "type": "header", "content": "Color Palette" },
    { "type": "color", "id": "background_color", "label": "Page Background", "default": "#FFFFFF" },
    { "type": "color", "id": "card_background_color", "label": "Card Background", "default": "#F9FAFB" },
    { "type": "color", "id": "border_color", "label": "Border Color", "default": "#F3F4F6" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111827" },
    { "type": "color", "id": "text_color", "label": "Body Text Color", "default": "#4B5563" },
    { "type": "color", "id": "accent_color_main", "label": "Accent Color (Primary)", "default": "#00529B" },
    { "type": "color", "id": "accent_color_light", "label": "Accent Color (Drop)", "default": "#FBBF24" },
    
    { "type": "header", "content": "General Content (Bosnian)" },
    { "type": "text", "id": "main_heading_bs", "label": "Main Heading (BS)", "default": "Kreirajte Svoju Idealnu Argan Rutinu" },
    { "type": "textarea", "id": "subheading_bs", "label": "Subheading (BS)", "default": "Otkrijte beskrajnu svestranost čistog arganovog ulja. Odaberite željeni način upotrebe, a mi ćemo za Vas kreirati personalizirani plan njege i otkriti Vam koliko dugo će trajati Vaša bočica." },
    { "type": "text", "id": "routine_builder_title_bs", "label": "Routine Builder Title (BS)", "default": "Želim koristiti arganovo ulje za:" },
