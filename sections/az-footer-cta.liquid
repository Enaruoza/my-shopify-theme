        }
      ]
    },
    {
      "type": "payment",
      "name": "Payment Method",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Payment Name",
          "default": "Visa"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Payment Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AZ Premium Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "title": "Shop"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "About"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "Help"
          }
        },
        {
          "type": "social",
          "settings": {
            "platform": "Instagram"
          }
        },
        {
          "type": "social",
          "settings": {
            "platform": "Facebook"
          }
        }
      ]
