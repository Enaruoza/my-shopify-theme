{% liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign gap = section.settings.gap
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
%}

<div class="master-grid section color-{{ section.settings.color_scheme }}" style="--padding-top: {{ padding_top }}px; --padding-bottom: {{ padding_bottom }}px;">
  <div class="master-grid__container">
    {%- if section.settings.heading != blank -%}
      <div class="master-grid__header {{ section.settings.heading_alignment }}">
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <div class="rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="master-grid__items" style="--columns-desktop: {{ columns_desktop }}; --columns-mobile: {{ columns_mobile }}; --gap: {{ gap }}px;">
      {%- if section.settings.source == 'collection' and section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.items_limit -%}
          <div class="master-grid__item">
            {% render 'card-product', card_product: product, show_vendor: section.settings.show_vendor %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <div class="master-grid__item master-grid__item--{{ block.type }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'image_card' -%}
                <div class="card-image">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 800 | image_tag: class: 'card-image__img', loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'card-image__img card-image__placeholder' }}
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <div class="card-image__overlay">
                      <h3 class="card-image__title">{{ block.settings.title }}</h3>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="card-image__link" aria-label="{{ block.settings.title }}"></a>
                  {%- endif -%}
                </div>

              {%- when 'content_card' -%}
                <div class="card-content color-{{ block.settings.color_scheme }}">
                  {%- if block.settings.icon != 'none' -%}
                    <div class="card-content__icon">{% render 'icon', icon: block.settings.icon %}</div>
                  {%- endif -%}
                  <h3 class="card-content__title">{{ block.settings.title }}</h3>
                  <div class="rte card-content__text">{{ block.settings.text }}</div>
                  {%- if block.settings.link_label != blank -%}
                    <a href="{{ block.settings.link }}" class="card-content__link">{{ block.settings.link_label }}</a>
                  {%- endif -%}
                </div>

              {%- when 'product_card' -%}
                {%- if block.settings.product != blank -%}
                  {% render 'card-product', card_product: block.settings.product %}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}

            {%- endcase -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .master-grid {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }
  
  .master-grid__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .master-grid__header {
    margin-bottom: 2rem;
  }
  .master-grid__header.text-center { text-align: center; }
  .master-grid__header.text-right { text-align: right; }

  .master-grid__items {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile), 1fr);
    gap: var(--gap);
  }

  @media (min-width: 768px) {
    .master-grid__items {
      grid-template-columns: repeat(var(--columns-desktop), 1fr);
    }
  }

  .master-grid__item {
    height: 100%;
  }
  
  /* Card Image */
  .card-image {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    height: 100%;
    aspect-ratio: 1;
  }
  
  .card-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .card-image:hover .card-image__img {
    transform: scale(1.05);
  }
  
  .card-image__placeholder {
    background-color: #e5e7eb;
  }
  
  .card-image__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  }
  
  .card-image__title {
    color: #fff;
    font-weight: bold;
    font-size: 1.25rem;
    margin: 0;
  }
  
  .card-image__link {
    position: absolute;
    inset: 0;
    z-index: 10;
  }

  /* Card Content */
  .card-content {
    padding: 1.5rem;
    border-radius: 8px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid rgba(0,0,0,0.1);
  }
  
  .card-content__icon {
    margin-bottom: 1rem;
  }
  
  .card-content__title {
    font-size: 1.25rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .card-content__text {
    font-size: 0.875rem;
  }
  
  .card-content__link {
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: bold;
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Master Grid",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-left"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Desktop Columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1",
      "label": "Mobile Columns"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24,
      "label": "Gap (px)"
    },
    {
      "type": "header",
      "content": "Data Source"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Source",
      "options": [
        { "value": "blocks", "label": "Manual Blocks" },
        { "value": "collection", "label": "Collection" }
      ],
      "default": "blocks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used if Source is 'Collection'"
    },
    {
      "type": "range",
      "id": "items_limit",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 8,
      "label": "Items Limit"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "label": "Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "content_card",
      "name": "Content Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Feature" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Description</p>" },
        { "type": "text", "id": "link_label", "label": "Link Label" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "select", "id": "icon", "label": "Icon", "options": [
            { "value": "none", "label": "None" },
            { "value": "check", "label": "Check" },
            { "value": "star", "label": "Star" }
          ], "default": "none" 
        },
        { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-2" }
      ]
    },
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Master Grid",
      "blocks": [
        { "type": "content_card" },
        { "type": "content_card" },
        { "type": "content_card" }
      ]
    }
  ]
}
{% endschema %}
