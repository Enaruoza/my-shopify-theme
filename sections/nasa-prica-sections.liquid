{% schema %}
{
  "name": "Naša Priča Sections",
  "tag": "section",
  "class": "section-nasa-prica",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Naša Misija"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Prirodna ljepota iz srca Maroka."
        }
      ]
    },
    {
      "type": "image_text",
      "name": "Image + Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Image Position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Počeci"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Ovdje napišite vašu priču...</p>"
        }
      ]
    },
    {
      "type": "values",
      "name": "Values Grid",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Section Heading",
          "default": "Naše Vrijednosti"
        },
        {
          "type": "header",
          "content": "Value 1"
        },
        {
          "type": "text",
          "id": "val_1_icon",
          "label": "Icon 1 (Emoji)",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "val_1_text",
          "label": "Text 1",
          "default": "Prirodno"
        },
        {
          "type": "header",
          "content": "Value 2"
        },
        {
          "type": "text",
          "id": "val_2_icon",
          "label": "Icon 2 (Emoji)",
          "default": "🐰"
        },
        {
          "type": "text",
          "id": "val_2_text",
          "label": "Text 2",
          "default": "Cruelty Free"
        },
        {
          "type": "header",
          "content": "Value 3"
        },
        {
          "type": "text",
          "id": "val_3_icon",
          "label": "Icon 3 (Emoji)",
          "default": "✨"
        },
        {
          "type": "text",
          "id": "val_3_text",
          "label": "Text 3",
          "default": "Premium"
        },
        {
          "type": "header",
          "content": "Value 4"
        },
        {
          "type": "text",
          "id": "val_4_icon",
          "label": "Icon 4 (Emoji)",
          "default": "🌍"
        },
        {
          "type": "text",
          "id": "val_4_text",
          "label": "Text 4",
          "default": "Održivo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Naša Priča Template"
    }
  ]
}
{% endschema %}

<style>
  .nasa-prica-container {
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .nasa-prica-block {
    margin-bottom: 4rem;
  }

  /* Hero Block */
  .story-hero {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
    height: 24rem; /* 96 tailwind */
  }
  
  .story-hero img,
  .story-hero svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-hero__content {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
  }

  .story-hero__heading {
    font-size: 2.25rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }
  
  @media (min-width: 768px) {
    .story-hero__heading {
      font-size: 3.75rem;
    }
  }

  .story-hero__text {
    font-size: 1.25rem;
    color: white;
    max-width: 42rem;
  }

  /* Image + Text Block */
  .story-split {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .story-split {
      flex-direction: row;
    }
    .story-split--reverse {
      flex-direction: row-reverse;
    }
  }

  .story-split__image-wrapper,
  .story-split__content-wrapper {
    width: 100%;
  }

  @media (min-width: 768px) {
    .story-split__image-wrapper,
    .story-split__content-wrapper {
      width: 50%;
    }
  }

  .story-split__image {
    width: 100%;
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    transition: transform 0.5s;
  }

  .story-split__image:hover {
    transform: scale(1.02);
  }

  .story-split__heading {
    font-size: 1.875rem;
    font-family: var(--font-heading-family);
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .story-split__text {
    font-size: 1.125rem;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.6;
  }

  /* Values Block */
  .story-values {
    text-align: center;
  }

  .story-values__heading {
    font-size: 1.875rem;
    font-family: var(--font-heading-family);
    margin-bottom: 2.5rem;
  }

  .story-values__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .story-values__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .value-item {
    padding: 1.5rem;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 0.5rem;
    transition: box-shadow 0.3s;
  }

  .value-item:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .value-item__icon {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .value-item__title {
    font-weight: 700;
  }
</style>

<div class="nasa-prica-container" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  {% for block in section.blocks %}
    <div class="nasa-prica-block block-{{ block.type }} reveal-on-scroll" {{ block.shopify_attributes }}>
      
      {% case block.type %}
        {% when 'hero' %}
          <div class="story-hero">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'story-hero__image', loading: 'lazy' }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'story-hero__image' }}
            {% endif %}
            <div class="story-hero__content">
              <h1 class="story-hero__heading">{{ block.settings.heading }}</h1>
              <p class="story-hero__text">{{ block.settings.text }}</p>
            </div>
          </div>

        {% when 'image_text' %}
          <div class="story-split {% if block.settings.layout == 'right' %}story-split--reverse{% endif %}">
            <div class="story-split__image-wrapper">
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'story-split__image', loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'story-split__image' }}
              {% endif %}
            </div>
            <div class="story-split__content-wrapper">
              <h2 class="story-split__heading">{{ block.settings.heading }}</h2>
              <div class="story-split__text">
                {{ block.settings.content }}
              </div>
            </div>
          </div>

        {% when 'values' %}
          <div class="story-values">
            <h2 class="story-values__heading">{{ block.settings.heading }}</h2>
            <div class="story-values__grid">
              <div class="value-item">
                <div class="value-item__icon">{{ block.settings.val_1_icon }}</div>
                <h3 class="value-item__title">{{ block.settings.val_1_text }}</h3>
              </div>
              <div class="value-item">
                <div class="value-item__icon">{{ block.settings.val_2_icon }}</div>
                <h3 class="value-item__title">{{ block.settings.val_2_text }}</h3>
              </div>
              <div class="value-item">
                <div class="value-item__icon">{{ block.settings.val_3_icon }}</div>
                <h3 class="value-item__title">{{ block.settings.val_3_text }}</h3>
              </div>
              <div class="value-item">
                <div class="value-item__icon">{{ block.settings.val_4_icon }}</div>
                <h3 class="value-item__title">{{ block.settings.val_4_text }}</h3>
              </div>
            </div>
          </div>

      {% endcase %}
    </div>
  {% endfor %}
</div>
