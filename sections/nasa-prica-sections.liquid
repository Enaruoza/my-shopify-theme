{% schema %}
{
  "name": "Naša Priča Sections",
  "tag": "section",
  "class": "section-nasa-prica",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Naša Misija"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Prirodna ljepota iz srca Maroka."
        }
      ]
    },
    {
      "type": "image_text",
      "name": "Image + Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Image Position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Počeci"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Ovdje napišite vašu priču...</p>"
        }
      ]
    },
    {
      "type": "values",
      "name": "Values Grid",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Section Heading",
          "default": "Naše Vrijednosti"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Naša Priča Template"
    }
  ]
}
{% endschema %}

<div class="nasa-prica-container page-width" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  {% for block in section.blocks %}
    <div class="nasa-prica-block block-{{ block.type }} reveal-on-scroll" {{ block.shopify_attributes }}>
      
      {% case block.type %}
        {% when 'hero' %}
          <div class="story-hero relative overflow-hidden rounded-lg mb-12">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'w-full h-96 object-cover', loading: 'lazy' }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-96 object-cover bg-gray-100' }}
            {% endif %}
            <div class="absolute inset-0 bg-black/30 flex flex-col justify-center items-center text-center p-6">
              <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">{{ block.settings.heading }}</h1>
              <p class="text-xl text-white max-w-2xl">{{ block.settings.text }}</p>
            </div>
          </div>

        {% when 'image_text' %}
          <div class="story-split flex flex-col md:flex-row gap-8 items-center mb-16 {% if block.settings.layout == 'right' %}md:flex-row-reverse{% endif %}">
            <div class="w-full md:w-1/2">
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full rounded-lg shadow-lg hover:scale-[1.02] transition-transform duration-500', loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'w-full rounded-lg bg-gray-100' }}
              {% endif %}
            </div>
            <div class="w-full md:w-1/2">
              <h2 class="text-3xl font-serif mb-4 text-primary">{{ block.settings.heading }}</h2>
              <div class="prose prose-lg text-gray-700">
                {{ block.settings.content }}
              </div>
            </div>
          </div>

        {% when 'values' %}
          <div class="story-values text-center mb-16">
            <h2 class="text-3xl font-serif mb-10">{{ block.settings.heading }}</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
              <div class="value-item p-6 border rounded-lg hover:shadow-md transition-shadow">
                <div class="text-4xl mb-3">🌿</div>
                <h3 class="font-bold">Prirodno</h3>
              </div>
              <div class="value-item p-6 border rounded-lg hover:shadow-md transition-shadow">
                <div class="text-4xl mb-3">🐰</div>
                <h3 class="font-bold">Cruelty Free</h3>
              </div>
              <div class="value-item p-6 border rounded-lg hover:shadow-md transition-shadow">
                <div class="text-4xl mb-3">✨</div>
                <h3 class="font-bold">Premium</h3>
              </div>
              <div class="value-item p-6 border rounded-lg hover:shadow-md transition-shadow">
                <div class="text-4xl mb-3">🌍</div>
                <h3 class="font-bold">Održivo</h3>
              </div>
            </div>
          </div>

      {% endcase %}
    </div>
  {% endfor %}
</div>
