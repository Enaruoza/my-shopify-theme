        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Magazine About",
      "blocks": [
        {
          "type": "hero",
          "settings": {
            "text": "WE ARE",
            "bold": false
          }
        },
        {
          "type": "hero",
          "settings": {
            "text": "SICKY",
            "bold": true
          }
        },
        {
          "type": "grid_start"
        },
        {
          "type": "text",
          "settings": {
            "heading": "EVERLASTING NEW STATIC",
            "content": "<p>A fashion magazine which promotes art, fashion, and photography with the best experimental talents artists, designers, photographers and stylists.</p>",
