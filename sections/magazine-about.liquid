      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Mobile Horizontal Padding",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
