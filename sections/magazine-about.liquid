{%- liquid
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
-%}

<style>
  .magazine-about-{{ section.id }} {
    background-color: {{ bg_color }};
    color: {{ text_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 749px) {
    .magazine-about-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .magazine-about__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* Hero Block - Large Italic Typography */
  .mag-hero {
    margin: 60px 0;
    text-align: {{ section.settings.hero_alignment }};
  }

  .mag-hero__text {
    font-family: var(--font-heading-family);
    font-size: clamp({{ section.settings.hero_size_mobile }}px, 12vw, {{ section.settings.hero_size_desktop }}px);
    font-weight: 300;
    font-style: italic;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
    text-transform: uppercase;
  }

  .mag-hero__text--bold {
    font-weight: 800;
    font-style: normal;
  }

  /* Magazine Grid Layout */
  .mag-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ section.settings.grid_gap }}px;
    margin: 60px 0;
  }

  @media (max-width: 749px) {
    .mag-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      margin: 40px 0;
    }
  }

  /* Image Block */
  .mag-image {
    position: relative;
    overflow: hidden;
  }

  .mag-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale({{ section.settings.image_grayscale }}%);
  }

  .mag-image--caption {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.9);
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Text Block */
  .mag-text {
    padding: 24px;
  }

  .mag-text__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(32px, 5vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px 0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .mag-text__body {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .mag-text__body strong {
    font-weight: 800;
  }

  /* Collage Row */
  .mag-collage {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ section.settings.grid_gap }}px;
    margin: 40px 0;
  }

  @media (max-width: 749px) {
    .mag-collage {
      grid-template-columns: 1fr;
    }
  }

  /* Contact/CTA Section */
  .mag-cta {
    text-align: center;
    padding: 80px 24px;
    border-top: 1px solid {{ text_color }};
    margin-top: 80px;
  }

  .mag-cta__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 800;
    line-height: 1;
    margin: 0 0 40px 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .mag-cta__links {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    margin-top: 40px;
  }

  .mag-cta__link {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ text_color }};
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .mag-cta__link:hover {
    opacity: 0.6;
  }

  /* Grid Span Utilities */
  .span-3 { grid-column: span 3; }
  .span-4 { grid-column: span 4; }
  .span-5 { grid-column: span 5; }
  .span-6 { grid-column: span 6; }
  .span-7 { grid-column: span 7; }
  .span-8 { grid-column: span 8; }
  .span-9 { grid-column: span 9; }
  .span-12 { grid-column: span 12; }

  @media (max-width: 749px) {
    .span-3, .span-4, .span-5, .span-6, 
    .span-7, .span-8, .span-9, .span-12 {
      grid-column: span 1;
    }
  }

  /* Aspect Ratios */
  .aspect-square { aspect-ratio: 1 / 1; }
  .aspect-portrait { aspect-ratio: 3 / 4; }
  .aspect-landscape { aspect-ratio: 4 / 3; }
  .aspect-wide { aspect-ratio: 16 / 9; }
  .aspect-auto { aspect-ratio: auto; }
</style>

<div class="magazine-about-{{ section.id }}">
  <div class="magazine-about__container">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'hero' -%}
          <div class="mag-hero" {{ block.shopify_attributes }}>
            <h1 class="mag-hero__text {% if block.settings.bold %}mag-hero__text--bold{% endif %}">
              {{ block.settings.text }}
            </h1>
          </div>

        {%- when 'grid_start' -%}
          <div class="mag-grid">

        {%- when 'grid_end' -%}
          </div>

        {%- when 'image' -%}
          <div class="mag-image span-{{ block.settings.grid_span }} aspect-{{ block.settings.aspect_ratio }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.caption }}
            {%- else -%}
              <div style="background: #e0e0e0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                <span style="color: #999; font-size: 14px;">Image placeholder</span>
              </div>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <div class="mag-image--caption">{{ block.settings.caption }}</div>
            {%- endif -%}
          </div>

        {%- when 'text' -%}
          <div class="mag-text span-{{ block.settings.grid_span }}" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="mag-text__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="mag-text__body">{{ block.settings.content }}</div>
            {%- endif -%}
          </div>

        {%- when 'collage_start' -%}
          <div class="mag-collage">

        {%- when 'collage_end' -%}
          </div>

        {%- when 'cta' -%}
          <div class="mag-cta" {{ block.shopify_attributes }}>
            <h2 class="mag-cta__heading">{{ block.settings.heading }}</h2>
            {%- if block.settings.show_links -%}
              <div class="mag-cta__links">
                {%- if block.settings.link_1_text != blank -%}
                  <a href="{{ block.settings.link_1_url }}" class="mag-cta__link">{{ block.settings.link_1_text }}</a>
                {%- endif -%}
                {%- if block.settings.link_2_text != blank -%}
                  <a href="{{ block.settings.link_2_url }}" class="mag-cta__link">{{ block.settings.link_2_text }}</a>
                {%- endif -%}
                {%- if block.settings.link_3_text != blank -%}
                  <a href="{{ block.settings.link_3_url }}" class="mag-cta__link">{{ block.settings.link_3_text }}</a>
                {%- endif -%}
                {%- if block.settings.link_4_text != blank -%}
                  <a href="{{ block.settings.link_4_url }}" class="mag-cta__link">{{ block.settings.link_4_text }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Magazine About",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
