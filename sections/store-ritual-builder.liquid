<section class="page-width" style="padding: 80px 0;">
  <div style="text-align: center; max-width: 600px; margin: 0 auto 60px;">
    {%- if section.settings.heading != 'AUTO' and section.settings.heading != blank -%}
      <h2 class="h2">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <p style="color: #666; margin-top: 20px;">Select your primary skincare goal to discover your customized Moroccan ritual.</p>
  </div>

  <div class="ritual-builder" style="display: flex; gap: 40px; flex-wrap: wrap; justify-content: center;">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="ritual-card" style="display: block; width: 100%; max-width: 300px; text-align: center; border: 1px solid #eee; padding: 40px 20px; transition: border-color 0.3s ease;">
        {%- if block.settings.icon_image != blank -%}
          <div style="width: 60px; height: 60px; margin: 0 auto 20px;">
            {{ block.settings.icon_image | image_url: width: 120 | image_tag: style: 'width: 100%; height: auto;' }}
          </div>
        {%- else -%}
          <div style="width: 60px; height: 60px; margin: 0 auto 20px; border-radius: 50%; background: var(--color-base-text);"></div>
        {%- endif -%}
        <h3 class="h4" style="margin-bottom: 10px;">{{ block.settings.title }}</h3>
        <p style="font-size: 14px; color: #666;">View Recommended Ritual &rarr;</p>
      </a>
    {%- endfor -%}
  </div>

  <style>
    .ritual-card:hover {
      border-color: var(--color-base-text);
      background: rgba(0,0,0,0.02);
    }
  </style>
</section>

{% schema %}
{
  "name": "Ritual Builder",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Ritual"
    }
  ],
  "blocks": [
    {
      "type": "goal",
      "name": "Skin Goal",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Goal Title",
          "default": "Deep Hydration"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to Collection or Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ritual Builder",
      "blocks": [
        { "type": "goal", "settings": { "title": "Deep Hydration" } },
        { "type": "goal", "settings": { "title": "Radiance & Glow" } },
        { "type": "goal", "settings": { "title": "Purify & Cleanse" } }
      ]
    }
  ]
}
{% endschema %}
