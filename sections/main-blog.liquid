<section class="page-width" style="padding: 60px 0;">
  <h1 class="h2" style="text-align: center; margin-bottom: 40px;">{{ blog.title }}</h1>
  <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px;">
    {%- for article in blog.articles -%}
      <article class="article-card">
        {%- if article.image -%}
          <a href="{{ article.url }}" style="display: block; margin-bottom: 20px;">
            {{ article.image | image_url: width: 600 | image_tag: width: article.image.width, height: article.image.height, alt: article.title, style: 'width: 100%; height: auto;' }}
          </a>
        {%- endif -%}
        <h2 class="h4"><a href="{{ article.url }}">{{ article.title }}</a></h2>
        <p style="color: #666; font-size: 14px;">{{ article.published_at | date: "%B %d, %Y" }}</p>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog content",
  "settings": []
}
{% endschema %}
