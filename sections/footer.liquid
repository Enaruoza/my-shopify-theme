<footer class="footer page-width" style="padding: 60px 0; border-top: 1px solid var(--color-base-text);">
  <div class="footer__grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px;">
    {%- for block in section.blocks -%}
      <div class="footer__block" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h2 class="h4">{{ block.settings.heading }}</h2>
        {%- endif -%}

        {%- case block.type -%}
          {%- when 'text' -%}
            <div class="footer__text">{{ block.settings.text }}</div>
          {%- when 'link_list' -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer__links" style="list-style: none; margin: 0; padding: 0;">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" style="padding: 8px 0; display: block;">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
  
  <div class="footer__bottom" style="margin-top: 60px; text-align: center; font-size: 14px;">
    &copy; {{ 'now' | date: "%Y" }}, {{ shop.name | link_to: routes.root_url }}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About AZOURANE"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>",
          "label": "Text"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text"
      },
      {
        "type": "link_list"
      }
    ]
  }
}
{% endschema %}
