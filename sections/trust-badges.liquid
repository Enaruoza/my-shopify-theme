{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section-trust-badges",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Zašto Azourane?"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji or SVG)",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "100% Prirodno"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Bez štetnih kemikalija"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "🌿", "text": "100% Prirodno" } },
        { "type": "badge", "settings": { "icon": "🐰", "text": "Bez Okrutnosti" } },
        { "type": "badge", "settings": { "icon": "🚚", "text": "Brza Dostava" } },
        { "type": "badge", "settings": { "icon": "🛡️", "text": "Sigurna Kupovina" } }
      ]
    }
  ]
}
{% endschema %}

<div class="trust-badges-container page-width py-12" style="background-color: {{ section.settings.bg_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="text-center text-2xl font-serif mb-8 reveal-on-scroll">{{ section.settings.heading }}</h2>
  {% endif %}
  
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
    {% for block in section.blocks %}
      <div class="trust-badge-item reveal-on-scroll" {{ block.shopify_attributes }}>
        <div class="text-4xl mb-3 transform hover:scale-110 transition-transform duration-300">{{ block.settings.icon }}</div>
        <h3 class="font-bold text-lg mb-1">{{ block.settings.text }}</h3>
        {% if block.settings.subtext != blank %}
          <p class="text-sm text-gray-600">{{ block.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
