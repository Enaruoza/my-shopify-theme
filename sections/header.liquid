<header class="header page-width">
  <div class="header__inner" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0;">
    <div class="header__logo">
      <a href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 400 | image_tag: height: section.settings.logo.height, width: section.settings.logo.width, alt: section.settings.logo.alt | default: shop.name }}
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <nav class="header__nav">
      <ul style="display: flex; gap: 20px; list-style: none; margin: 0; padding: 0;">
        {%- for link in section.settings.menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="header__actions">
      <a href="{{ routes.search_url }}" class="header__search-link" aria-label="Search">Search</a>
      
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__account-link">
          Account
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__cart-link" id="cart-icon-bubble">
        Cart ({%- if cart.item_count < 100 -%}{{ cart.item_count }}{%- endif -%})
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
