{% schema %}
{
  "name": "Editorial Testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Šta kažu naše klijentice"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Ovo ulje je čudo. Koža mi nikad nije bila mekša."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Amra D."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Sarajevo"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Author Image"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .editorial-testimonials {
    padding: 60px 20px;
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    font-family: 'Montserrat', sans-serif;
  }

  .et-heading {
    font-size: 2rem;
    margin-bottom: 40px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .et-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .et-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .et-card {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: transform 0.3s ease;
  }

  .et-card:hover {
    transform: translateY(-5px);
  }

  .et-stars {
    color: #f59e0b;
    margin-bottom: 15px;
    font-size: 1.2rem;
  }

  .et-quote {
    font-size: 1.1rem;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .et-author-block {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .et-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    background-color: #eee;
  }

  .et-meta {
    text-align: left;
  }

  .et-name {
    font-weight: 700;
    font-size: 0.9rem;
    display: block;
  }

  .et-location {
    font-size: 0.8rem;
    opacity: 0.7;
  }
  
  .et-verified {
    color: #10b981;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 2px;
  }
</style>

<div class="editorial-testimonials">
  {% if section.settings.heading != blank %}
    <h2 class="et-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="et-grid">
    {% for block in section.blocks %}
      <div class="et-card">
        <div class="et-stars">
          {% for i in (1..block.settings.rating) %}★{% endfor %}
        </div>
        <blockquote class="et-quote">"{{ block.settings.quote }}"</blockquote>
        <div class="et-author-block">
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 100 | image_tag: class: 'et-avatar' }}
          {% else %}
            <div class="et-avatar" style="display:flex;align-items:center;justify-content:center;font-weight:bold;color:#888;">
              {{ block.settings.author | slice: 0 }}
            </div>
          {% endif %}
          <div class="et-meta">
            <span class="et-name">{{ block.settings.author }}</span>
            <span class="et-location">{{ block.settings.location }}</span>
            <span class="et-verified">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              Verifikovan kupac
            </span>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
