<section class="drops-hub-journey section-spacing page-width">
  
  {%- if section.settings.heading != 'AUTO' and section.settings.heading != blank -%}
    <div style="text-align: center; margin-bottom: 80px; max-width: 800px; margin-left: auto; margin-right: auto;">
      <h2 class="h2">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != 'AUTO' and section.settings.subheading != blank -%}
        <p class="h5" style="color: var(--color-base-text-light); margin-top: 15px;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- A) In stock now (core-stock) -->
  <div class="drops-hub__section" style="margin-bottom: 120px;">
    <h3 class="h3" style="border-bottom: 1px solid var(--color-border); padding-bottom: 15px; margin-bottom: 50px;">
      1. In Stock Now (Core Essentials)
    </h3>
    {%- assign core_stock = collections[section.settings.core_stock] -%}
    
    <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
      {%- if core_stock != blank and core_stock.products_count > 0 -%}
        {%- for product in core_stock.products limit: 4 -%}
          <div class="product-card">
            <a href="{{ product.url }}" style="display: block;">
              <div class="product-card__image-wrapper">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 800 | image_tag: alt: product.title }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </a>
            <h4 class="product-card__title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h4>
            <div class="product-card__price">{{ product.price | money }}</div>
            
            <form method="post" action="{{ routes.cart_add_url }}" style="width: 100%;">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="button" style="width: 100%; border-radius: var(--radius-button);" {% if product.available == false %}disabled{% endif %}>
                {%- if product.available -%}
                  Add to cart
                {%- else -%}
                  Sold out
                {%- endif -%}
              </button>
            </form>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
             <div class="product-card__image-wrapper">
               {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
             </div>
             <h4 class="product-card__title">Example Product</h4>
             <div class="product-card__price">$45.00</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <!-- B) Last chance (october-remnants) -->
  <div class="drops-hub__section" style="margin-bottom: 120px;">
    <h3 class="h3" style="border-bottom: 1px solid var(--color-border); padding-bottom: 15px; margin-bottom: 50px; display: flex; justify-content: space-between; align-items: baseline;">
      <span>2. Last Chance (Past Drops)</span>
    </h3>
    
    {%- assign remnants = collections[section.settings.remnants] -%}
    <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
      {%- if remnants != blank and remnants.products_count > 0 -%}
        {%- for product in remnants.products limit: 4 -%}
          <div class="product-card">
            
            {%- assign low_stock = false -%}
            {%- if product.variants.first.inventory_management == 'shopify' -%}
              {%- if product.variants.first.inventory_quantity > 0 and product.variants.first.inventory_quantity <= settings.low_stock_threshold -%}
                {%- assign low_stock = true -%}
              {%- endif -%}
            {%- endif -%}

            {%- if low_stock -%}
              <div class="product-badge">
                Only {{ product.variants.first.inventory_quantity }} left
              </div>
            {%- endif -%}

            <a href="{{ product.url }}" style="display: block;">
              <div class="product-card__image-wrapper">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 800 | image_tag: alt: product.title, style: 'filter: {% if product.available == false %}grayscale(100%){% else %}none{% endif %};' }}
                {%- else -%}
                  {{ 'product-5' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </a>
            
            <h4 class="product-card__title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h4>
            <div class="product-card__price">{{ product.price | money }}</div>
            
            <form method="post" action="{{ routes.cart_add_url }}" style="width: 100%;">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="button button--secondary" style="width: 100%; border-radius: var(--radius-button);" {% if product.available == false %}disabled{% endif %}>
                {%- if product.available -%}
                  {%- if low_stock -%}Claim last remaining{%- else -%}Add to cart{%- endif -%}
                {%- else -%}
                  Archived / Sold out
                {%- endif -%}
              </button>
            </form>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
             <div class="product-card__image-wrapper">
               {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
             </div>
             <h4 class="product-card__title">Example Archive</h4>
             <div class="product-card__price">$0.00</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <!-- C) Next drop incoming (coming-soon) -->
  <div class="drops-hub__section" style="background: var(--color-base-bg-alt); padding: 80px 40px; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto; ">
      <h3 class="h3" style="margin-bottom: 20px;">3. Next Drop Incoming</h3>
      <p style="margin-bottom: 30px; font-size: 1.25rem; font-family: var(--font-heading-family); color: var(--color-base-text-light);">{{ section.settings.next_drop_eta }}</p>
      <p style="margin-bottom: 40px; line-height: 1.6;">Join the waitlist to receive 24h early access before the general public. Our drops sell out fast.</p>
      
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter, next_drop_waitlist">
        <div style="display: flex; gap: 0; max-width: 500px; margin: 0 auto;">
          <input type="email" name="contact[email]" required placeholder="Enter your email" style="flex: 1; border-right: none;">
          <button type="submit" class="button" style="min-width: 150px;">Join</button>
        </div>
        {% if form.posted_successfully? %}
          <p class="form-success" style="margin-top: 20px; color: #4A7055; font-weight: 500;">You are on the list.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Drops Hub Journey",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The AZOURANE Drops"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Small batches. Truthful scarcity."
    },
    {
      "type": "collection",
      "id": "core_stock",
      "label": "Core Stock Collection"
    },
    {
      "type": "collection",
      "id": "remnants",
      "label": "Last Chance Collection"
    },
    {
      "type": "text",
      "id": "next_drop_eta",
      "label": "Next Drop ETA Text",
      "default": "Delivery expected late February"
    }
  ],
  "presets": [
    {
      "name": "Drops Hub Journey"
    }
  ]
}
{% endschema %}
