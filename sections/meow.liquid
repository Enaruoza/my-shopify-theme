{% liquid
  assign section_padding = 'section'

  assign title_setting = section.settings.title
  if title_setting == 'AUTO'
    assign title_setting = ''
  endif

  if title_setting == blank
    if section.blocks.size == 0
      assign section_padding = 'section--no-padding'
    endif
  endif

  assign css_vars = ''
  assign css_vars = css_vars | append: '--icon-max-width: ' | append: section.settings.icon_max_width | append: 'px;'
  assign css_vars = css_vars | append: '--icon-stroke-width: ' | append: section.settings.icon_thickness | append: ';'
  assign css_vars = css_vars | append: '--icon-bg-color: ' | append: section.settings.icon_bg_color | append: ';'

  if section.settings.show_border
    assign css_vars = css_vars | append: '--icon-border: var(--icon-stroke-width) solid currentColor;'
  else
    assign css_vars = css_vars | append: '--icon-border: none;'
  endif

  if section.settings.uppercase
    assign css_vars = css_vars | append: '--text-transform: uppercase;'
  else
    assign css_vars = css_vars | append: '--text-transform: none;'
  endif

  assign wrapper_classes = 'icon-list-wrapper'
  assign wrapper_classes = wrapper_classes | append: ' mobile-layout--' | append: section.settings.mobile_layout
  assign wrapper_classes = wrapper_classes | append: ' desktop-align--' | append: section.settings.desktop_alignment
%}

<div
  class="section-icon-list color-{{ section.settings.color_scheme }}{% if section.settings.use_gradient %} gradient{% endif %} {{ section_padding }}"
  style="{{ css_vars | escape }}"
>
  <div class="page-width">
    {% if title_setting != blank %}
      <h2 class="section-icon-list__title title h2">
        {{ title_setting | escape }}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="{{ wrapper_classes }}">
        <ul class="icon-list" role="list">
          {% for block in section.blocks %}
            {% liquid
              assign block_text = block.settings.text
              if block_text == 'AUTO'
                assign block_text = ''
              endif
            %}
            <li class="icon-list__item" {{ block.shopify_attributes }}>
              <div class="icon-list__icon-wrapper">
                {% if block.settings.custom_image != blank %}
                  {{
                    block.settings.custom_image
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', class: 'icon-list__image'
                  }}
                {% elsif block.settings.icon != blank %}
                  {% render 'theme-icon', icon: block.settings.icon, class: 'icon-list__icon' %}
                {% endif %}
              </div>

              {% if block_text != blank %}
                {% if section.settings.text_style == 'heading' %}
                  <h3 class="icon-list__text h5">{{ block_text | escape }}</h3>
                {% else %}
                  <p class="icon-list__text body-small">{{ block_text | escape }}</p>
                {% endif %}
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>
</div>

{% liquid
  assign custom_css = section.settings.custom_css
  if custom_css == 'AUTO'
    assign custom_css = ''
  endif
%}

<style>
  .section-icon-list {
    display: block;
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  .section-icon-list__title {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .icon-list-wrapper {
    display: block;
  }

  .icon-list {
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
  }

  .icon-list__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .icon-list__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-max-width);
    height: var(--icon-max-width);
    margin-bottom: 1rem;
    border-radius: 50%;
    background-color: var(--icon-bg-color);
    border: var(--icon-border);
    box-sizing: border-box;
    padding: 15%;
    color: currentColor;
  }

  .section-icon-list .theme-icon,
  .section-icon-list .icon-list__icon {
    width: 100%;
    height: 100%;
    display: block;
  }

  .section-icon-list .theme-icon svg,
  .section-icon-list .icon-list__icon svg {
    width: 100%;
    height: 100%;
    stroke-width: var(--icon-stroke-width);
  }

  .icon-list__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
  }

  .icon-list__text {
    margin: 0;
    text-transform: var(--text-transform);
    word-break: break-word;
  }

  @media screen and (max-width: 749px) {
    .section-icon-list {
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }

    .mobile-layout--wrap .icon-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem 1.5rem;
    }

    .mobile-layout--scroll .icon-list-wrapper {
      overflow-x: auto;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      margin: 0 calc(var(--page-width-margin) * -1);
      padding: 0 var(--page-width-margin);
    }

    .mobile-layout--scroll .icon-list-wrapper::-webkit-scrollbar {
      display: none;
    }

    .mobile-layout--scroll .icon-list {
      display: flex;
      flex-wrap: nowrap;
      justify-content: flex-start;
    }

    .mobile-layout--scroll .icon-list__item {
      flex: 0 0 auto;
      width: calc(var(--icon-max-width) * 0.8);
    }
  }

  @media screen and (min-width: 750px) {
    .icon-list-wrapper {
      margin: 0;
      padding: 0;
      overflow-x: visible;
    }

    .icon-list {
      display: flex;
      flex-wrap: nowrap;
      justify-content: center;
    }

    .desktop-align--spread .icon-list {
      justify-content: space-between;
    }

    .icon-list__item {
      flex: 1 1 0;
      padding: 0 0.5rem;
    }
  }

  {% if custom_css != blank %}
    {{ custom_css }}
  {% endif %}
</style>

{% schema %}
{
