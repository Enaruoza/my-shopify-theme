<section class="page-width" style="padding: 60px 0;">
  <h1 class="h2" style="text-align: center; margin-bottom: 40px;">Search Results</h1>

  <div style="max-width: 600px; margin: 0 auto; margin-bottom: 60px;">
    <form action="{{ routes.search_url }}" method="get" role="search" style="display: flex; gap: 10px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." style="flex: 1; padding: 12px; border: 1px solid var(--color-base-text);">
      <button type="submit" class="button">Search</button>
    </form>
  </div>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="text-align: center;">No results found for "{{ search.terms | escape }}". Check the spelling or use a different word.</p>
    {%- else -%}
      <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 40px;">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <div class="product-card" style="text-align: center;">
              <a href="{{ item.url }}" style="display: block;">
                <div class="product-card__image-wrapper" style="margin-bottom: 20px; aspect-ratio: 1; background: #eee;">
                  {%- if item.featured_media -%}
                    {{ item.featured_media | image_url: width: 600 | image_tag: width: item.featured_media.width, height: item.featured_media.height, alt: item.title, style: 'object-fit: cover; width: 100%; height: 100%;' }}
                  {%- endif -%}
                </div>
                <h3 class="h5" style="margin-bottom: 8px;">{{ item.title }}</h3>
                <div class="product-card__price">{{ item.price | money }}</div>
              </a>
            </div>
          {%- else -%}
            <div class="article-card" style="text-align: center; padding: 20px; border: 1px solid #eee;">
               <h3 class="h5" style="margin-bottom: 8px;"><a href="{{ item.url }}">{{ item.title }}</a></h3>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
