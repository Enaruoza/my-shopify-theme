<section class="page-width" style="padding: 60px 0;">
  {%- if section.settings.show_title -%}
    <h1 class="h2" style="text-align: center;">{{ collection.title }}</h1>
  {%- endif -%}

  {%- if collection.products_count > 0 -%}
    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 40px; margin-top: 40px;">
      {%- for product in collection.products -%}
        <div class="product-card" style="text-align: center;">
          <a href="{{ product.url }}" style="display: block;">
            <div class="product-card__image-wrapper" style="margin-bottom: 20px; aspect-ratio: 1; background: #eee;">
              {%- if product.featured_media -%}
                {{ product.featured_media | image_url: width: 600 | image_tag: width: product.featured_media.width, height: product.featured_media.height, alt: product.title, style: 'object-fit: cover; width: 100%; height: 100%;' }}
              {%- endif -%}
            </div>
            <h3 class="h5" style="margin-bottom: 8px;">{{ product.title }}</h3>
            <div class="product-card__price">{{ product.price | money }}</div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p style="text-align: center; margin-top: 40px;">No products found.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    }
  ]
}
{% endschema %}
