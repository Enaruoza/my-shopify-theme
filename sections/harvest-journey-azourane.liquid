{% schema %}
{
  "name": "Harvest Journey Azourane",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One Land. Two Traditions. Endless Rituals."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>From the same mountains and valleys of Morocco — two completely different journeys, all hand-picked by the women who keep this land alive.</p>"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "<p>One land. One tradition. But every harvest tells a different story. Follow the journey.</p>"
    },
    {
      "type": "header",
      "content": "Evolving Center Graphic (Desktop)"
    },
    {
      "type": "paragraph",
      "content": "These images will fade in/out in the center column as you scroll through the steps."
    },
    {
      "type": "image_picker",
      "id": "center_seed_image",
      "label": "Seed Stage Image"
    },
    {
      "type": "image_picker",
      "id": "center_fruit_image",
      "label": "Fruit Stage Image"
    },
    {
      "type": "image_picker",
      "id": "center_oil_image",
      "label": "Oil Stage Image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F0EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#3D3D35"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#6B705C"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Harvest Step",
      "settings": [
        {
          "type": "select",
          "id": "step_key",
          "label": "Step Stage",
          "options": [
            { "value": "seed", "label": "Seed / Soil" },
            { "value": "early_harvest", "label": "Early Harvest" },
            { "value": "oil", "label": "Oil / Ritual" }
          ],
          "default": "seed",
          "info": "Determines which center image is active."
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow (Caps)",
          "default": "STEP EYEBROW"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body Text",
          "default": "<p>Description of this stage in the harvest journey.</p>"
        },
        {
          "type": "text",
          "id": "detail_line",
          "label": "Detail Line (Yield info)",
          "default": "Detail or efficiency statistic."
        },
        {
          "type": "text",
          "id": "mood",
          "label": "Mood Words",
          "default": "Calm. Strong."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Side Image",
          "info": "Optional image displayed to the side of the text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Harvest Journey Azourane",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_key": "seed",
            "eyebrow": "SEED & SOIL — WHERE IT STARTS",
            "title": "The land chooses first.",
            "body": "<p>Our ingredients begin in wild and semi-wild Moroccan landscapes — argan groves, prickly pear fields, and small family plots.<br>Women’s collectives walk these lands, watching the seasons, choosing only trees and plants that grow strong without forced irrigation or artificial push.</p>",
            "detail_line": "One seed, countless possibilities.",
            "mood": "Quiet. Patient. Rooted."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_key": "early_harvest",
            "eyebrow": "HARVESTED EARLY — WHEN THE LAND IS AT ITS SHARPEST",
            "title": "High-potency face oils.",
            "body": "<p>Our women’s collectives hand-pick the very first fruits of the season — young, firm, and high in active nutrients.<br>Early harvest oils are naturally more intense, richer in antioxidants, and extremely limited in yield.</p>",
            "detail_line": "24 kg of early-season fruit = 1 liter of pure oil. Small yield. Big character.",
            "mood": "Punchy. Alive. Focused."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_key": "oil",
            "eyebrow": "HARVESTED LATER — WHEN THE FRUIT IS FULL + GENEROUS",
            "title": "From one harvest to many rituals.",
            "body": "<p>As the season matures, the fruit softens and yields more oil. This is when the collectives gather the richer, juicier crops — perfect for everyday nourishment, hair care, and our saponified bars.<br>Early harvest oils become our most intensive face care. Later harvest oils flow into creams, soaps, and hair masks designed for daily use.</p>",
            "detail_line": "13 kg of ripe fruit = 1 liter of oil. Higher yield. Softer profile.",
            "mood": "Mellow. Warm. Versatile."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="az-harvest-section" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }}; --accent-color: {{ section.settings.accent_color }};">
  <div class="page-width">
    
    <!-- Section Header -->
    <div class="az-harvest-header">
      {% if section.settings.heading != blank %}
        <h2 class="az-h2">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="az-subheading">{{ section.settings.subheading }}</div>
      {% endif %}
    </div>

    <!-- Timeline Container -->
    <div class="az-timeline-wrapper">
      
      <!-- Sticky Center Graphic (Desktop Only) -->
      <div class="az-center-track">
        <div class="az-dotted-line"></div>
        <div class="az-sticky-graphic">
          <div class="az-graphic-stage stage-seed" data-stage="seed">
            {% if section.settings.center_seed_image != blank %}
              {{ section.settings.center_seed_image | image_url: width: 300 | image_tag: loading: 'eager', class: 'az-stage-img' }}
            {% else %}
               <div class="az-placeholder-circle">Seed</div>
            {% endif %}
          </div>
          <div class="az-graphic-stage stage-fruit" data-stage="early_harvest">
            {% if section.settings.center_fruit_image != blank %}
              {{ section.settings.center_fruit_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'az-stage-img' }}
            {% else %}
               <div class="az-placeholder-circle">Fruit</div>
            {% endif %}
          </div>
          <div class="az-graphic-stage stage-oil" data-stage="oil">
            {% if section.settings.center_oil_image != blank %}
              {{ section.settings.center_oil_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'az-stage-img' }}
            {% else %}
               <div class="az-placeholder-circle">Oil</div>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- Steps List -->
      <div class="az-steps-container">
        {% for block in section.blocks %}
          {% assign mod = forloop.index | modulo: 2 %}
          <div class="az-step-block {% if mod == 0 %}az-step-even{% else %}az-step-odd{% endif %}" {{ block.shopify_attributes }} data-step-target="{{ block.settings.step_key }}">
            
            <!-- Mobile Inline Graphic (Shows specific stage for this step) -->
            <div class="az-mobile-graphic">
              {% case block.settings.step_key %}
                {% when 'seed' %}
                  {% if section.settings.center_seed_image != blank %}
                    {{ section.settings.center_seed_image | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {% endif %}
                {% when 'early_harvest' %}
                   {% if section.settings.center_fruit_image != blank %}
                    {{ section.settings.center_fruit_image | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {% endif %}
                {% when 'oil' %}
                   {% if section.settings.center_oil_image != blank %}
                    {{ section.settings.center_oil_image | image_url: width: 140 | image_tag: loading: 'lazy' }}
                  {% endif %}
              {% endcase %}
            </div>

            <!-- Content Column -->
            <div class="az-step-content">
              {% if block.settings.eyebrow != blank %}
                <div class="az-eyebrow">{{ block.settings.eyebrow }}</div>
              {% endif %}
              
              {% if block.settings.title != blank %}
                <h3 class="az-h3">{{ block.settings.title }}</h3>
              {% endif %}
              
              <div class="az-body">{{ block.settings.body }}</div>
              
              {% if block.settings.detail_line != blank %}
                <div class="az-detail-line">{{ block.settings.detail_line }}</div>
              {% endif %}
              
              {% if block.settings.mood != blank %}
                <div class="az-mood">{{ block.settings.mood }}</div>
              {% endif %}
            </div>

            <!-- Image Column -->
            <div class="az-step-image-col">
              {% if block.settings.image != blank %}
                <div class="az-step-img-wrapper">
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'az-step-img' }}
                </div>
              {% endif %}
            </div>

          </div>
        {% endfor %}
      </div>

    </div>

    <!-- Footer Text -->
    {% if section.settings.footer_text != blank %}
      <div class="az-harvest-footer">
        {{ section.settings.footer_text }}
      </div>
    {% endif %}

  </div>
</div>

<style>
  /* --- LAYOUT VARIABLES --- */
  .az-harvest-section {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: clamp(3rem, 5vw, 5rem) 0;
    position: relative;
    overflow: hidden;
  }
  
  .az-harvest-section .page-width {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* --- HEADER --- */
  .az-harvest-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem auto;
  }

  .az-h2 {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .az-subheading p {
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    line-height: 1.5;
    opacity: 0.85;
    margin: 0;
  }

  /* --- TIMELINE GRID --- */
  .az-timeline-wrapper {
    position: relative;
    /* Grid: [Left Content] [Center Track] [Right Content] */
    display: grid;
    grid-template-columns: 1fr 120px 1fr; 
    gap: 2rem;
  }

  /* --- CENTER TRACK (DESKTOP) --- */
  .az-center-track {
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
  }

  .az-dotted-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    border-left: 2px dotted var(--accent-color);
    opacity: 0.3;
    z-index: 0;
  }

  .az-sticky-graphic {
    position: sticky;
    top: 50vh; /* Center of viewport */
    transform: translateY(-50%);
    width: 120px;
    height: 120px;
    z-index: 2;
  }

  .az-graphic-stage {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease-in-out, transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    transform: scale(0.9);
    pointer-events: none;
  }
  
  .az-graphic-stage.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .az-stage-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  
  .az-placeholder-circle {
    width: 100%;
    height: 100%;
    background: var(--accent-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.8rem;
  }

  /* --- STEPS CONTAINER --- */
  .az-steps-container {
    grid-column: 1 / -1; /* Spans full width but internally grid items align */
    display: grid;
    grid-template-columns: subgrid; /* Inherit parent columns if using CSS subgrid, but safer manually */
    /* Fallback logic since subgrid validation varies */
    display: contents; 
  }

  .az-step-block {
    display: contents; /* Allows children to place themselves in parent grid */
  }
  
  /* ODD STEPS: Text Left (Col 1), Image Right (Col 3) */
  .az-step-block.az-step-odd .az-step-content {
    grid-column: 1 / 2;
    text-align: right;
    padding-right: 2rem;
    align-self: center;
    padding-bottom: 20vh; /* Spacing between steps */
  }
  
  .az-step-block.az-step-odd .az-step-image-col {
    grid-column: 3 / 4;
    align-self: center;
    padding-bottom: 20vh;
  }

  /* EVEN STEPS: Text Right (Col 3), Image Left (Col 1) */
  .az-step-block.az-step-even .az-step-content {
    grid-column: 3 / 4;
    text-align: left;
    padding-left: 2rem;
    align-self: center;
    padding-bottom: 20vh;
  }
  
  .az-step-block.az-step-even .az-step-image-col {
    grid-column: 1 / 2;
    align-self: center;
    padding-bottom: 20vh;
  }

  /* --- MOBILE GRAPHIC (Hidden on Desktop) --- */
  .az-mobile-graphic {
    display: none; 
  }
  
  /* --- STEP CONTENT --- */
  .az-eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-color);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .az-h3 {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .az-body {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 400px;
    margin-left: auto; /* For right aligned text */
  }
  
  .az-step-even .az-body {
    margin-left: 0;
    margin-right: auto;
  }

  .az-detail-line {
    font-family: var(--font-heading-family);
    border-top: 1px solid rgba(0,0,0,0.1);
    border-bottom: 1px solid rgba(0,0,0,0.1);
    padding: 0.75rem 0;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    display: inline-block; /* Wraps tightly */
  }

  .az-mood {
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--accent-color);
  }

  .az-step-img-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0,0,0,0.02);
  }

  .az-step-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- FOOTER --- */
  .az-harvest-footer {
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    margin-top: 3rem;
    opacity: 0.8;
  }
  
  /* --- MOBILE RESPONSIVE --- */
  @media screen and (max-width: 768px) {
    .az-timeline-wrapper {
      display: flex;
      flex-direction: column;
      gap: 4rem;
    }
    
    .az-center-track {
      display: none; /* Hide sticky complex graphic logic on mobile */
    }

    .az-step-block {
      display: flex;
      flex-direction: column;
      text-align: center !important; /* Force center alignment */
      gap: 1.5rem;
    }
    
    /* Reset grid columns logic */
    .az-step-block .az-step-content,
    .az-step-block .az-step-image-col {
      grid-column: auto;
      padding: 0 !important;
      max-width: 100%;
    }

    .az-body {
      margin: 0 auto !important;
    }
    
    /* Show mobile inline graphic */
    .az-mobile-graphic {
      display: block;
      width: 80px;
      height: 80px;
      margin: 0 auto 1rem auto;
    }
    
    .az-mobile-graphic img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .az-step-img-wrapper {
      margin-top: 1rem;
    }
    
    /* Order adjustment: Title -> Graphic -> Body -> Image */
    .az-step-content {
      display: flex;
      flex-direction: column;
    }
    
    .az-eyebrow { order: 1; }
    .az-h3 { order: 2; }
    /* Mobile graphic is technically outside content div, inserted via DOM order in HTML structure...
       Let's adjust HTML structure slightly or order via flex parent. 
       Current HTML: MobileGraphic, Content, Image.
       We want: Graphic inside content? Or Graphic between Title and Body.
       
       Simpler approach: Just put Graphic at top of step on mobile.
    */
    .az-mobile-graphic { order: -1; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Only run Desktop logic if track is visible
    const track = document.querySelector('.az-center-track');
    if (!track || getComputedStyle(track).display === 'none') return;

    const stages = document.querySelectorAll('.az-graphic-stage');
    const steps = document.querySelectorAll('.az-step-block');
    
    const observerOptions = {
      root: null,
      threshold: 0.4 // Trigger when 40% of step is visible
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const targetKey = entry.target.getAttribute('data-step-target');
          
          // Switch active class
          stages.forEach(stage => {
            if (stage.getAttribute('data-stage') === targetKey) {
              stage.classList.add('is-active');
            } else {
              stage.classList.remove('is-active');
            }
          });
        }
      });
    }, observerOptions);

    steps.forEach(step => observer.observe(step));
  });
</script>
