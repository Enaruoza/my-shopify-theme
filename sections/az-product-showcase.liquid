    { "type": "checkbox", "id": "show_hover_image", "label": "Show second image on hover", "default": true },
    { "type": "text", "id": "add_to_cart_text", "label": "Add to Cart Text", "default": "AUTO" },
    { "type": "text", "id": "sold_out_text", "label": "Sold Out Text", "default": "AUTO" },

    { "type": "header", "content": "Badges" },
