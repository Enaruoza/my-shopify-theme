      "step": 1,
      "default": 0
    },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "color_title_gradient_start", "label": "Title Gradient Start", "default": "#374151" },
    { "type": "color", "id": "color_title_gradient_end", "label": "Title Gradient End", "default": "#111827" },
    { "type": "color", "id": "color_primary", "label": "Primary Color (Buttons, 'All' Filter)", "default": "#3B82F6" },
    { "type": "color", "id": "color_secondary", "label": "Secondary Text", "default": "#6B7280" },
    { "type": "color", "id": "color_background", "label": "Section Background", "default": "#FFFFFF" },
    { "type": "color", "id": "color_card_bg", "label": "Product Card Background", "default": "#FFFFFF" },
    { "type": "color", "id": "color_text", "label": "Text", "default": "#111827" },
    { "type": "color", "id": "color_text_inverse", "label": "Inverse Text (on Primary)", "default": "#FFFFFF" },
    { "type": "color", "id": "color_border", "label": "Borders", "default": "#E5E7EB" },
    { "type": "color", "id": "color_sale", "label": "Sale & Success Color", "default": "#DC2626" },

    { "type": "header", "content": "Sizing & Style" },
    { "type": "range", "id": "button_radius", "label": "Button Roundness", "min": 0, "max": 50, "step": 2, "unit": "px", "default": 8 },
    { "type": "range", "id": "card_radius", "label": "Card Roundness", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 16 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 6,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Choose Collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
