    { "type": "header", "content": "Layout & Spacing" },
    { "type": "range", "id": "products_to_show", "label": "Products to show per collection", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "range", "id": "columns_desktop", "label": "Columns on desktop", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "spacing_below_filters", "label": "Space Below Filters", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },

    { "type": "header", "content": "Mobile Layout" },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Default Mobile Carousel Style",
      "options": [
        { "value": "carousel_peek", "label": "Carousel (1.5 products visible)" },
        { "value": "carousel_single", "label": "Carousel (1 product visible)" }
      ],
      "default": "carousel_peek"
    },

    { "type": "header", "content": "Product Card" },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/5", "label": "Portrait (4:5)" },
        { "value": "3/4", "label": "Tall (3:4)" }
