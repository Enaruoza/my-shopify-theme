{% comment %}
AZR Mini Cart Drawer – v1.0
- Pops open on any /cart/add.js, /cart/change.js, or /cart/update.js success
- Renders items from /cart.js (no Section Rendering dependency)
- Works with your existing sections (Routine Tabs, Bundles) without edits
{% endcomment %}

{% liquid
  assign sid = section.id | replace:'_','' | downcase
%}

<style>
.azr-minicart-{{ sid }}{position:fixed;inset:0;z-index:99999;display:none}
.azr-minicart-{{ sid }}[data-open="1"]{display:block}
.azr-minicart-{{ sid }} .overlay{position:absolute;inset:0;background:rgba(15,18,25,.45);backdrop-filter:blur(3px);opacity:0;transition:opacity .25s}
.azr-minicart-{{ sid }}[data-open="1"] .overlay{opacity:1}
.azr-minicart-{{ sid }} .panel{position:absolute;top:0;right:0;height:100%;width:min(420px,92vw);background:#fff;box-shadow:-12px 0 40px rgba(0,0,0,.18);transform:translateX(12px);opacity:.95;transition:transform .25s,opacity .25s;display:flex;flex-direction:column}
.azr-minicart-{{ sid }}[data-open="1"] .panel{transform:none;opacity:1}
.azr-minicart-{{ sid }} .hd{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid #eee}
.azr-minicart-{{ sid }} .hd h3{margin:0;font:700 16px/1.2 system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial}
.azr-minicart-{{ sid }} .close{border:0;background:#f2f3f5;border-radius:10px;width:32px;height:32px;cursor:pointer}
.azr-minicart-{{ sid }} .body{overflow:auto;padding:10px 12px 140px}
.azr-minicart-{{ sid }} .empty{padding:24px 12px;color:#6b7280;font:500 14px/1.5 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .it{display:grid;grid-template-columns:64px 1fr auto;gap:10px;align-items:center;padding:10px 4px;border-bottom:1px solid #f0f0f0}
.azr-minicart-{{ sid }} .thumb{width:64px;height:64px;border-radius:10px;overflow:hidden;background:#f5f5f5}
.azr-minicart-{{ sid }} .thumb img{width:100%;height:100%;object-fit:cover;display:block}
.azr-minicart-{{ sid }} .ttl{margin:0 0 4px;font:700 14px/1.35 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .meta{color:#6b7280;font:500 12px/1.3 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .price{font:700 13px/1.2 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .qty{display:inline-flex;align-items:center;border:1px solid #e5e7eb;border-radius:999px;overflow:hidden}
.azr-minicart-{{ sid }} .step{width:28px;height:28px;border:0;background:#fff;cursor:pointer}
.azr-minicart-{{ sid }} .count{min-width:28px;text-align:center;font:700 13px/28px system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .rm{border:0;background:transparent;color:#9ca3af;cursor:pointer;margin-left:6px}
.azr-minicart-{{ sid }} .ft{position:absolute;left:0;right:0;bottom:0;padding:12px;border-top:1px solid #eee;background:#fff;display:grid;row-gap:10px}
.azr-minicart-{{ sid }} .row{display:flex;justify-content:space-between;align-items:center}
.azr-minicart-{{ sid }} .row .lab{color:#6b7280;font:600 12px/1.2 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .row .val{font:800 16px/1.2 system-ui,-apple-system,Segoe UI,Roboto}
.azr-minicart-{{ sid }} .cta{display:grid;gap:8px;grid-template-columns:1fr 1fr}
.azr-minicart-{{ sid }} .btn{appearance:none;border:0;border-radius:12px;padding:12px 14px;font:800 14px/1 system-ui,-apple-system,Segoe UI,Roboto;cursor:pointer}
.azr-minicart-{{ sid }} .btn.view{background:#f3f4f6;color:#111}
.azr-minicart-{{ sid }} .btn.checkout{background:#111827;color:#fff}
@media (max-width:420px){.azr-minicart-{{ sid }} .cta{grid-template-columns:1fr}}
</style>

<div class="azr-minicart-{{ sid }}" data-open="0" aria-hidden="true">
  <div class="overlay" data-azr-close></div>
  <aside class="panel" role="dialog" aria-modal="true" aria-label="Mini cart">
    <div class="hd">
      <h3>Vaša korpa</h3>
      <button class="close" type="button" data-azr-close aria-label="Zatvori">×</button>
    </div>
    <div class="body" data-azr-cart-body>
      <div class="empty">Korpa je prazna.</div>
    </div>
    <div class="ft">
      <div class="row">
        <span class="lab">Međuzbir</span>
        <span class="val" data-azr-subtotal>—</span>
      </div>
      <div class="cta">
        <a class="btn view" href="{{ routes.cart_url }}">Vidi korpu</a>
        <a class="btn checkout" href="{{ routes.cart_url }}?checkout=1">Checkout</a>
      </div>
    </div>
  </aside>
</div>

<script>
(() => {
  const root = document.querySelector('.azr-minicart-{{ sid }}');
  if(!root) return;

  const bodyEl = root.querySelector('[data-azr-cart-body]');
  const subtotalEl = root.querySelector('[data-azr-subtotal]');
  const CURRENCY = {{ shop.currency | json }};
  const money = (cents) => new Intl.NumberFormat(undefined,{style:'currency',currency:CURRENCY}).format((cents||0)/100);

  function openCart(){ root.setAttribute('data-open','1'); root.setAttribute('aria-hidden','false'); document.documentElement.style.overflow='hidden'; refresh(); }
  function closeCart(){ root.setAttribute('data-open','0'); root.setAttribute('aria-hidden','true'); document.documentElement.style.overflow=''; }
  root.addEventListener('click', e => { if(e.target.hasAttribute('data-azr-close')) closeCart(); });
  document.addEventListener('keydown', e => { if(e.key === 'Escape') closeCart(); });

  async function fetchCart(){ const r = await fetch('/cart.js',{headers:{'Accept':'application/json'}}); return r.json(); }

  function lineItemHTML(it){
    const img = it.image ? `<img src="${it.image}" alt="">` : '';
    const variant = it.variant_title && it.variant_title !== 'Default Title' ? `<div class="meta">${it.variant_title}</div>` : '';
    return `
      <div class="it" data-key="${it.key}" data-id="${it.id}">
        <div class="thumb">${img}</div>
        <div>
          <div class="ttl">${it.product_title}</div>
          ${variant}
          <div class="price">${money(it.final_line_price)}</div>
          <div class="qty" role="group" aria-label="Količina">
            <button class="step" data-step="dec" aria-label="Smanji">−</button>
            <span class="count">${it.quantity}</span>
            <button class="step" data-step="inc" aria-label="Povećaj">+</button>
            <button class="rm" data-remove aria-label="Ukloni">✕</button>
          </div>
        </div>
      </div>`;
  }

  async function setQty(key, qty){
    qty = Math.max(0, qty|0);
    const r = await fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({ id:key, quantity:qty })});
    return r.json();
  }

  async function refresh(){
    try{
      const cart = await fetchCart();
      subtotalEl.textContent = money(cart.items_subtotal_price ?? cart.total_price);
      if(!cart.items || !cart.items.length){
        bodyEl.innerHTML = `<div class="empty">Korpa je prazna.</div>`;
        return;
      }
      bodyEl.innerHTML = cart.items.map(lineItemHTML).join('');
    }catch(e){ console.error(e); }
  }

  // Quantity / remove handlers
  bodyEl.addEventListener('click', async (e)=>{
    const it = e.target.closest('.it'); if(!it) return;
    const key = it.getAttribute('data-key');
    if(e.target.matches('[data-step="inc"], [data-step="dec"]')){
      e.preventDefault();
      const countEl = it.querySelector('.count');
      let n = parseInt(countEl.textContent||'0',10);
      n = e.target.getAttribute('data-step') === 'inc' ? n+1 : n-1;
      await setQty(key, n);
      await refresh();
    }
    if(e.target.matches('[data-remove]')){
      e.preventDefault();
      await setQty(key, 0);
      await refresh();
    }
  });

  // Open on custom events fired by your sections
  document.addEventListener('azr:bundle-added', () => openCart());
  document.addEventListener('azr:cart-open', () => openCart());

  // Also open automatically whenever theme code hits cart APIs successfully
  const origFetch = window.fetch.bind(window);
  window.fetch = async function(input, init){
    const res = await origFetch(input, init);
    try{
      const url = typeof input === 'string' ? input : input.url;
      const method = (init && init.method) || 'GET';
      if(url && url.indexOf('/cart/') !== -1 && res.ok && /add\.js|change\.js|update\.js/.test(url)){
        openCart();
      }
    }catch(_){}
    return res;
  };

  // Expose a tiny API if you ever need to trigger manually
  window.AZRMiniCart = { open: openCart, close: closeCart, refresh };
})();
</script>

{% schema %}
{
  "name": "AZR Mini Cart Drawer",
  "settings": [],
  "presets": [{ "name": "AZR Mini Cart Drawer" }]
}
{% endschema %}
