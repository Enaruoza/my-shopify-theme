{% comment %}
  Curtain Reveal Animation
  Slides up to reveal the site content. Runs once per session.
{% endcomment %}

<style>
  .curtain-reveal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ settings.colors_solid_button_labels | default: '#000' }}; /* Use brand color */
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  .curtain-reveal.is-hidden {
    transform: translateY(-100%);
  }

  .curtain-logo {
    opacity: 0;
    transform: scale(0.9);
    animation: logoFadeIn 0.8s ease-out forwards;
    max-width: 200px;
  }
  
  .curtain-logo img {
    width: 100%;
    height: auto;
  }

  @keyframes logoFadeIn {
    0% { opacity: 0; transform: scale(0.9); }
    100% { opacity: 1; transform: scale(1); }
  }
</style>

<div id="curtain-reveal" class="curtain-reveal" style="display: none;">
  <div class="curtain-logo">
    {% if settings.logo != blank %}
      {{ settings.logo | image_url: width: 400 | image_tag: loading: 'eager' }}
    {% else %}
      <h1 style="color: white; font-size: 2rem; font-weight: bold;">{{ shop.name }}</h1>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const curtain = document.getElementById('curtain-reveal');
    const hasSeenIntro = sessionStorage.getItem('hasSeenIntro');

    // Only show if user hasn't seen it in this session
    if (!hasSeenIntro) {
      curtain.style.display = 'flex';
      
      // Wait for logo animation, then slide up
      setTimeout(() => {
        curtain.classList.add('is-hidden');
        sessionStorage.setItem('hasSeenIntro', 'true');
        
        // Remove from DOM after animation to free resources
        setTimeout(() => {
          curtain.remove();
        }, 1200);
      }, 1500); // 1.5s display time
    }
  });
</script>
