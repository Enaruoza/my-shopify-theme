{%- if settings.enable_atmosphere -%}
<style>
  #living-atmosphere {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: {{ settings.atmosphere_z_index | default: 1 }};
    opacity: {{ settings.atmosphere_opacity | default: 0.6 }};
  }
</style>

<canvas id="living-atmosphere"></canvas>

<script>
  (function() {
    const canvas = document.getElementById('living-atmosphere');
    const ctx = canvas.getContext('2d');
    let width, height;
    let particles = [];
    
    // Configuration
    const particleCount = {{ settings.atmosphere_density | default: 50 }};
    const particleType = "{{ settings.atmosphere_type | default: 'dust' }}"; // dust, bubbles, petals
    const speed = {{ settings.atmosphere_speed | default: 1 }};
    const color = "{{ settings.atmosphere_color | default: '#ffffff' }}";

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }

    class Particle {
      constructor() {
        this.reset();
      }

      reset() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.vx = (Math.random() - 0.5) * speed * 0.5;
        this.vy = (Math.random() - 0.5) * speed * 0.5;
        this.size = Math.random() * 2 + 1;
        this.alpha = Math.random() * 0.5 + 0.1;
        this.angle = Math.random() * Math.PI * 2;
        this.spin = (Math.random() - 0.5) * 0.02;
        
        if (particleType === 'petals') {
          this.size = Math.random() * 5 + 3;
          this.vy = Math.random() * speed + 0.5; // Fall down
        } else if (particleType === 'bubbles') {
          this.vy = -Math.random() * speed - 0.5; // Float up
        }
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;
        this.angle += this.spin;

        if (particleType === 'petals') {
           this.x += Math.sin(this.angle) * 0.5;
        }

        // Wrap around screen
        if (this.x < -10) this.x = width + 10;
        if (this.x > width + 10) this.x = -10;
        if (this.y < -10) this.y = height + 10;
        if (this.y > height + 10) this.y = -10;
      }

      draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate(this.angle);
        ctx.globalAlpha = this.alpha;
        ctx.fillStyle = color;

        if (particleType === 'dust') {
          ctx.beginPath();
          ctx.arc(0, 0, this.size, 0, Math.PI * 2);
          ctx.fill();
        } else if (particleType === 'petals') {
          ctx.beginPath();
          ctx.ellipse(0, 0, this.size, this.size * 0.5, 0, 0, Math.PI * 2);
          ctx.fill();
        } else if (particleType === 'bubbles') {
          ctx.strokeStyle = color;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.arc(0, 0, this.size, 0, Math.PI * 2);
          ctx.stroke();
        }

        ctx.restore();
      }
    }

    function init() {
      resize();
      for (let i = 0; i < particleCount; i++) {
        particles.push(new Particle());
      }
      animate();
    }

    function animate() {
      ctx.clearRect(0, 0, width, height);
      particles.forEach(p => {
        p.update();
        p.draw();
      });
      requestAnimationFrame(animate);
    }

    window.addEventListener('resize', resize);
    init();
  })();
</script>
{%- endif -%}
