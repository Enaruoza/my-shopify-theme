{% comment %}
  Cart Drawer Upsell
  Displays a list of recommended products in the cart drawer.
{% endcomment %}

<div class="cart-drawer-upsell">
  <h3 class="cart-drawer-upsell__heading">You May Also Like</h3>
  <div class="cart-drawer-upsell__items">
    {% assign upsell_collection = collections['all'] %}
    {% assign count = 0 %}
    
    {% for product in upsell_collection.products %}
      {% assign in_cart = false %}
      {% for item in cart.items %}
        {% if item.product.id == product.id %}
          {% assign in_cart = true %}
        {% endif %}
      {% endfor %}
      
      {% if in_cart == false and product.available %}
        <div class="cart-drawer-upsell__item">
          <div class="cart-drawer-upsell__image">
            <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title }}" loading="lazy" width="100" height="100">
          </div>
          <div class="cart-drawer-upsell__content">
            <a href="{{ product.url }}" class="cart-drawer-upsell__title">{{ product.title }}</a>
            <p class="cart-drawer-upsell__price">{{ product.price | money }}</p>
            
            {% form 'product', product, class: 'cart-drawer-upsell__form' %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" name="add" class="button button--small button--secondary cart-drawer-upsell__add-btn">
                Add
              </button>
            {% endform %}
          </div>
        </div>
        {% assign count = count | plus: 1 %}
      {% endif %}
      
      {% if count >= 2 %}{% break %}{% endif %}
    {% endfor %}
  </div>
</div>

<style>
  .cart-drawer-upsell {
    padding: 1.5rem;
    background-color: var(--color-secondary-background, #f9f9f9);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .cart-drawer-upsell__heading {
    font-size: 1rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .cart-drawer-upsell__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cart-drawer-upsell__item {
    display: flex;
    gap: 1rem;
    align-items: center;
    background: var(--color-background);
    padding: 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .cart-drawer-upsell__image img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
  }

  .cart-drawer-upsell__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cart-drawer-upsell__title {
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-foreground);
    font-weight: 500;
  }

  .cart-drawer-upsell__price {
    font-size: 0.85rem;
    color: var(--color-foreground-secondary);
    margin: 0;
  }

  .cart-drawer-upsell__add-btn {
    width: fit-content;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    min-height: 30px;
    margin-top: 0.25rem;
  }
</style>
