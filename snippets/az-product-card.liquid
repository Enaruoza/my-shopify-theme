<div
  class="az-card"
  style="--aspect-ratio: {{ aspect_ratio | default: '1/1' }};"
>
  <div class="az-card__media">
    <a href="{{ product.url }}" class="az-card__media-link" aria-label="{{ product.title }}">
      {% if product.featured_image != blank %}
        <img
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="900"
          height="900"
          loading="lazy"
          class="az-card__image"
        >
      {% else %}
        <div class="az-card__placeholder"></div>
      {% endif %}
    </a>
    {% if product.available %}
      <form method="post" action="/cart/add" class="az-card__form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="az-card__add-button" aria-label="Add {{ product.title }} to cart">
          <span class="az-card__add-icon">+</span>
          <span class="az-card__add-text">{{ card_add_text | default: 'Add to Cart' }}</span>
        </button>
      </form>
    {% endif %}
  </div>

  <div class="az-card__content">
    <a href="{{ product.url }}" class="az-card__content-link">
      <h3 class="az-card__title">{{ product.title }}</h3>
    </a>
    <div class="az-card__price-wrapper">
      <span class="az-card__price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="az-card__price az-card__price--compare">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .az-card {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .az-card__media {
    position: relative;
    display: block;
    aspect-ratio: var(--aspect-ratio);
    border-radius: var(--card-radius);
    overflow: hidden;
    background-color: #f5f5f5;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .az-card:hover .az-card__media {
    transform: scale(1.03);
    z-index: 2;
  }
  .az-card__media-link {
    display: block;
    width: 100%;
    height: 100%;
  }
  .az-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .az-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: #f0f0f0;
  }
  .az-card__form {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 3;
  }
  .az-card__add-button {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 99px;
    height: 2.25rem;
    width: 2.25rem;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s var(--ease-out-expo);
  }
  .az-card:hover .az-card__add-button {
    width: auto;
    padding: 0 1rem 0 0.75rem;
    background-color: white;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  .az-card__add-icon {
    font-size: 1.5rem;
    line-height: 1;
    font-weight: 300;
    color: #333;
    transition: transform 0.3s var(--ease-out-expo);
  }
  .az-card:hover .az-card__add-icon {
    transform: rotate(90deg);
  }
  .az-card__add-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: #111;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    transition: max-width 0.4s var(--ease-out-expo), opacity 0.2s ease;
    margin-left: 0;
  }
  .az-card:hover .az-card__add-text {
    max-width: 100px;
    opacity: 1;
    margin-left: 0.5rem;
    transition-delay: 0.05s;
  }
  .az-card__content {
    padding: 1rem 0.25rem;
  }
  .az-card__content-link {
    text-decoration: none;
    color: inherit;
  }
  .az-card__title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    transition: color 0.2s ease;
  }
  .az-card:hover .az-card__title {
    color: var(--color-primary);
  }
  .az-card__price-wrapper {
    margin-top: 0.25rem;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }
  .az-card__price {
    font-size: 0.9rem;
    color: var(--color-secondary);
  }
  .az-card__price--compare {
    text-decoration: line-through;
    opacity: 0.7;
  }
</style>