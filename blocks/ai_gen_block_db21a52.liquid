{% doc %}
  @prompt
    google maps
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-google-map-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-google-map__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.map_height }}px;
  }

  .ai-google-map__iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-google-map__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-google-map__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    color: #ffffff;
    pointer-events: none;
  }

  .ai-google-map__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-google-map__address-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.address_size }}px;
    line-height: 1.5;
  }

  .ai-google-map__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.map_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-google-map__placeholder-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .ai-google-map__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #ffffff;
    font-size: 14px;
    border-radius: 4px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-google-map__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.map_height_mobile }}px;
    }

    .ai-google-map__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.map_height_mobile }}px;
    }

    .ai-google-map__content-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-google-map__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-google-map__address-{{ ai_gen_id }} {
      font-size: {{ block.settings.address_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-google-map-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.map_address != blank %}
    <div class="ai-google-map__wrapper-{{ ai_gen_id }}">
      <iframe
        class="ai-google-map__iframe-{{ ai_gen_id }}"
        src="https://maps.google.com/maps?q={{ block.settings.map_address | url_encode }}&t={{ block.settings.map_type }}&z={{ block.settings.zoom_level }}&output=embed"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="{{ block.settings.title | default: 'Google Map' }}"
      ></iframe>

      {% if block.settings.show_overlay %}
        <div class="ai-google-map__overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.show_content and block.settings.title != blank or block.settings.address != blank %}
        <div class="ai-google-map__content-{{ ai_gen_id }}">
          {% if block.settings.title != blank %}
            <h3 class="ai-google-map__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.address != blank %}
            <p class="ai-google-map__address-{{ ai_gen_id }}">{{ block.settings.address }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-google-map__placeholder-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      <div class="ai-google-map__empty-state-{{ ai_gen_id }}">
        Add a map address to display the map
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Google Maps",
  "settings": [
    {
      "type": "header",
      "content": "Map settings"
    },
    {
      "type": "text",
      "id": "map_address",
      "label": "Map address",
      "info": "Enter a full address or coordinates"
    },
    {
      "type": "select",
      "id": "map_type",
      "label": "Map type",
      "options": [
        {
          "value": "m",
          "label": "Roadmap"
        },
        {
          "value": "k",
          "label": "Satellite"
        },
        {
          "value": "h",
          "label": "Hybrid"
        },
        {
          "value": "p",
          "label": "Terrain"
        }
      ],
      "default": "m"
    },
    {
      "type": "range",
      "id": "zoom_level",
      "min": 1,
      "max": 20,
      "step": 1,
      "label": "Zoom level",
      "default": 14
    },
    {
      "type": "range",
      "id": "map_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop height",
      "default": 450
    },
    {
      "type": "range",
      "id": "map_height_mobile",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile height",
      "default": 300
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 20
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Show content",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Visit us"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Main Street, City, Country"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 24
    },
    {
      "type": "range",
      "id": "address_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Address size",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Google Maps"
    }
  ]
}
{% endschema %}