{% doc %}
  @prompt
    Build a two-column hero section with the following layout:
    
    Left Column:
    
    Large JUMBO headline: “CLEAN BEAUTY. CLEAR CONSCIENCE” in all caps, modern sans-serif font.
    
    Bold red-orange CTA button: “SHOP NOW”, full width or auto-fit.
    
    Optional: Add product preview (image + label) and hashtags below.
    
    Right Column:
    
    Floating product image with lock icon (top right, optional).
    
    Vertical accordion menu with 4 links: Home, New Collections, About, Why Us?
    
    Use CSS grid or flexbox for layout, make it fully responsive, and use dark background with high-contrast text.
    
    I should have the ability to adjust how many items there are in the accordion, all aspects of the block ought to be customizable;,  the accordion should be an actual accordion that i can add text under when its chose; not link to a page

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .hero-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    min-height: {{ block.settings.section_height }}px;
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  .hero-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px;
    position: relative;
  }

  .hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: {{ block.settings.headline_color }};
    max-width: 100%;
  }

  .hero-cta-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    padding: 15px 30px;
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.3s;
    width: {{ block.settings.button_width }};
    text-align: center;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 30px;
  }

  .hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .product-preview-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-top: 20px;
    margin-bottom: 20px;
  }

  .product-preview-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    margin-right: 15px;
  }

  .product-preview-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-preview-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
  }

  .hashtags-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .hashtag-{{ ai_gen_id }} {
    background-color: {{ block.settings.hashtag_background }};
    color: {{ block.settings.hashtag_color }};
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 12px;
  }

  .product-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 80%;
    position: relative;
  }

  .product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-image-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
    max-width: 400px;
    max-height: 400px;
  }

  .lock-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    background-color: {{ block.settings.lock_background }};
    color: {{ block.settings.lock_color }};
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .accordion-menu-{{ ai_gen_id }} {
    margin-top: 40px;
    width: 100%;
    max-width: 300px;
  }

  .accordion-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.accordion_border_color }};
  }

  .accordion-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.accordion_text_color }};
    cursor: pointer;
    padding: 15px 0;
    width: 100%;
    text-align: left;
    font-size: 16px;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accordion-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accordion_hover_color }};
  }

  .accordion-icon-{{ ai_gen_id }} {
    transition: transform 0.3s ease;
  }

  .accordion-icon-{{ ai_gen_id }}.active {
    transform: rotate(180deg);
  }

  .accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    padding: 0 15px;
    color: {{ block.settings.accordion_text_color }};
  }

  .accordion-content-{{ ai_gen_id }}.active {
    max-height: 200px;
    padding-bottom: 15px;
  }

  @media screen and (max-width: 768px) {
    .hero-section-{{ ai_gen_id }} {
      flex-direction: column;
      padding: 20px;
    }

    .hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .hero-column-{{ ai_gen_id }} {
      padding: 10px;
    }

    .product-image-{{ ai_gen_id }} {
      max-height: 60%;
    }

    .accordion-menu-{{ ai_gen_id }} {
      margin-top: 20px;
      max-width: 100%;
    }
  }
{% endstyle %}

<div class="hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="hero-column-{{ ai_gen_id }}">
    <h1 class="hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    
    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="hero-cta-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
    
    {% if block.settings.show_product_preview %}
      <div class="product-preview-{{ ai_gen_id }}">
        {% if block.settings.preview_product != blank %}
          <div class="product-preview-image-{{ ai_gen_id }}">
            {% if block.settings.preview_product.featured_image %}
              <img 
                src="{{ block.settings.preview_product.featured_image | img_url: '160x160', crop: 'center' }}" 
                alt="{{ block.settings.preview_product.title | escape }}"
                loading="lazy"
                width="80"
                height="80"
              >
            {% else %}
              <div class="product-preview-placeholder-{{ ai_gen_id }}">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="product-preview-label-{{ ai_gen_id }}">
            {{ block.settings.preview_product.title }}
          </div>
        {% endif %}
      </div>
    {% endif %}
    
    {% if block.settings.show_hashtags %}
      <div class="hashtags-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% assign hashtag_key = 'hashtag_' | append: i %}
          {% if block.settings[hashtag_key] != blank %}
            <div class="hashtag-{{ ai_gen_id }}">#{{ block.settings[hashtag_key] }}</div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div><div class="hero-column-{{ ai_gen_id }}">
    <div class="product-image-container-{{ ai_gen_id }}">
      {% if block.settings.show_lock_icon %}
        <div class="lock-icon-{{ ai_gen_id }}">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.5 7H12V5C12 2.24 9.76 0 7 0C4.24 0 2 2.24 2 5V7H1.5C0.67 7 0 7.67 0 8.5V14.5C0 15.33 0.67 16 1.5 16H12.5C13.33 16 14 15.33 14 14.5V8.5C14 7.67 13.33 7 12.5 7ZM8 12C7.17 12 6.5 11.33 6.5 10.5C6.5 9.67 7.17 9 8 9C8.83 9 9.5 9.67 9.5 10.5C9.5 11.33 8.83 12 8 12ZM10.5 7H5.5V5C5.5 4.17 6.17 3.5 7 3.5C7.83 3.5 8.5 4.17 8.5 5V7H10.5V5C10.5 3.01 8.99 1.5 7 1.5C5.01 1.5 3.5 3.01 3.5 5V7H3V7Z" fill="currentColor"/>
          </svg>
        </div>
      {% endif %}
      
      {% if block.settings.product_image %}
        <img 
          src="{{ block.settings.product_image | img_url: '800x' }}" 
          alt="{{ block.settings.product_image.alt | escape }}"
          class="product-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
        >
      {% else %}
        <div class="product-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    
    <div class="accordion-menu-{{ ai_gen_id }}">
      {% for i in (1..block.settings.accordion_items) %}
        {% assign title_key = 'accordion_title_' | append: i %}
        {% assign content_key = 'accordion_content_' | append: i %}
        
        {% if block.settings[title_key] != blank %}
          <div class="accordion-item-{{ ai_gen_id }}">
            <button class="accordion-button-{{ ai_gen_id }}" aria-expanded="false" aria-controls="accordion-content-{{ ai_gen_id }}-{{ i }}">
              {{ block.settings[title_key] }}
              <span class="accordion-icon-{{ ai_gen_id }}">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 9L12 3H0L6 9Z" fill="currentColor"/>
                </svg>
              </span>
            </button>
            <div id="accordion-content-{{ ai_gen_id }}-{{ i }}" class="accordion-content-{{ ai_gen_id }}">
              {{ block.settings[content_key] }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    class HeroSection extends HTMLElement {
      constructor() {
        super();
        this.accordionButtons = this.querySelectorAll('.accordion-button-{{ ai_gen_id }}');
        this.accordionContents = this.querySelectorAll('.accordion-content-{{ ai_gen_id }}');
        this.accordionIcons = this.querySelectorAll('.accordion-icon-{{ ai_gen_id }}');
        
        this.init();
      }
      
      init() {
        this.accordionButtons.forEach((button, index) => {
          button.addEventListener('click', () => {
            const content = this.accordionContents[index];
            const icon = this.accordionIcons[index];
            const isActive = content.classList.contains('active');
            
            // Close all accordions
            this.accordionContents.forEach(item => {
              item.classList.remove('active');
            });
            
            this.accordionButtons.forEach(btn => {
              btn.setAttribute('aria-expanded', 'false');
            });
            
            this.accordionIcons.forEach(icn => {
              icn.classList.remove('active');
            });
            
            // Open clicked accordion if it wasn't already open
            if (!isActive) {
              content.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
              icon.classList.add('active');
            }
          });
        });
      }
    }
    
    customElements.define('hero-section-{{ ai_gen_id }}', HeroSection);
    
    // Initialize the component
    const heroSection = document.querySelector('.hero-section-{{ ai_gen_id }}');
    if (heroSection) {
      new HeroSection();
    }
  })();
</script>

