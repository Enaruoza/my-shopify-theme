{% doc %}
  @prompt
    Build a two-column hero section with the following layout:
    
    Left Column:
    
    Large JUMBO headline: “CLEAN BEAUTY. CLEAR CONSCIENCE” in all caps, modern sans-serif font.
    
    Bold red-orange CTA button: “SHOP NOW”, full width or auto-fit.
    
    Optional: Add product preview (image + label) and hashtags below.
    
    Right Column:
    
    Floating product image with lock icon (top right, optional).
    
    Vertical accordion menu with 4 links: Home, New Collections, About, Why Us?
    
    Use CSS grid or flexbox for layout, make it fully responsive, and use dark background with high-contrast text.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    width: 100%;
    padding: {{ block.settings.section_padding }}px;
    gap: 30px;
  }

  .ai-hero-left-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px;
  }

  .ai-hero-right-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    padding: 20px;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 30px;
    font-family: {{ block.settings.heading_font.family }}, sans-serif;
    font-weight: {{ block.settings.heading_font.weight }};
  }

  .ai-hero-cta-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    padding: 15px 30px;
    text-transform: uppercase;
    font-weight: 700;
    border: none;
    cursor: pointer;
    font-size: 16px;
    margin-bottom: 30px;
    transition: background-color 0.3s;
    width: {{ block.settings.button_width }};
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .ai-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-product-preview-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
  }

  .ai-product-preview-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin-right: 15px;
    border-radius: 5px;
    overflow: hidden;
  }

  .ai-product-preview-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-preview-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-preview-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-product-preview-label-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-hashtags-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ai-hashtag-{{ ai_gen_id }} {
    color: {{ block.settings.hashtag_color }};
    font-size: 14px;
  }

  .ai-product-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 400px;
    margin-bottom: 30px;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-height: 400px;
  }

  .ai-lock-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: {{ block.settings.lock_icon_background }};
    color: {{ block.settings.lock_icon_color }};
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-accordion-menu-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.accordion_border_color }};
  }

  .ai-accordion-button-{{ ai_gen_id }} {
    width: 100%;
    text-align: left;
    padding: 15px 0;
    background: none;
    border: none;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-accordion-button-{{ ai_gen_id }}:after {
    content: '+';
    font-size: 20px;
  }

  .ai-accordion-button-{{ ai_gen_id }}.active:after {
    content: '-';
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

  .ai-accordion-content-{{ ai_gen_id }}.active {
    max-height: 200px;
  }

  .ai-accordion-link-{{ ai_gen_id }} {
    display: block;
    padding: 10px 0;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    opacity: 0.8;
  }

  .ai-accordion-link-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-section-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-hero-left-{{ ai_gen_id }}, 
    .ai-hero-right-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-left-{{ ai_gen_id }}">
    <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    
    <a href="{{ block.settings.button_link }}" class="ai-hero-cta-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
    
    {% if block.settings.show_product_preview %}
      <div class="ai-product-preview-{{ ai_gen_id }}">
        <div class="ai-product-preview-image-{{ ai_gen_id }}">
          {% if block.settings.preview_product_image %}
            <img 
              src="{{ block.settings.preview_product_image | img_url: '160x160', crop: 'center' }}" 
              alt="{{ block.settings.preview_product_image.alt | escape }}"
              loading="lazy"
              width="80"
              height="80"
            >
          {% else %}
            <div class="ai-product-preview-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-product-preview-label-{{ ai_gen_id }}">
          {{ block.settings.preview_product_label }}
        </div>
      </div>
    {% endif %}
    
    {% if block.settings.show_hashtags %}
      <div class="ai-hashtags-{{ ai_gen_id }}">
        {% assign hashtags = block.settings.hashtags | split: ',' %}
        {% for hashtag in hashtags %}
          <span class="ai-hashtag-{{ ai_gen_id }}">#{{ hashtag | strip }}</span>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  
  <div class="ai-hero-right-{{ ai_gen_id }}">
    <div class="ai-product-image-container-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img 
          src="{{ block.settings.product_image | img_url: '800x', crop: 'center' }}" 
          alt="{{ block.settings.product_image.alt | escape }}"
          class="ai-product-image-{{ ai_gen_id }}"
          loading="lazy"
          width="400"
          height="400"
        >
      {% else %}
        <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      
      {% if block.settings.show_lock_icon %}
        <div class="ai-lock-icon-{{ ai_gen_id }}">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.5 7H12V5C12 2.24 9.76 0 7 0C4.24 0 2 2.24 2 5V7H1.5C0.67 7 0 7.67 0 8.5V14.5C0 15.33 0.67 16 1.5 16H12.5C13.33 16 14 15.33 14 14.5V8.5C14 7.67 13.33 7 12.5 7ZM4 5C4 3.34 5.34 2 7 2C8.66 2 10 3.34 10 5V7H4V5ZM12 14H2V9H12V14ZM7 11.5C7.83 11.5 8.5 10.83 8.5 10C8.5 9.17 7.83 8.5 7 8.5C6.17 8.5 5.5 9.17 5.5 10C5.5 10.83 6.17 11.5 7 11.5Z" fill="currentColor"/>
          </svg>
        </div>
      {% endif %}
    </div>
    
    <div class="ai-accordion-menu-{{ ai_gen_id }}">
      <div class="ai-accordion-item-{{ ai_gen_id }}">
        <button class="ai-accordion-button-{{ ai_gen_id }}" aria-expanded="false">
          {{ block.settings.menu_item_1 }}
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_link_1 }}" class="ai-accordion-link-{{ ai_gen_id }}">{{ block.settings.menu_item_1 }}</a>
        </div>
      </div>
      
      <div class="ai-accordion-item-{{ ai_gen_id }}">
        <button class="ai-accordion-button-{{ ai_gen_id }}" aria-expanded="false">
          {{ block.settings.menu_item_2 }}
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_link_2 }}" class="ai-accordion-link-{{ ai_gen_id }}">{{ block.settings.menu_item_2 }}</a>
        </div>
      </div>
      
      <div class="ai-accordion-item-{{ ai_gen_id }}">
        <button class="ai-accordion-button-{{ ai_gen_id }}" aria-expanded="false">
          {{ block.settings.menu_item_3 }}
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_link_3 }}" class="ai-accordion-link-{{ ai_gen_id }}">{{ block.settings.menu_item_3 }}</a>
        </div>
      </div>
      
      <div class="ai-accordion-item-{{ ai_gen_id }}">
        <button class="ai-accordion-button-{{ ai_gen_id }}" aria-expanded="false">
          {{ block.settings.menu_item_4 }}
        </button>
        <div class="ai-accordion-content-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_link_4 }}" class="ai-accordion-link-{{ ai_gen_id }}">{{ block.settings.menu_item_4 }}</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    class HeroSection extends HTMLElement {
      constructor() {
        super();
        this.accordionButtons = this.querySelectorAll('.ai-accordion-button-{{ ai_gen_id }}');
        this.init();
      }

      init() {
        this.accordionButtons.forEach(button => {
          button.addEventListener('click', this.toggleAccordion.bind(this));
        });
      }

      toggleAccordion(event) {
        const button = event.currentTarget;
        const content = button.nextElementSibling;
        const isActive = button.classList.contains('active');
        
        // Close all accordions
        this.accordionButtons.forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-expanded', 'false');
          btn.nextElementSibling.classList.remove('active');
        });
        
        // Open clicked accordion if it wasn't already open
        if (!isActive) {
          button.classList.add('active');
          button.setAttribute('aria-expanded', 'true');
          content.classList.add('active');
        }
      }
    }

    customElements.define('hero-section-{{ ai_gen_id }}', HeroSection);

    // Initialize the component
    document.querySelector('.ai-hero-section-{{ ai_gen_id }}').outerHTML = 
      `<hero-section-{{ ai_gen_id }} class="ai-hero-section-{{ ai_gen_id }}" ${document.querySelector('.ai-hero-section-{{ ai_gen_id }}').getAttribute('{{ block.shopify_attributes }}')}>
        ${document.querySelector('.ai-hero-section-{{ ai_gen_id }}').innerHTML}
      </hero-section-{{ ai_gen_id }}>`;
  })();
</script>

