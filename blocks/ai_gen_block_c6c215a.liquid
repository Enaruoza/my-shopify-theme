{% doc %}
  @prompt
    Funky, VHS; 90S; COUNTDOwn. 
    
    with stock amount showing limited quantity

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vhs-countdown-{{ ai_gen_id }} {
    background: linear-gradient(135deg, #ff006e, #8338ec, #3a86ff);
    padding: 30px;
    border-radius: 15px;
    position: relative;
    overflow: hidden;
    font-family: 'Courier New', monospace;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .ai-vhs-countdown-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.1) 2px,
      rgba(0, 0, 0, 0.1) 4px
    );
    pointer-events: none;z-index: 1;
  }

  .ai-vhs-countdown-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;}

  .ai-vhs-countdown-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: bold;
    margin: 0 0 20px 0;
    text-shadow: 3px 3px 0px rgba(0, 0, 0, 0.5);
    filter: drop-shadow(0 0 10px currentColor);
  }

  .ai-vhs-countdown-timer-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 25px;
    flex-wrap: wrap;
  }

  .ai-vhs-countdown-unit-{{ ai_gen_id }} {
    background: rgba(0, 0, 0, 0.7);
    border: 2px solid {{ block.settings.timer_border_color }};
    border-radius: 8px;
    padding: 15px 10px;
    min-width: 80px;
    box-shadow: 
      0 0 20px rgba(255, 0, 110, 0.5),
      inset 0 0 20px rgba(255, 255, 255, 0.1);}

  .ai-vhs-countdown-number-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.timer_size }}px;
    font-weight: bold;
    color: {{ block.settings.timer_color }};
    text-shadow: 0 0 10px currentColor;
    line-height: 1;
    margin-bottom: 5px;
  }

  .ai-vhs-countdown-label-{{ ai_gen_id }} {
    display: block;
    font-size: 12px;
    color: {{ block.settings.timer_label_color }};
    font-weight: normal;}

  .ai-vhs-countdown-stock-{{ ai_gen_id }} {
    background: rgba(255, 0, 110, 0.2);
    border: 2px solid #ff006e;
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 20px;
    backdrop-filter: blur(5px);
  }

  .ai-vhs-countdown-stock-text-{{ ai_gen_id }} {
    color: {{ block.settings.stock_color }};
    font-size: {{ block.settings.stock_size }}px;
    font-weight: bold;
    margin: 0;text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.5);
  }

  .ai-vhs-countdown-stock-number-{{ ai_gen_id }} {
    color: #ffff00;
    font-size: {{ block.settings.stock_size | plus: 4 }}px;
    text-shadow: 0 0 15px currentColor;
  }

  .ai-vhs-countdown-cta-{{ ai_gen_id }} {
    background: linear-gradient(45deg, #ff006e, #ffff00);
    color: #000;
    border: none;
    padding: 15px 30px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 25px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    box-shadow: 
      0 5px 15px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(255, 255, 0, 0.5);
    transition: all 0.3s ease;
  }

  .ai-vhs-countdown-cta-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 
      0 7px 20px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(255, 255, 0, 0.7);
  }

  @media screen and (max-width: 768px) {
    .ai-vhs-countdown-{{ ai_gen_id }} {
      padding: 20px;
    }
    
    .ai-vhs-countdown-timer-{{ ai_gen_id }} {
      gap: 10px;
    }
    
    .ai-vhs-countdown-unit-{{ ai_gen_id }} {
      min-width: 60px;
      padding: 10px 8px;
    }
    
    .ai-vhs-countdown-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.timer_size | times: 0.8 }}px;
    }
  }
{% endstyle %}<vhs-countdown-{{ ai_gen_id }}
  class="ai-vhs-countdown-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.countdown_date }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-vhs-countdown-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-vhs-countdown-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}<div class="ai-vhs-countdown-timer-{{ ai_gen_id }}">
      <div class="ai-vhs-countdown-unit-{{ ai_gen_id }}">
        <span class="ai-vhs-countdown-number-{{ ai_gen_id }}" data-days>00</span>
        <span class="ai-vhs-countdown-label-{{ ai_gen_id }}">Days</span>
      </div>
      <div class="ai-vhs-countdown-unit-{{ ai_gen_id }}">
        <span class="ai-vhs-countdown-number-{{ ai_gen_id }}" data-hours>00</span>
        <span class="ai-vhs-countdown-label-{{ ai_gen_id }}">Hours</span>
      </div>
      <div class="ai-vhs-countdown-unit-{{ ai_gen_id }}">
        <span class="ai-vhs-countdown-number-{{ ai_gen_id }}" data-minutes>00</span>
        <span class="ai-vhs-countdown-label-{{ ai_gen_id }}">Minutes</span>
      </div>
      <div class="ai-vhs-countdown-unit-{{ ai_gen_id }}">
        <span class="ai-vhs-countdown-number-{{ ai_gen_id }}" data-seconds>00</span>
        <span class="ai-vhs-countdown-label-{{ ai_gen_id }}">Seconds</span>
      </div>
    </div>

    {% if block.settings.show_stock and block.settings.stock_quantity != blank %}
      <div class="ai-vhs-countdown-stock-{{ ai_gen_id }}">
        <p class="ai-vhs-countdown-stock-text-{{ ai_gen_id }}">
          Only<span class="ai-vhs-countdown-stock-number-{{ ai_gen_id }}">{{ block.settings.stock_quantity }}</span> left in stock!
        </p>
      </div>
    {% endif %}

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-vhs-countdown-cta-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</vhs-countdown-{{ ai_gen_id }}>

<script>
  (function() {
    class VhsCountdown{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = null;
        this.timer = null;
      }

      connectedCallback() {
        const endDateStr = this.dataset.endDate;
        if (endDateStr) {
          this.endDate = new Date(endDateStr).getTime();
          this.startCountdown();
        }
      }

      disconnectedCallback() {
        if (this.timer) {
          clearInterval(this.timer);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.timer = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const now = new Date().getTime();
        const distance = this.endDate - now;

        if (distance < 0) {
          this.querySelector('[data-days]').textContent = '00';
          this.querySelector('[data-hours]').textContent = '00';
          this.querySelector('[data-minutes]').textContent = '00';
          this.querySelector('[data-seconds]').textContent = '00';
          clearInterval(this.timer);
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.querySelector('[data-days]').textContent = String(days).padStart(2, '0');
        this.querySelector('[data-hours]').textContent = String(hours).padStart(2, '0');
        this.querySelector('[data-minutes]').textContent = String(minutes).padStart(2, '0');
        this.querySelector('[data-seconds]').textContent = String(seconds).padStart(2, '0');
      }
    }

    customElements.define('vhs-countdown-{{ ai_gen_id }}', VhsCountdown{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "VHS 90s Countdown",
  "settings": [
    {
      "type": "header",
      "content": "Countdown Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "countdown_date",
      "label": "End date and time",
      "info": "Format: YYYY-MM-DD HH:MM:SS (24-hour format)"
    },
    {
      "type": "header",
      "content": "Stock Display"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "label": "Show stock quantity",
      "default": true
    },
    {
      "type": "text",
      "id": "stock_quantity",
      "label": "Stock quantity",
      "default": "7"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffff00"
    },
    {
      "type": "color",
      "id": "timer_color",
      "label": "Timer numbers color",
      "default": "#00ffff"
    },
    {
      "type": "color",
      "id": "timer_label_color",
      "label": "Timer labels color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_border_color",
      "label": "Timer border color",
      "default": "#ff006e"
    },
    {
      "type": "color",
      "id": "stock_color",
      "label": "Stock text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "range",
      "id": "timer_size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Timer size",
      "default": 28
    },
    {
      "type": "range",
      "id": "stock_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Stock text size",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "VHS 90s Countdown"
    }
  ]
}
{% endschema %}