{% doc %}
  @prompt
    NA DLANOVE – Utrljaj nekoliko kapi ulja na dlanove.
    
    NA ČISTO LICE – Umasiraj nježno na čisto lice, ujutro i navečer.
    
    NA KRAJEVE KOSE I TIJELO – Zagrij kap ili dvije i nanesi na krajeve kose ili suhu kožu.
    For "Za muškarce", show:
    
    NA BRADU I RUKU – Utrljaj ulje u bradu i dlanove nakon tuširanja.
    
    NA LICE NAKON BRIJANJA – Koristi kao prirodni aftershave – njeguje i umiruje kožu.
    
    NA KOŽU TIJELA – Umasiraj na suhe dijelove tijela: laktove, koljena, stopala.
    Headline (centered, bold, all caps) reads: TRAŽIŠ SAVRŠENU RUTINU NJEGE? with subheading: Bez brige – imamo jednostavnu rutinu za zdravu, sjajnu kožu i kosu. Allow full control over font sizes, image shapes, layout spacing, and ability to add or remove cards. Include optional product image with a green badge that says: 100% ČISTO. CERTIFIKOVANO. Cards should stack vertically on mobile and include subtle hover effects., the cards should have images, displayed in an interesting and dynamic way, the viewer should be able to choose between for men or for women (also in bosnian, i should be able to edit the font type, there should be a CTA button that i can also disable or enable.
    
    the tabs should have a nicely designed shape; i dont want it to look so ugly please. Apple sorta design, there should be less CTA's, just one is enough.
    
    also let's up the ante more please we need a smart way to present the customization; we need a really solid block here.
    
    
    also for some reason i'm still unagble to change the font type

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .skincare-routine-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    max-width: 100%;
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .skincare-routine__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .skincare-routine__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: {{ block.settings.title_color }};
    font-family: {{ block.settings.font_family }}, sans-serif;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .skincare-routine__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin-top: 0;
    font-family: {{ block.settings.font_family }}, sans-serif;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  .skincare-routine__tabs-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .skincare-routine__tabs-{{ ai_gen_id }} {
    display: inline-flex;
    background-color: {{ block.settings.tab_container_background }};
    border-radius: {{ block.settings.tab_container_radius }}px;
    padding: {{ block.settings.tab_container_padding }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    position: relative;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .skincare-routine__tab-{{ ai_gen_id }} {
    padding: {{ block.settings.tab_padding_y }}px {{ block.settings.tab_padding_x }}px;
    background: none;
    color: {{ block.settings.tab_text_color }};
    border: none;
    border-radius: {{ block.settings.tab_radius }}px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: {{ block.settings.font_family }}, sans-serif;
    position: relative;
    z-index: 2;
    font-size: {{ block.settings.tab_font_size }}px;
    min-width: 100px;
  }

  .skincare-routine__tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_text_color }};
    font-weight: 600;
  }

  .skincare-routine__tab-indicator-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.tab_container_padding }}px;
    left: {{ block.settings.tab_container_padding }}px;
    height: calc(100% - {{ block.settings.tab_container_padding | times: 2 }}px);
    background-color: {{ block.settings.tab_active_background }};
    border-radius: {{ block.settings.tab_radius }}px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .skincare-routine__cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .skincare-routine__tab-content-{{ ai_gen_id }} {
    display: none;
  }

  .skincare-routine__tab-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .skincare-routine__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
  }

  {% if block.settings.enable_hover_effect %}
  .skincare-routine__card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
  }

  .skincare-routine__card-image-{{ ai_gen_id }}:hover img,
  .skincare-routine__card-image-{{ ai_gen_id }}:hover svg {
    transform: scale(1.05);
  }
  {% endif %}

  .skincare-routine__card-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
  }

  .skincare-routine__card-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .skincare-routine__card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .skincare-routine__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    transition: transform 0.5s ease;
  }

  .skincare-routine__card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .skincare-routine__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin-bottom: 10px;
    color: {{ block.settings.card_title_color }};
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.card_text_color }};
    flex-grow: 1;
    font-family: {{ block.settings.font_family }}, sans-serif;
    margin-bottom: 15px;
  }

  .skincare-routine__product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-top: 20px;
    margin-bottom: 15px;
  }

  .skincare-routine__product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.product_image_size }}px;
    height: {{ block.settings.product_image_size }}px;
    margin-right: 15px;
    flex-shrink: 0;
  }

  .skincare-routine__product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .skincare-routine__product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.product_image_radius }}px;
    background-color: #f4f4f4;
  }

  .skincare-routine__product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .skincare-routine__badge-{{ ai_gen_id }} {
    position: absolute;
    top: -10px;
    right: -10px;
    background-color: {{ block.settings.badge_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 10px;
    font-weight: 700;
    padding: 5px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    line-height: 1;
    z-index: 1;
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__card-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: {{ block.settings.badge_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    line-height: 1;
    z-index: 1;
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .skincare-routine__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 5px;
    color: {{ block.settings.card_title_color }};
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.card_text_color }};
    font-family: {{ block.settings.font_family }}, sans-serif;
  }

  .skincare-routine__cta-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
  }

  .skincare-routine__cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_y }}px {{ block.settings.cta_padding_x }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_radius }}px;
    font-weight: 600;
    font-size: {{ block.settings.cta_font_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    font-family: {{ block.settings.font_family }}, sans-serif;
    min-width: 200px;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .skincare-routine__cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
  }

  /* Card styles with different shapes */
  .skincare-routine__card-{{ ai_gen_id }}:nth-child(3n+1) .skincare-routine__card-image-{{ ai_gen_id }} {
    clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
  }

  .skincare-routine__card-{{ ai_gen_id }}:nth-child(3n+2) .skincare-routine__card-image-{{ ai_gen_id }} {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 85%);
  }

  .skincare-routine__card-{{ ai_gen_id }}:nth-child(3n+3) .skincare-routine__card-image-{{ ai_gen_id }} {
    clip-path: polygon(0 0, 100% 0, 95% 100%, 0 100%);
  }

  /* Custom animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .skincare-routine__tab-content-{{ ai_gen_id }}.active .skincare-routine__card-{{ ai_gen_id }} {
    animation: fadeInUp 0.5s ease forwards;
  }

  .skincare-routine__tab-content-{{ ai_gen_id }}.active .skincare-routine__card-{{ ai_gen_id }}:nth-child(2) {
    animation-delay: 0.1s;
  }

  .skincare-routine__tab-content-{{ ai_gen_id }}.active .skincare-routine__card-{{ ai_gen_id }}:nth-child(3) {
    animation-delay: 0.2s;
  }

  @media screen and (max-width: 749px) {
    .skincare-routine__cards-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .skincare-routine__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .skincare-routine__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .skincare-routine__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }

    .skincare-routine__card-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_text_size | times: 0.9 }}px;
    }

    .skincare-routine__tabs-{{ ai_gen_id }} {
      padding: {{ block.settings.tab_container_padding | times: 0.8 }}px;
    }

    .skincare-routine__tab-{{ ai_gen_id }} {
      padding: {{ block.settings.tab_padding_y | times: 0.8 }}px {{ block.settings.tab_padding_x | times: 0.8 }}px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
      min-width: 80px;
    }
  }
{% endstyle %}

<div class="skincare-routine-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="skincare-routine__container-{{ ai_gen_id }}">
    <div class="skincare-routine__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="skincare-routine__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="skincare-routine__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="skincare-routine__tabs-wrapper-{{ ai_gen_id }}">
      <div class="skincare-routine__tabs-{{ ai_gen_id }}">
        <div class="skincare-routine__tab-indicator-{{ ai_gen_id }}"></div>
        <button class="skincare-routine__tab-{{ ai_gen_id }} active" data-tab="women">{{ block.settings.tab_women_text }}</button>
        <button class="skincare-routine__tab-{{ ai_gen_id }}" data-tab="men">{{ block.settings.tab_men_text }}</button></div>
    </div>

    <div class="skincare-routine__tab-content-{{ ai_gen_id }} active" data-tab-content="women">
      <div class="skincare-routine__cards-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% case i %}
            {% when 1 %}
              {% assign card_title = block.settings.women_card_title_1 | default: "NA DLANOVE" %}
              {% assign card_text = block.settings.women_card_text_1 | default: "Utrljaj nekoliko kapi ulja na dlanove." %}
              {% assign card_image = block.settings.women_card_image_1 %}
            {% when 2 %}
              {% assign card_title = block.settings.women_card_title_2 | default: "NA ČISTO LICE" %}
              {% assign card_text = block.settings.women_card_text_2 | default: "Umasiraj nježno na čisto lice, ujutro i navečer." %}
              {% assign card_image = block.settings.women_card_image_2 %}
            {% when 3 %}
              {% assign card_title = block.settings.women_card_title_3 | default: "NA KRAJEVE KOSE I TIJELO" %}
              {% assign card_text = block.settings.women_card_text_3 | default: "Zagrij kap ili dvije i nanesi na krajeve kose ili suhu kožu." %}
              {% assign card_image = block.settings.women_card_image_3 %}
          {% endcase %}

          {% if forloop.index <= block.settings.number_of_cards %}
            <div class="skincare-routine__card-{{ ai_gen_id }}">
              <div class="skincare-routine__card-image-{{ ai_gen_id }}">
                {% if card_image %}
                  <img 
                    src="{{ card_image | image_url: width: 800 }}" 
                    alt="{{ card_image.alt | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="skincare-routine__card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                
                {% if block.settings.show_card_badge %}
                  <span class="skincare-routine__card-badge-{{ ai_gen_id }}">{{ block.settings.card_badge_text }}</span>
                {% endif %}
              </div>
              
              <div class="skincare-routine__card-content-{{ ai_gen_id }}">
                <h3 class="skincare-routine__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
                <div class="skincare-routine__card-text-{{ ai_gen_id }}">{{ card_text }}</div>

                {% if block.settings.show_product %}
                  <div class="skincare-routine__product-{{ ai_gen_id }}">
                    <div class="skincare-routine__product-image-wrapper-{{ ai_gen_id }}">
                      {% if block.settings.women_product_image %}
                        <img 
                          src="{{ block.settings.women_product_image | image_url: width: 150 }}" 
                          alt="{{ block.settings.women_product_image.alt | escape }}"
                          loading="lazy"
                          class="skincare-routine__product-image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="skincare-routine__product-image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-apparel-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                      {% if block.settings.show_badge %}
                        <span class="skincare-routine__badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
                      {% endif %}
                    </div>
                    <div class="skincare-routine__product-info-{{ ai_gen_id }}">
                      {% if block.settings.women_product_title != blank %}
                        <h4 class="skincare-routine__product-title-{{ ai_gen_id }}">{{ block.settings.women_product_title }}</h4>
                      {% endif %}
                      {% if block.settings.women_product_price != blank %}
                        <div class="skincare-routine__product-price-{{ ai_gen_id }}">{{ block.settings.women_product_price }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="skincare-routine__tab-content-{{ ai_gen_id }}" data-tab-content="men">
      <div class="skincare-routine__cards-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% case i %}
            {% when 1 %}
              {% assign card_title = block.settings.men_card_title_1 | default: "NA BRADU I RUKU" %}
              {% assign card_text = block.settings.men_card_text_1 | default: "Utrljaj ulje u bradu i dlanove nakon tuširanja." %}
              {% assign card_image = block.settings.men_card_image_1 %}
            {% when 2 %}
              {% assign card_title = block.settings.men_card_title_2 | default: "NA LICE NAKON BRIJANJA" %}
              {% assign card_text = block.settings.men_card_text_2 | default: "Koristi kao prirodni aftershave – njeguje i umiruje kožu." %}
              {% assign card_image = block.settings.men_card_image_2 %}
            {% when 3 %}
              {% assign card_title = block.settings.men_card_title_3 | default: "NA KOŽU TIJELA" %}
              {% assign card_text = block.settings.men_card_text_3 | default: "Umasiraj na suhe dijelove tijela: laktove, koljena, stopala." %}
              {% assign card_image = block.settings.men_card_image_3 %}
          {% endcase %}

          {% if forloop.index <= block.settings.number_of_cards %}
            <div class="skincare-routine__card-{{ ai_gen_id }}">
              <div class="skincare-routine__card-image-{{ ai_gen_id }}">
                {% if card_image %}
                  <img 
                    src="{{ card_image | image_url: width: 800 }}" 
                    alt="{{ card_image.alt | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="skincare-routine__card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                
                {% if block.settings.show_card_badge %}
                  <span class="skincare-routine__card-badge-{{ ai_gen_id }}">{{ block.settings.card_badge_text }}</span>
                {% endif %}
              </div>
              <div class="skincare-routine__card-content-{{ ai_gen_id }}">
                <h3 class="skincare-routine__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
                <div class="skincare-routine__card-text-{{ ai_gen_id }}">{{ card_text }}</div>

                {% if block.settings.show_product %}
                  <div class="skincare-routine__product-{{ ai_gen_id }}">
                    <div class="skincare-routine__product-image-wrapper-{{ ai_gen_id }}">
                      {% if block.settings.men_product_image %}
                        <img 
                          src="{{ block.settings.men_product_image | image_url: width: 150 }}" 
                          alt="{{ block.settings.men_product_image.alt | escape }}"
                          loading="lazy"
                          class="skincare-routine__product-image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="skincare-routine__product-image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-apparel-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                      
                      {% if block.settings.show_badge %}
                        <span class="skincare-routine__badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
                      {% endif %}
                    </div>
                    <div class="skincare-routine__product-info-{{ ai_gen_id }}">
                      {% if block.settings.men_product_title != blank %}
                        <h4 class="skincare-routine__product-title-{{ ai_gen_id }}">{{ block.settings.men_product_title }}</h4>
                      {% endif %}
                      {% if block.settings.men_product_price != blank %}
                        <div class="skincare-routine__product-price-{{ ai_gen_id }}">{{ block.settings.men_product_price }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if block.settings.show_cta %}
      <div class="skincare-routine__cta-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_url }}" class="skincare-routine__cta-button-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    const tabButtons = document.querySelectorAll('.skincare-routine__tab-{{ ai_gen_id }}');
    const tabContents = document.querySelectorAll('.skincare-routine__tab-content-{{ ai_gen_id }}');
    const tabIndicator = document.querySelector('.skincare-routine__tab-indicator-{{ ai_gen_id }}');
    
    function updateIndicator(activeTab) {
      const tabIndex = Array.from(tabButtons).indexOf(activeTab);
      const tabWidth = activeTab.offsetWidth;
      const tabLeft = activeTab.offsetLeft;
      
      tabIndicator.style.width = tabWidth + 'px';
      tabIndicator.style.transform = `translateX(${tabLeft}px)`;
    }
    
    // Initialize indicator position
    const activeTab = document.querySelector('.skincare-routine__tab-{{ ai_gen_id }}.active');
    if (activeTab) {
      updateIndicator(activeTab);
    }
    
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons and contents
        tabButtons.forEach(btn => btn.classList.remove('active'));
        tabContents.forEach(content => content.classList.remove('active'));
        
        // Add active class to clicked button
        button.classList.add('active');
        
        // Update indicator position
        updateIndicator(button);
        
        // Show corresponding content
        const tabName = button.getAttribute('data-tab');
        const activeContent = document.querySelector(`.skincare-routine__tab-content-{{ ai_gen_id }}[data-tab-content="${tabName}"]`);
        activeContent.classList.add('active');
      });
    });
    
    // Update indicator on window resize
    window.addEventListener('resize', () => {
      const activeTab = document.querySelector('.skincare-routine__tab-{{ ai_gen_id }}.active');
      if (activeTab) {
        updateIndicator(activeTab);
      }
    });
  })();
</script>

