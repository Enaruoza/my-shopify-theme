{% doc %}
  @prompt
    Create a flexible two-column content section:
    
    Left Column:
    
    Large image container with dynamic shape support (circle, square, hexagon, etc.) via CSS clip-path or SVG mask.
    
    Below the image, add a bold heading: “Glow Is The Essence Of Beauty”.
    
    Right Column:
    
    Two text blocks:
    
    “Face Skin Care” with paragraph.
    
    “Body Skin Care” with paragraph.
    
    Smaller product image at the bottom with optional shape variations.
    
    Use CSS grid or flexbox for layout, allow shape customization through reusable classes or props. Make it responsive for mobile stacking.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .two-column-section-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.column_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    padding: {{ block.settings.section_padding }}px;
  }

  .column-{{ ai_gen_id }} {
    flex: 1;
    min-width: 300px;
  }

  .left-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .right-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Image shape variations */
  .shape-circle-{{ ai_gen_id }} .image-wrapper-{{ ai_gen_id }} {
    clip-path: circle(50% at 50% 50%);
  }

  .shape-square-{{ ai_gen_id }} .image-wrapper-{{ ai_gen_id }} {
    clip-path: none;
  }

  .shape-rounded-{{ ai_gen_id }} .image-wrapper-{{ ai_gen_id }} {
    border-radius: 20px;
    overflow: hidden;
  }

  .shape-hexagon-{{ ai_gen_id }} .image-wrapper-{{ ai_gen_id }} {
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
  }

  .shape-diamond-{{ ai_gen_id }} .image-wrapper-{{ ai_gen_id }} {
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  }

  .placeholder-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_color }};
  }

  .placeholder-wrapper-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
    opacity: 0.7;
  }

  .main-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .text-block-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: {{ block.settings.subheading_color }};
  }

  .text-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .product-image-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.product_image_width }}px;
    margin-top: auto;
  }

  .product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  @media screen and (max-width: 768px) {
    .two-column-section-{{ ai_gen_id }} {
      flex-direction: column;
    }
    
    .column-{{ ai_gen_id }} {
      width: 100%;
      margin-bottom: 32px;
    }
    
    .main-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
    
    .text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="two-column-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="column-{{ ai_gen_id }} left-column-{{ ai_gen_id }}">
    <div class="image-container-{{ ai_gen_id }} shape-{{ block.settings.main_image_shape }}-{{ ai_gen_id }}">
      <div class="image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.main_image %}
          <img 
            src="{{ block.settings.main_image | image_url: width: 1000 }}" 
            alt="{{ block.settings.main_image.alt | escape }}"
            class="image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.main_image.width }}"
            height="{{ block.settings.main_image.height }}"
          >
        {% else %}
          <div class="placeholder-wrapper-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
    
    <h2 class="main-heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
  </div>
  
  <div class="column-{{ ai_gen_id }} right-column-{{ ai_gen_id }}">
    <div class="text-blocks-{{ ai_gen_id }}">
      <div class="text-block-{{ ai_gen_id }}">
        <h3 class="text-heading-{{ ai_gen_id }}">{{ block.settings.text_heading_1 }}</h3>
        <p class="text-content-{{ ai_gen_id }}">{{ block.settings.text_content_1 }}</p>
      </div>
      
      <div class="text-block-{{ ai_gen_id }}">
        <h3 class="text-heading-{{ ai_gen_id }}">{{ block.settings.text_heading_2 }}</h3>
        <p class="text-content-{{ ai_gen_id }}">{{ block.settings.text_content_2 }}</p>
      </div>
    </div>
    
    <div class="product-image-container-{{ ai_gen_id }}">
      <div class="image-container-{{ ai_gen_id }} shape-{{ block.settings.product_image_shape }}-{{ ai_gen_id }}">
        <div class="image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.product_image %}
            <img 
              src="{{ block.settings.product_image | image_url: width: 500 }}" 
              alt="{{ block.settings.product_image.alt | escape }}"
              class="image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.product_image.width }}"
              height="{{ block.settings.product_image.height }}"
            >
          {% else %}
            <div class="placeholder-wrapper-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

